has-session -t forge-1
new-session -d -s forge-1 -c __DIR__ -e TMUX_SESSION=forge-1 -e FORGE_ROOT=__DIR__
split-window -h -t forge-1:.0 -c __DIR__ -p 50
split-window -v -t forge-1:.0 -c __DIR__ -p 50
split-window -v -t forge-1:.2 -c __DIR__ -p 66
split-window -v -t forge-1:.3 -c __DIR__ -p 50
set -g mouse on
send-keys -t forge-1:.0 claude --model claude-opus-4-8 --permission-mode acceptEdits Enter
send-keys -t forge-1:.1 claude --model claude-opus-4-8 Enter
send-keys -t forge-1:.2 codex -m gpt-5.5 -c model_reasoning_effort=xhigh -c service_tier=fast Enter
send-keys -t forge-1:.3 codex -m gpt-5.5 -c model_reasoning_effort=medium -c service_tier=fast Enter
send-keys -t forge-1:.4 claude --model claude-sonnet-5 --permission-mode acceptEdits Enter
list-panes -t forge-1 -F #{pane_index} #{pane_left}
select-pane -t forge-1:.1
