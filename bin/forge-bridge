#!/bin/bash
# ============================================================
# forge-bridge — cross-pane messaging with hooks and audit log
# ============================================================
#
# Auto-detects which tmux session you're in.
# Falls back to .dev/.forge-session file, then scans for forge sessions.
#
# Pane layout:
#   0 = claude-opus worker      TOP-LEFT
#   1 = claude orchestrator     BOTTOM-LEFT
#   2 = codex A                 TOP-RIGHT
#   3 = codex B                 MIDDLE-RIGHT
#   4 = claude-sonnet worker    BOTTOM-RIGHT
#
# Hooks (enforced by the script, not by skills):
#   1. send refuses to dispatch unless a pending log entry targets the same pane
#      (per-target log-before-send; alias-normalized so historical `to: inline`
#      entries resolve to the canonical `claude-opus` pane-0 worker name and
#      historical `to: claude` entries match the canonical `claude` orchestrator name)
#   2. log-response auto-updates .dev/forge-context.yml on completion
#      (qa, qa-fix, qa-retry do NOT auto-advance — orchestrator decides)
#   3. context command loads pipeline state for session start
#   4. require_pane_count validates pane count at every tmux session entry point
#
# Tmux-required commands (operate on panes):
#   send <pane> <message>       — type into a pane (per-target log-before-send hook)
#   send --force <pane> <msg>   — bypass log check (for non-pipeline messages / callbacks)
#   read <pane> [lines]         — read from a pane
#   focus <pane>                — switch focus to a pane
#   back                        — return focus to orchestrator
#
# No-tmux commands (file-based; work from any directory):
#   preflight                   — kickoff snapshot: pwd, branch, merge state, halt code
#   signal <from> <message>     — file-based signal
#   check-signals               — list pending signals
#   clear-signals               — remove all signal files
#   review-status               — commit-review verdict counts
#   log --slug <s> --stage <s> --from <f> --to <t> --prompt <p>
#   log-response --slug <s> --response <r> [--file <path:action>]...
#   history [lines]             — project-wide summary
#   pipeline-log <slug> [lines] — per-pipeline detail
#   context                     — load current pipeline state (for session start)
#   set-context --slug <s>      — manually set the active pipeline
#   add-note <text>             — annotate context (persists across sessions)
#   alias-self-test [--strict]  — verify pane alias maps stay in lockstep
#
# Pane names: inline/general/claude-opus/opus (0), claude/orchestrator/claude-orchestrator (1),
#             codex/codex-a (2), codex-b (3), claude-sonnet/sonnet (4)
# ============================================================

# --- Session-independent globals (no tmux required) ---

WINDOW="0"
DEV_DIR=".dev"
SUMMARY_LOG="$DEV_DIR/forge-log.yml"
CONTEXT_FILE="$DEV_DIR/forge-context.yml"
SESSION=""   # populated by require_identity() (=$ID_target_session) for session-scoped commands

# Required pane count (Phase 2: 5 panes)
FORGE_REQUIRED_PANES="${FORGE_REQUIRED_PANES:-5}"

# --- Session Detection (called explicitly by tmux-required commands) ---

require_pane_count() {
    local s="$1"
    local required="${2:-$FORGE_REQUIRED_PANES}"
    local count
    count=$(tmux list-panes -t "$s" 2>/dev/null | wc -l | tr -d ' ')
    if [ "$count" -lt "$required" ]; then
        cat >&2 <<EOF
ERROR: Forge session '$s' has $count panes (need $required).
       This session is pre-Phase-2 (4-pane). Migration required:
         1. Pause or complete the current pipeline stage
         2. tmux kill-session -t $s
         3. rm -f ~/.cache/forge/${s}-pane*.snapshot ~/.cache/forge/${s}-pane*.last-stall-check
         4. forge-start
         5. ~/bin/forge-bridge context && type 'forge-resume' to the orchestrator
EOF
        return 1
    fi
    return 0
}

# ---- Canonical project-root ownership (session-pin hardening §3.0) ----
# ownership_root <dir> — THE one root function, applied identically to every operand
# of every root comparison (fixes the realpath-vs-logical asymmetry; tolerates
# subdir-created sessions + symlinks). Walks up from realpath(dir) to the nearest
# .claude/forge-project.yml; anchors on that dir's configured forge.expected_root if
# non-empty, else the yml dir; else dir itself. Returns pwd -P so BOTH operands
# canonicalize the same way. bash-3.2-safe. Never applies the name charset guard to a PATH.
ownership_root() {
    local dir="$1" real anchor y ydir expected
    [ -n "$dir" ] || return 1
    real="$(cd "$dir" 2>/dev/null && pwd -P)" || real="$dir"
    ydir="$real"
    while [ "$ydir" != "/" ] && [ -n "$ydir" ]; do
        if [ -f "$ydir/.claude/forge-project.yml" ]; then y="$ydir/.claude/forge-project.yml"; break; fi
        ydir="$(dirname "$ydir")"
    done
    if [ -n "${y:-}" ]; then
        expected="$(python3 -c "
import yaml
try:
    with open('$y') as f: d=yaml.safe_load(f) or {}
    print((d.get('forge',{}) or {}).get('expected_root','') or '')
except Exception: pass
" 2>/dev/null)"
        if [ -n "$expected" ]; then anchor="$expected"; else anchor="$(dirname "$(dirname "$y")")"; fi
    else
        anchor="$real"
    fi
    (cd "$anchor" 2>/dev/null && pwd -P) || printf '%s' "$anchor"
}

# _same_root_sessions <dir> — list every LIVE session whose ownership_root equals
# ownership_root(dir), REGARDLESS of name prefix (fixes the goparentbugs miss). Test
# seam FORGE_TMUX_LIST names a 'name<TAB>path' file (seat/forge-watch convention,
# bin/forge:67-75). One name per line. bash-3.2-safe.
_same_root_sessions() {
    local dir="$1" want inject _sn _sp
    want="$(ownership_root "$dir")"
    [ -n "$want" ] || return 0
    inject="${FORGE_TMUX_LIST:-}"
    if [ -n "$inject" ]; then
        while IFS=$'\t' read -r _sn _sp; do
            [ -n "$_sn" ] || continue
            [ "$(ownership_root "$_sp")" = "$want" ] && printf '%s\n' "$_sn"
        done < "$inject"
    else
        tmux list-sessions -F '#{session_name}	#{session_path}' 2>/dev/null \
        | while IFS=$'\t' read -r _sn _sp; do
            [ -n "$_sn" ] || continue
            [ "$(ownership_root "$_sp")" = "$want" ] && printf '%s\n' "$_sn"
          done
    fi
}

# ---- Structured identity descriptor (session-pin hardening P1.1-P1.3) ----
# _forge_identity computes {host,target,source,root,incarnation,state} and assigns it
# to caller-shell ID_* globals by DIRECT ASSIGNMENT — no eval, no serialization, no
# exported var. Stale-globals invariant: each forge-bridge process runs exactly one
# command, so ID_* cannot bleed between commands; require_identity calls this at the
# TOP of the command body, before any $(...) filename resolution, so every downstream
# read is consistent. The charset guard applies to session NAMES only, never to paths.
_valid_session_name() { printf '%s' "$1" | grep -Eq '^[A-Za-z0-9_.-]+$'; }

_forge_identity() {
    ID_host_session=""; ID_host_pane=""; ID_host_root=""; ID_host_incarnation=""
    ID_target_session=""; ID_target_source="none"; ID_target_root=""
    ID_legacy_file_session=""; ID_state=""; ID_ambiguous_list=""
    local env_stamp="${TMUX_SESSION:-}"
    [ -n "$env_stamp" ] && ! _valid_session_name "$env_stamp" && env_stamp=""

    # --- Host probe: ONE TMUX_PANE-targeted display-message (untargeted resolves the
    #     ACTIVE pane, not the caller — tests/forge-start/run.sh:98-100). ---
    local host_state="" hp rc pid sn spath screated
    if [ -n "${TMUX:-}" ] && [ -n "${TMUX_PANE:-}" ]; then
        hp="$(tmux display-message -p -t "$TMUX_PANE" \
            '#{pane_id}	#{session_name}	#{session_path}	#{session_created}' 2>/dev/null)"; rc=$?
        if [ "$rc" -ne 0 ] || [ -z "$hp" ]; then
            host_state="tmux-unavailable"
        else
            IFS=$'\t' read -r pid sn spath screated <<< "$hp"
            if [ "$pid" = "$TMUX_PANE" ]; then
                host_state="in-pane"
                ID_host_pane="$pid"
                _valid_session_name "$sn" && ID_host_session="$sn"
                ID_host_root="$(ownership_root "$spath")"; ID_host_incarnation="$screated"
            else
                host_state="tmux-unavailable"     # probe hit the wrong pane → do not trust
            fi
        fi
    elif [ -n "${TMUX:-}" ]; then
        host_state="tmux-unavailable"             # $TMUX set but no TMUX_PANE
    else
        host_state="no-tmux"
    fi

    # --- Legacy file: DIAGNOSTICS ONLY, never a routing source (P3.18). New writers
    #     prepend a "# advisory only" header; read the first non-comment, non-empty
    #     line and charset-guard it. Routing uses only the LIVE same-root set below,
    #     so a stale name is dropped by construction. ---
    local _dir; _dir="$(pwd)"; local _lf
    while [ "$_dir" != "/" ]; do
        if [ -f "$_dir/.dev/.forge-session" ]; then
            _lf="$(grep -v '^#' "$_dir/.dev/.forge-session" 2>/dev/null | grep -m1 . || true)"
            _valid_session_name "$_lf" && ID_legacy_file_session="$_lf"
            break
        fi
        _dir="$(dirname "$_dir")"
    done

    local cwd_root; cwd_root="$(ownership_root "$(pwd)")"

    # --- Explicit cross-session declaration (validated later; P4.19). --target-root
    #     (if given) is the intended-root operand, else the caller's cwd. ---
    if [ "${_FORGE_CROSS:-0}" = "1" ] && [ -n "${_FORGE_TARGET:-}" ]; then
        ID_target_session="$_FORGE_TARGET"; ID_target_source="explicit-arg"
        ID_target_root="$(ownership_root "${_FORGE_TARGET_ROOT:-$(pwd)}")"
        ID_state="CROSS_SESSION_DECLARED"
    else
        case "$host_state" in
            in-pane)
                ID_target_session="$ID_host_session"; ID_target_source="host"
                ID_target_root="$ID_host_root"
                if [ -n "$ID_host_root" ] && [ -n "$cwd_root" ] && [ "$ID_host_root" != "$cwd_root" ]; then
                    ID_state="MISMATCH"          # wrong checkout / nested tmux / wandered cwd
                elif [ -n "$env_stamp" ] && [ "$env_stamp" != "$ID_host_session" ]; then
                    ID_state="MISMATCH"          # env stamp ≠ probed host (incident replay; MINOR-1)
                else
                    ID_state="MATCH"
                fi
                ;;
            no-tmux)
                local cands n
                cands="$(_same_root_sessions "$(pwd)")"
                n="$(printf '%s\n' "$cands" | grep -c . || true)"
                if [ "$n" -eq 1 ]; then
                    ID_target_session="$(printf '%s\n' "$cands" | grep . | head -1)"
                    ID_target_source="unique-root-candidate"; ID_target_root="$cwd_root"; ID_state="MATCH"
                elif [ "$n" -gt 1 ]; then
                    ID_state="AMBIGUOUS"; ID_ambiguous_list="$cands"
                else
                    ID_state="UNAVAILABLE"
                fi
                ;;
            *) ID_state="UNAVAILABLE" ;;          # tmux-unavailable
        esac
    fi

    if [ -n "$ID_target_session" ] && ! _valid_session_name "$ID_target_session"; then
        ID_target_session=""
    fi
    [ "$ID_target_session" = "__nosession__" ] && ID_target_session=""
    return 0
}

# Shared descriptor printer (also prepended by preflight/health/identity, P1.10).
_print_identity_block() {
    printf 'host_session=%s   host_pane=%s   host_root=%s\n' \
        "${ID_host_session:-none}" "${ID_host_pane:-none}" "${ID_host_root:-unknown}"
    printf 'target_session=%s target_source=%s\n' \
        "${ID_target_session:-none}" "${ID_target_source:-none}"
    printf 'legacy_file_session=%s   identity_state=%s\n' \
        "${ID_legacy_file_session:-none}" "${ID_state:-UNAVAILABLE}"
}

# Resolve the current forge session name for FILE-NAMING / FILTERING only. Fast path:
# if the gate ran (ID_state set), echo its target; else compute inline. Empty on
# MISMATCH-with-no-host / AMBIGUOUS / UNAVAILABLE so __nosession__ engages instead of a
# wrong name (P1.4). On an in-pane MISMATCH the target is the correct host pane, so the
# echoed name stays safe.
_resolve_session() {
    local s
    if [ -n "${ID_state:-}" ]; then
        s="$ID_target_session"
    else
        _forge_identity
        s="$ID_target_session"
    fi
    if [ -n "$s" ] && ! _valid_session_name "$s"; then s=""; fi
    [ "$s" = "__nosession__" ] && s=""
    printf '%s' "$s"
}

# Map "no session" to a private sentinel token (never a real forge-N name).
_session_or_sentinel() {
    local s; s="$(_resolve_session)"
    printf '%s' "${s:-__nosession__}"
}

# Per-call context pointer path. Pure function of the resolved session token.
_context_file() { printf '%s/forge-context.%s.yml' "$DEV_DIR" "$(_session_or_sentinel)"; }

# Per-call usage snapshot path. Same session scoping as _context_file, but a
# DEDICATED file so the resume-critical update_context() heredoc writer is never
# touched (folding usage into the context file would force a clobber-preservation
# edit there). Relative to $DEV_DIR like _context_file; callers prefix
# $project_root. See .dev/proposals/per-task-usage-reporting/final-plan.md.
_usage_file() { printf '%s/forge-usage.%s.yml' "$DEV_DIR" "$(_session_or_sentinel)"; }

# require_tmux_session was superseded by require_identity (session-pin hardening).
# Every former caller now calls `require_identity <cmd> <class-token>`.

# ---- Classified identity gate (session-pin hardening P1.7) ----
# Report-only in Phases 1-3; the Phase-4 commit flips the default to 1.
FORGE_IDENTITY_ENFORCE="${FORGE_IDENTITY_ENFORCE:-1}"

# session_path_of <name> — echo a live session's #{session_path}; empty if gone. Uses
# the same FORGE_TMUX_LIST seam as _same_root_sessions so P4 root-validation tests can
# inject topology hermetically.
session_path_of() {
    local inject="${FORGE_TMUX_LIST:-}"
    if [ -n "$inject" ]; then
        awk -F'\t' -v s="$1" '$1==s{print $2; exit}' "$inject"
    else
        tmux list-sessions -F '#{session_name}	#{session_path}' 2>/dev/null \
            | awk -F'\t' -v s="$1" '$1==s{print $2; exit}'
    fi
}

# Durable board attention event + operator block on a class-2/3 identity refuse (P4.20).
_identity_refuse() {
    local cmd="$1"
    _emit_event identity-mismatch "-" \
        "cmd=$cmd root=${ID_host_root:-unknown} host=${ID_host_session:-none} target=${ID_target_session:-none} source=${ID_target_source:-none} state=${ID_state:-UNAVAILABLE}" 2>/dev/null || true
    {
        echo "ERROR: identity ${ID_state} — command '$cmd' refused (host=${ID_host_session:-none} target=${ID_target_session:-none})."
        _print_identity_block
        echo "  Run 'forge-bridge identity' for the full descriptor."
    } >&2
}

# require_identity <cmd> <class-token> — THE one fail-closed identity gate; supersedes
# require_tmux_session. Runs _forge_identity, sets ID_*, records an IDENTITY event, sets
# legacy SESSION="$ID_target_session" so every "$SESSION:$WINDOW.$PANE" call site is
# byte-unchanged. Unknown class → fail closed. Tokens: root-scoped | host-pane |
# host-session | host-degrade | target-scoped | diagnostic.
require_identity() {
    local cmd="${1:-(unknown)}" class="${2:-}"

    # Dual-mode: send/callback upgrade to class-3 iff BOTH flags present.
    if { [ "$cmd" = "send" ] || [ "$cmd" = "callback" ]; } \
       && [ "${_FORGE_CROSS:-0}" = "1" ] && [ -n "${_FORGE_TARGET:-}" ]; then
        class="target-scoped"
    fi

    _forge_identity
    _emit_event IDENTITY "-" \
        "cmd=$cmd class=$class state=${ID_state} host=${ID_host_session:-none} target=${ID_target_session:-none} source=${ID_target_source}" 2>/dev/null || true
    SESSION="$ID_target_session"

    case "$class" in
        root-scoped|diagnostic) return 0 ;;       # diagnostics: SESSION set, body prints/handles; never refuse (R7)
        host-pane|host-session|host-degrade|target-scoped) : ;;
        *) echo "ERROR: command '$cmd' has no identity class — refusing (fail-closed gate)." >&2; return 1 ;;
    esac

    # Identity-state refusal — dormant until FORGE_IDENTITY_ENFORCE=1 (P4).
    if [ "$FORGE_IDENTITY_ENFORCE" = "1" ]; then
        case "$class" in
            host-degrade)                                   # callback/log-response/context/stall-check-status
                [ "$ID_state" = "MISMATCH" ] && { _identity_refuse "$cmd"; return 1; } ;;
            host-pane|host-session|target-scoped)
                case "$ID_state" in
                    MISMATCH|AMBIGUOUS|UNAVAILABLE) _identity_refuse "$cmd"; return 1 ;;
                esac ;;
        esac
        # class-3 cross-session validation: target exists + rooted at the intended
        # (caller-supplied, cd-bound or --target-root) root — NOT the bridge cwd (MAJOR-1 / P4.19).
        if [ "$class" = "target-scoped" ]; then
            if ! tmux has-session -t "$ID_target_session" 2>/dev/null; then
                echo "ERROR: --cross-session target '$ID_target_session' does not exist — refusing." >&2
                return 1
            fi
            local troot; troot="$(ownership_root "$(session_path_of "$ID_target_session")")"
            if [ "$troot" != "$ID_target_root" ]; then
                echo "ERROR: --cross-session target '$ID_target_session' is rooted at $troot, not the intended root $ID_target_root — refusing." >&2
                return 1
            fi
            _emit_event CROSS "-" "cmd=$cmd host=${ID_host_session:-none} target=$ID_target_session target_root=$ID_target_root source=${ID_target_source} caller_mode=explicit-arg"
        fi
    fi

    # Pane precondition (BOTH phases) — pane ops need a live host session with the full
    # pane count (= the old require_tmux_session contract); cross-session needs a live
    # target. host-session / host-degrade / diagnostic have NO precondition (they were
    # unguarded before and must tolerate headless invocation — this structurally
    # resolves OQ-3: file mutators never newly require 5 panes).
    case "$class" in
        host-pane)
            if [ -z "$SESSION" ]; then
                echo "ERROR: command '$cmd' requires a live forge session. Run forge-start first." >&2
                return 1
            fi
            if ! tmux has-session -t "$SESSION" 2>/dev/null; then
                echo "ERROR: resolved session '$SESSION' but no such tmux session exists (stale pin/arg)." >&2
                return 1
            fi
            require_pane_count "$SESSION" "$FORGE_REQUIRED_PANES" || return 1
            ;;
        target-scoped)
            if [ -z "$SESSION" ] || ! tmux has-session -t "$SESSION" 2>/dev/null; then
                echo "ERROR: cross-session target '$SESSION' is not a live session." >&2
                return 1
            fi
            require_pane_count "$SESSION" "$FORGE_REQUIRED_PANES" || return 1
            ;;
    esac
    return 0
}

# ---- Helpers ----

# Alias maps must stay in lockstep across:
#   - pane_index() / pane_name()
#   - every inline Python ALIAS_TO_CANONICAL map in this file
#   - cmd_stall_check_status NAME_TO_IDX
#   - cmd_send worker allowlist
# Run `~/bin/forge-bridge alias-self-test --strict` after edits.
pane_index() {
    case "$1" in
        inline|general|claude-general|claude-opus|opus) echo "0" ;;
        claude|orchestrator|claude-orchestrator)        echo "1" ;;
        codex|codex-a)                                  echo "2" ;;
        codex-b)                                        echo "3" ;;
        claude-sonnet|sonnet)                           echo "4" ;;
        *)                                              echo "$1" ;;
    esac
}

pane_name() {
    case "$1" in
        0) echo "claude-opus" ;;
        1) echo "claude" ;;
        2) echo "codex-a" ;;
        3) echo "codex-b" ;;
        4) echo "claude-sonnet" ;;
        *) echo "pane-$1" ;;
    esac
}

timestamp() {
    date -u +"%Y-%m-%dT%H:%M:%SZ"
}

ensure_pipeline_log() {
    local slug="$1"
    local dir="$DEV_DIR/proposals/$slug"
    local log="$dir/forge-log.yml"
    mkdir -p "$dir"
    if [ ! -f "$log" ]; then
        cat > "$log" << EOF
pipeline: $slug
entries:
EOF
    fi
}

ensure_summary_log() {
    mkdir -p "$DEV_DIR"
    if [ ! -f "$SUMMARY_LOG" ]; then
        cat > "$SUMMARY_LOG" << EOF
entries:
EOF
    fi
}

yaml_escape() {
    local text="$1"
    if echo "$text" | grep -q $'\n'; then
        echo "|"
        echo "$text" | sed 's/^/      /'
    else
        local escaped
        escaped=$(echo "$text" | sed 's/"/\\"/g')
        echo "\"$escaped\""
    fi
}

# ---- Heartbeat event log helpers (passive pane-1 event stream) ----
#
# Caller-visible behavior: any value passed through _sanitize_event_value
# is mutated for the log line:
#   1) CR/LF/TAB collapse to space
#   2) double-quote -> single-quote
#   3) runs of whitespace -> single underscore (keeps KV tokens parseable)
#   4) byte-truncate to 200 bytes, with "…" suffix on overflow
# Idempotent. cmd_emit callers (e.g. the orchestrator) should keep values
# short and avoid embedded whitespace; verbatim round-trip is NOT preserved.
_sanitize_event_value() {
    local raw="$1"
    local clean
    clean=$(printf '%s' "$raw" \
        | tr '\r\n\t' '   ' \
        | sed -e 's/"/'\''/g' -e 's/[[:space:]][[:space:]]*/_/g')
    printf '%s' "$clean" | awk '{ if (length($0) > 200) print substr($0, 1, 200) "…"; else print $0 }'
}

# _emit_event <TYPE> <slug> [fields-string]
# Best-effort line-emit to <project_root>/.dev/forge-tmp/orchestrator-events.log.
# Never writes to stdout/stderr (bridge contract: callers may parse those).
# Silently skips on unresolvable project root or fs write failure.
# Structured key=value tokens are NOT re-sanitized here — callers sanitize
# freeform values via _sanitize_event_value before assembling the fields arg.
_emit_event() {
    local type="$1"; shift
    local slug="$1"; shift
    local project_root
    project_root=$(_resolve_project_root "" 2>/dev/null) || return 0
    [ -z "$project_root" ] && return 0
    local log_dir="$project_root/.dev/forge-tmp"
    local log_file="$log_dir/orchestrator-events.log"
    mkdir -p "$log_dir" 2>/dev/null || return 0
    printf '%s: pipeline=%s %s\n' "$type" "$slug" "$*" >> "$log_file" 2>/dev/null || true
    # Step 6: BLOCKED/COMPLETE/stage events land at ~1s instead of the 30s floor. Detached,
    # fail-open, gated (FORGE_WATCH_TRIGGER=0 disables in tests). Never touches stdout/stderr or
    # the return code.
    if [ "${FORGE_WATCH_TRIGGER:-1}" = "1" ]; then
        local _fw="${FORGE_WATCH_BIN:-$HOME/bin/forge-watch}"
        [ -x "$_fw" ] && ( nohup "$_fw" check >/dev/null 2>&1 & ) 2>/dev/null || true
    fi
}

# _observe_usage <worker_canonical> <slug> <stage> <worker_idx> <project_root>
# Read-only, family-aware per-task usage observation. Invoked from cmd_callback
# AFTER all critical callback work, wrapped `|| true`. ALWAYS returns 0 — usage
# observation must never delay or break a callback or the pipeline. It NEVER
# sends keystrokes and NEVER issues /clear, /new, or /compact: it only
# `capture-pane`s (read-only) and writes an advisory snapshot + a USAGE event.
#
# Claude panes carry usage in the persistent footer `[Model] ctx: Nk (P%)` — the
# same line stall-check's idle_prompt_anchor matches (shared `ctx: Nk (P%)` shape,
# so a footer-format drift breaks both in lockstep). Codex panes expose NO usage
# in pane text on the current gpt-5.5 build (the trailing `· …` segment is the
# git branch, not usage) → recorded as honest unknown, no capture, no regex.
# See .dev/proposals/per-task-usage-reporting/final-plan.md.
_observe_usage() {
    local worker="$1" slug="$2" stage="$3" worker_idx="$4" project_root="$5"

    # Guard 1: only the four worker panes (an orchestrator self-callback that
    # resolves to `claude` is silently skipped — no usage signal wanted there).
    case "$worker" in
        claude-opus|claude-sonnet|codex-a|codex-b) ;;
        *) return 0 ;;
    esac

    # Family from the canonical worker name (mirrors family() in cmd_health).
    local family
    case "$worker" in
        claude-*) family="claude" ;;
        codex-*)  family="codex"  ;;
        *)        return 0 ;;
    esac

    local usage_file="$project_root/$(_usage_file)"
    local measured_at; measured_at=$(timestamp)
    local fields=""

    if [ "$family" = "codex" ]; then
        # No usage in pane text — honest unknown. No capture, no regex.
        fields="pct=null tokens=null headroom=unknown source=unsupported confidence=none reason=codex-no-pane-usage"
        FORGE_U_FAMILY="$family" FORGE_U_WORKER="$worker" FORGE_U_STAGE="$stage" \
        FORGE_U_AT="$measured_at" FORGE_U_RAWFILE="" \
            python3 - "$usage_file" >/dev/null 2>&1 <<'PYEOF' || true
import os, sys, re, yaml, fcntl
usage_file = sys.argv[1]
fam   = os.environ.get("FORGE_U_FAMILY", "")
wk    = os.environ.get("FORGE_U_WORKER", "")
stage = os.environ.get("FORGE_U_STAGE", "")
at    = os.environ.get("FORGE_U_AT", "")
rawf  = os.environ.get("FORGE_U_RAWFILE", "")

record = {"family": fam, "pct": None, "tokens": None, "headroom": "unknown",
          "source": "unsupported", "confidence": "none",
          "reason": "codex-no-pane-usage", "stage": stage, "measured_at": at}

def upsert(path, worker, rec, updated):
    d = os.path.dirname(path) or "."
    os.makedirs(d, exist_ok=True)
    lp = path + ".lock"
    with open(lp, "w") as lf:
        fcntl.flock(lf, fcntl.LOCK_EX)
        try:
            data = {}
            if os.path.exists(path):
                try:
                    with open(path) as f:
                        data = yaml.safe_load(f) or {}
                except Exception:
                    data = {}
            if not isinstance(data, dict):
                data = {}
            workers = data.get("workers")
            if not isinstance(workers, dict):
                workers = {}
            workers[worker] = rec
            data["workers"] = workers
            data["updated"] = updated
            tmp = path + ".tmp"
            with open(tmp, "w") as f:
                yaml.safe_dump(data, f, default_flow_style=False, sort_keys=True)
            os.replace(tmp, path)
        finally:
            fcntl.flock(lf, fcntl.LOCK_UN)

try:
    upsert(usage_file, wk, record, at)
except Exception:
    pass
PYEOF
        _emit_event USAGE "$slug" "stage=$stage worker=$worker family=$family $fields"
        return 0
    fi

    # Claude: capture the pane footer (read-only) and parse the ctx usage.
    # Test seam: FORGE_USAGE_FIXTURE points at a pre-captured pane file and
    # bypasses tmux entirely (used by T1 unit tests; never set in production).
    local raw_file="" fixture_mode=""
    if [ -n "${FORGE_USAGE_FIXTURE:-}" ] && [ -f "${FORGE_USAGE_FIXTURE}" ]; then
        raw_file="$FORGE_USAGE_FIXTURE"; fixture_mode=1
    else
        # cmd_callback ran require_identity, so ID_target_session is authoritative
        # (host for a worker self-callback; the declared target for a seat relay).
        case "$worker_idx" in
            ''|*[!0-9]*) fields="pct=null tokens=null headroom=unknown source=pane-footer confidence=none reason=bad-pane"
                         _emit_event USAGE "$slug" "stage=$stage worker=$worker family=$family $fields"
                         return 0 ;;
        esac
        local sess="${ID_target_session:-}"
        if [ -z "$sess" ]; then
            fields="pct=null tokens=null headroom=unknown source=pane-footer confidence=none reason=no-session"
            _emit_event USAGE "$slug" "stage=$stage worker=$worker family=$family $fields"
            return 0
        fi
        raw_file=$(mktemp -t forge-usage-XXXXXX 2>/dev/null) || raw_file=""
        if [ -n "$raw_file" ]; then
            tmux capture-pane -p -t "$sess:$WINDOW.$worker_idx" -S -12 > "$raw_file" 2>/dev/null || true
        fi
    fi

    # Parse + persist in one python pass; it prints the USAGE event fields (NOT
    # the raw footer line — raw lives only in the snapshot YAML, never in the
    # line-oriented event log) and always exits 0 with a well-formed fields line.
    fields=$(FORGE_U_FAMILY="$family" FORGE_U_WORKER="$worker" FORGE_U_STAGE="$stage" \
             FORGE_U_AT="$measured_at" FORGE_U_RAWFILE="${raw_file:-}" \
             python3 - "$usage_file" 2>/dev/null <<'PYEOF'
import os, sys, re, yaml, fcntl
usage_file = sys.argv[1]
fam   = os.environ.get("FORGE_U_FAMILY", "")
wk    = os.environ.get("FORGE_U_WORKER", "")
stage = os.environ.get("FORGE_U_STAGE", "")
at    = os.environ.get("FORGE_U_AT", "")
rawf  = os.environ.get("FORGE_U_RAWFILE", "")

def fields_line(d):
    def v(x):
        return "null" if x is None else x
    return ("pct=%s tokens=%s headroom=%s source=%s confidence=%s%s" % (
        v(d.get("pct")), v(d.get("tokens")), v(d.get("headroom")), v(d.get("source")),
        v(d.get("confidence")),
        (" reason=%s" % d["reason"]) if d.get("reason") else ""))

def upsert(path, worker, rec, updated):
    d = os.path.dirname(path) or "."
    os.makedirs(d, exist_ok=True)
    lp = path + ".lock"
    with open(lp, "w") as lf:
        fcntl.flock(lf, fcntl.LOCK_EX)
        try:
            data = {}
            if os.path.exists(path):
                try:
                    with open(path) as f:
                        data = yaml.safe_load(f) or {}
                except Exception:
                    data = {}
            if not isinstance(data, dict):
                data = {}
            workers = data.get("workers")
            if not isinstance(workers, dict):
                workers = {}
            workers[worker] = rec
            data["workers"] = workers
            data["updated"] = updated
            tmp = path + ".tmp"
            with open(tmp, "w") as f:
                yaml.safe_dump(data, f, default_flow_style=False, sort_keys=True)
            os.replace(tmp, path)
        finally:
            fcntl.flock(lf, fcntl.LOCK_UN)

# Defaults → unknown; refined on a successful parse.
rec = {"family": fam, "pct": None, "tokens": None, "headroom": "unknown",
       "raw": None, "source": "pane-footer", "confidence": "none",
       "reason": "no-anchor", "stage": stage, "measured_at": at}
try:
    raw = ""
    if rawf and os.path.exists(rawf):
        with open(rawf) as f:
            raw = f.read()
    if not raw.strip():
        rec["reason"] = "capture-failed"
    else:
        # Strip ANSI/OSC, then find the LAST `ctx: Nk (P%)` footer line.
        norm = re.sub(r'\x1b\[[0-9;]*[A-Za-z]', '', raw)
        norm = re.sub(r'\x1b\][0-9;]*\x07', '', norm)
        found = None
        for line in reversed([l for l in norm.splitlines() if l.strip()][-12:]):
            mm = re.search(r'ctx:\s*(\d+)(k?)\s*\((\d+)%\)', line)
            if mm:
                found = (mm, line.strip()); break
        if found:
            mm, line = found
            pct = int(mm.group(3))
            tokens = mm.group(1) + (mm.group(2) or "")
            headroom = max(0, min(100, 100 - pct))
            rec.update({"pct": pct, "tokens": tokens, "headroom": headroom,
                        "raw": line, "source": "pane-footer",
                        "confidence": ("high" if 0 <= pct <= 100 else "low"),
                        "reason": None})
except Exception:
    rec = {"family": fam, "pct": None, "tokens": None, "headroom": "unknown",
           "raw": None, "source": "pane-footer", "confidence": "none",
           "reason": "observe-error", "stage": stage, "measured_at": at}

try:
    upsert(usage_file, wk, rec, at)
except Exception:
    pass

print(fields_line(rec))
PYEOF
)
    [ -z "$fixture_mode" ] && [ -n "$raw_file" ] && rm -f "$raw_file" 2>/dev/null
    [ -z "$fields" ] && fields="pct=null tokens=null headroom=unknown source=pane-footer confidence=none reason=observe-error"
    _emit_event USAGE "$slug" "stage=$stage worker=$worker family=$family $fields"
    return 0
}

# ---- Hook: Check for pending log entry ----

# Resolve any pane alias to its canonical name via pane_index → pane_name.
canonical_pane_name() {
    pane_name "$(pane_index "$1")"
}

# Per-target pending-log check. Returns 0 if a log entry with
# response: null exists targeting the canonical form of the requested pane.
# Both the request and each log entry's `to:` field are normalized via
# the alias map so historical entries (e.g. `to: claude`) resolve correctly.
has_pending_log_for() {
    local target_canonical="$1"
    local current_session="${2:-$(_resolve_session)}"
    local current_incarnation="${3:-${ID_host_incarnation:-}}"
    if [ ! -f "$SUMMARY_LOG" ]; then
        return 1
    fi
    python3 - "$SUMMARY_LOG" "$target_canonical" "$current_session" "$current_incarnation" << 'PYEOF'
import sys, yaml

log_file, target_canonical, current_session, current_incarnation = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

# Inline alias map mirroring shell pane_index/pane_name.
# Keep this in lockstep with all other ALIAS_TO_CANONICAL maps.
ALIAS_TO_CANONICAL = {
    'inline': 'claude-opus', 'general': 'claude-opus', 'claude-general': 'claude-opus',
    'claude-opus': 'claude-opus', 'opus': 'claude-opus',
    'claude': 'claude', 'orchestrator': 'claude', 'claude-orchestrator': 'claude',
    'codex': 'codex-a', 'codex-a': 'codex-a',
    'codex-b': 'codex-b',
    'claude-sonnet': 'claude-sonnet', 'sonnet': 'claude-sonnet',
}

def canonical(name):
    return ALIAS_TO_CANONICAL.get(name, name)

try:
    with open(log_file) as f:
        data = yaml.safe_load(f) or {}
except FileNotFoundError:
    sys.exit(1)

for entry in data.get('entries', []):
    if entry.get('response') is not None:
        continue
    entry_session = entry.get('session', '') or ''
    # Never skip legacy (no/empty session) entries — keeps in-flight upgrades
    # closeable; only skip a CONFIRMED different-session pending.
    if entry_session and current_session and entry_session != current_session:
        continue  # different session; skip silently
    # Incarnation tiebreak BENEATH the session filter (R10): a reborn same-name session
    # must not be blocked by a dead predecessor's orphan. Legacy no/empty incarnation
    # still matches by name.
    entry_incarnation = str(entry.get('incarnation', '') or '')
    if entry_incarnation and current_incarnation and entry_incarnation != str(current_incarnation):
        continue
    entry_target = canonical(entry.get('to', ''))
    if entry_target == target_canonical:
        sys.exit(0)
sys.exit(1)
PYEOF
}

# ---- Hook: Update forge-context.yml ----

update_context() {
    local slug="$1"
    local stage="$2"
    local status="$3"  # done, blocked, error
    local worker="$4"
    # Per-call session-scoped pointer. Shadows the static global so the SOLE
    # writer never writes the bare forge-context.yml for a live session (§4.1).
    local CONTEXT_FILE; CONTEXT_FILE="$(_context_file)"
    local ts
    ts=$(timestamp)

    mkdir -p "$DEV_DIR"

    # Read existing notes if any
    local existing_notes=""
    if [ -f "$CONTEXT_FILE" ]; then
        existing_notes=$(python3 -c "
import yaml, sys
try:
    with open('$CONTEXT_FILE') as f:
        data = yaml.safe_load(f) or {}
    notes = data.get('notes', [])
    for n in notes:
        print(n)
except:
    pass
" 2>/dev/null)
    fi

    # Determine next stage.
    # qa, qa-fix, and qa-retry do NOT auto-advance — the orchestrator
    # decides whether to enter qa-fix (findings present), qa-retry,
    # verify, or halt. For these stages, preserve any prior orchestrator
    # intent in next_stage; otherwise fall back to "pending-orchestrator-decision".
    local next_stage=""
    if [ "$status" = "done" ]; then
        case "$stage" in
            proposal)            next_stage="review" ;;
            review)              next_stage="incorporate" ;;
            incorporate)         next_stage="implementation" ;;
            implementation)      next_stage="impl-review" ;;
            impl-review)         next_stage="coding" ;;
            coding)              next_stage="qa" ;;
            qa|qa-fix|qa-retry)  next_stage="" ;;       # orchestrator decides
            verify)              next_stage="complete" ;;
            commit-review)       next_stage="" ;;       # side-channel, not a pipeline stage
            *)                   next_stage="unknown" ;;
        esac

        # For orchestrator-decision stages, preserve previous intent if any.
        if [ -z "$next_stage" ] && [ "$stage" != "commit-review" ]; then
            local existing
            existing=$(grep "^next_stage:" "$CONTEXT_FILE" 2>/dev/null | awk '{print $2}')
            next_stage="${existing:-pending-orchestrator-decision}"
        fi
    fi

    # Write context file
    cat > "$CONTEXT_FILE" << EOF
# Forge Context — auto-updated by forge-bridge hooks
# Read this on session start to resume pipeline state
active_pipeline: $slug
last_stage_completed: $stage
last_stage_status: $status
last_worker: $worker
next_stage: $next_stage
updated_at: "$ts"
EOF

    # Append notes if they exist
    if [ -n "$existing_notes" ]; then
        echo "notes:" >> "$CONTEXT_FILE"
        echo "$existing_notes" | while IFS= read -r line; do
            echo "  - \"$line\"" >> "$CONTEXT_FILE"
        done
    else
        echo "notes: []" >> "$CONTEXT_FILE"
    fi

    # Heartbeat: stage RESULT recorded (not necessarily an advance).
    # commit-review is a side-channel, not a pipeline stage transition — skip.
    # Fires from both cmd_log_response (normal callback path) and cmd_set_context
    # (manual operator recovery); the second source is intentional so pane 1 sees
    # interventions.
    if [ "$stage" != "commit-review" ]; then
        _emit_event STAGE "$slug" "result_stage=$stage status=$status next=${next_stage:-pending-orchestrator-decision} worker=$worker"
    fi

    # Heartbeat: pipeline complete — strict terminal condition. Qualified when the
    # session-scoped unresolved set (parked + non-ask blocked) is non-empty (§3.4).
    if [ "$stage" = "verify" ] && [ "$status" = "done" ] && [ "$next_stage" = "complete" ]; then
        local _cpr; _cpr=$(_resolve_project_root "" 2>/dev/null)
        local _cq=""
        if [ -n "$_cpr" ]; then
            local _cu; _cu=$(_completion_unresolved "$_cpr")
            case "$_cu" in
                "parked=0 blocked=0") : ;;
                *) _cq=" qualifier=incomplete $_cu" ;;
            esac
        fi
        _emit_event COMPLETE "$slug" "last_stage=$stage worker=$worker$_cq"
    fi
}

# ---- Signal (file-based, no tmux needed — works from sandboxed agents) ----

SIGNAL_DIR=".dev/signals"

cmd_signal() {
    local from="$1"
    shift
    local msg="$*"
    local ts
    ts=$(timestamp)
    mkdir -p "$SIGNAL_DIR"
    local filename="${from}-$(date +%s).signal"
    cat > "$SIGNAL_DIR/$filename" << EOF
from: $from
timestamp: $ts
message: $msg
EOF
    echo "Signal sent: $from | $msg"
}

cmd_check_signals() {
    local signal_dir="$SIGNAL_DIR"
    if [ ! -d "$signal_dir" ] || [ -z "$(ls -A "$signal_dir"/*.signal 2>/dev/null)" ]; then
        echo "(no pending signals)"
        return 1
    fi
    for f in "$signal_dir"/*.signal; do
        cat "$f"
        echo "---"
    done
}

cmd_clear_signals() {
    rm -f "$SIGNAL_DIR"/*.signal 2>/dev/null
    echo "Signals cleared"
}

# ---- Review Status ----

REVIEWS_DIR=".dev/reviews"

cmd_review_status() {
    local pending_dir="$REVIEWS_DIR/pending"
    local pending=0 pass=0 concerns=0 blocking=0 total_reviewed=0

    # Count pending
    if [ -d "$pending_dir" ]; then
        pending=$(ls -1 "$pending_dir"/*.review 2>/dev/null | wc -l | tr -d ' ')
    fi

    # Scan completed reviews (YAML frontmatter)
    if [ -d "$REVIEWS_DIR" ]; then
        for f in "$REVIEWS_DIR"/*.md; do
            [ -f "$f" ] || continue
            local verdict
            verdict=$(sed -n 's/^verdict: *//p' "$f" 2>/dev/null | head -1 | tr -d ' ')
            case "$verdict" in
                PASS)     pass=$((pass + 1)) ;;
                CONCERNS) concerns=$((concerns + 1)) ;;
                BLOCKING) blocking=$((blocking + 1)) ;;
            esac
            total_reviewed=$((total_reviewed + 1))
        done
    fi

    local total=$((pending + total_reviewed))

    if [ "$total" -eq 0 ]; then
        echo "(no reviews)"
        return 0
    fi

    echo "Reviews: $total total"
    echo "  pending:  $pending"
    echo "  pass:     $pass"
    echo "  concerns: $concerns"
    echo "  blocking: $blocking"

    if [ "$blocking" -gt 0 ]; then
        echo ""
        echo "BLOCKING reviews:"
        for f in "$REVIEWS_DIR"/*.md; do
            [ -f "$f" ] || continue
            local v short subj
            v=$(sed -n 's/^verdict: *//p' "$f" 2>/dev/null | head -1 | tr -d ' ')
            if [ "$v" = "BLOCKING" ]; then
                short=$(sed -n 's/^short: *//p' "$f" 2>/dev/null | head -1)
                subj=$(sed -n 's/^subject: *"*\([^"]*\)"*/\1/p' "$f" 2>/dev/null | head -1)
                echo "  $short — $subj"
            fi
        done
    fi

    if [ "$pending" -gt 0 ]; then
        echo ""
        echo "Pending reviews:"
        for f in "$pending_dir"/*.review; do
            [ -f "$f" ] || continue
            local short subj
            short=$(sed -n 's/^short: *//p' "$f" 2>/dev/null | head -1)
            subj=$(sed -n 's/^subject: *"*\([^"]*\)"*/\1/p' "$f" 2>/dev/null | head -1)
            echo "  $short — $subj"
        done
    fi

    return 0
}

# Copy-mode guard: a pane that wandered into tmux copy-mode (stray mouse
# scroll — mouse mode is on) EATS literal sends as navigation commands; a
# swallowed 'f' even parks tmux at a "(jump forward)" status-line prompt and
# the next send-keys blocks indefinitely (live incident 2026-07-09: codex-b
# dispatch swallowed, retry send blocked 4+ min). Cancel any pane mode before
# typing so every dispatch is self-unsticking. `|| true` throughout — the
# guard must never fail the send path it protects.
_cancel_copy_mode() {
    local target="$1"
    if [ "$(tmux display-message -p -t "$target" '#{pane_in_mode}' 2>/dev/null)" = "1" ]; then
        tmux send-keys -t "$target" -X cancel 2>/dev/null || true
    fi
}

# ---- Commands ----

cmd_send() {
    require_identity "send" host-pane || return 1

    local FORCE=false ALLOW_BLOCKED="" SKIP_BLOCK_GUARD=0
    while :; do
        case "${1:-}" in
            --force) FORCE=true; shift ;;
            --allow-blocked) ALLOW_BLOCKED="$2"; shift 2 ;;
            --_internal) SKIP_BLOCK_GUARD=1; shift ;;   # dispatch's own delivery send
            *) break ;;
        esac
    done

    local PANE_NAME="$1"
    local PANE
    PANE=$(pane_index "$1")
    local TARGET
    TARGET=$(canonical_pane_name "$1")
    shift
    local MSG="$*"

    # Per-target log-before-send hook. Worker panes only.
    # Hard Rule 20's /clear is the only worker-pane --force exemption.
    if [ "$FORCE" = false ]; then
        case "$TARGET" in
            codex-a|codex-b|claude-opus|claude-sonnet)
                if ! has_pending_log_for "$TARGET" "$SESSION" "$ID_host_incarnation"; then
                    echo "HOOK BLOCKED: No pending log entry targeting '$TARGET'." >&2
                    echo "Run 'forge-bridge log --to $TARGET ...' before sending." >&2
                    echo "Or use 'forge-bridge send --force' to bypass for non-pipeline messages." >&2
                    return 1
                fi
                ;;
        esac
    fi

    # All-boundary guard on WORKER sends (covers log+send, §3.4). --_internal (the
    # dispatch delivery send) skips it — dispatch already ran its own guard. On a
    # --force fix-and-continue, exempt the block held by THIS TARGET worker (keyed on
    # the target, never glob order); a --force to a worker holding NO block, or a send
    # while a DIFFERENT worker's block is unresolved, is refused.
    if [ "$SKIP_BLOCK_GUARD" != 1 ]; then
        case "$TARGET" in
            codex-a|codex-b|claude-opus|claude-sonnet)
                local _pr; _pr="$(_resolve_project_root "" 2>/dev/null)"
                if [ -n "$_pr" ]; then
                    if [ "$FORCE" = true ]; then
                        _work_start_guard "$_pr" "send" "$ALLOW_BLOCKED" "" "" "$TARGET" || return 1
                    else
                        _work_start_guard "$_pr" "send" "$ALLOW_BLOCKED" "" "" "" || return 1
                    fi
                fi
                ;;
        esac
    fi

    tmux select-pane -t "$SESSION:$WINDOW.$PANE"
    sleep 0.3
    _cancel_copy_mode "$SESSION:$WINDOW.$PANE"
    # Split the send into two events: type the text literally first (-l), pause
    # so the worker TUI commits the line into its input buffer, THEN press Enter
    # as a standalone keystroke. Combining text+Enter into one send-keys call
    # leaves the text sitting UNSUBMITTED on current Codex/Claude TUI builds —
    # the dispatch reports success but the worker pane never receives the prompt.
    # Same fix already proven on the callback path (see _send notify below).
    tmux send-keys -t "$SESSION:$WINDOW.$PANE" -l "$MSG"
    sleep "${FORGE_SEND_COMMIT_WAIT_S:-0.3}"
    tmux send-keys -t "$SESSION:$WINDOW.$PANE" Enter
}

cmd_read() {
    require_identity "read" host-pane || return 1
    local PANE
    PANE=$(pane_index "$1")
    local LINES="${2:-20}"
    tmux capture-pane -t "$SESSION:$WINDOW.$PANE" -p -S "-$LINES"
}

cmd_focus() {
    require_identity "focus" host-pane || return 1
    local PANE
    PANE=$(pane_index "$1")
    tmux select-pane -t "$SESSION:$WINDOW.$PANE"
}

cmd_back() {
    require_identity "back" host-pane || return 1
    tmux select-pane -t "$SESSION:$WINDOW.1"
}

cmd_log() {
    require_identity "log" host-session || return 1
    local slug="" stage="" from="" to="" prompt=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)    slug="$2";    shift 2 ;;
            --stage)   stage="$2";   shift 2 ;;
            --from)    from="$2";    shift 2 ;;
            --to)      to="$2";      shift 2 ;;
            --prompt)  prompt="$2";  shift 2 ;;
            *)         shift ;;
        esac
    done

    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$from" ] || [ -z "$to" ] || [ -z "$prompt" ]; then
        echo "ERROR: Missing required flags."
        echo "Usage: forge-bridge log --slug <s> --stage <s> --from <f> --to <t> --prompt <p>"
        return 1
    fi

    local ts
    ts=$(timestamp)
    local escaped_prompt
    escaped_prompt=$(yaml_escape "$prompt")

    # Phase 1b Step 4b: record session in pending entries so cmd_stall_check_status
    # can filter by current session (multi-session correlation, review item #4).
    # Session resolution mirrors require_tmux_session: only consult
    # `tmux display-message` when inside tmux; otherwise walk up to .dev/.forge-session.
    # Stamp the resolving session into pending entries so the send-hook and
    # stall-check-status can filter by session. Empty -> "unknown" (NOT the
    # context sentinel): the never-skip-legacy filter keys on empty/"unknown" to
    # keep in-flight upgrades closeable. See final-plan §4.3.
    local session
    session="$(_resolve_session)"
    [ -z "$session" ] && session="unknown"

    ensure_pipeline_log "$slug"
    ensure_summary_log

    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"

    local incarnation="${ID_host_incarnation:-}"
    cat >> "$pipeline_log" << EOF

  - timestamp: "$ts"
    stage: $stage
    from: $from
    to: $to
    session: $session
    incarnation: $incarnation
    prompt: $escaped_prompt
    response: null
    files: []
EOF

    cat >> "$SUMMARY_LOG" << EOF

  - timestamp: "$ts"
    pipeline: $slug
    stage: $stage
    from: $from
    to: $to
    session: $session
    incarnation: $incarnation
    response: null
EOF

    echo "Logged: $from → $to | $slug/$stage | $ts (session=$session)"
}

# Internal no-context patch primitive (orphan-log-entries fix, v2 Review #1).
# Rewrites `response: null` -> a given string on a timestamp anchor in BOTH the
# per-pipeline log and the summary log, reusing the same surgical string-replace
# as cmd_log_response (preserves YAML/comments) but WITHOUT deriving a status or
# calling update_context. Used by `dispatch --supersede` and the orphan
# migration to close pendings as sentinels — routing those through the public
# cmd_log_response would corrupt forge-context.yml (status=unknown) and spam a
# STAGE heartbeat. Real worker callbacks must still use cmd_log_response.
#   _patch_response_by_ts <slug> <timestamp> <response>
_patch_response_by_ts() {
    local slug="$1" target_ts="$2" response="$3"
    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"
    if [ ! -f "$pipeline_log" ]; then
        echo "ERROR: _patch_response_by_ts: no log file for pipeline '$slug'" >&2
        return 1
    fi
    python3 - "$pipeline_log" "$SUMMARY_LOG" "$target_ts" "$response" <<'PYEOF'
import re, sys

pipeline_log, summary_log, target_ts, response = sys.argv[1:5]
escaped_response = response.replace('\\', '\\\\').replace('"', '\\"')

# Match the entry by its timestamp anchor; replace ONLY its `response: null`.
pat = re.compile(
    r'(timestamp:\s*"' + re.escape(target_ts) + r'"[^\n]*\n(?:\s+[^\n]*\n)*?\s+)response:\s*null',
    re.MULTILINE)

def patch(text):
    return pat.subn(lambda m: m.group(1) + 'response: "' + escaped_response + '"',
                    text, count=1)

with open(pipeline_log) as f:
    content = f.read()
content, n = patch(content)
if n != 1:
    print(f"ERR: _patch_response_by_ts: pipeline_log patch failed (n={n}, ts={target_ts})",
          file=sys.stderr)
    sys.exit(2)
with open(pipeline_log, "w") as f:
    f.write(content)

# Summary log: same anchor; soft-fail if absent (older entries may pre-date it).
try:
    with open(summary_log) as f:
        s_content = f.read()
    s_new, sn = patch(s_content)
    if sn == 1:
        with open(summary_log, "w") as f:
            f.write(s_new)
except FileNotFoundError:
    pass
PYEOF
    local rc=$?
    if [ $rc -ne 0 ]; then
        echo "ERROR: _patch_response_by_ts: failed for slug=$slug ts=$target_ts" >&2
        return 1
    fi
}

# ---- Lifecycle lock: per-(slug,stage) mutex for park/resolve/supersede/publish/consume ----
# §3.3. flock via an inherited fd (fd 9) so a bash critical section can hold the lock
# across multiple statements (revalidate-under-lock). Short wait then loud failure —
# never hang a pane. Callers MUST pair _lifecycle_lock with _lifecycle_unlock (or a
# subshell exit closes fd 9 → auto-release). The infra lock is acquired/released
# OUTSIDE this lock (park step 4) — no nested locks.
_lifecycle_lock() {   # <slug> <stage> ; rc 0 = held on fd 9
    local slug="$1" stage="$2"
    local pr; pr="$(_resolve_project_root "" 2>/dev/null)"
    [ -n "$pr" ] || { echo "ERROR: lifecycle-lock: no project root" >&2; return 1; }
    local ld="$pr/.dev/forge-tmp/locks"; mkdir -p "$ld" 2>/dev/null
    local lf="$ld/lifecycle-${slug}--${stage}.lock"
    exec 9>"$lf" || { echo "ERROR: lifecycle-lock: cannot open $lf" >&2; return 1; }
    FORGE_LC_WAIT_S="${FORGE_LIFECYCLE_LOCK_WAIT_S:-5}" python3 - <<'PY'
import fcntl, os, time, sys
deadline = time.time() + float(os.environ.get("FORGE_LC_WAIT_S", "5"))
while True:
    try:
        fcntl.flock(9, fcntl.LOCK_EX | fcntl.LOCK_NB); sys.exit(0)
    except OSError:
        if time.time() >= deadline:
            sys.exit(75)
        time.sleep(0.1)
PY
    local rc=$?
    if [ "$rc" -ne 0 ]; then
        exec 9>&-
        echo "LIFECYCLE_LOCK: busy — could not acquire lifecycle-${slug}--${stage} within ${FORGE_LIFECYCLE_LOCK_WAIT_S:-5}s (another transition holds it)." >&2
        return 1
    fi
    return 0
}
_lifecycle_unlock() { exec 9>&- 2>/dev/null || true; }

# Insert parked_at/parked_reason/uncommitted as SIBLINGS of a specific open entry
# (located by timestamp anchor), keeping response: null, in BOTH logs — mirroring
# _patch_response_by_ts's dual-write (pipeline hard-fail, summary soft-fail). §3.1.
# Reason is YAML-escaped (read back by yaml.safe_load). Never yaml.dump. Idempotent:
# a pre-existing parked_* set on that entry is stripped first (re-park overwrites).
_insert_parked_fields_by_ts() {   # <slug> <ts> <parked_at> <reason> <uncommitted-true|false>
    local slug="$1" target_ts="$2" parked_at="$3" reason="$4" uncommitted="$5"
    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"
    if [ ! -f "$pipeline_log" ]; then
        echo "ERROR: _insert_parked_fields_by_ts: no log for '$slug'" >&2; return 1
    fi
    FORGE_PK_AT="$parked_at" FORGE_PK_REASON="$reason" FORGE_PK_UNCO="$uncommitted" \
    python3 - "$pipeline_log" "$SUMMARY_LOG" "$target_ts" <<'PYEOF'
import os, re, sys
pipeline_log, summary_log, target_ts = sys.argv[1:4]
parked_at = os.environ.get("FORGE_PK_AT", "")
uncommitted = "true" if os.environ.get("FORGE_PK_UNCO") == "true" else "false"
reason = os.environ.get("FORGE_PK_REASON", "")
reason = " ".join(reason.splitlines()[0].split())[:120] if reason else ""
esc = reason.replace('\\', '\\\\').replace('"', '\\"')

# Anchor the newest open (response: null) entry at this ts; insert siblings each on
# their OWN line at the same indentation as `response:` (indent here is spaces-only —
# the anchor's trailing newline is consumed by group(1)). Drop any prior parked_* on
# that entry first (re-park overwrites, never duplicates). Reconstruct through
# `response: null` (group 3) so the fields land immediately before it.
pat = re.compile(
    r'(timestamp:\s*"' + re.escape(target_ts) + r'"[^\n]*\n(?:\s+[^\n]*\n)*?)(\s+)(response:\s*null)',
    re.MULTILINE)

def patch(text):
    matches = list(pat.finditer(text))
    if not matches:
        return text, 0, 0
    m = matches[-1]                 # D2 newest
    head, indent = m.group(1), m.group(2)
    head = re.sub(r'[ \t]+(?:parked_at|parked_reason|uncommitted):[^\n]*\n', '', head)
    ins = (f'{indent}parked_at: "{parked_at}"\n'
           f'{indent}parked_reason: "{esc}"\n'
           f'{indent}uncommitted: {uncommitted}\n'
           f'{indent}response: null')
    new = text[:m.start(1)] + head + ins + text[m.end(3):]
    return new, 1, len(matches) - 1

with open(pipeline_log) as f:
    content = f.read()
content, n, dups = patch(content)
if n != 1:
    print(f"ERR: _insert_parked_fields_by_ts: pipeline patch failed (n={n}, ts={target_ts})", file=sys.stderr)
    sys.exit(2)
with open(pipeline_log, "w") as f:
    f.write(content)
if dups:
    print(f"WARN: parked fields inserted on the NEWEST of {dups+1} open entries at ts={target_ts}; {dups} older duplicate(s) left un-parked.", file=sys.stderr)

try:
    with open(summary_log) as f:
        s = f.read()
    s2, sn, _ = patch(s)
    if sn == 1:
        with open(summary_log, "w") as f:
            f.write(s2)
except FileNotFoundError:
    pass
PYEOF
    local rc=$?
    [ $rc -eq 0 ] || { echo "ERROR: _insert_parked_fields_by_ts failed slug=$slug ts=$target_ts" >&2; return 1; }
}

# Session-scoped (plus unowned-legacy, WARN) top-level BLOCKED callbacks whose
# (slug,stage) has an open pending, EXCLUDING ask-origin. One python pass. Echoes
# "slug\tstage\tcallback_id\tworker" per unresolved block.
_unresolved_blocked_items() {   # <project_root> [exempt_slug] [exempt_stage]
    local pr="$1" ex_slug="${2:-}" ex_stage="${3:-}"
    local sess; sess="$(_resolve_session)"
    FORGE_G_SESS="$sess" FORGE_G_EXSLUG="$ex_slug" FORGE_G_EXSTAGE="$ex_stage" \
    python3 - "$pr" <<'PY'
import os, sys, glob, re, json
try: import yaml
except Exception: yaml = None
root=sys.argv[1]; sess=os.environ.get("FORGE_G_SESS") or ""
ex_slug=os.environ.get("FORGE_G_EXSLUG") or ""; ex_stage=os.environ.get("FORGE_G_EXSTAGE") or ""
dev=os.path.join(root, ".dev")
openp=set()
for logp in glob.glob(os.path.join(dev, "proposals", "*", "forge-log.yml")):
    slug=os.path.basename(os.path.dirname(logp))
    try: entries=(yaml.safe_load(open(logp)) or {}).get("entries", []) or [] if yaml else []
    except Exception: entries=[]
    for e in entries:
        if isinstance(e, dict) and e.get("response") is None:
            openp.add((slug, e.get("stage")))
asks=set()
for ap in glob.glob(os.path.join(dev, "attention", "ask-*.json")):
    try: a=json.load(open(ap))
    except Exception: continue
    if a.get("event")=="ask" and a.get("slug") and a.get("mode")=="stage":
        asks.add((a.get("slug"), a.get("stage")))
for cbp in glob.glob(os.path.join(dev, "forge-tmp", "callbacks", "*.callback")):
    hdr={}
    for ln in open(cbp).read().splitlines():
        if ln.startswith("message:"): break
        m=re.match(r'^([a-z_]+):\s*(.*)$', ln)
        if m: hdr[m.group(1)]=m.group(2).strip()
    if (hdr.get("status") or "").upper() != "BLOCKED": continue
    slug, stage = hdr.get("slug"), hdr.get("stage")
    if (slug, stage) not in openp: continue
    origin=hdr.get("origin")
    if origin=="ask" or (not origin and (slug, stage) in asks): continue
    csess=hdr.get("session")
    sessq=bool(re.search(r'\.[^.]+\.callback$', os.path.basename(cbp)))
    if sessq and csess and sess and csess != sess: continue     # another session
    if not (sessq and csess): sys.stderr.write("WARN: guard counting unowned legacy BLOCKED %s\n" % os.path.basename(cbp))
    if ex_slug and slug == ex_slug and (not ex_stage or stage == ex_stage): continue  # same-item
    print("%s\t%s\t%s\t%s" % (slug, stage, hdr.get("callback_id") or "", hdr.get("worker") or ""))
PY
}

# Refusal (or --allow-blocked bypass) for a boundary. Returns 1 to refuse, 0 to allow.
# <exempt_worker> (send --force only): drop rows whose callback `worker:` == the send
# TARGET — the fix-and-continue continuation for the worker's own held block.
_work_start_guard() {   # <project_root> <ctx: dispatch|send> <allow_reason> <exempt_slug> <exempt_stage> [exempt_worker]
    local pr="$1" ctx="$2" allow="$3" ex_slug="$4" ex_stage="$5" ex_worker="${6:-}"
    local raw; raw="$(_unresolved_blocked_items "$pr" "$ex_slug" "$ex_stage")"
    local items="" s st cid w
    while IFS=$'\t' read -r s st cid w; do
        [ -z "$s" ] && continue
        [ -n "$ex_worker" ] && [ "$w" = "$ex_worker" ] && continue
        items="${items}${s}"$'\t'"${st}"$'\t'"${cid}"$'\t'"${w}"$'\n'
    done <<< "$raw"
    [ -z "$items" ] && return 0
    local n; n=$(printf '%s' "$items" | grep -c .)
    if [ -n "$allow" ]; then
        local keys; keys=$(printf '%s' "$items" | tr '\n' ';')
        _emit_event GUARD_BLOCK "${ex_slug:-multi}" "stage=${ex_stage:-?} boundary=$ctx reason=allow-blocked-bypass n=$n bypassed=$keys allow_reason=$(_sanitize_event_value "$allow")"
        echo "GUARD BYPASS (--allow-blocked): $allow — bypassed $n unresolved item(s): $keys" >&2
        return 0
    fi
    {
        echo "HOOK BLOCKED: $ctx refused — unresolved BLOCKED item(s):"
        printf '%s' "$items" | while IFS=$'\t' read -r s st cid w; do
            [ -n "$s" ] && echo "    - $s/$st (worker=$w callback_id=$cid): fix+continue (send --force + callback-consume) · dispatch --supersede · or forge-bridge park"
        done
        echo "  Or re-run with --allow-blocked \"<reason>\" (one-shot, logged)."
    } >&2
    _emit_event GUARD_BLOCK "${ex_slug:-multi}" "stage=${ex_stage:-?} boundary=$ctx reason=unresolved-blocked-item n=$n"
    return 1
}

# Session-scoped unresolved-set counts for COMPLETE qualification (§3.4): parked
# entries (open pendings carrying parked_at) + non-ask BLOCKED callbacks with open
# pendings. Echoes "parked=<n> blocked=<m>".
_completion_unresolved() {   # <project_root>
    local pr="$1"
    local blocked; blocked="$(_unresolved_blocked_items "$pr" 2>/dev/null | grep -c . )"
    local sess; sess="$(_resolve_session)"
    local parked
    parked=$(FORGE_C_SESS="$sess" python3 - "$pr/.dev/proposals" <<'PY'
import os, sys, glob
try: import yaml
except Exception: yaml=None
base=sys.argv[1]; sess=os.environ.get("FORGE_C_SESS") or ""; n=0
for logp in glob.glob(os.path.join(base, "*", "forge-log.yml")):
    try: entries=(yaml.safe_load(open(logp)) or {}).get("entries", []) or [] if yaml else []
    except Exception: entries=[]
    for e in entries:
        if isinstance(e, dict) and e.get('response') is None and e.get('parked_at'):
            es=e.get('session') or ""
            if not sess or not es or es == sess:
                n += 1
print(n)
PY
)
    printf 'parked=%s blocked=%s' "${parked:-0}" "${blocked:-0}"
}

# Revalidate-under-lock: confirm the callback status+callback_id and the target
# pending (open + timestamp) match what the operation validated before acquiring.
# Echoes "OK" or "MISMATCH:<detail>"; caller refuses on mismatch.
_lifecycle_revalidate() {   # <cb_file> <want_status> <want_cb_id> <pipeline_log> <want_ts>
    local cbf="$1" want_status="$2" want_cbid="$3" plog="$4" want_ts="$5"
    if [ ! -f "$cbf" ]; then echo "MISMATCH:callback-gone"; return 0; fi
    local now_status now_cbid
    now_status=$(grep '^status:' "$cbf" 2>/dev/null | awk '{print $2}')
    now_cbid=$(grep '^callback_id:' "$cbf" 2>/dev/null | awk '{print $2}')
    if [ -n "$want_status" ] && [ "$now_status" != "$want_status" ]; then
        echo "MISMATCH:status-changed have=$now_status want=$want_status"; return 0
    fi
    if [ -n "$want_cbid" ] && [ "$now_cbid" != "$want_cbid" ]; then
        echo "MISMATCH:callback_id-changed have=$now_cbid want=$want_cbid"; return 0
    fi
    if [ -n "$want_ts" ]; then
        grep -q "timestamp: \"$want_ts\"" "$plog" 2>/dev/null || { echo "MISMATCH:pending-gone"; return 0; }
        python3 - "$plog" "$want_ts" <<'PY' || { echo "MISMATCH:pending-closed"; return 0; }
import re, sys
plog, ts = sys.argv[1], sys.argv[2]
raw = open(plog).read()
pat = re.compile(r'timestamp:\s*"' + re.escape(ts) + r'"[^\n]*\n(?:\s+[^\n]*\n)*?\s+response:\s*(null|"[^"]*")', re.M)
m = pat.search(raw)
sys.exit(0 if (m and m.group(1) == 'null') else 1)
PY
    fi
    echo "OK"
}

cmd_log_response() {
    require_identity "log-response" host-degrade || return 1
    # Phase 1b Step 4a: target-aware response update.
    # New flags: --to <pane> (alias-normalized), --stage <stage>
    # Without --to/--stage, ambiguity guard refuses if more than one
    # `response: null` entry exists in the pipeline log (review item #3).
    # Backward compat: single-pending-entry pipelines work unchanged.

    local slug="" response="" target="" target_stage=""
    local -a files=()

    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)     slug="$2";     shift 2 ;;
            --response) response="$2"; shift 2 ;;
            --file)     files+=("$2"); shift 2 ;;
            --to)       target="$2";   shift 2 ;;
            --stage)    target_stage="$2"; shift 2 ;;
            *)          shift ;;
        esac
    done

    if [ -z "$slug" ] || [ -z "$response" ]; then
        echo "ERROR: Missing required flags."
        echo "Usage: forge-bridge log-response --slug <s> --response <r> [--to <pane>] [--stage <stage>] [--file <path:action>]..."
        return 1
    fi

    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"

    if [ ! -f "$pipeline_log" ]; then
        echo "ERROR: No log file for pipeline '$slug'"
        return 1
    fi

    # Normalize --to via the same alias map used in has_pending_log_for.
    local target_canonical=""
    if [ -n "$target" ]; then
        target_canonical=$(canonical_pane_name "$target")
    fi

    local files_yaml="[]"
    if [ ${#files[@]} -gt 0 ]; then
        files_yaml=""
        for f in "${files[@]}"; do
            local fpath="${f%%:*}"
            local faction="${f##*:}"
            files_yaml="$files_yaml
      - path: $fpath
        action: $faction"
        done
    fi

    # Determine status from response keyword.
    local status="unknown"
    if echo "$response" | grep -qi "FORGE_DONE"; then
        status="done"
    elif echo "$response" | grep -qi "FORGE_BLOCKED"; then
        status="blocked"
    elif echo "$response" | grep -qi "FORGE_ERROR"; then
        status="error"
    fi

    # Find the target entry's timestamp (the surgical anchor for string-replace).
    # Filter pending entries by --to (canonical) and --stage. Apply ambiguity
    # guard if no filters provided and more than one pending entry exists.
    local matched
    matched=$(python3 - "$pipeline_log" "$target_canonical" "$target_stage" "$ID_target_session" "$ID_host_incarnation" << 'PYEOF'
import sys, yaml

pipeline_log = sys.argv[1]
target_canonical = sys.argv[2] or None
target_stage = sys.argv[3] or None
caller_session = sys.argv[4] or None
caller_incarnation = sys.argv[5] or None

ALIAS_TO_CANONICAL = {
    'inline': 'claude-opus', 'general': 'claude-opus', 'claude-general': 'claude-opus',
    'claude-opus': 'claude-opus', 'opus': 'claude-opus',
    'claude': 'claude', 'orchestrator': 'claude', 'claude-orchestrator': 'claude',
    'codex': 'codex-a', 'codex-a': 'codex-a',
    'codex-b': 'codex-b',
    'claude-sonnet': 'claude-sonnet', 'sonnet': 'claude-sonnet',
}
def canonical(name):
    return ALIAS_TO_CANONICAL.get(name, name)

try:
    with open(pipeline_log) as f:
        data = yaml.safe_load(f) or {}
except Exception as ex:
    print(f"ERR_PARSE:{ex}", file=sys.stderr); sys.exit(2)

entries = data.get('entries') or []
pending = [e for e in entries if e.get('response') is None]
if not pending:
    print("ERR_NO_PENDING", file=sys.stderr); sys.exit(2)

def matches(e):
    if target_canonical and canonical(e.get('to', '')) != target_canonical:
        return False
    if target_stage and e.get('stage', '') != target_stage:
        return False
    # R10 (MAJOR-3): filter by the caller's session so a close from session X can never
    # close session Y's coincident slug+stage+to pending. Never-skip-legacy: entries
    # with empty session still match (mirrors :604). A headless caller (empty
    # caller_session) also matches empty-session entries — the infra-lock lifecycle.
    es = e.get('session', '') or ''
    if es and caller_session and es != caller_session:
        return False
    # Incarnation is a finer tiebreak BENEATH the session filter (inert until CG-6
    # stamps the field; caller_incarnation from the host probe, entries empty pre-CG-6).
    ei = str(e.get('incarnation', '') or '')
    if ei and caller_incarnation and ei != str(caller_incarnation):
        return False
    return True

candidates = [e for e in pending if matches(e)]
# Headless cross-session close guard: when the caller has NO resolved session
# (host-degrade headless), matches() cannot session-filter, so a close spanning >1
# DISTINCT nonempty session is unsafe — refuse and demand an explicit target. A
# single-session or empty-session (legacy / infra-lock) candidate set proceeds.
if caller_session is None:
    _distinct = set((e.get('session', '') or '') for e in candidates)
    _distinct.discard('')
    if len(_distinct) > 1:
        print("ERR_XSESSION:%d distinct sessions in the pending set; pass --target-session <name> --cross-session to disambiguate the close." % len(_distinct), file=sys.stderr)
        sys.exit(2)
if not candidates:
    filt = []
    if target_canonical: filt.append(f"--to={target_canonical}")
    if target_stage: filt.append(f"--stage={target_stage}")
    print(f"ERR_NO_MATCH:{' '.join(filt)}", file=sys.stderr); sys.exit(2)

# Ambiguity guard: only when caller supplied no filters.
if len(candidates) > 1 and not target_canonical and not target_stage:
    msg = f"ERR_AMBIGUOUS:{len(candidates)} pending entries (run with --to and/or --stage to disambiguate):\n"
    for e in candidates:
        msg += f"  - to={e.get('to','?')} stage={e.get('stage','?')} ts={e.get('timestamp','?')}\n"
    print(msg, file=sys.stderr); sys.exit(2)

# Most recent matching entry (last in list-order).
chosen = candidates[-1]
# D2 (orphan-log-entries): a filtered call may still match >1 pending (the
# ambiguity guard above fires only when NO filters are given). We close this
# most-recent one and report the older skipped duplicates so the shell can emit
# a durable WARN + audit event. Extra tab fields are ignored by older callers.
skipped = candidates[:-1]
skipped_ts = ",".join(e.get('timestamp', '') for e in skipped)
print(f"OK\t{chosen.get('timestamp','')}\t{chosen.get('stage','')}\t{chosen.get('to','')}\t{len(skipped)}\t{skipped_ts}")
PYEOF
)
    local rc=$?
    if [ $rc -ne 0 ] || [[ "$matched" != OK* ]]; then
        # python wrote diagnostic to stderr already; surface a one-line stdout summary
        echo "ERROR: log-response: target-resolution failed for slug=$slug" >&2
        return 1
    fi

    local target_ts target_stage_resolved target_to n_skipped skipped_ts
    target_ts=$(echo "$matched" | awk -F'\t' '{print $2}')
    target_stage_resolved=$(echo "$matched" | awk -F'\t' '{print $3}')
    target_to=$(echo "$matched" | awk -F'\t' '{print $4}')
    n_skipped=$(echo "$matched" | awk -F'\t' '{print $5}')
    skipped_ts=$(echo "$matched" | awk -F'\t' '{print $6}')

    # Targeted string-replace anchored to the resolved timestamp. Preserves
    # YAML formatting / comments (yaml.dump would re-emit and lose them).
    python3 << PYEOF
import re, sys

target_ts = """$target_ts"""
escaped_response = """$response""".replace('\\\\', '\\\\\\\\').replace('"', '\\\\"')
files_data = """$files_yaml"""
# Preserve the leading newline that separates `files:` from the first list
# item; an inline `files:- path:` is malformed YAML. Keep trailing whitespace
# trimmed only.
files_data = files_data.rstrip()

# Match the entry by its timestamp anchor; replace ONLY its response: null
# (and files: [] if files_data is provided).
pat = re.compile(
    r'(timestamp:\s*"' + re.escape(target_ts) + r'"[^\n]*\n(?:\s+[^\n]*\n)*?\s+)response:\s*null',
    re.MULTILINE)

def patch_response(text):
    new_text, n = pat.subn(
        lambda m: m.group(1) + 'response: "' + escaped_response + '"', text, count=1)
    return new_text, n

# Pipeline log
with open("$pipeline_log") as f:
    content = f.read()
content, n = patch_response(content)
if n != 1:
    print(f"ERR: pipeline_log patch failed (n={n}, ts={target_ts})", file=sys.stderr)
    sys.exit(2)
if files_data and files_data != "[]":
    fpat = re.compile(
        r'(timestamp:\s*"' + re.escape(target_ts) + r'"[^\n]*\n(?:\s+[^\n]*\n)*?\s+)files:\s*\[\]',
        re.MULTILINE)
    content, _ = fpat.subn(
        lambda m: m.group(1) + 'files:' + files_data, content, count=1)
with open("$pipeline_log", "w") as f:
    f.write(content)

# Summary log: same anchor; soft-fail if not found (older entries may pre-date Phase 1b).
try:
    with open("$SUMMARY_LOG") as f:
        s_content = f.read()
    s_new, sn = patch_response(s_content)
    if sn == 1:
        with open("$SUMMARY_LOG", "w") as f:
            f.write(s_new)
except FileNotFoundError:
    pass

print("Updated: $slug | to=$target_to | stage=$target_stage_resolved | ts=$target_ts | response: $response")
PYEOF
    # R4-2: the patch block above can fail (regex anchor not found ⇒ sys.exit(2))
    # but its exit code was previously dropped, so a failed close returned ~0.
    # The terminal callback path now relies on a TRUE failure signal to refuse
    # publishing a DONE/ERROR callback over an unclosed pending — propagate it.
    local _patch_rc=$?
    if [ "$_patch_rc" -ne 0 ]; then
        echo "ERROR: log-response: failed to patch the pending entry for slug=$slug stage=$target_stage_resolved (response NOT recorded; anchor ts=$target_ts not found or write failed)." >&2
        _emit_event ERROR "$slug" "stage=$target_stage_resolved reason=log-response-patch-failed rc=$_patch_rc to=$target_to"
        return 1
    fi

    # D2 (orphan-log-entries): >1 pending matched the filter; we closed the most
    # recent (candidates[-1]) and left the older duplicate(s) OPEN. Emit a loud
    # stderr WARN AND a durable audit event. cmd_callback runs this with
    # >/dev/null 2>&1 (the normal callback path), so the audit event — not the
    # stderr WARN — is the signal that survives there. MUST NOT change the exit
    # code: this sits before the final update_context, whose rc stays the
    # function's return value (the orchestrator reads it as success/failure).
    if [ -n "$n_skipped" ] && [ "$n_skipped" -gt 0 ] 2>/dev/null; then
        echo "WARN: log-response closed the most recent of $((n_skipped + 1)) pending entries for slug=$slug stage=$target_stage_resolved to=$target_to; $n_skipped older duplicate(s) left OPEN (ts: $skipped_ts). Run 'dispatch --supersede' or the orphan migration to close them." >&2
        _emit_event WARN_DUP_PENDING "$slug" "stage=$target_stage_resolved to=$target_to closed_ts=$target_ts skipped=$n_skipped skipped_ts=$skipped_ts"
    fi

    # Hook 2: auto-update forge-context.yml using the resolved entry.
    if [ -n "$target_stage_resolved" ] && [ -n "$status" ]; then
        update_context "$slug" "$target_stage_resolved" "$status" "$target_to"
    fi
}

cmd_history() {
    local LINES="${1:-30}"
    if [ -f "$SUMMARY_LOG" ]; then
        tail -n "$LINES" "$SUMMARY_LOG"
    else
        echo "(no log entries yet)"
    fi
}

cmd_pipeline_log() {
    local slug="$1"
    local LINES="${2:-50}"

    if [ -z "$slug" ]; then
        echo "Usage: forge-bridge pipeline-log <slug> [lines]"
        return 1
    fi

    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"
    if [ -f "$pipeline_log" ]; then
        tail -n "$LINES" "$pipeline_log"
    else
        echo "(no log for pipeline '$slug')"
    fi
}

# ---- Context (session start / recovery) ----

cmd_context() {
    # host-degrade (MINOR-3): with a host present it is host-scoped (an in-pane
    # MISMATCH halts under enforce); headless with >1 same-root it DEGRADES to
    # "(no active pipeline)" via the __nosession__ sentinel rather than a hard refuse.
    # The single-session early-return below is preserved.
    require_identity "context" host-degrade || return 1
    local CONTEXT_FILE; CONTEXT_FILE="$(_context_file)"
    # Phase 1b Step 3: prepend stall-check-status section if non-empty.
    # Inserted BEFORE the existing early-return so stale-pending warnings
    # surface even when no $CONTEXT_FILE exists yet.
    local _stall_status_output
    local _resolved_root
    _resolved_root=$(_resolve_project_root "")
    if [ -n "$_resolved_root" ]; then
        _stall_status_output=$(cmd_stall_check_status --project-root "$_resolved_root" 2>/dev/null)
    else
        _stall_status_output=$(cmd_stall_check_status 2>/dev/null)
    fi
    if [ -n "$_stall_status_output" ]; then
        echo "$_stall_status_output"
        echo ""
    fi

    if [ ! -f "$CONTEXT_FILE" ]; then
        echo "(no forge context — no active pipeline)"
        echo ""
        # Read-only migration HINT (§6): a legacy SHARED forge-context.yml may
        # hold a pre-upgrade pipeline. Surface it; NEVER auto-adopt (could import
        # another session's pointer). The owning session runs set-context --slug.
        local _legacy_ctx="$DEV_DIR/forge-context.yml"
        if [ -f "$_legacy_ctx" ]; then
            local _legacy_slug
            _legacy_slug=$(grep "^active_pipeline:" "$_legacy_ctx" 2>/dev/null | awk '{print $2}')
            if [ -n "$_legacy_slug" ] && [ "$_legacy_slug" != "null" ]; then
                echo "legacy shared context found; if this pipeline is yours, run: set-context --slug $_legacy_slug"
                echo ""
            fi
        fi
        echo "Start a new pipeline with forge-bridge log, or set one manually:"
        echo "  forge-bridge set-context --slug <slug-name>"

        # Still show reviews even without a pipeline
        local has_reviews_noctx=false
        if [ -d "$REVIEWS_DIR/pending" ] && [ -n "$(ls -A "$REVIEWS_DIR/pending/"*.review 2>/dev/null)" ]; then
            has_reviews_noctx=true
        fi
        if [ -n "$(ls -A "$REVIEWS_DIR/"*.md 2>/dev/null)" ]; then
            has_reviews_noctx=true
        fi
        if [ "$has_reviews_noctx" = true ]; then
            echo ""
            echo "=== Commit Reviews ==="
            cmd_review_status
        fi
        return 0
    fi

    echo "=== Forge Context ==="
    cat "$CONTEXT_FILE"
    echo ""

    # Show last few log entries for the active pipeline
    local slug
    slug=$(grep "active_pipeline:" "$CONTEXT_FILE" 2>/dev/null | awk '{print $2}')
    if [ -n "$slug" ] && [ "$slug" != "null" ]; then
        local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"
        if [ -f "$pipeline_log" ]; then
            echo "=== Recent Activity ($slug) ==="
            tail -20 "$pipeline_log"
        fi

        # Check for pending signals
        if [ -d "$SIGNAL_DIR" ] && [ -n "$(ls -A "$SIGNAL_DIR"/*.signal 2>/dev/null)" ]; then
            echo ""
            echo "=== Pending Signals ==="
            cmd_check_signals
        fi
    fi

    # Show review status if any reviews exist
    local has_reviews=false
    if [ -d "$REVIEWS_DIR/pending" ] && [ -n "$(ls -A "$REVIEWS_DIR/pending/"*.review 2>/dev/null)" ]; then
        has_reviews=true
    fi
    if [ -n "$(ls -A "$REVIEWS_DIR/"*.md 2>/dev/null)" ]; then
        has_reviews=true
    fi
    if [ "$has_reviews" = true ]; then
        echo ""
        echo "=== Commit Reviews ==="
        cmd_review_status
    fi
}

cmd_set_context() {
    require_identity "set-context" host-session || return 1
    local slug=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --slug) slug="$2"; shift 2 ;;
            *)      shift ;;
        esac
    done

    if [ -z "$slug" ]; then
        echo "Usage: forge-bridge set-context --slug <slug-name>"
        return 1
    fi

    mkdir -p "$DEV_DIR"

    # If pipeline log exists, derive state from it
    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"
    local last_stage="none"
    local last_status="none"
    local last_worker="none"

    if [ -f "$pipeline_log" ]; then
        last_stage=$(python3 -c "
import yaml
with open('$pipeline_log') as f:
    data = yaml.safe_load(f) or {}
entries = data.get('entries', [])
for e in reversed(entries):
    r = e.get('response', '')
    if r and 'FORGE_DONE' in str(r):
        print(e.get('stage', 'none'))
        break
else:
    print('none')
" 2>/dev/null || echo "none")
        last_worker=$(python3 -c "
import yaml
with open('$pipeline_log') as f:
    data = yaml.safe_load(f) or {}
entries = data.get('entries', [])
for e in reversed(entries):
    r = e.get('response', '')
    if r and 'FORGE_DONE' in str(r):
        print(e.get('to', 'none'))
        break
else:
    print('none')
" 2>/dev/null || echo "none")
        if [ "$last_stage" != "none" ]; then
            last_status="done"
        fi
    fi

    update_context "$slug" "$last_stage" "$last_status" "$last_worker"
    echo "Context set to pipeline: $slug"
    cmd_context
}

# ---- Status file (.dev/forge-status.md) ----
#
# Human-readable rolling summary. Re-rendered as a side effect of dispatch,
# wait, and callback so a fresh `cat .dev/forge-status.md` always works.
# Computed from forge-context.yml + the per-pipeline log; never the source of
# truth.

# Per-session rendered-status filename (mirrors _context_file's session scope).
# Defined once and used at BOTH the render-write site and the cmd_status read
# site so the two can never drift. (Replaces the old static status-filename
# constant, which is now removed — it had no remaining reader.)
_status_file_name() { printf 'forge-status.%s.md' "$(_session_or_sentinel)"; }

_render_status_file() {
    # Resolve project root; if we can't, skip silently (status is best-effort).
    local project_root
    project_root=$(_resolve_project_root "" 2>/dev/null)
    if [ -z "$project_root" ]; then
        return 0
    fi
    # Per-session read + output (in-place resolve; this function does not cd).
    # Callers run pinned/in-pane (dispatch, callback, wait), so the resolver
    # names the correct session for both the read path and the output name.
    local CONTEXT_FILE; CONTEXT_FILE="$(_context_file)"
    local out_file="$project_root/$DEV_DIR/$(_status_file_name)"
    mkdir -p "$(dirname "$out_file")"
    # Infra-lock status line (best-effort; empty when identity/anchor/git is
    # unresolved or there is no tmux session — never fatal to status rendering).
    # `infra-lock status` does not call _render_status_file, so no recursion.
    local il_line=""
    il_line=$(cmd_infra_lock status 2>/dev/null | sed 's/^INFRA_LOCK: //')
    python3 - "$project_root/$CONTEXT_FILE" "$project_root/$DEV_DIR" "$out_file" "$il_line" <<'PYEOF'
import sys, os, yaml, datetime

context_file, dev_dir, out_file = sys.argv[1:4]
infra_lock_line = sys.argv[4] if len(sys.argv) > 4 else ''

# Worker callback responses (and notes) arrive as raw markdown source; the
# status file is a plain-text surface, so `**bold**`/backticks/[x](url) would
# render verbatim. Same conservative ruleset as forge-watch strip_md (kept in
# lockstep): double-asterisk emphasis only (`2 * 3`, `*.json` survive), heading
# hashes need a following space (`#192` survives), underscore emphasis never
# touched (`__init__`), truncated link tails degrade to their link text.
import re as _re
_MD_SUBS = [
    (_re.compile(r'`{3,}[A-Za-z0-9_-]*'), ' '),                  # code fences
    (_re.compile(r'!?\[([^\]]*)\]\([^)]*\)'), r'\1'),            # links/images → text
    (_re.compile(r'!?\[([^\]]*)\]\([^)]*$'), r'\1'),             # link truncated mid-target
    (_re.compile(r'\*{2,3}(\S(?:[^*]*?\S)?)\*{2,3}'), r'\1'),    # **bold** / ***both***
    (_re.compile(r'~~(\S(?:[^~]*?\S)?)~~'), r'\1'),              # ~~strike~~
    (_re.compile(r'`([^`]+)`'), r'\1'),                          # `inline code`
    (_re.compile(r'(?:(?<=\s)|^)#{1,6}(?=\s)'), ''),             # heading hashes
]
def strip_md(s):
    for rx, rep in _MD_SUBS:
        s = rx.sub(rep, s)
    return ' '.join(s.split())

ctx = {}
try:
    with open(context_file) as f:
        ctx = yaml.safe_load(f) or {}
except FileNotFoundError:
    pass

slug          = ctx.get('active_pipeline') or '(none)'
last_stage    = ctx.get('last_stage_completed') or '(none)'
last_status   = ctx.get('last_stage_status') or '(none)'
last_worker   = ctx.get('last_worker') or '(none)'
next_stage    = ctx.get('next_stage') or '(none)'
notes         = ctx.get('notes') or []

# Read per-pipeline log (canonical event timeline for this slug). Fall back
# to regex extraction when yaml.safe_load fails on malformed entries
# (some legacy log-response emissions produced bad indentation in `files:`).
entries = []
if slug and slug != '(none)':
    pipeline_log = os.path.join(dev_dir, 'proposals', slug, 'forge-log.yml')
    if os.path.exists(pipeline_log):
        try:
            with open(pipeline_log) as f:
                data = yaml.safe_load(f) or {}
            entries = data.get('entries', []) or []
        except Exception:
            import re
            with open(pipeline_log) as f:
                raw = f.read()
            # Best-effort parse of `  - timestamp: ... stage: ... to: ... response: ...` blocks.
            # Splits on the entry-start marker and reconstructs fields per block.
            block_re = re.compile(
                r'^\s*-\s+timestamp:\s*"([^"]+)"', re.MULTILINE)
            starts = [(m.start(), m.group(1)) for m in block_re.finditer(raw)]
            for i, (off, ts) in enumerate(starts):
                end = starts[i+1][0] if i+1 < len(starts) else len(raw)
                blk = raw[off:end]
                def grab(field):
                    m = re.search(rf'^\s+{field}:\s*(.*?)\s*$', blk, re.MULTILINE)
                    return m.group(1).strip() if m else None
                stage = grab('stage')
                to    = grab('to')
                # Response can be `null` or a quoted string.
                rmatch = re.search(r'^\s+response:\s*(null|"(?:[^"\\]|\\.)*")', blk, re.MULTILINE)
                if not rmatch:
                    continue
                resp_raw = rmatch.group(1)
                response = None if resp_raw == 'null' else resp_raw.strip('"').replace('\\"', '"')
                entries.append({
                    'timestamp': ts, 'stage': stage, 'to': to, 'response': response,
                    'parked_at': grab('parked_at'),  # keep the PARKED tag through the fallback
                    'files': [],
                })

# Pending = response: null entries; current stage = most recent pending.
pending = [e for e in entries if e.get('response') is None]
current_stage  = (pending[-1].get('stage')  if pending else next_stage) or '(idle)'
current_worker = (pending[-1].get('to')     if pending else None)
current_since  = (pending[-1].get('timestamp') if pending else None)

def short_time(ts):
    return ts[11:16] if isinstance(ts, str) and len(ts) >= 16 else (ts or '?')

def _stale_suffix(ts):
    # D3 (orphan-log-entries): mark a pending entry STALE when its age exceeds
    # 2 * FORGE_STALL_THRESHOLD_S (env, default 600) — same semantics as
    # cmd_stall_check_status without sharing its out-of-scope heredoc constant.
    # Compare the UTC 'Z' timestamp against now(UTC) (this heredoc's `now` at the
    # bottom is local naive time, used only for display). Skip silently on a
    # missing/malformed ts so `status` never breaks. Label-only — does NOT change
    # which pending is chosen.
    if not ts or not isinstance(ts, str):
        return ''
    try:
        thr = int(os.environ.get('FORGE_STALL_THRESHOLD_S', '600'))
    except (TypeError, ValueError):
        thr = 600
    stale = 2 * thr
    raw = ts.strip()
    iso = raw[:-1] + '+00:00' if raw.endswith('Z') else raw
    try:
        dt = datetime.datetime.fromisoformat(iso)
    except ValueError:
        return ''
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=datetime.timezone.utc)
    age = (datetime.datetime.now(datetime.timezone.utc) - dt).total_seconds()
    return f" (STALE — pending since {short_time(ts)}, possible orphan)" if age > stale else ''

# Recent activity: last 15 entries.
activity = []
for e in entries[-15:]:
    ts = short_time(e.get('timestamp'))
    stage = e.get('stage', '?')
    worker = e.get('to', '?')
    resp = e.get('response')
    if resp is None:
        _pk = ' ⏸ PARKED' if e.get('parked_at') else ''
        activity.append(f"  {ts}  · dispatched {stage:<14} → {worker} (PENDING{_pk})")
    else:
        rs = str(resp)
        if 'FORGE_DONE' in rs:
            icon, tag = '✓', 'complete'
        elif 'FORGE_BLOCKED' in rs:
            icon, tag = '✗', 'BLOCKED'
        elif 'FORGE_ERROR' in rs:
            icon, tag = '⚠', 'ERROR'
        else:
            icon, tag = '·', 'updated'
        tail = strip_md(rs.split('—', 1)[1].strip()) if '—' in rs else ''
        tail = (tail[:60] + '…') if len(tail) > 60 else tail
        line = f"  {ts}  {icon} {stage:<14} {tag}"
        if tail:
            line += f"  ({tail})"
        activity.append(line)

# Artifacts: union of `files[].path` across entries.
artifacts = []
seen = set()
for e in entries:
    for f_entry in (e.get('files') or []):
        if isinstance(f_entry, dict):
            p = f_entry.get('path', '')
            if p and p not in seen:
                seen.add(p)
                artifacts.append(p)

now = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')

L = []
L.append("# Forge Pipeline Status")
L.append("")
L.append(f"Pipeline: {slug}")
if pending:
    _pk = ' ⏸ PARKED' if (pending[-1].get('parked_at')) else ''
    L.append(f"Current stage: {current_stage} ({current_worker}, PENDING since {short_time(current_since)}){_pk}{_stale_suffix(current_since)}")
else:
    L.append(f"Current stage: (idle) — last completed: {last_stage} → {last_status} by {last_worker}")
L.append(f"Next stage: {next_stage}")
L.append(f"Last update: {now}")
if infra_lock_line:
    L.append(f"Infra lock: {infra_lock_line}")
L.append("")
L.append("## Recent activity")
L.append("")
L.extend(activity or ["  (no activity yet)"])
L.append("")
L.append("## Pending callbacks")
L.append("")
if pending:
    for e in pending:
        _pk = ' ⏸ PARKED' if e.get('parked_at') else ''
        L.append(f"  - {e.get('stage','?')} ({e.get('to','?')}, since {short_time(e.get('timestamp'))}){_pk}")
else:
    L.append("  (none)")
L.append("")
L.append("## Artifacts")
L.append("")
if artifacts:
    for a in artifacts:
        L.append(f"  {a}")
else:
    L.append("  (none yet)")
L.append("")
L.append("## Notes")
L.append("")
if notes:
    for n in notes:
        L.append(f"  - {strip_md(str(n))}")
else:
    L.append("  (none)")
L.append("")

with open(out_file, 'w') as f:
    f.write("\n".join(L))
PYEOF
}

cmd_status() {
    require_identity "status" host-session || return 1
    _render_status_file
    local project_root
    project_root=$(_resolve_project_root "" 2>/dev/null)
    if [ -z "$project_root" ]; then
        echo "ERROR: status requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi
    local out_file="$project_root/$DEV_DIR/$(_status_file_name)"
    if [ -f "$out_file" ]; then
        cat "$out_file"
    else
        echo "(no status file)"
    fi
}

# ---- Prompt template rendering (Phase 3) ----
#
# Template directories:
#   ~/.config/forge/prompts/  — stage prompts; supports <<<INCLUDE _name>>>
#   ~/.config/forge/digests/  — digest prompts; same include syntax
#
# Variables substituted in rendered prompts:
#   {slug}, {worker}, {worker_pane}, {project_root}
#
# The synthetic <<<INCLUDE _preamble>>> is generated from forge-project.yml
# (services.backend, services.frontend, forge.expected_root). Other includes
# resolve to ~/.config/forge/prompts/<name>.txt.

FORGE_PROMPTS_DIR="${FORGE_PROMPTS_DIR:-$HOME/.config/forge/prompts}"
FORGE_DIGESTS_DIR="${FORGE_DIGESTS_DIR:-$HOME/.config/forge/digests}"

# Render the {ENVIRONMENT_PREAMBLE} block from a project_root containing
# .claude/forge-project.yml. Echoes preamble text on stdout; empty on miss.
_render_preamble() {
    local project_root="$1"
    local yml="$project_root/.claude/forge-project.yml"
    if [ ! -f "$yml" ]; then
        return 0
    fi
    python3 - "$yml" "$project_root" <<'PYEOF'
import sys, yaml
yml_path, project_root = sys.argv[1], sys.argv[2]
try:
    with open(yml_path) as f:
        data = yaml.safe_load(f) or {}
except Exception:
    sys.exit(0)
services = data.get('services') or {}
backend = services.get('backend') or {}
frontend = services.get('frontend') or {}
lines = ["Environment setup (run before any other commands):"]
lines.append(f"  Working directory: {project_root}")
venv = backend.get('activate_venv')
if venv:
    bw = backend.get('working_dir')
    if bw and venv.startswith('source ') and not venv.startswith(f'source {bw}/'):
        venv = f"source {bw}/" + venv[len('source '):]
    lines.append(f"  Python venv: {venv}")
app_env = (data.get('forge') or {}).get('app_env') or data.get('app_env')
if app_env:
    lines.append(f"  APP_ENV: {app_env}")
bp = backend.get('port')
if bp:
    lines.append(f"  Backend port: {bp}")
fp = frontend.get('port')
if fp:
    lines.append(f"  Frontend port: {fp}")
print("\n".join(lines))
PYEOF
}

# Render a template file with includes + variable substitution.
# Args: template_path slug stage worker worker_pane project_root
# Echoes rendered text on stdout. Returns 1 if template missing.
_render_template() {
    local tmpl_path="$1" slug="$2" stage="$3" worker="$4" worker_pane="$5" project_root="$6"
    if [ ! -f "$tmpl_path" ]; then
        echo "ERROR: template not found: $tmpl_path" >&2
        return 1
    fi
    local preamble
    preamble=$(_render_preamble "$project_root")
    python3 - "$tmpl_path" "$FORGE_PROMPTS_DIR" "$slug" "$stage" "$worker" \
        "$worker_pane" "$project_root" "$preamble" <<'PYEOF'
import sys, os, re
(tmpl_path, prompts_dir, slug, stage, worker, worker_pane, project_root, preamble) = sys.argv[1:9]

with open(tmpl_path) as f:
    text = f.read()

INCLUDE_RE = re.compile(r'<<<INCLUDE\s+(\S+)\s*>>>')

def resolve_include(name):
    if name == '_preamble':
        return preamble
    path = os.path.join(prompts_dir, f"{name}.txt")
    if not os.path.exists(path):
        sys.stderr.write(f"ERROR: include not found: {name}\n")
        sys.exit(2)
    with open(path) as f:
        return f.read().rstrip('\n')

# Resolve includes (single pass; nested includes are not supported by design).
def expand(m):
    return resolve_include(m.group(1))
text = INCLUDE_RE.sub(expand, text)

# Substitute variables.
text = (text
        .replace('{slug}', slug)
        .replace('{stage}', stage)
        .replace('{worker}', worker)
        .replace('{worker_pane}', str(worker_pane))
        .replace('{project_root}', project_root))

sys.stdout.write(text)
PYEOF
}

# dispatch — render a stage prompt, write it, log, send.
#   forge-bridge dispatch --slug <s> --stage <s> --worker <w>
#                          [--clear] [--dry-run]
# --clear: send /clear to the worker pane before the dispatch (Hard Rule 20).
# --dry-run: print rendered prompt to stdout; do NOT write/log/send.
cmd_dispatch() {
    local slug="" stage="" worker="" do_clear=false dry_run=false supersede=false allow_blocked=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)      slug="$2";   shift 2 ;;
            --stage)     stage="$2";  shift 2 ;;
            --worker)    worker="$2"; shift 2 ;;
            --clear)     do_clear=true; shift ;;
            --dry-run)   dry_run=true;  shift ;;
            --supersede) supersede=true; shift ;;
            --allow-blocked) [ -n "${2:-}" ] || { echo "ERROR: --allow-blocked requires a non-empty reason" >&2; return 1; }
                             allow_blocked="$2"; shift 2 ;;
            *)           shift ;;
        esac
    done

    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$worker" ]; then
        echo "Usage: forge-bridge dispatch --slug <s> --stage <s> --worker <w> [--clear] [--dry-run] [--supersede]" >&2
        return 1
    fi

    # Identity gate at the TOP of the body (session-pin invariant): the pending
    # guard and --supersede below filter by ID_target_session/ID_host_incarnation,
    # so the gate MUST populate them first — a late gate leaves the filters inert.
    require_identity "dispatch" host-pane || {
        _emit_event ERROR "$slug" "stage=$stage reason=tmux-session-missing"
        return 1
    }

    local worker_canonical worker_pane
    worker_canonical=$(canonical_pane_name "$worker")
    worker_pane=$(pane_index "$worker")

    case "$worker_canonical" in
        claude-opus|claude-sonnet|codex-a|codex-b) ;;
        *)
            _emit_event ERROR "$slug" "stage=$stage reason=invalid-worker worker=$worker"
            echo "ERROR: --worker must resolve to a worker pane (claude-opus|claude-sonnet|codex-a|codex-b); got '$worker_canonical'" >&2
            return 1
            ;;
    esac

    # --- Reasoning-tier routing policy guard (SKILL Hard Rule 22) ---
    # Enforce stage->pane tier so HIGH-reasoning stages cannot be dispatched to a
    # throughput pane (and vice-versa). Placed BEFORE the --dry-run early return
    # so `dispatch --dry-run` exercises it (negative tests). Only the main
    # build-pipeline stages are constrained; fix-pipeline / commit-review / ad-hoc
    # stages are unlisted and fall through unconstrained. The verify "!= latest QA
    # worker" exclusion stays in orchestrator prose — the bridge enforces tier,
    # not pipeline history.
    case "$stage" in
        review|incorporate|implementation|impl-review|verify)
            case "$worker_canonical" in
                claude-opus|codex-a) ;;
                *)
                    _emit_event ERROR "$slug" "stage=$stage reason=tier-violation tier=high worker=$worker_canonical"
                    echo "ERROR: stage '$stage' is HIGH-reasoning tier (Hard Rule 22): --worker must be claude-opus or codex-a, got '$worker_canonical'. High-thought stages never route to a throughput pane (claude-sonnet/codex-b)." >&2
                    return 1
                    ;;
            esac
            ;;
        coding|qa|qa-fix|qa-retry)
            case "$worker_canonical" in
                claude-sonnet|codex-b) ;;
                *)
                    _emit_event ERROR "$slug" "stage=$stage reason=tier-violation tier=throughput worker=$worker_canonical"
                    echo "ERROR: stage '$stage' is THROUGHPUT tier (Hard Rule 22): --worker must be claude-sonnet or codex-b, got '$worker_canonical'." >&2
                    return 1
                    ;;
            esac
            ;;
        proposal)
            _emit_event ERROR "$slug" "stage=$stage reason=proposal-not-dispatchable worker=$worker_canonical"
            echo "ERROR: stage 'proposal' runs locally in pane 1 via Agent Teams; it is not dispatchable to a worker. Run it inline, then close with 'forge-bridge log-response --to claude --stage proposal'." >&2
            return 1
            ;;
    esac

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: dispatch requires a forge-project.yml. Walk-up from cwd failed." >&2
        return 1
    fi

    local tmpl_path="$FORGE_PROMPTS_DIR/$stage.txt"
    local rendered
    rendered=$(_render_template "$tmpl_path" "$slug" "$stage" "$worker_canonical" "$worker_pane" "$project_root") || {
        _emit_event ERROR "$slug" "stage=$stage reason=template-render-failed"
        return 1
    }

    if [ "$dry_run" = true ]; then
        printf '%s' "$rendered"
        return 0
    fi

    # --- Slug-scoped dispatch guard (orphan-log-entries fix) ---
    # Refuse to dispatch a new stage while ANY pending (response: null) entry
    # exists for this slug, unless --supersede. Stops class-2 (advance-without-
    # close) and class-3 (rapid re-dispatch) orphans at the only birth site for
    # dispatched pendings. The predicate is SLUG-scoped, not (stage,to)-scoped:
    # a (stage,to) predicate would let a different-stage advance through and
    # re-open class 2 (see fix-plan.md). Placed AFTER the dry-run early-return so
    # `--dry-run` never blocks. The destructive --supersede close is deferred to
    # just before cmd_log (after preflight) — see below.
    local guard_log="$DEV_DIR/proposals/$slug/forge-log.yml"
    local pending_ts
    pending_ts=$(python3 - "$guard_log" "$ID_target_session" "$ID_host_incarnation" <<'PYEOF'
import sys, yaml
guard_log = sys.argv[1]
cur_session = sys.argv[2] if len(sys.argv) > 2 else ''
cur_incarnation = sys.argv[3] if len(sys.argv) > 3 else ''
try:
    with open(guard_log) as f:
        data = yaml.safe_load(f) or {}
except FileNotFoundError:
    sys.exit(0)
except Exception as ex:
    print(f"ERR_PARSE:{ex}", file=sys.stderr); sys.exit(3)
for e in (data.get('entries') or []):
    if e.get('response') is not None:
        continue
    es = e.get('session', '') or ''
    if es and cur_session and es != cur_session:
        continue
    ei = str(e.get('incarnation', '') or '')
    if ei and cur_incarnation and ei != str(cur_incarnation):
        continue
    ts = e.get('timestamp', '')
    if ts:
        print(ts)
PYEOF
)
    if [ $? -eq 3 ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=dispatch-guard-parse-failed"
        echo "ERROR: dispatch guard could not parse $guard_log — refusing to dispatch." >&2
        return 1
    fi
    local n_pending=0
    [ -n "$pending_ts" ] && n_pending=$(printf '%s\n' "$pending_ts" | grep -c .)
    if [ "$n_pending" -gt 0 ] && [ "$supersede" != true ]; then
        {
            echo "HOOK BLOCKED: dispatch refused — slug '$slug' has $n_pending open pending entry(ies) (response: null):"
            printf '%s\n' "$pending_ts" | while IFS= read -r t; do [ -n "$t" ] && echo "    - pending since $t"; done
            echo "  A prior stage was never closed. Close it first — a worker callback, or for a local"
            echo "  to:claude stage run:"
            echo "    ~/bin/forge-bridge log-response --slug $slug --to claude --stage <stage> --response \"FORGE_DONE: <stage> — ...\""
            echo "  then retry; or re-run this dispatch with --supersede to auto-close the open entry(ies)"
            echo "  (FORGE_SUPERSEDED) and dispatch anew."
        } >&2
        _emit_event GUARD_BLOCK "$slug" "stage=$stage reason=open-pending-exists worker=$worker_canonical n_pending=$n_pending"
        return 1
    fi

    # All-boundary guard: refuse a NEW dispatch while any OTHER-slug unresolved block
    # exists (§3.4). --supersede for THIS slug is the same-item exemption. Identity was
    # already gated at the top of the body (session-pin invariant) — do not re-gate.
    if [ "$supersede" = true ]; then
        _work_start_guard "$project_root" "dispatch" "$allow_blocked" "$slug" "" || return 1
    else
        _work_start_guard "$project_root" "dispatch" "$allow_blocked" "" "" || return 1
    fi

    local prompt_file="$project_root/.dev/forge-tmp/${worker_canonical}-${stage}-${slug}.txt"
    mkdir -p "$(dirname "$prompt_file")"
    printf '%s' "$rendered" > "$prompt_file"

    # Hard Rule 20 — orchestrator (this bridge call) drives /clear, never the worker.
    if [ "$do_clear" = true ]; then
        # Split text/Enter (same TUI-commit reason as cmd_send) so /clear
        # reliably submits instead of sitting unsubmitted in the worker input.
        _cancel_copy_mode "$SESSION:$WINDOW.$worker_pane"
        tmux send-keys -t "$SESSION:$WINDOW.$worker_pane" -l "/clear"
        sleep "${FORGE_SEND_COMMIT_WAIT_S:-0.3}"
        tmux send-keys -t "$SESSION:$WINDOW.$worker_pane" Enter
        sleep "${FORGE_CLEAR_WAIT_S:-2}"
    fi

    # --supersede destructive close (deferred — fix-plan Review #5): close every
    # open same-slug pending as FORGE_SUPERSEDED via the no-context helper (NOT
    # cmd_log_response, which would corrupt context). Done HERE, after
    # require_tmux_session/clear preflight, so a preflight failure can't leave a
    # slug with closed-old entries and no replacement. Loops over ALL pendings —
    # cmd_log_response closes only candidates[-1], so a single delegated call
    # would silently leave duplicates open on a multi-pending slug.
    if [ "$supersede" = true ]; then
        # Session-scoped, incarnation-AGNOSTIC (R10): close same-slug pendings of the
        # caller's OWN session name regardless of incarnation, so a reborn same-name
        # session can clean its dead predecessor's orphan — but never reach a
        # DIFFERENT-named same-root session's pending. Re-gather here (NOT the guard's
        # incarnation-scoped list), else supersede would be incarnation-strict and
        # strand the dead orphan.
        local _sup_pendings
        _sup_pendings=$(python3 - "$guard_log" "$ID_target_session" <<'PYEOF'
import sys, yaml
guard_log = sys.argv[1]; cur_session = sys.argv[2] if len(sys.argv) > 2 else ''
try:
    with open(guard_log) as f: data = yaml.safe_load(f) or {}
except Exception: sys.exit(0)
for e in (data.get('entries') or []):
    if e.get('response') is not None: continue
    es = e.get('session', '') or ''
    if es and cur_session and es != cur_session: continue
    ts = e.get('timestamp', '')
    if ts: print(ts)
PYEOF
)
        local _sup_ts _sup_now _sup_n _sup_fail=0
        _sup_now=$(timestamp)
        # Close pendings first; collect failures (here-string, not a pipe subshell —
        # the loop must set _sup_fail to gate the consume that follows, §3.3). The
        # incarnation-scoped _sup_pendings gather above (session-pin R10) is preserved.
        while IFS= read -r _sup_ts; do
            [ -z "$_sup_ts" ] && continue
            if ! _patch_response_by_ts "$slug" "$_sup_ts" \
                "FORGE_SUPERSEDED: re-dispatched $stage (orphan-log-entries guard); auto-closed $_sup_now"; then
                echo "WARN: --supersede: failed to close pending ts=$_sup_ts for slug=$slug (callbacks for its stage RETAINED)" >&2
                _sup_fail=1
            fi
        done <<< "$_sup_pendings"
        _sup_n="$(printf '%s\n' "$_sup_pendings" | grep -c . || true)"
        [ "$_sup_n" -gt 0 ] && _emit_event SUPERSEDE "$slug" "stage=$stage closed_pending=$_sup_n worker=$worker_canonical partial_fail=$_sup_fail"
        if [ "$_sup_n" -gt 0 ] && [ "$_sup_fail" -eq 0 ]; then
            # Only after ALL closes succeed: consume+audit each PARKED/BLOCKED callback
            # of this slug (all stages, session-scoped glob), preserving disposition.
            local _cb _sess; _sess="$(_resolve_session)"
            for _cb in "$project_root/.dev/forge-tmp/callbacks/${slug}-"*.callback; do
                [ -e "$_cb" ] || continue
                local _st _cbid _reason _unco _cbstage
                _st=$(grep '^status:' "$_cb" | awk '{print $2}')
                case "$_st" in PARKED|BLOCKED) ;; *) continue ;; esac
                _cbstage=$(grep '^stage:' "$_cb" | awk '{print $2}')
                _cbid=$(grep '^callback_id:' "$_cb" | awk '{print $2}')
                _reason=$(grep '^parked_reason:' "$_cb" | sed 's/^parked_reason:[[:space:]]*//')
                _unco=$(grep '^uncommitted:' "$_cb" | awk '{print $2}')
                _lifecycle_lock "$slug" "$_cbstage" || continue
                _emit_event SUPERSEDE_AUDIT "$slug" "stage=$_cbstage prior_callback_id=$_cbid prior_status=$_st uncommitted=${_unco:-false} actor=$_sess reason=$(_sanitize_event_value "$_reason")"
                [ "$_unco" = true ] && echo "WARN: --supersede: discarding PARKED callback with UNCOMMITTED work ($slug/$_cbstage, prior_callback_id=$_cbid)." >&2
                ( cd "$project_root" && cmd_callback_consume --_no_lock --slug "$slug" --stage "$_cbstage" --status "$_st" >/dev/null 2>&1 ) || true
                _lifecycle_unlock
            done
        elif [ "$_sup_fail" -ne 0 ]; then
            echo "WARN: --supersede: partial close failure — callbacks RETAINED (not consumed) for slug=$slug." >&2
        fi
    fi

    local ref_msg="Read and follow instructions in .dev/forge-tmp/${worker_canonical}-${stage}-${slug}.txt"
    cmd_log --slug "$slug" --stage "$stage" --from claude --to "$worker_canonical" --prompt "$ref_msg" >/dev/null
    cmd_send --_internal "$worker_canonical" "$ref_msg" || {
        _emit_event ERROR "$slug" "stage=$stage reason=send-failed worker=$worker_canonical"
        return 1
    }

    _emit_event DISPATCH "$slug" "stage=$stage worker=$worker_canonical"
    _render_status_file
    echo "DISPATCHED stage=$stage worker=$worker_canonical slug=$slug prompt=$prompt_file"
}

# callback — worker-side declarative completion signal.
#   forge-bridge callback --slug <s> --stage <s> --status <DONE|BLOCKED|ERROR>
#                         [--message <m>] [--worker <w>]
# Behavior:
#   1. Writes .dev/forge-tmp/callbacks/<slug>-<stage>.callback (machine-readable)
#   2. Auto-calls log-response to mark the matching pending log entry done
#   3. (Back-compat) sends a FORGE_<STATUS>: <stage> — <message> line to the
#      orchestrator pane for any human reading scrollback.
# --worker auto-resolves from TMUX_PANE if omitted.
cmd_callback() {
    require_identity "callback" host-degrade || return 1
    local slug="" stage="" status="" message="" worker="" quiet=false origin=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)    slug="$2";    shift 2 ;;
            --stage)   stage="$2";   shift 2 ;;
            --status)  status="$2";  shift 2 ;;
            --message) message="$2"; shift 2 ;;
            --worker)  worker="$2";  shift 2 ;;
            --origin)  origin="$2";  shift 2 ;;
            --quiet)   quiet=true;   shift ;;
            *)         shift ;;
        esac
    done
    # --origin: defined value set only ('ask'), and 'ask' is settable ONLY via the
    # internal token the public CLI does not document (§3.5). An ordinary worker
    # callback therefore cannot acquire the ask carve-out.
    if [ -n "$origin" ]; then
        case "$origin" in
            ask)
                if [ "${FORGE_INTERNAL_ASK_ORIGIN:-}" != "1" ]; then
                    echo "ERROR: --origin ask is internal (set by 'forge ask' only); not a public flag" >&2
                    return 1
                fi ;;
            *)  echo "ERROR: --origin must be one of: ask; got '$origin'" >&2; return 1 ;;
        esac
    fi
    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$status" ]; then
        echo "Usage: forge-bridge callback --slug <s> --stage <s> --status <DONE|BLOCKED|ERROR> [--message <m>] [--worker <w>] [--quiet]" >&2
        return 1
    fi
    case "$status" in
        DONE|BLOCKED|ERROR) ;;
        *)
            _emit_event ERROR "$slug" "stage=$stage reason=invalid-status status=$status"
            echo "ERROR: --status must be DONE, BLOCKED, or ERROR; got '$status'" >&2
            return 1
            ;;
    esac

    # Auto-resolve worker from TMUX_PANE if not supplied.
    if [ -z "$worker" ]; then
        local pane_id="${TMUX_PANE:-}"
        if [ -n "$pane_id" ]; then
            local sess="${ID_host_session:-}"
            if [ -n "$sess" ]; then
                local idx
                idx=$(tmux list-panes -t "$sess:$WINDOW" -F '#{pane_index} #{pane_id}' 2>/dev/null \
                    | awk -v pid="$pane_id" '$2==pid {print $1}')
                if [ -n "$idx" ]; then
                    worker=$(pane_name "$idx")
                fi
            fi
        fi
    fi
    if [ -z "$worker" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=worker-unresolvable"
        echo "ERROR: callback requires --worker (TMUX_PANE auto-resolution failed)" >&2
        return 1
    fi
    local worker_canonical
    worker_canonical=$(canonical_pane_name "$worker")

    # Pane index for the worker, resolved UNCONDITIONALLY. The TMUX_PANE
    # auto-resolve block above only runs when --worker is omitted, but installed
    # stage prompts always pass --worker — so derive the index here (used by the
    # read-only usage observation below; never re-derive from the conditional
    # auto-resolve `idx`, which is unset on the normal --worker path).
    local worker_idx
    worker_idx=$(pane_index "$worker_canonical")

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: callback requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi

    local cb_dir="$project_root/.dev/forge-tmp/callbacks"
    mkdir -p "$cb_dir"
    # Session-qualified filename when the session resolves; legacy path otherwise
    # (§3.2). Readers glob ${slug}-${stage}*.callback (_resolve_callback_file); a
    # session-qualified file is OWNED by its session, a legacy file is unowned.
    local cb_session; cb_session="$(_resolve_session)"
    local cb_file
    if [ -n "$cb_session" ]; then
        cb_file="$cb_dir/${slug}-${stage}.${cb_session}.callback"
    else
        cb_file="$cb_dir/${slug}-${stage}.callback"
    fi
    local ts cb_id
    ts=$(timestamp)
    cb_id="$(date -u +%Y%m%dT%H%M%SZ)-$$-${RANDOM}"

    local cb_body
    cb_body=$(cat <<EOF
slug: $slug
stage: $stage
status: $status
worker: $worker_canonical
session: ${cb_session:-}
origin: ${origin:-}
callback_id: $cb_id
timestamp: $ts
message: $(yaml_escape "$message")
EOF
)
    # Legacy-style response string (for log-response close + the human notify).
    local legacy="FORGE_${status}: ${stage}"
    if [ -n "$message" ]; then
        legacy="${legacy} — ${message}"
    fi

    # --- Callback lifecycle: terminal vs non-terminal (R3-3 / R4-1 / R4-2) ---
    # Atomic publish writes to a temp file in the SAME dir (same filesystem) then
    # renames into place.
    local cb_tmp="$cb_dir/.$(basename "$cb_file").tmp.$$"
    # §3.3: serialize publication against park/resolve/supersede/consume on the same
    # (slug,stage). Acquire before close-then-publish; release after the mv.
    _lifecycle_lock "$slug" "$stage" || return 1
    case "$status" in
        DONE|ERROR)
            # R4-2 (terminal path — used by EVERY stage, highest blast radius):
            # close the pending log entry FIRST. A failed close MUST abort and
            # MUST NOT publish the terminal callback (the old `|| true` is gone),
            # so a polling `wait` can never observe DONE/ERROR before the pending
            # is closed — which would let the orchestrator release the infra lock
            # and race the next dispatch against the open-pending guard.
            if ! (cd "$project_root" && cmd_log_response --slug "$slug" --stage "$stage" \
                    --to "$worker_canonical" --response "$legacy" >/dev/null 2>&1); then
                _emit_event ERROR "$slug" "stage=$stage worker=$worker_canonical reason=terminal-close-failed status=$status"
                echo "ERROR: callback $status: failed to close the pending log entry for slug=$slug stage=$stage; terminal callback NOT published (no matching open pending, or patch failed). Resolve the log state and retry." >&2
                rm -f "$cb_tmp"
                _lifecycle_unlock
                return 1
            fi
            # Close succeeded → publish the terminal callback atomically.
            if ! { printf '%s\n' "$cb_body" > "$cb_tmp" && mv -f "$cb_tmp" "$cb_file"; }; then
                rm -f "$cb_tmp"
                _lifecycle_unlock
                _emit_event ERROR "$slug" "stage=$stage worker=$worker_canonical reason=callback-publish-failed status=$status"
                echo "ERROR: callback $status: pending closed but callback publish failed for slug=$slug stage=$stage." >&2
                return 1
            fi
            ;;
        BLOCKED)
            # R3-3 / R4-1 / R4-3 (non-terminal): publish the BLOCKED callback
            # atomically and KEEP the dispatch pending (response: null) OPEN — do
            # NOT call log-response. The open pending is the durable "in-flight
            # under a held infra lock" signal the stall-classifier and
            # `/forge status` depend on (else the held lock looks abandoned). The
            # canonical callback file is the source of truth for the blocked
            # message; `wait` reads it (read-only) and it is archived only later
            # by `callback-consume`, AFTER the orchestrator commits a
            # `send --force` continuation. add-note is deliberately NOT the source
            # of truth (R4-3); the canonical file + the human notify below carry
            # the message.
            if ! { printf '%s\n' "$cb_body" > "$cb_tmp" && mv -f "$cb_tmp" "$cb_file"; }; then
                rm -f "$cb_tmp"
                _lifecycle_unlock
                _emit_event ERROR "$slug" "stage=$stage worker=$worker_canonical reason=callback-publish-failed status=$status"
                echo "ERROR: callback BLOCKED: callback publish failed for slug=$slug stage=$stage." >&2
                return 1
            fi
            ;;
    esac
    _lifecycle_unlock

    # Back-compat: still notify the orchestrator pane so humans see the line.
    # Suppressed by --quiet. Only attempts when inside a tmux session.
    #
    # Split the send-keys call: type the text first, sleep briefly so Claude's
    # TUI input buffer commits the line, THEN press Enter. Combining text and
    # Enter into one send-keys call leaves the text sitting in the input
    # unsubmitted on current Claude TUI builds.
    if [ "$quiet" != true ] && [ -n "${TMUX:-}" ]; then
        local sess="${ID_target_session:-$ID_host_session}"
        if [ -n "$sess" ]; then
            _cancel_copy_mode "$sess:$WINDOW.1"
            tmux send-keys -t "$sess:$WINDOW.1" -l "$legacy" 2>/dev/null || true
            sleep 0.2
            tmux send-keys -t "$sess:$WINDOW.1" Enter 2>/dev/null || true
        fi
    fi

    local cb_msg_len
    cb_msg_len=$(printf '%s' "$message" | wc -c | tr -d ' ')
    _emit_event CALLBACK "$slug" "stage=$stage worker=$worker_canonical status=$status message_len=$cb_msg_len callback_file=$cb_file"

    # Read-only, family-aware per-task usage observation. Placed AFTER all
    # critical callback work above (callback file, log-response, CALLBACK emit)
    # and wrapped `|| true` so it can never delay or break the callback. NEVER
    # issues /clear, /new, or /compact — see _observe_usage.
    _observe_usage "$worker_canonical" "$slug" "$stage" "$worker_idx" "$project_root" || true

    _render_status_file
    echo "CALLBACK $status stage=$stage slug=$slug worker=$worker_canonical → $cb_file"
}

# Resolve the callback file for (slug,stage) for the ACTING session. Prefers the
# session-owned file, else an unowned legacy file, else empty (a different-session
# owned file is NOT returned). §3.2 blast radius. NOTE: this is called on the wait
# POLL path (every tick), so it stays SILENT — callers on the wait path suppress
# stderr anyway. The "unowned legacy" WARN is emitted by the mutation callers
# (consume/park) at their decision point (see P1e), not here, so it is not lost.
_resolve_callback_file() {   # <cb_dir> <slug> <stage> <session>
    local d="$1" slug="$2" stage="$3" sess="$4"
    local owned="$d/${slug}-${stage}.${sess}.callback"
    local legacy="$d/${slug}-${stage}.callback"
    if [ -n "$sess" ] && [ -f "$owned" ]; then printf '%s' "$owned"; return 0; fi
    if [ -f "$legacy" ]; then printf '%s' "$legacy"; return 0; fi
    return 1
}

# Legacy ask carve-out: a pre-origin BLOCKED callback is ask-origin iff its explicit
# header says so, OR a live ask-*.json record matches root+slug+stage+stage-mode.
# NEVER "any ask-*.json for the pair" (§3.5). Echoes "ask" or "".
_callback_ask_origin() {   # <project_root> <slug> <stage> <cb_origin_header>
    local pr="$1" slug="$2" stage="$3" hdr="$4"
    if [ "$hdr" = "ask" ]; then printf 'ask'; return 0; fi
    FORGE_AO_ROOT="$pr" FORGE_AO_SLUG="$slug" FORGE_AO_STAGE="$stage" python3 - <<'PY'
import os, glob, json
root=os.environ["FORGE_AO_ROOT"]; slug=os.environ["FORGE_AO_SLUG"]; stage=os.environ["FORGE_AO_STAGE"]
for fp in glob.glob(os.path.join(root, ".dev", "attention", "ask-*.json")):
    try: r = json.load(open(fp))
    except Exception: continue
    if (r.get("event")=="ask" and r.get("slug")==slug and r.get("stage")==stage
            and r.get("mode")=="stage"):
        # An answered ask is archived by dispatch --answers, so a live ask-*.json is
        # by construction unresolved.
        print("ask"); break
PY
}

# wait — block until a callback file appears for <slug>/<stage>, or until
# stall-check classifies the worker as STALLED/PROMPTING/DEAD.
#   forge-bridge wait --slug <s> --stage <s> --worker <w>
#                     [--timeout <seconds>]
#                     [--digest-template <name>]
#                     [--interval <seconds>]
# Outputs a single structured block on stdout. Forwards SIGINT cleanly.
cmd_wait() {
    local slug="" stage="" worker="" timeout="" digest_template="" interval="${FORGE_WAIT_INTERVAL_S:-15}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)            slug="$2";            shift 2 ;;
            --stage)           stage="$2";           shift 2 ;;
            --worker)          worker="$2";          shift 2 ;;
            --timeout)         timeout="$2";         shift 2 ;;
            --digest-template) digest_template="$2"; shift 2 ;;
            --interval)        interval="$2";        shift 2 ;;
            *)                 shift ;;
        esac
    done
    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$worker" ]; then
        echo "Usage: forge-bridge wait --slug <s> --stage <s> --worker <w> [--timeout <s>] [--digest-template <name>] [--interval <s>]" >&2
        return 1
    fi

    local worker_canonical
    worker_canonical=$(canonical_pane_name "$worker")

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: wait requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi

    require_identity "wait" host-pane || {
        _emit_event ERROR "$slug" "stage=$stage reason=tmux-session-missing"
        return 1
    }

    local cb_dir="$project_root/.dev/forge-tmp/callbacks"
    local wait_session; wait_session="$(_resolve_session)"
    local cb_file=""
    local started
    started=$(date +%s)

    # Trap SIGINT: emit ERROR FIRST so it survives even if the printf is
    # interrupted; use :-unknown defaults so a SIGINT during arg-parse still
    # produces a §4.1.8-conforming line.
    trap '_emit_event ERROR "${slug:-unknown}" "stage=${stage:-unknown} worker=${worker_canonical:-unknown} reason=INTERRUPTED"; printf "STATUS: INTERRUPTED\nSTAGE: %s\nSLUG: %s\nWORKER: %s\n" "$stage" "$slug" "$worker_canonical"; exit 130' INT

    _emit_event WAIT "$slug" "stage=$stage worker=$worker_canonical"

    while true; do
        if cb_file="$(_resolve_callback_file "$cb_dir" "$slug" "$stage" "$wait_session" 2>/dev/null)" && [ -n "$cb_file" ] && [ -f "$cb_file" ]; then
            _wait_emit_callback "$cb_file" "$slug" "$stage" "$worker_canonical" \
                "$digest_template" "$project_root"
            _render_status_file
            return 0
        fi

        local sc_out sc_state
        sc_out=$(cmd_stall_check --project-root "$project_root" "$worker_canonical" 2>/dev/null)
        sc_state=$(echo "$sc_out" | awk '{print $1}')
        case "$sc_state" in
            STALLED|PROMPTING|DEAD)
                _emit_event STALL "$slug" "stage=$stage worker=$worker_canonical state=$sc_state"
                printf 'STATUS: %s\nSTAGE: %s\nSLUG: %s\nWORKER: %s\nDETAIL: %s\n' \
                    "$sc_state" "$stage" "$slug" "$worker_canonical" "$sc_out"
                _render_status_file
                return 0
                ;;
        esac

        if [ -n "$timeout" ]; then
            local elapsed
            elapsed=$(( $(date +%s) - started ))
            if [ "$elapsed" -ge "$timeout" ]; then
                _emit_event STALL "$slug" "stage=$stage worker=$worker_canonical state=TIMEOUT elapsed=${elapsed}s"
                printf 'STATUS: TIMEOUT\nSTAGE: %s\nSLUG: %s\nWORKER: %s\nELAPSED: %ss\n' \
                    "$stage" "$slug" "$worker_canonical" "$elapsed"
                _render_status_file
                return 0
            fi
        fi

        sleep "$interval"
    done
}

# Internal: emit the structured block from a callback file. Optionally render
# a digest prompt to disk for the orchestrator to spawn an Agent against.
_wait_emit_callback() {
    local cb_file="$1" slug="$2" stage="$3" worker_canonical="$4" digest_template="$5" project_root="$6"

    local status message
    status=$(grep '^status:' "$cb_file" | awk '{print $2}')
    message=$(python3 -c "
import yaml, sys
with open('$cb_file') as f:
    d = yaml.safe_load(f) or {}
print(d.get('message', '') or '')
" 2>/dev/null)

    printf 'STATUS: %s\nSTAGE: %s\nSLUG: %s\nWORKER: %s\nCALLBACK: %s\n' \
        "$status" "$stage" "$slug" "$worker_canonical" "$message"

    if [ -n "$digest_template" ] && [ "$status" = "DONE" ]; then
        local digest_tmpl="$FORGE_DIGESTS_DIR/$digest_template.txt"
        if [ ! -f "$digest_tmpl" ]; then
            _emit_event ERROR "$slug" "stage=$stage reason=digest-template-not-found template=$digest_template"
            printf 'DIGEST_PROMPT_ERROR: template not found: %s\n' "$digest_tmpl"
            return 0
        fi
        local digest_out_dir="$project_root/.dev/forge-tmp"
        mkdir -p "$digest_out_dir"
        local digest_out="$digest_out_dir/digest-${stage}-${slug}.txt"
        local worker_pane
        worker_pane=$(pane_index "$worker_canonical")
        _render_template "$digest_tmpl" "$slug" "$stage" "$worker_canonical" \
            "$worker_pane" "$project_root" > "$digest_out" || return 0
        _emit_event DIGEST "$slug" "stage=$stage template=$digest_template event=prompt-rendered out_file=$digest_out"
        printf 'DIGEST_PROMPT: %s\n' "$digest_out"
    fi
}

# callback-consume — archive a CONSUMED non-terminal (BLOCKED) callback (R4-1).
#   forge-bridge callback-consume --slug <s> --stage <s> --status BLOCKED
# Read and consume are deliberately SPLIT: `wait` reads the canonical BLOCKED
# callback and LEAVES it in place (so a resume before the continuation re-surfaces
# the same blocked state — no deadlock). The orchestrator calls THIS only AFTER a
# `send --force` continuation has succeeded, atomically moving the canonical
# callback out of the way so the next `wait` blocks for the worker's FRESH
# callback instead of re-reading the stale one. No timestamps (timestamp() is
# second-resolution) — purely presence-based.
#   - Canonical BLOCKED present  -> atomic `mv` to
#       .dev/forge-tmp/callbacks/archive/<slug>-<stage>.<callback_id>.callback
#   - Nothing to consume (no canonical file, or its status != the requested
#     non-terminal status) -> STRUCTURED NO-OP (exit 0) so the orchestrator does
#     not re-wait blindly.
cmd_callback_consume() {
    local slug="" stage="" status="BLOCKED" _no_lock=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)     slug="$2";   shift 2 ;;
            --stage)    stage="$2";  shift 2 ;;
            --status)   status="$2"; shift 2 ;;
            --_no_lock) _no_lock=1;  shift ;;   # caller already holds the lifecycle lock
            *)          shift ;;
        esac
    done
    if [ -z "$slug" ] || [ -z "$stage" ]; then
        echo "Usage: forge-bridge callback-consume --slug <s> --stage <s> [--status BLOCKED]" >&2
        return 1
    fi
    # Only non-terminal statuses are consumable. Terminal callbacks (DONE/ERROR)
    # are the stage's permanent record and are never archived here.
    case "$status" in
        BLOCKED|PARKED) ;;
        *)
            echo "ERROR: callback-consume only consumes non-terminal callbacks (--status BLOCKED|PARKED); got '$status'" >&2
            return 1
            ;;
    esac

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: callback-consume requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi

    local cb_dir="$project_root/.dev/forge-tmp/callbacks"
    local consume_session; consume_session="$(_resolve_session)"
    local cb_file
    cb_file="$(_resolve_callback_file "$cb_dir" "$slug" "$stage" "$consume_session" 2>/dev/null)" || cb_file=""
    [ -z "$cb_file" ] && cb_file="$cb_dir/${slug}-${stage}.${consume_session}.callback"
    # Un-suppressed decision-point WARN (the resolver is silent on the poll path):
    # consuming a legacy unqualified file that no session owns.
    case "$cb_file" in
        "$cb_dir/${slug}-${stage}.callback")
            [ -f "$cb_file" ] && echo "WARN: callback-consume: archiving unowned legacy callback $cb_file (no session identity)" >&2 ;;
    esac

    # Structured no-op: nothing to consume.
    if [ ! -f "$cb_file" ]; then
        _emit_event CALLBACK_CONSUME "$slug" "stage=$stage action=noop reason=no-canonical-callback status=$status"
        echo "CALLBACK_CONSUME NOOP stage=$stage slug=$slug reason=no-canonical-callback (nothing to archive)"
        return 0
    fi

    # Verify the on-disk status matches the requested non-terminal status. If the
    # worker already advanced to a terminal callback (DONE/ERROR) at the same
    # path, this is NOT ours to consume — leave it, no-op (R4-1: continuation
    # fails / nothing fresh to consume).
    local file_status file_cb_id
    file_status=$(grep '^status:' "$cb_file" | awk '{print $2}')
    if [ "$file_status" != "$status" ]; then
        _emit_event CALLBACK_CONSUME "$slug" "stage=$stage action=noop reason=status-mismatch want=$status have=$file_status"
        echo "CALLBACK_CONSUME NOOP stage=$stage slug=$slug reason=status-mismatch (canonical status=$file_status, not $status; left in place)"
        return 0
    fi

    file_cb_id=$(grep '^callback_id:' "$cb_file" | awk '{print $2}')
    if [ -z "$file_cb_id" ]; then
        # Defensive: a callback written before callback_id existed. Synthesize a
        # filename-safe unique id so the archive name is still unique.
        file_cb_id="legacy-$(date -u +%Y%m%dT%H%M%SZ)-$$-${RANDOM}"
    fi

    local archive_dir="$cb_dir/archive"
    mkdir -p "$archive_dir"
    local archive_file="$archive_dir/${slug}-${stage}.${file_cb_id}.callback"
    if [ -e "$archive_file" ]; then
        archive_file="$archive_dir/${slug}-${stage}.${file_cb_id}.$$-${RANDOM}.callback"
    fi
    # §3.3: serialize the archive mv against a concurrent transition. Callers that
    # ALREADY hold the lifecycle lock (park-resolve, supersede) pass --_no_lock so a
    # fresh subshell OFD does not self-conflict. Never nest _lifecycle_lock in one
    # process — hold at most one fd 9 at a time.
    local _held=0
    if [ "$_no_lock" != 1 ]; then _lifecycle_lock "$slug" "$stage" || return 1; _held=1; fi
    if ! mv -f "$cb_file" "$archive_file"; then
        [ "$_held" = 1 ] && _lifecycle_unlock
        _emit_event ERROR "$slug" "stage=$stage reason=callback-archive-failed status=$status"
        echo "ERROR: callback-consume: failed to archive $cb_file → $archive_file" >&2
        return 1
    fi
    [ "$_held" = 1 ] && _lifecycle_unlock
    _emit_event CALLBACK_CONSUME "$slug" "stage=$stage action=archived status=$status callback_id=$file_cb_id archive=$archive_file"
    echo "CALLBACK_CONSUME ARCHIVED stage=$stage slug=$slug status=$status → $archive_file"
}

cmd_park() {
    # forge-bridge park --slug <s> --stage <s> --reason <text> [--worker <w>] [--uncommitted]
    #  (and: park --resolve --slug <s> --stage <s> [--note …])
    local resolve=false slug="" stage="" reason="" worker="" uncommitted=false note=""
    while [ $# -gt 0 ]; do case "$1" in
        --resolve)     resolve=true; shift ;;
        --slug)        slug="$2";   shift 2 ;;
        --stage)       stage="$2";  shift 2 ;;
        --reason)      reason="$2"; shift 2 ;;
        --worker)      worker="$2"; shift 2 ;;
        --uncommitted) uncommitted=true; shift ;;
        --note)        note="$2";   shift 2 ;;
        *) shift ;;
    esac; done
    [ -n "$slug" ] && [ -n "$stage" ] || { echo "Usage: forge-bridge park --slug <s> --stage <s> --reason <text> [--worker <w>] [--uncommitted]" >&2; return 1; }

    local project_root; project_root=$(_resolve_project_root "")
    [ -n "$project_root" ] || { echo "ERROR: park requires forge-project.yml in cwd ancestry" >&2; return 1; }
    local cb_dir="$project_root/.dev/forge-tmp/callbacks"
    local sess; sess="$(_resolve_session)"
    local pipeline_log="$project_root/.dev/proposals/$slug/forge-log.yml"

    if [ "$resolve" = true ]; then cmd_park_resolve "$slug" "$stage" "$note"; return $?; fi
    [ -n "$reason" ] || { echo "ERROR: park requires --reason" >&2; return 1; }

    local cb_file; cb_file="$(_resolve_callback_file "$cb_dir" "$slug" "$stage" "$sess" 2>/dev/null)" || cb_file=""
    local cb_status="" cb_id="" cb_origin=""
    if [ -n "$cb_file" ] && [ -f "$cb_file" ]; then
        cb_status=$(grep '^status:' "$cb_file" | awk '{print $2}')
        cb_id=$(grep '^callback_id:' "$cb_file" | awk '{print $2}')
        cb_origin=$(grep '^origin:' "$cb_file" | awk '{print $2}')
    fi

    if [ "$(_callback_ask_origin "$project_root" "$slug" "$stage" "$cb_origin")" = "ask" ]; then
        echo "REFUSED: '$slug/$stage' is an operator ask — answer via 'forge dispatch @<session> --answers', not park." >&2
        return 1
    fi
    if [ "$cb_status" = "PARKED" ]; then echo "PARK NOOP slug=$slug stage=$stage (already parked)"; return 0; fi
    if [ -z "$cb_file" ] || [ -z "$cb_status" ]; then echo "PARK NOOP slug=$slug stage=$stage reason=no-blocked-callback"; return 0; fi
    if [ "$cb_status" != "BLOCKED" ]; then echo "PARK NOOP slug=$slug stage=$stage reason=callback-status=$cb_status (not BLOCKED)"; return 0; fi

    local park_ts
    park_ts=$(FORGE_PK_STAGE="$stage" python3 - "$pipeline_log" <<'PY'
import os, sys, yaml
try: d = yaml.safe_load(open(sys.argv[1])) or {}
except Exception: sys.exit(3)
c=[e for e in (d.get('entries') or []) if isinstance(e,dict) and e.get('response') is None and e.get('stage')==os.environ["FORGE_PK_STAGE"]]
if not c: sys.exit(2)
c.sort(key=lambda e: e.get('timestamp') or '')
print(c[-1].get('timestamp') or '')
if len(c) > 1:
    older=" ".join((e.get('timestamp') or '?') for e in c[:-1])
    sys.stderr.write("WARN park D2: newest of %d open entries at this stage chosen; older duplicates: %s\n" % (len(c), older))
PY
)
    local prc=$?
    if [ "$prc" -eq 3 ]; then echo "ERROR: park: cannot parse $pipeline_log" >&2; return 1; fi
    if [ "$prc" -eq 2 ] || [ -z "$park_ts" ]; then
        echo "ERROR: park: callback BLOCKED but no open pending at $slug/$stage — cannot park." >&2; return 1
    fi

    _lifecycle_lock "$slug" "$stage" || return 1
    local rv; rv=$(_lifecycle_revalidate "$cb_file" BLOCKED "$cb_id" "$pipeline_log" "$park_ts")
    if [ "$rv" != OK ]; then _lifecycle_unlock; echo "REFUSED: park revalidation failed ($rv) — no write performed." >&2; return 1; fi
    local parked_at; parked_at=$(timestamp)
    local unc_bool; unc_bool=$([ "$uncommitted" = true ] && echo true || echo false)
    if ! _insert_parked_fields_by_ts "$slug" "$park_ts" "$parked_at" "$reason" "$unc_bool"; then
        _lifecycle_unlock
        echo "ERROR: park: failed to insert the durable parked record; callback left BLOCKED (re-park to retry)." >&2; return 1
    fi
    local cb_tmp="$cb_dir/.$(basename "$cb_file").tmp.$$"
    FORGE_PK_AT="$parked_at" FORGE_PK_REASON="$reason" FORGE_PK_UNCO="$unc_bool" \
    python3 - "$cb_file" "$cb_tmp" <<'PY'
import os, sys
src, dst = sys.argv[1], sys.argv[2]
parked_at = os.environ["FORGE_PK_AT"]; unc = os.environ["FORGE_PK_UNCO"]
reason = " ".join(os.environ.get("FORGE_PK_REASON","").splitlines()[0].split())[:120] if os.environ.get("FORGE_PK_REASON") else ""
esc = reason.replace('\\','\\\\').replace('"','\\"')
out = []
for ln in open(src).read().splitlines(keepends=True):
    if ln.startswith('status:'):
        out.append('status: PARKED\n'); continue
    if ln.startswith(('parked_at:', 'parked_reason:', 'uncommitted:')):
        continue
    if ln.startswith('message:'):
        out.append(f'parked_at: {parked_at}\n')
        out.append(f'parked_reason: "{esc}"\n')
        out.append(f'uncommitted: {unc}\n')
    out.append(ln)
open(dst, 'w').write(''.join(out))
PY
    if ! mv -f "$cb_tmp" "$cb_file"; then
        rm -f "$cb_tmp"; _lifecycle_unlock
        echo "ERROR: park: durable record written but callback flip failed (PARK-INCONSISTENT will surface; re-run park)." >&2; return 1
    fi
    _lifecycle_unlock

    # (4) infra-lock release — NOT best-effort; OUTSIDE the lifecycle lock (no nesting).
    local il_out il_v park_rc=0 lock_release_state
    il_out=$(cmd_infra_lock release --slug "$slug" --stage "$stage" 2>&1)
    il_v=$(printf '%s' "$il_out" | sed -n 's/^INFRA_LOCK: \([A-Z_]*\).*/\1/p')
    case "$il_v" in
        RELEASED|FORCE_RELEASED) lock_release_state="RELEASED" ;;
        RELEASE_NOOP)
            case "$il_out" in
                *reason=not-held*)  lock_release_state="RELEASE_NOOP_NOT_HELD" ;;   # success
                *)                  lock_release_state="RELEASE_NOOP_NOT_OWNER"; park_rc=1 ;;
            esac ;;
        ESCALATE)                lock_release_state="ESCALATE"; park_rc=1 ;;
        *)                       lock_release_state="IDENTITY_FAILURE"; park_rc=1 ;;
    esac
    if [ "$park_rc" -ne 0 ]; then
        _emit_event PARK "$slug" "stage=$stage action=parked lock_release_state=$lock_release_state callback_id=$cb_id needs=manual-lock-release"
        _emit_event ERROR "$slug" "stage=$stage reason=park-lock-release-$lock_release_state"
        echo "PARK PARTIAL slug=$slug stage=$stage lock_release_state=$lock_release_state — parked record stands; infra lock needs manual release." >&2
    else
        _emit_event PARK "$slug" "stage=$stage action=parked lock_release_state=$lock_release_state callback_id=$cb_id uncommitted=$uncommitted"
    fi

    if [ -n "${TMUX:-}" ]; then
        local s; s="${TMUX_SESSION:-$(tmux display-message -p '#{session_name}' 2>/dev/null)}"
        if [ -n "$s" ]; then
            _cancel_copy_mode "$s:$WINDOW.1"
            tmux send-keys -t "$s:$WINDOW.1" -l "FORGE_PARKED: $slug/$stage — $reason" 2>/dev/null || true
            sleep 0.2; tmux send-keys -t "$s:$WINDOW.1" Enter 2>/dev/null || true
        fi
    fi
    _render_status_file
    echo "PARKED slug=$slug stage=$stage lock_release_state=$lock_release_state parked_at=$parked_at"
    return $park_rc
}

cmd_park_resolve() {   # <slug> <stage> <note>   (acquires the lifecycle lock)
    local slug="$1" stage="$2" note="$3"
    local project_root; project_root=$(_resolve_project_root "")
    [ -n "$project_root" ] || { echo "ERROR: park --resolve requires forge-project.yml" >&2; return 1; }
    local cb_dir="$project_root/.dev/forge-tmp/callbacks"
    local sess; sess="$(_resolve_session)"
    local cb_file; cb_file="$(_resolve_callback_file "$cb_dir" "$slug" "$stage" "$sess" 2>/dev/null)" || cb_file=""
    local pipeline_log="$project_root/.dev/proposals/$slug/forge-log.yml"
    local ts
    ts=$(FORGE_PK_STAGE="$stage" python3 - "$pipeline_log" <<'PY'
import os, sys, yaml
try: d = yaml.safe_load(open(sys.argv[1])) or {}
except Exception: sys.exit(2)
c=[e for e in (d.get('entries') or []) if isinstance(e,dict) and e.get('response') is None and e.get('stage')==os.environ["FORGE_PK_STAGE"]]
c.sort(key=lambda e: e.get('timestamp') or '')
print(c[-1].get('timestamp') if c else '')
PY
)
    [ -n "$ts" ] || { echo "ERROR: park --resolve: no open pending at $slug/$stage" >&2; return 1; }
    _lifecycle_lock "$slug" "$stage" || return 1
    if ! _patch_response_by_ts "$slug" "$ts" "FORGE_PARK_RESOLVED: ${note:-resolved}"; then
        _lifecycle_unlock; echo "ERROR: park --resolve: failed to close pending" >&2; return 1
    fi
    if [ -n "$cb_file" ] && [ -f "$cb_file" ]; then
        ( cd "$project_root" && cmd_callback_consume --_no_lock --slug "$slug" --stage "$stage" --status PARKED >/dev/null 2>&1 ) || true
    fi
    _lifecycle_unlock
    _emit_event PARK "$slug" "stage=$stage action=resolved note=$(_sanitize_event_value "$note")"
    _render_status_file
    echo "PARK RESOLVED slug=$slug stage=$stage"
}

cmd_blocked_audit() {
    local root_override="" jsonout=0
    while [ $# -gt 0 ]; do case "$1" in
        --root) root_override="$2"; shift 2 ;;
        --json) jsonout=1; shift ;;
        *) shift ;;
    esac; done
    local project_root
    if [ -n "$root_override" ]; then project_root="$root_override"; else project_root=$(_resolve_project_root ""); fi
    [ -n "$project_root" ] || { echo "ERROR: blocked-audit requires a project root" >&2; return 1; }
    FORGE_BA_JSON="$jsonout" python3 - "$project_root" <<'PY'
import os, sys, glob, json, re
root = sys.argv[1]; jsonout = os.environ.get("FORGE_BA_JSON") == "1"
dev = os.path.join(root, ".dev"); items = []
try:
    import yaml; HAVE = True
except Exception:
    HAVE = False
adir = os.path.join(dev, "attention")
def ask_match(slug, stage):
    for fp in glob.glob(os.path.join(adir, "ask-*.json")):
        try: r = json.load(open(fp))
        except Exception: continue
        if r.get("event")=="ask" and r.get("slug")==slug and r.get("stage")==stage and r.get("mode")=="stage":
            return True
    return False
for cbp in glob.glob(os.path.join(dev, "forge-tmp", "callbacks", "*.callback")):
    raw = open(cbp).read()
    def g(f):
        m = re.search(rf'^{f}:\s*(.*?)\s*$', raw, re.M); return m.group(1).strip() if m else None
    slug, stage, status, origin = g('slug'), g('stage'), (g('status') or '').upper(), g('origin')
    base = os.path.basename(cbp)
    legacy = bool(slug and stage and re.match(rf'^{re.escape(slug)}-{re.escape(stage)}\.callback$', base))
    if status == 'BLOCKED':
        isask = (origin == 'ask') or ask_match(slug, stage)
        items.append({"kind": "blocked-callback", "slug": slug, "stage": stage,
                      "origin": "ask" if isask else "worker", "legacy_filename": legacy,
                      "suggest": "answer via dispatch --answers" if isask else "park / consume / supersede"})
    elif status == 'PARKED':
        items.append({"kind": "parked-callback", "slug": slug, "stage": stage,
                      "legacy_filename": legacy, "suggest": "resolve or supersede"})
for logp in glob.glob(os.path.join(dev, "proposals", "*", "forge-log.yml")):
    slug = os.path.basename(os.path.dirname(logp))
    if not HAVE: continue
    try: d = yaml.safe_load(open(logp)) or {}
    except Exception:
        items.append({"kind": "unparseable-log", "slug": slug, "suggest": "manual"}); continue
    by = {}
    for e in (d.get('entries') or []):
        if isinstance(e, dict) and e.get('response') is None:
            by.setdefault(e.get('stage'), []).append(e)
            if e.get('parked_at'):
                items.append({"kind": "half-parked-record", "slug": slug, "stage": e.get('stage'),
                              "suggest": "recover quadrant — verify callback flipped to PARKED"})
    for stage, lst in by.items():
        if len(lst) > 1:
            items.append({"kind": "duplicate-open-pending", "slug": slug, "stage": stage,
                          "count": len(lst), "suggest": "supersede (D2 newest authoritative)"})
sf = os.path.join(os.path.expanduser("~/.cache/forge-watch"), "state.json")
if os.path.exists(sf):
    try:
        st = json.load(open(sf))
        for k in (st.get("conditions") or {}):
            if "WORKER-BLOCKED" in k:
                items.append({"kind": "stale-state-key", "key": k, "suggest": "orphans harmlessly after rename"})
    except Exception: pass
if jsonout:
    print(json.dumps({"root": root, "items": items}, indent=2))
else:
    if not items: print("blocked-audit: clean (no residue)")
    for it in items:
        print("  " + " ".join(f"{k}={v}" for k, v in it.items()))
    print(f"blocked-audit: {len(items)} item(s) — MUTATES NOTHING")
PY
}

# ===========================================================================
# infra-lock — cross-worktree mutex serializing infra-touching stages.
#
# Forge is share-nothing per worktree EXCEPT all worktrees hit one shared infra
# stack (fixed-port services + a shared Postgres). This is a single global mutex
# so the five infra stages {coding, qa, qa-fix, qa-retry, verify} never run
# simultaneously across worktrees; the five reasoning stages stay fully parallel.
# It is a LOCK, not a scheduler. See docs/forge-technical-reference.md (Hard
# Rule 23) and the orchestrator SKILL (Shapes A/B).
#
# Anchor: $(git rev-parse --path-format=absolute --git-common-dir)/forge-infra-lock/
# (worktrees share .git but not .dev/, so the git COMMON dir is the one anchor
# all worktrees resolve identically). Override with FORGE_INFRA_LOCK_DIR (tests).
#   - infra.flock  : flock guard, held only during the brief check-then-act
#   - infra.holder : sidecar YAML, present  <=>  lock held (ephemeral, rm on release)
#
# Owner key = (host, session_id, session_created, slug) for BOTH acquire
# same-session detection AND release match (release omits only `stage`, so a
# stage-update holder still releases cleanly). Liveness uses REAL tmux (no shell
# eval). A dead holder (session id+creation no longer live on this host) is stolen
# by the next waiter under the flock guard; a live-but-abandoned or foreign-host
# holder surfaces via status + the wait-ceiling escalation for operator recovery.
# ===========================================================================

# Resolve the lock anchor dir. FORGE_INFRA_LOCK_DIR overrides (tests / debug).
_infra_lock_anchor() {
    if [ -n "${FORGE_INFRA_LOCK_DIR:-}" ]; then
        printf '%s' "$FORGE_INFRA_LOCK_DIR"
        return 0
    fi
    local common
    common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
    [ -z "$common" ] && return 1
    printf '%s/forge-infra-lock' "$common"
}

# Resolve THIS process's session identity for the owner key. From tmux when in a
# session; overridable via data-only FORGE_LOCK_SELF_* env (test seam — these are
# written verbatim into the sidecar and only ever string-compared, never eval'd;
# liveness ALWAYS uses real tmux). Echoes: host|session|session_id|session_created|tmux_pid
_infra_lock_identity() {
    local host session sid screated tpid
    host="${FORGE_LOCK_SELF_HOST:-$(hostname 2>/dev/null)}"
    if [ -n "${FORGE_LOCK_SELF_SESSION_ID:-}" ]; then
        session="${FORGE_LOCK_SELF_SESSION:-unknown}"
        sid="$FORGE_LOCK_SELF_SESSION_ID"
        screated="${FORGE_LOCK_SELF_SESSION_CREATED:-0}"
        tpid="${FORGE_LOCK_SELF_TMUX_PID:-0}"
    else
        local idinfo
        idinfo=$(tmux display-message -p '#{session_name}|#{session_id}|#{session_created}|#{pid}' 2>/dev/null)
        if [ -z "$idinfo" ]; then
            return 1
        fi
        session="${idinfo%%|*}"; idinfo="${idinfo#*|}"
        sid="${idinfo%%|*}";     idinfo="${idinfo#*|}"
        screated="${idinfo%%|*}"; idinfo="${idinfo#*|}"
        tpid="${idinfo%%|*}"
    fi
    printf '%s|%s|%s|%s|%s' "$host" "$session" "$sid" "$screated" "$tpid"
}

# Run one infra-lock action in Python under the flock guard. Inputs via env;
# prints a single `VERDICT=<CODE> k=v …` line. All sidecar I/O is yaml.safe_*
# (injection-safe); all owner comparisons are Python string ops; liveness shells
# out to real `tmux list-sessions`. A corrupt/unparseable sidecar yields
# VERDICT=ESCALATE reason=corrupt-holder, never a traceback.
_infra_lock_run() {
    python3 - <<'PYEOF'
import os, sys, yaml, fcntl, subprocess

anchor   = os.environ["FORGE_IL_ANCHOR"]
action   = os.environ["FORGE_IL_ACTION"]
force    = os.environ.get("FORGE_IL_FORCE", "") == "1"
me = {
    "host":            os.environ.get("FORGE_IL_HOST", ""),
    "session":         os.environ.get("FORGE_IL_SESSION", ""),
    "session_id":      os.environ.get("FORGE_IL_SID", ""),
    "session_created": os.environ.get("FORGE_IL_SCREATED", ""),
    "tmux_pid":        os.environ.get("FORGE_IL_TPID", ""),
    "slug":            os.environ.get("FORGE_IL_SLUG", ""),
    "stage":           os.environ.get("FORGE_IL_STAGE", ""),
    "project_root":    os.environ.get("FORGE_IL_ROOT", ""),
    "pid":             os.environ.get("FORGE_IL_PID", ""),
    "acquired_at":     os.environ.get("FORGE_IL_AT", ""),
}
holder_path = os.path.join(anchor, "infra.holder")
flock_path  = os.path.join(anchor, "infra.flock")
os.makedirs(anchor, exist_ok=True)

def emit(verdict, **kw):
    parts = " ".join("%s=%s" % (k, v) for k, v in kw.items() if v is not None and v != "")
    sys.stdout.write("VERDICT=%s %s\n" % (verdict, parts))

def write_holder(rec):
    tmp = holder_path + ".tmp.%d" % os.getpid()
    with open(tmp, "w") as f:
        yaml.safe_dump(rec, f, default_flow_style=False, sort_keys=True)
    os.replace(tmp, holder_path)

def tmux_live(host, sid, created):
    # Liveness is only verifiable on THIS host (tmux session ids are server-local).
    if host != me["host"]:
        return "foreign"
    try:
        out = subprocess.run(["tmux", "list-sessions", "-F", "#{session_id} #{session_created}"],
                             capture_output=True, text=True, timeout=5)
    except Exception:
        return "dead"
    if out.returncode != 0:
        return "dead"   # no server / no sessions => holder's session is gone
    want = (str(sid), str(created))
    for line in out.stdout.splitlines():
        p = line.split()
        if len(p) >= 2 and (p[0], p[1]) == want:
            return "live"
    return "dead"

def same_session(h):
    return (h.get("host") == me["host"]
            and str(h.get("session_id")) == me["session_id"]
            and str(h.get("session_created")) == me["session_created"])

def full_owner_match(h):
    # Release / ownership: full owner key (host, session_id, session_created, slug).
    return same_session(h) and h.get("slug") == me["slug"]

with open(flock_path, "w") as lf:
    fcntl.flock(lf, fcntl.LOCK_EX)
    try:
        try:
            h = None
            if os.path.exists(holder_path):
                with open(holder_path) as f:
                    h = yaml.safe_load(f)
                if h is not None and not isinstance(h, dict):
                    raise ValueError("holder is not a mapping")
        except Exception as ex:
            # Corrupt sidecar -> safe escalation, never a traceback.
            emit("ESCALATE", reason="corrupt-holder")
            sys.exit(0)

        if action == "try-acquire":
            if h is None:
                write_holder(me); emit("ACQUIRED", action="acquired")
            elif h.get("host") != me["host"]:
                emit("WAIT", reason="foreign-host", held_host=h.get("host"),
                     held_by=h.get("slug"), held_session=h.get("session"), held_stage=h.get("stage"))
            elif same_session(h):
                # Genuinely THIS live session already holds it.
                if h.get("slug") == me["slug"]:
                    if h.get("stage") == me["stage"]:
                        emit("ALREADY_HELD", slug=h.get("slug"), stage=h.get("stage"))
                    else:
                        write_holder(me)  # me carries the new stage + acquired_at
                        emit("ACQUIRED", action="stage_update", stage=me["stage"],
                             prev_stage=h.get("stage"))
                else:
                    emit("CONFLICT", held_slug=h.get("slug"), held_stage=h.get("stage"),
                         held_session=h.get("session"))
            else:
                # Same host, different session identity -> check real liveness.
                live = tmux_live(h.get("host"), h.get("session_id"), h.get("session_created"))
                if live == "dead":
                    write_holder(me)
                    emit("ACQUIRED", action="steal", stole_from=h.get("slug"),
                         stole_session=h.get("session"))
                else:
                    emit("WAIT", reason="held-by-live-session", held_by=h.get("slug"),
                         held_session=h.get("session"), held_stage=h.get("stage"))

        elif action == "release":
            if h is None:
                emit("RELEASE_NOOP", reason="not-held")
            elif force:
                os.remove(holder_path)
                emit("FORCE_RELEASED", prev_slug=h.get("slug"), prev_session=h.get("session"))
            elif full_owner_match(h):
                os.remove(holder_path)
                emit("RELEASED", slug=h.get("slug"))
            else:
                emit("RELEASE_NOOP", reason="not-owner", held_by=h.get("slug"),
                     held_host=h.get("host"), held_session=h.get("session"))

        elif action == "status":
            if h is None:
                emit("FREE")
            elif h.get("host") != me["host"]:
                emit("FOREIGN", held_by=h.get("slug"), held_host=h.get("host"),
                     held_session=h.get("session"), held_stage=h.get("stage"),
                     session_id=h.get("session_id"), session_created=h.get("session_created"),
                     acquired_at=h.get("acquired_at"), project_root=h.get("project_root"),
                     liveness="foreign-host")
            else:
                live = tmux_live(h.get("host"), h.get("session_id"), h.get("session_created"))
                state = "HELD_LIVE" if live == "live" else "STALE"
                emit(state, held_by=h.get("slug"), held_host=h.get("host"),
                     held_session=h.get("session"), held_stage=h.get("stage"),
                     session_id=h.get("session_id"), session_created=h.get("session_created"),
                     acquired_at=h.get("acquired_at"), project_root=h.get("project_root"),
                     liveness=live)
        else:
            emit("ESCALATE", reason="unknown-action", action=action)
    finally:
        fcntl.flock(lf, fcntl.LOCK_UN)
PYEOF
}

# Parse `k=v` field from a VERDICT line.
_il_field() { printf '%s\n' "$1" | sed -n "s/.*[[:space:]]$2=\\([^ ]*\\).*/\\1/p" | head -1; }

cmd_infra_lock() {
    local action="" slug="" stage="" timeout="" interval="" force=false
    # First positional (not starting with --) is the action.
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)     slug="$2";     shift 2 ;;
            --stage)    stage="$2";    shift 2 ;;
            --timeout)  timeout="$2";  shift 2 ;;
            --interval) interval="$2"; shift 2 ;;
            --force)    force=true;    shift ;;
            acquire|release|status) [ -z "$action" ] && action="$1"; shift ;;
            *)          shift ;;
        esac
    done
    if [ -z "$action" ]; then
        echo "Usage: forge-bridge infra-lock <acquire|release|status> --slug <s> --stage <t> [--timeout N] [--interval I] [--force]" >&2
        return 1
    fi

    local anchor
    anchor=$(_infra_lock_anchor) || {
        echo "ERROR: infra-lock: cannot resolve git common dir (set FORGE_INFRA_LOCK_DIR or run inside a git repo)." >&2
        return 1
    }
    mkdir -p "$anchor" 2>/dev/null

    local ident host session sid screated tpid
    ident=$(_infra_lock_identity) || {
        echo "ERROR: infra-lock: cannot resolve a tmux session identity (must run inside the forge tmux session, or set FORGE_LOCK_SELF_* for tests)." >&2
        return 1
    }
    host="${ident%%|*}";    ident="${ident#*|}"
    session="${ident%%|*}"; ident="${ident#*|}"
    sid="${ident%%|*}";     ident="${ident#*|}"
    screated="${ident%%|*}"; ident="${ident#*|}"
    tpid="${ident%%|*}"

    # project_root is best-effort (recovery metadata); never fatal.
    local project_root; project_root=$(_resolve_project_root "" 2>/dev/null || true)

    export FORGE_IL_ANCHOR="$anchor" FORGE_IL_HOST="$host" FORGE_IL_SESSION="$session" \
           FORGE_IL_SID="$sid" FORGE_IL_SCREATED="$screated" FORGE_IL_TPID="$tpid" \
           FORGE_IL_SLUG="$slug" FORGE_IL_STAGE="$stage" FORGE_IL_ROOT="$project_root" \
           FORGE_IL_PID="$$" FORGE_IL_AT="$(timestamp)"

    case "$action" in
        status)
            local out; out=$(FORGE_IL_ACTION=status _infra_lock_run)
            local v; v=$(printf '%s' "$out" | sed -n 's/^VERDICT=\([A-Z_]*\).*/\1/p')
            case "$v" in
                FREE)      echo "INFRA_LOCK: FREE" ;;
                HELD_LIVE) echo "INFRA_LOCK: HELD live by $(_il_field "$out" held_by) stage $(_il_field "$out" held_stage) session $(_il_field "$out" held_session) ($(_il_field "$out" session_id) created $(_il_field "$out" session_created)) since $(_il_field "$out" acquired_at)" ;;
                STALE)     echo "INFRA_LOCK: STALE dead-session holder by $(_il_field "$out" held_by) session $(_il_field "$out" held_session) (next acquire steals; or 'infra-lock release --force' if intentionally aborting — WARNING: force while the holder still runs can collide)" ;;
                FOREIGN)   echo "INFRA_LOCK: HELD foreign-host by $(_il_field "$out" held_by) host $(_il_field "$out" held_host) (liveness unverifiable from here)" ;;
                ESCALATE)  echo "INFRA_LOCK: ESCALATE reason=$(_il_field "$out" reason) (corrupt sidecar at $anchor/infra.holder — inspect/clear manually)" ;;
                *)         echo "INFRA_LOCK: UNKNOWN ($out)"; return 1 ;;
            esac
            return 0
            ;;
        release)
            if [ -z "$slug" ]; then
                echo "ERROR: infra-lock release requires --slug" >&2; return 1
            fi
            local fenv=""; [ "$force" = true ] && fenv="1"
            local out; out=$(FORGE_IL_ACTION=release FORGE_IL_FORCE="$fenv" _infra_lock_run)
            local v; v=$(printf '%s' "$out" | sed -n 's/^VERDICT=\([A-Z_]*\).*/\1/p')
            case "$v" in
                RELEASED)       _emit_event LOCK "$slug" "action=released stage=$stage session=$session"; echo "INFRA_LOCK: RELEASED slug=$slug stage=$stage" ;;
                FORCE_RELEASED) _emit_event LOCK "$slug" "action=force_release stage=$stage session=$session prev_slug=$(_il_field "$out" prev_slug)"; echo "INFRA_LOCK: FORCE_RELEASED (was: slug=$(_il_field "$out" prev_slug) session=$(_il_field "$out" prev_session))" ;;
                RELEASE_NOOP)   _emit_event LOCK "$slug" "action=release_noop stage=$stage reason=$(_il_field "$out" reason)"; echo "INFRA_LOCK: RELEASE_NOOP slug=$slug reason=$(_il_field "$out" reason) (not the holder; nothing removed)" ;;
                ESCALATE)       _emit_event LOCK "$slug" "action=release_escalate reason=$(_il_field "$out" reason)"; echo "INFRA_LOCK: ESCALATE reason=$(_il_field "$out" reason) (corrupt sidecar; use --force after inspecting $anchor/infra.holder)"; return 1 ;;
                *)              echo "INFRA_LOCK: UNKNOWN ($out)"; return 1 ;;
            esac
            _render_status_file 2>/dev/null || true
            return 0
            ;;
        acquire)
            if [ -z "$slug" ] || [ -z "$stage" ]; then
                echo "ERROR: infra-lock acquire requires --slug and --stage" >&2; return 1
            fi
            local to_s int_s
            to_s="${timeout:-${FORGE_INFRA_LOCK_TIMEOUT_S:-1800}}"
            int_s="${interval:-${FORGE_INFRA_LOCK_INTERVAL_S:-15}}"
            local started; started=$(date +%s)
            _emit_event LOCK "$slug" "action=acquire_begin stage=$stage session=$session timeout=${to_s}s"
            while true; do
                # Refresh acquired_at each attempt so the recorded time reflects
                # the actual grant, not the first poll.
                export FORGE_IL_AT="$(timestamp)"
                local out; out=$(FORGE_IL_ACTION=try-acquire _infra_lock_run)
                local v; v=$(printf '%s' "$out" | sed -n 's/^VERDICT=\([A-Z_]*\).*/\1/p')
                [ -z "$v" ] && v="ESCALATE"
                case "$v" in
                    ACQUIRED)
                        local act; act=$(_il_field "$out" action)
                        _emit_event LOCK "$slug" "action=$act stage=$stage session=$session held=true"
                        echo "INFRA_LOCK: ACQUIRED slug=$slug stage=$stage session=$session (action=$act)"
                        _render_status_file 2>/dev/null || true
                        return 0 ;;
                    ALREADY_HELD)
                        _emit_event LOCK "$slug" "action=already_held stage=$stage session=$session"
                        echo "INFRA_LOCK: ALREADY_HELD slug=$slug stage=$stage session=$session (reentrant)"
                        return 0 ;;
                    CONFLICT)
                        _emit_event LOCK "$slug" "action=conflict stage=$stage session=$session held_slug=$(_il_field "$out" held_slug)"
                        {
                            echo "INFRA_LOCK: CONFLICT — this live session ($session) already holds the infra lock for a DIFFERENT slug:"
                            echo "    held_slug=$(_il_field "$out" held_slug) held_stage=$(_il_field "$out" held_stage)"
                            echo "    requested slug=$slug stage=$stage"
                            echo "  This is not auto-stealable (the other slug's infra worker may still be live)."
                            echo "  Resolve: release the prior slug's lock first, or abort it. (Do NOT --force blindly.)"
                        } >&2
                        return 3 ;;
                    ESCALATE)
                        _emit_event LOCK "$slug" "action=acquire_escalate stage=$stage reason=$(_il_field "$out" reason)"
                        echo "INFRA_LOCK: ESCALATE reason=$(_il_field "$out" reason) — corrupt sidecar at $anchor/infra.holder. Inspect and clear with 'infra-lock release --force' before retrying." >&2
                        return 4 ;;
                    WAIT)
                        local elapsed; elapsed=$(( $(date +%s) - started ))
                        if [ "$elapsed" -ge "$to_s" ]; then
                            # Ceiling: dump full holder metadata + liveness for the operator.
                            local sout; sout=$(FORGE_IL_ACTION=status _infra_lock_run)
                            _emit_event LOCK "$slug" "action=timeout stage=$stage waited=${elapsed}s held_by=$(_il_field "$out" held_by)"
                            {
                                echo "INFRA_LOCK: TIMEOUT — waited ${elapsed}s for the infra lock (slug=$slug stage=$stage)."
                                echo "  Current holder:"
                                echo "    held_by        = $(_il_field "$sout" held_by)"
                                echo "    host           = $(_il_field "$sout" held_host)"
                                echo "    session        = $(_il_field "$sout" held_session)"
                                echo "    session_id     = $(_il_field "$sout" session_id)"
                                echo "    session_created= $(_il_field "$sout" session_created)"
                                echo "    stage          = $(_il_field "$sout" held_stage)"
                                echo "    acquired_at    = $(_il_field "$sout" acquired_at)"
                                echo "    project_root   = $(_il_field "$sout" project_root)"
                                echo "    liveness       = $(_il_field "$sout" liveness)"
                                echo "  If the holder is confirmed stopped/abandoned, force-release (WARNING: a force"
                                echo "  while an infra worker still runs can collide on the shared DB/ports):"
                                echo "    ~/bin/forge-bridge infra-lock release --slug $(_il_field "$sout" held_by) --stage $(_il_field "$sout" held_stage) --force"
                            } >&2
                            return 2
                        fi
                        _emit_event LOCK "$slug" "action=wait stage=$stage held_by=$(_il_field "$out" held_by) reason=$(_il_field "$out" reason) waited=${elapsed}s"
                        sleep "$int_s"
                        ;;
                    *)
                        _emit_event LOCK "$slug" "action=acquire_unknown stage=$stage verdict=$v"
                        echo "INFRA_LOCK: UNKNOWN verdict ($out)" >&2
                        return 1 ;;
                esac
            done
            ;;
        *)
            echo "ERROR: infra-lock: unknown action '$action' (acquire|release|status)" >&2
            return 1 ;;
    esac
}

# digest — render a digest prompt to disk for ad-hoc use.
#   forge-bridge digest --slug <s> --stage <s> --template <name> [--worker <w>]
# Worker defaults to claude-opus when not supplied (digest agents are
# orchestrator-side; the worker token here only affects {worker}/{worker_pane}
# substitutions, which most digest templates do not reference).
cmd_digest() {
    local slug="" stage="" template="" worker="claude-opus"
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)     slug="$2";     shift 2 ;;
            --stage)    stage="$2";    shift 2 ;;
            --template) template="$2"; shift 2 ;;
            --worker)   worker="$2";   shift 2 ;;
            *)          shift ;;
        esac
    done
    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$template" ]; then
        echo "Usage: forge-bridge digest --slug <s> --stage <s> --template <name> [--worker <w>]" >&2
        return 1
    fi

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: digest requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi

    local worker_canonical worker_pane
    worker_canonical=$(canonical_pane_name "$worker")
    worker_pane=$(pane_index "$worker")

    local tmpl_path="$FORGE_DIGESTS_DIR/$template.txt"
    local out_dir="$project_root/.dev/forge-tmp"
    mkdir -p "$out_dir"
    local out_file="$out_dir/digest-${stage}-${slug}.txt"

    _render_template "$tmpl_path" "$slug" "$stage" "$worker_canonical" \
        "$worker_pane" "$project_root" > "$out_file" || {
        _emit_event ERROR "$slug" "stage=$stage reason=template-render-failed template=$template"
        return 1
    }

    _emit_event DIGEST "$slug" "stage=$stage template=$template event=prompt-rendered out_file=$out_file"
    echo "DIGEST_PROMPT: $out_file"
}

# emit — orchestrator-driven event emission for the heartbeat log.
#   forge-bridge emit <TYPE> --slug <s> [--stage <s>] [key=value …]
# Validates TYPE against the 9-event whitelist; sanitizes the RHS of each
# passthrough key=value and forwards through _emit_event. Used by the
# orchestrator to emit DIGEST verdicts after consuming digest output
# (and, in v2, routing-decision events).
cmd_emit() {
    if [ $# -lt 1 ]; then
        echo "Usage: forge-bridge emit <TYPE> --slug <s> [--stage <s>] [key=value …]" >&2
        return 1
    fi
    local type="$1"; shift
    case "$type" in
        DISPATCH|WAIT|CALLBACK|DIGEST|STAGE|STALL|ERROR|COMPLETE|USAGE) ;;
        *)
            echo "ERROR: emit TYPE must be one of DISPATCH|WAIT|CALLBACK|DIGEST|STAGE|STALL|ERROR|COMPLETE|USAGE; got '$type'" >&2
            return 1
            ;;
    esac
    local slug="" stage=""
    local -a passthrough=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)  slug="$2";  shift 2 ;;
            --stage) stage="$2"; shift 2 ;;
            *)
                if [[ "$1" == *=* ]]; then
                    local k="${1%%=*}" v="${1#*=}"
                    local v_clean
                    v_clean=$(_sanitize_event_value "$v")
                    passthrough+=("$k=$v_clean")
                else
                    passthrough+=("$1")
                fi
                shift
                ;;
        esac
    done
    if [ -z "$slug" ]; then
        echo "ERROR: emit requires --slug" >&2
        return 1
    fi
    local fields=""
    [ -n "$stage" ] && fields="stage=$stage"
    if [ "${#passthrough[@]}" -gt 0 ]; then
        if [ -n "$fields" ]; then
            fields="$fields ${passthrough[*]}"
        else
            fields="${passthrough[*]}"
        fi
    fi
    # Completion gating (§3.4): auto-qualify a manual COMPLETE when the caller did not
    # and the session-scoped unresolved set is non-empty.
    if [ "$type" = COMPLETE ] && [[ "$fields" != *qualifier=* ]]; then
        local _epr; _epr=$(_resolve_project_root "" 2>/dev/null)
        if [ -n "$_epr" ]; then
            local _eu; _eu=$(_completion_unresolved "$_epr")
            case "$_eu" in
                "parked=0 blocked=0") : ;;
                *) fields="$fields qualifier=incomplete $_eu" ;;
            esac
        fi
    fi
    _emit_event "$type" "$slug" "$fields"
}

# usage — print the per-worker usage snapshot for the current session.
#   forge-bridge usage [<worker>]
# Read-only FILE read (forge-usage.<session>.yml); never scrapes a pane — a
# status query must not perturb workers. Recorded per task by _observe_usage.
cmd_usage() {
    require_identity "usage" host-session || return 1
    local filter="${1:-}"
    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        echo "usage: no project root resolved (run from a forge project directory)"
        return 0
    fi
    local sess_token; sess_token=$(_session_or_sentinel)
    if [ "$sess_token" = "__nosession__" ]; then
        echo "usage: no forge session resolved — cannot identify a usage snapshot."
        echo "       (set TMUX_SESSION, or run from a project dir with .dev/.forge-session)"
        return 0
    fi
    local usage_file="$project_root/$(_usage_file)"
    if [ ! -f "$usage_file" ]; then
        echo "usage: no usage recorded yet for session '$sess_token'"
        echo "       ($usage_file)"
        return 0
    fi
    FORGE_U_FILTER="$filter" python3 - "$usage_file" 2>/dev/null <<'PYEOF'
import os, sys, yaml
usage_file = sys.argv[1]
flt = os.environ.get("FORGE_U_FILTER", "")
try:
    with open(usage_file) as f:
        data = yaml.safe_load(f) or {}
except Exception as e:
    print("usage: snapshot unreadable: %s" % e); sys.exit(0)
if not isinstance(data, dict):
    data = {}
workers = data.get("workers") or {}
updated = data.get("updated", "?")
print("usage snapshot (updated %s):" % updated)
if not isinstance(workers, dict) or not workers:
    print("  (empty)"); sys.exit(0)
order = ["claude-opus", "claude-sonnet", "codex-a", "codex-b"]
keys = [k for k in order if k in workers] + [k for k in workers if k not in order]
shown = 0
for w in keys:
    if flt and w != flt:
        continue
    r = workers[w] if isinstance(workers[w], dict) else {}
    hr = r.get("headroom", "?")
    if hr == "unknown":
        extra = "reason=%s" % r.get("reason", "?")
    else:
        extra = "pct=%s tokens=%s" % (r.get("pct", "?"), r.get("tokens", "?"))
    print("  %-13s family=%-6s headroom=%-7s confidence=%-5s stage=%-13s %s" % (
        w, r.get("family", "?"), hr, r.get("confidence", "?"),
        r.get("stage", "?"), extra))
    shown += 1
if flt and shown == 0:
    print("  (no record for worker '%s')" % flt)
PYEOF
    return 0
}

cmd_preflight() {
    # Pre-flight discipline (Phase 1a). Prints a kickoff snapshot and a
    # final status_code line. Does NOT require a tmux session. Always
    # exits 0; orchestrator decides whether to halt based on status_code.
    # Carries the identity descriptor even in a bad state (R7); the documented exit
    # code lives ONLY on `identity`, never here.
    require_identity "preflight" diagnostic
    _print_identity_block

    local cur_pwd
    cur_pwd=$(pwd)

    # Resolve expected_root: forge-project.yml field, else nearest-ancestor walk-up.
    local expected_root="" project_yml=""
    local _dir="$cur_pwd"
    while [ "$_dir" != "/" ]; do
        if [ -f "$_dir/.claude/forge-project.yml" ]; then
            project_yml="$_dir/.claude/forge-project.yml"
            break
        fi
        _dir=$(dirname "$_dir")
    done

    if [ -n "$project_yml" ]; then
        expected_root=$(python3 -c "
import yaml
try:
    with open('$project_yml') as f:
        data = yaml.safe_load(f) or {}
    print(data.get('forge', {}).get('expected_root', ''))
except Exception:
    pass
" 2>/dev/null)
        if [ -z "$expected_root" ]; then
            expected_root=$(dirname "$(dirname "$project_yml")")
        fi
    fi

    local directory_state="OK"
    local _pwd_real _exp_real
    _pwd_real="$(cd "$cur_pwd" 2>/dev/null && pwd -P)"; [ -n "$_pwd_real" ] || _pwd_real="$cur_pwd"
    _exp_real="$(cd "$expected_root" 2>/dev/null && pwd -P)"; [ -n "$_exp_real" ] || _exp_real="$expected_root"
    if [ -z "$expected_root" ]; then
        directory_state="UNKNOWN"
    elif [ "$_pwd_real" != "$_exp_real" ]; then
        directory_state="WRONG_DIRECTORY"
    fi

    # Branch detection
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    local detached="false"
    if [ -z "$branch" ]; then
        local sha
        sha=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
        branch="(detached: $sha)"
        detached="true"
    fi

    # Resolve base_ref: forge-project.yml override, else origin/HEAD, else origin/main, else main
    local base_ref=""
    if [ -n "$project_yml" ]; then
        base_ref=$(python3 -c "
import yaml
try:
    with open('$project_yml') as f:
        data = yaml.safe_load(f) or {}
    print(data.get('forge', {}).get('base_ref', ''))
except Exception:
    pass
" 2>/dev/null)
    fi
    if [ -z "$base_ref" ]; then
        base_ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/@@')
    fi
    if [ -z "$base_ref" ] && git rev-parse --verify origin/main >/dev/null 2>&1; then
        base_ref="origin/main"
    fi
    if [ -z "$base_ref" ]; then
        base_ref="main"
    fi

    # Merge state detection — see check_merge_state() below
    local merge_state="" merge_method="" merge_detail=""
    if [ "$detached" = "true" ]; then
        merge_state="DETACHED_HEAD"
        merge_method="n/a"
        merge_detail="HEAD is detached at $branch"
    else
        # Method 1: gh-aware
        if command -v gh >/dev/null && gh auth status >/dev/null 2>&1; then
            local pr_json
            pr_json=$(gh pr list --state merged --head "$branch" --limit 1 --json number,mergedAt 2>/dev/null)
            local pr_num
            pr_num=$(echo "$pr_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0]['number']) if d else None" 2>/dev/null)
            if [ -n "$pr_num" ] && [ "$pr_num" != "None" ]; then
                local pr_merged_at
                pr_merged_at=$(echo "$pr_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0]['mergedAt'][:10]) if d else None" 2>/dev/null)
                local cherry_count
                cherry_count=$(git rev-list --cherry-pick --right-only --count "$base_ref...$branch" 2>/dev/null || echo "?")
                merge_method="gh"
                if [ "$cherry_count" = "0" ]; then
                    merge_state="BRANCH_MERGED_CLEAN"
                    merge_detail="PR #$pr_num merged $pr_merged_at; no drift"
                elif [ "$cherry_count" = "?" ]; then
                    merge_state="BRANCH_UNCLEAR"
                    merge_detail="PR #$pr_num merged $pr_merged_at; cherry-pick count failed"
                else
                    merge_state="BRANCH_MERGED_WITH_DRIFT"
                    merge_detail="PR #$pr_num merged $pr_merged_at; $cherry_count commits since merge (vs $base_ref)"
                fi
            fi
        fi

        # Method 2: git-only fallback
        if [ -z "$merge_state" ]; then
            merge_method="git-only"
            if git merge-base --is-ancestor HEAD "$base_ref" 2>/dev/null; then
                merge_state="BRANCH_MERGED_CLEAN"
                merge_detail="HEAD is an ancestor of $base_ref"
            else
                local cherry_count
                cherry_count=$(git rev-list --cherry-pick --right-only --count "$base_ref...$branch" 2>/dev/null)
                if [ "$cherry_count" = "0" ]; then
                    merge_state="BRANCH_MERGED_CLEAN"
                    merge_detail="cherry-pick count vs $base_ref is 0"
                else
                    merge_state="BRANCH_UNMERGED"
                    merge_detail="${cherry_count:-?} unique commits vs $base_ref"
                fi
            fi
        fi
    fi

    # Determine status_code and human status
    local status_code=""
    local status=""
    case "$merge_state" in
        BRANCH_UNMERGED)
            if [ "$directory_state" = "WRONG_DIRECTORY" ]; then
                status_code="WRONG_DIRECTORY"
                status="HALT: pwd does not match expected_root ($expected_root)."
            else
                status_code="OK"
                status="OK"
            fi
            ;;
        BRANCH_MERGED_CLEAN)
            if [ "$directory_state" = "WRONG_DIRECTORY" ]; then
                status_code="WRONG_DIRECTORY"
                status="HALT: pwd does not match expected_root ($expected_root)."
            else
                status_code="BRANCH_MERGED_CLEAN"
                status="WARN: branch is fully merged with no drift. Proceed only if intentionally re-using a merged branch."
            fi
            ;;
        BRANCH_MERGED_WITH_DRIFT)
            status_code="BRANCH_MERGED_WITH_DRIFT"
            status="HALT: branch was merged in $merge_detail. Continuing risks piling onto an already-merged branch."
            ;;
        DETACHED_HEAD)
            status_code="DETACHED_HEAD"
            status="HALT: HEAD is detached. Check out a branch before running pipeline."
            ;;
        BRANCH_UNCLEAR)
            status_code="BRANCH_UNCLEAR"
            status="HALT: merge state is ambiguous. Resolve manually before proceeding."
            ;;
        *)
            status_code="UNKNOWN"
            status="HALT: merge state could not be determined."
            ;;
    esac

    cat <<EOF
=== Forge Preflight ===
pwd:                $cur_pwd
expected_root:      ${expected_root:-(not configured)}
directory_state:    $directory_state
branch:             $branch
base_ref:           $base_ref
merge_state:        $merge_state
merge_check_method: $merge_method
merge_check_detail: $merge_detail
host_session:       ${ID_host_session:-none}
target_session:     ${ID_target_session:-none}
identity_state:     ${ID_state:-UNAVAILABLE}
status:             $status
status_code:        $status_code
EOF
    return 0
}

cmd_add_note() {
    require_identity "add-note" host-session || return 1
    local note="$*"
    # Per-call session-scoped pointer (shadows the static global).
    local CONTEXT_FILE; CONTEXT_FILE="$(_context_file)"

    if [ -z "$note" ]; then
        echo "Usage: forge-bridge add-note <your note>"
        return 1
    fi

    if [ ! -f "$CONTEXT_FILE" ]; then
        echo "ERROR: No active context. Run set-context first."
        return 1
    fi

    python3 << PYEOF
import yaml

with open("$CONTEXT_FILE") as f:
    data = yaml.safe_load(f) or {}

notes = data.get("notes", [])
if isinstance(notes, list):
    notes.append("$note")
else:
    notes = ["$note"]
data["notes"] = notes

with open("$CONTEXT_FILE", "w") as f:
    yaml.dump(data, f, default_flow_style=False, sort_keys=False)

print("Note added.")
PYEOF
}

# ---- Stall Detection (Phase 1b) ----

# Cache and config locations.
FORGE_CACHE_DIR="${FORGE_CACHE_DIR:-$HOME/.cache/forge}"
FORGE_IDLE_PROMPTS_FILE="${FORGE_IDLE_PROMPTS_FILE:-$HOME/.config/forge/idle-prompts.yml}"

# Resolve project root. With $1 set (explicit --project-root arg), validate
# the path contains .claude/forge-project.yml. Without, walk up from cwd.
# Echoes the resolved absolute path on success; empty on failure.
_resolve_project_root() {
    local explicit="$1"
    if [ -n "$explicit" ]; then
        if [ -d "$explicit" ] && [ -f "$explicit/.claude/forge-project.yml" ]; then
            (cd "$explicit" && pwd -P)
            return 0
        fi
        return 1
    fi
    local _dir
    _dir="$(pwd -P)"
    while [ "$_dir" != "/" ]; do
        if [ -f "$_dir/.claude/forge-project.yml" ]; then
            (cd "$_dir" && pwd -P)
            return 0
        fi
        _dir=$(dirname "$_dir")
    done
    return 1
}

# stall-check — classify pane state per Phase 1b §2.1 gate.
# Tmux-required. Reads pane via capture-pane; writes per-pane snapshot to
# ~/.cache/forge/; writes signal via cmd_signal on STALLED/PROMPTING/
# COMPLETED-PENDING-LOG-RESPONSE/DEAD; never writes to .dev/forge-log.yml.
cmd_stall_check() {
    local project_root_arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --project-root) project_root_arg="$2"; shift 2 ;;
            --) shift; break ;;
            -*) echo "Unknown flag: $1" >&2; return 1 ;;
            *) break ;;
        esac
    done
    local target="$1"
    if [ -z "$target" ]; then
        echo "Usage: forge-bridge stall-check [--project-root <path>] <pane>" >&2
        return 1
    fi

    # §2.6: resolve project root and cd before any .dev/ access.
    local project_root
    project_root=$(_resolve_project_root "$project_root_arg")
    if [ -z "$project_root" ]; then
        echo "UNKNOWN no_project_root pane=$target"
        return 0
    fi
    cd "$project_root" || { echo "UNKNOWN cd_failed pane=$target"; return 0; }

    require_identity "stall-check" host-pane || return 1

    local canonical idx
    canonical=$(canonical_pane_name "$target")
    idx=$(pane_index "$target")

    # Pane existence check → DEAD signal.
    if ! tmux list-panes -t "$SESSION:$WINDOW" -F '#{pane_index}' 2>/dev/null | grep -qx "$idx"; then
        cmd_signal "stall-check" "DEAD pane=$canonical session=$SESSION" >/dev/null
        echo "DEAD pane=$canonical session=$SESSION"
        return 0
    fi

    mkdir -p "$FORGE_CACHE_DIR"
    local cache_file="$FORGE_CACHE_DIR/${SESSION}-pane${idx}.snapshot"
    local last_check_file="$FORGE_CACHE_DIR/${SESSION}-pane${idx}.last-stall-check"

    # Capture pane → temp file (avoids argv size limits on large scrollback).
    local raw_file
    raw_file=$(mktemp -t forge-stall-XXXXXX)
    tmux capture-pane -p -t "$SESSION:$WINDOW.$idx" -S -50 > "$raw_file" 2>/dev/null
    if [ ! -s "$raw_file" ]; then
        rm -f "$raw_file"
        echo "UNKNOWN capture_failed pane=$canonical"
        return 0
    fi

    # has_pending_log_for is internal; runs against $SUMMARY_LOG in cwd.
    local pending="false"
    if has_pending_log_for "$canonical" "$SESSION"; then
        pending="true"
    fi

    local threshold="${FORGE_STALL_THRESHOLD_S:-600}"
    local now
    now=$(date +%s)

    # Run the classifier. Outputs: STATE: <line> [\n SIGNAL: <payload>].
    local out
    out=$(python3 - "$raw_file" "$cache_file" "$last_check_file" "$pending" \
        "$threshold" "$now" "$canonical" "$FORGE_IDLE_PROMPTS_FILE" \
        "$SUMMARY_LOG" "$project_root" <<'PYEOF'
import sys, os, re, hashlib, yaml

(raw_file, cache_file, last_check_file, pending_str,
 threshold_s, now_s, canonical, prompts_file, summary_log, project_root) = sys.argv[1:11]
pending = (pending_str == "true")
threshold = int(threshold_s)
now = int(now_s)

with open(raw_file) as f:
    raw = f.read()

# V3 normalization rules (committed at verification/phase1b-step0/normalize/regex.yml).
strip_rules = [
    (r'\x1B\[[0-9;]*[A-Za-z]', ''),
    (r'\x1B\][0-9;]*\x07', ''),
    (r'^•\s+Working\s+\([^)]*\)(\s+·\s+.*)?$', '• Working (...)'),
    (r'^─\s+Worked\s+for\s+\d+m?\s*\d*s\s*─*$', '─ Worked for X ──'),
    (r'…\s*$', ''),
    (r'[⠀-⣿]+\s*$', ''),
    (r'\s+$', ''),
]
def normalize(text):
    out = text
    for pat, repl in strip_rules:
        out = re.sub(pat, repl, out, flags=re.MULTILINE)
    return out

# Regex tables from idle-prompts.yml. Missing/empty → UNKNOWN per §3 #3.
prompts = {}
try:
    with open(prompts_file) as f:
        prompts = yaml.safe_load(f) or {}
except (FileNotFoundError, yaml.YAMLError):
    prompts = {}

regex_set = (prompts.get(canonical) or {}) if isinstance(prompts, dict) else {}
idle_re_str = (regex_set.get('idle_prompt_anchor') or
               regex_set.get('idle_prompt') or '').strip()
prompting_re_str = (regex_set.get('approval_prompt') or '').strip()
active_re_str = (regex_set.get('active_work_marker') or '').strip()

idle_re = None
if idle_re_str:
    try:
        idle_re = re.compile(idle_re_str, re.MULTILINE)
    except re.error:
        idle_re = None

prompting_re = None
if prompting_re_str:
    try:
        prompting_re = re.compile(prompting_re_str, re.MULTILINE)
    except re.error:
        prompting_re = None

active_re = None
if active_re_str:
    try:
        active_re = re.compile(active_re_str, re.MULTILINE)
    except re.error:
        active_re = None

normalized = normalize(raw)
new_hash = hashlib.sha256(normalized.encode()).hexdigest()

def _drop_trailing_blanks(text):
    out = text.splitlines()
    while out and not out[-1].strip():
        out.pop()
    return out

raw_lines = _drop_trailing_blanks(raw)
norm_lines_stripped = _drop_trailing_blanks(normalized)
last5 = '\n'.join(raw_lines[-5:])
norm_last5 = '\n'.join(norm_lines_stripped[-5:])
norm_last30 = '\n'.join(norm_lines_stripped[-30:])
lines = raw.splitlines()  # PROMPTING excerpt scan uses raw lines.

# Look up pending entry meta (slug, stage) for signal payload enrichment.
ALIAS_TO_CANONICAL = {
    'inline': 'claude-opus', 'general': 'claude-opus', 'claude-general': 'claude-opus',
    'claude-opus': 'claude-opus', 'opus': 'claude-opus',
    'claude': 'claude', 'orchestrator': 'claude', 'claude-orchestrator': 'claude',
    'codex': 'codex-a', 'codex-a': 'codex-a',
    'codex-b': 'codex-b',
    'claude-sonnet': 'claude-sonnet', 'sonnet': 'claude-sonnet',
}
def alias_canonical(name):
    return ALIAS_TO_CANONICAL.get(name, name)

def lookup_pending_meta():
    try:
        with open(summary_log) as f:
            data = yaml.safe_load(f) or {}
    except (FileNotFoundError, yaml.YAMLError):
        return None, None
    for e in data.get('entries', []) or []:
        if e.get('response') is not None: continue
        if alias_canonical(e.get('to', '')) != canonical: continue
        return e.get('pipeline', ''), e.get('stage', '')
    return None, None

slug_meta, stage_meta = lookup_pending_meta()

cache = None
if os.path.exists(cache_file):
    try:
        with open(cache_file) as f:
            cache = yaml.safe_load(f) or {}
    except Exception:
        cache = None

def write_cache(c):
    with open(cache_file, 'w') as f:
        yaml.safe_dump(c, f, default_flow_style=False, sort_keys=False)

def touch_last_check():
    with open(last_check_file, 'w') as f:
        f.write(str(now))

def emit(state, extra="", signal_payload=None):
    line = f"{state} pane={canonical}"
    if extra:
        line += f" {extra}"
    print(f"STATE: {line}")
    if signal_payload:
        print(f"SIGNAL: {signal_payload}")
    touch_last_check()

def make_payload(state, **kv):
    parts = [f"{state} pane={canonical}"]
    if slug_meta: parts.append(f"slug={slug_meta}")
    if stage_meta: parts.append(f"stage={stage_meta}")
    for k, v in kv.items():
        parts.append(f"{k}={v}")
    return " ".join(parts)

# 1. PROMPTING — before any threshold (§2.3).
if prompting_re and prompting_re.search(raw):
    excerpt = ""
    for line in lines[::-1]:
        if prompting_re.search(line):
            excerpt = line.strip()[:100].replace('"', "'")
            break
    payload = make_payload("PROMPTING", excerpt=f'"{excerpt}"' if excerpt else 'none')
    emit("PROMPTING", f'excerpt="{excerpt}"' if excerpt else "", payload)
    sys.exit(0)

# 2. No cache → baseline (§2.2 explicit UNKNOWN, never ACTIVE).
if not cache:
    write_cache({'version': 1, 'hash': new_hash,
                 'last_changed_at': now, 'last_checked_at': now,
                 'last_signaled_state': '', 'last_signaled_at': 0,
                 'project_root': project_root})
    emit("UNKNOWN", "baseline_pending")
    sys.exit(0)

# Project-root mismatch → wipe and rebaseline (§2.6 self-heal).
if cache.get('project_root') and cache.get('project_root') != project_root:
    write_cache({'version': 1, 'hash': new_hash,
                 'last_changed_at': now, 'last_checked_at': now,
                 'last_signaled_state': '', 'last_signaled_at': 0,
                 'project_root': project_root})
    emit("UNKNOWN", "project_root_mismatch_rebased")
    sys.exit(0)

# Version mismatch → wipe and rebaseline.
if cache.get('version') != 1:
    write_cache({'version': 1, 'hash': new_hash,
                 'last_changed_at': now, 'last_checked_at': now,
                 'last_signaled_state': '', 'last_signaled_at': 0,
                 'project_root': project_root})
    emit("UNKNOWN", "version_mismatch_rebased")
    sys.exit(0)

# 3. No pending dispatch → IDLE. By construction never STALLED (§2.1 gate).
if not pending:
    if new_hash != cache.get('hash'):
        cache.update(hash=new_hash, last_changed_at=now, last_checked_at=now)
    else:
        cache['last_checked_at'] = now
    write_cache(cache)
    emit("IDLE")
    sys.exit(0)

# 4. Pending exists. Idle-regex availability pre-check (§3 #3 — never permissive).
if not idle_re:
    cache['last_checked_at'] = now
    write_cache(cache)
    emit("UNKNOWN", "reason=idle_regex_unavailable")
    sys.exit(0)

# Phase 2: Claude panes require active_work_marker negative gate (§3 #3).
CLAUDE_WORKERS = {'claude-opus', 'claude-sonnet'}
if canonical in CLAUDE_WORKERS and not active_re:
    cache['last_checked_at'] = now
    write_cache(cache)
    emit("UNKNOWN", "reason=active_work_marker_unavailable")
    sys.exit(0)

# 5. Hash changed → real activity.
if new_hash != cache.get('hash'):
    cache.update(hash=new_hash, last_changed_at=now, last_checked_at=now,
                 last_signaled_state='', last_signaled_at=0)
    write_cache(cache)
    elapsed = now - cache['last_changed_at']
    emit("ACTIVE", f"elapsed={elapsed}s")
    sys.exit(0)

elapsed = now - cache.get('last_changed_at', now)

# Phase 2: ACTIVE-via-active_work_marker. This must precede COMPLETED-PENDING
# because Claude's model status line is visible during work and matches the
# idle anchor; the active marker is the discriminator.
if active_re and active_re.search(norm_last30):
    cache.update(hash=new_hash, last_changed_at=now, last_checked_at=now,
                 last_signaled_state='', last_signaled_at=0)
    write_cache(cache)
    elapsed = now - cache['last_changed_at']
    emit("ACTIVE", f"elapsed={elapsed}s")
    sys.exit(0)

# 6. Hash unchanged AND idle regex matches normalized tail → COMPLETED-PENDING-LOG-RESPONSE.
if idle_re.search(norm_last5):
    payload = make_payload("COMPLETED-PENDING-LOG-RESPONSE",
                           hint=f'"run forge-bridge log-response --to {canonical} from pane scrollback"')
    cache.update(last_checked_at=now,
                 last_signaled_state='COMPLETED-PENDING-LOG-RESPONSE',
                 last_signaled_at=now)
    write_cache(cache)
    emit("COMPLETED-PENDING-LOG-RESPONSE", "", payload)
    sys.exit(0)

# 7. Hash unchanged + no idle match + elapsed >= threshold → STALLED (idempotent).
if elapsed >= threshold:
    last_signaled_at = cache.get('last_signaled_at', 0) or 0
    last_changed_at = cache.get('last_changed_at', 0) or 0
    signal_payload = None
    if cache.get('last_signaled_state') != 'STALLED' or last_signaled_at < last_changed_at:
        signal_payload = make_payload("STALLED",
            elapsed=f"{elapsed}s",
            last_change=last_changed_at,
            reason="no-output-with-pending-dispatch")
        cache['last_signaled_state'] = 'STALLED'
        cache['last_signaled_at'] = now
    cache['last_checked_at'] = now
    write_cache(cache)
    emit("STALLED", f"elapsed={elapsed}s", signal_payload)
    sys.exit(0)

# 8. Hash unchanged + below threshold → ACTIVE (waiting). Don't bump last_changed_at.
cache['last_checked_at'] = now
write_cache(cache)
emit("ACTIVE", f"elapsed={elapsed}s")
PYEOF
)
    rm -f "$raw_file"

    local state_line signal_payload
    state_line=$(echo "$out" | grep '^STATE: ' | sed 's/^STATE: //' | head -1)
    signal_payload=$(echo "$out" | grep '^SIGNAL: ' | sed 's/^SIGNAL: //' | head -1)

    if [ -n "$signal_payload" ]; then
        cmd_signal "stall-check" "$signal_payload" >/dev/null
    fi

    if [ -n "$state_line" ]; then
        echo "$state_line"
    else
        echo "UNKNOWN classifier_failed pane=$canonical"
    fi
}

# stall-check-status — no-tmux self-check for stale stall-check coverage.
# Reads pending entries from $SUMMARY_LOG, filters by current session,
# checks last-stall-check timestamp per pane, prints WARN block to stdout
# when stale entries exist. Empty output when healthy.
cmd_stall_check_status() {
    local project_root_arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --project-root) project_root_arg="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local project_root
    project_root=$(_resolve_project_root "$project_root_arg")
    [ -z "$project_root" ] && return 0
    cd "$project_root" || return 0

    local threshold="${FORGE_STALL_THRESHOLD_S:-600}"

    # Resolve current session via the unified resolver (env / tmux / guarded
    # walk-up). Empty -> the python filter treats every entry as same-session
    # (over-warn, the safe direction on an ambiguous host).
    local current_session
    current_session="$(_resolve_session)"

    python3 - "$SUMMARY_LOG" "$FORGE_CACHE_DIR" "$current_session" "$threshold" "$project_root" <<'PYEOF'
import sys, os, time, yaml

summary_log, cache_dir, current_session, threshold_s, project_root = sys.argv[1:6]
threshold = int(threshold_s)
now = int(time.time())
stale_threshold = 2 * threshold

ALIAS_TO_CANONICAL = {
    'inline': 'claude-opus', 'general': 'claude-opus', 'claude-general': 'claude-opus',
    'claude-opus': 'claude-opus', 'opus': 'claude-opus',
    'claude': 'claude', 'orchestrator': 'claude', 'claude-orchestrator': 'claude',
    'codex': 'codex-a', 'codex-a': 'codex-a',
    'codex-b': 'codex-b',
    'claude-sonnet': 'claude-sonnet', 'sonnet': 'claude-sonnet',
}
def canonical(name): return ALIAS_TO_CANONICAL.get(name, name)

NAME_TO_IDX = {'claude-opus': 0, 'claude': 1, 'codex-a': 2, 'codex-b': 3, 'claude-sonnet': 4}

try:
    with open(summary_log) as f:
        data = yaml.safe_load(f) or {}
except (FileNotFoundError, yaml.YAMLError):
    sys.exit(0)

warnings = []
for entry in data.get('entries', []) or []:
    if entry.get('response') is not None:
        continue
    target = canonical(entry.get('to', ''))
    idx = NAME_TO_IDX.get(target)
    if idx is None:
        continue
    entry_session = entry.get('session', '')
    if entry_session and current_session and entry_session != current_session:
        continue  # different session; skip silently
    legacy = not bool(entry_session)
    session_for_cache = current_session or entry_session or 'unknown'
    last_check_file = os.path.join(cache_dir, f"{session_for_cache}-pane{idx}.last-stall-check")
    age = None
    if os.path.exists(last_check_file):
        try:
            age = now - int(open(last_check_file).read().strip())
        except Exception:
            age = None
    if age is None or age > stale_threshold:
        slug = entry.get('pipeline', '?')
        stage = entry.get('stage', '?')
        ago = f"{age // 60}m" if age is not None else "never"
        legacy_note = " (legacy entry, no session field)" if legacy else ""
        cmd = f"~/bin/forge-bridge stall-check --project-root \"{project_root}\" {target}"
        warnings.append((target, slug, stage, ago, legacy_note, cmd))

if warnings:
    print("=== Stall Check Status ===")
    for (target, slug, stage, ago, legacy_note, cmd) in warnings:
        print(f"WARN: {target} has pending dispatch (slug={slug}, stage={stage})")
        print(f"      stall-check has not run in {ago}.{legacy_note}")
        print(f"      Run: {cmd}")
PYEOF
}

cmd_alias_self_test() {
    local STRICT=false
    if [ "${1:-}" = "--strict" ]; then
        STRICT=true
        shift
    fi

    python3 - "$0" "$STRICT" <<'PYEOF'
import re, sys

bridge = sys.argv[1]
strict = (sys.argv[2] == 'true')
with open(bridge) as f:
    src = f.read()

pane_index_block = re.search(r'pane_index\(\)\s*\{(.*?)\n\}', src, re.DOTALL)
pane_name_block = re.search(r'pane_name\(\)\s*\{(.*?)\n\}', src, re.DOTALL)
problems = []
if not pane_index_block:
    problems.append("missing pane_index() block")
if not pane_name_block:
    problems.append("missing pane_name() block")
if problems:
    for p in problems:
        print(f"alias-self-test: {p}", file=sys.stderr)
    sys.exit(1)

m_idx = {}
for line in pane_index_block.group(1).splitlines():
    mm = re.match(r'\s+(\S+)\)\s*echo\s*"(\d+|\$1)"', line)
    if not mm:
        continue
    if mm.group(2) == '$1':
        continue
    for alias in mm.group(1).split('|'):
        m_idx[alias] = int(mm.group(2))

m_name = {}
for line in pane_name_block.group(1).splitlines():
    mm = re.match(r'\s+(\d+)\)\s*echo\s*"([^"]+)"', line)
    if mm:
        m_name[int(mm.group(1))] = mm.group(2)

expected_canonical = {alias: m_name[idx] for alias, idx in m_idx.items() if idx in m_name}
if strict and len(expected_canonical) < 7:
    print(f"alias-self-test: STRICT FAIL — parser found {len(expected_canonical)} aliases, expected >=7", file=sys.stderr)
    sys.exit(2)

py_maps = re.findall(r"ALIAS_TO_CANONICAL\s*=\s*\{([^}]+)\}", src)
if strict and len(py_maps) < 4:
    print(f"alias-self-test: STRICT FAIL — parser found {len(py_maps)} ALIAS_TO_CANONICAL maps, expected >=4", file=sys.stderr)
    sys.exit(2)

for i, py_map in enumerate(py_maps):
    pairs = re.findall(r"'([^']+)':\s*'([^']+)'", py_map)
    py_canon = dict(pairs)
    for alias, canonical in expected_canonical.items():
        if alias not in py_canon:
            problems.append(f"map#{i}: missing alias '{alias}'")
        elif py_canon[alias] != canonical:
            problems.append(f"map#{i}: '{alias}' bash='{canonical}' python='{py_canon[alias]}'")

name_to_idx_match = re.search(r"NAME_TO_IDX\s*=\s*\{([^}]+)\}", src)
if not name_to_idx_match:
    problems.append("NAME_TO_IDX missing")
else:
    pairs = re.findall(r"'([^']+)':\s*(\d+)", name_to_idx_match.group(1))
    name_to_idx = dict(pairs)
    for canonical in set(expected_canonical.values()):
        if canonical not in name_to_idx:
            problems.append(f"NAME_TO_IDX missing '{canonical}'")

if problems:
    for p in problems:
        print(f"alias-self-test: {p}", file=sys.stderr)
    sys.exit(1)

print(f"alias-self-test: OK ({len(expected_canonical)} aliases verified, {len(py_maps)} maps checked)")
PYEOF
}

cmd_health() {
    # Per-pane health check. For each canonical pane in the active forge
    # session, verify the pane exists and capture-pane output indicates the
    # expected worker process is running. Exits 0 only if every pane is OK.
    #
    # Output: one line per pane, machine-parseable:
    #   OK pane=<name> idx=<n> kind=<claude|codex> state=<idle|busy|prompting>
    #   DEAD pane=<name> idx=<n>
    #   WRONG_PROCESS pane=<name> idx=<n> expected=<kind> got=<shell|other|empty>
    #   UNKNOWN pane=<name> idx=<n> reason=<capture_failed|...>
    #
    # Followed by a one-line summary: SUMMARY total=5 ok=N dead=N wrong=N unknown=N

    require_identity "health" diagnostic
    _print_identity_block

    local tmpdir
    tmpdir=$(mktemp -d -t forge-health-XXXXXX)
    trap 'rm -rf "$tmpdir"' RETURN

    # Expected (canonical_name, idx, kind) tuples.
    # kind is 'claude' or 'codex' — matched against idle-prompts.yml regex tables.
    local specs=(
        "claude-opus:0:claude-opus"
        "claude:1:claude-opus"
        "codex-a:2:codex-a"
        "codex-b:3:codex-b"
        "claude-sonnet:4:claude-sonnet"
    )

    local existing_idxs
    existing_idxs=$(tmux list-panes -t "$SESSION:$WINDOW" -F '#{pane_index}' 2>/dev/null | tr '\n' ' ')

    local ok=0 dead=0 wrong=0 unknown=0
    local spec name idx kind raw_file out
    for spec in "${specs[@]}"; do
        name="${spec%%:*}"
        local rest="${spec#*:}"
        idx="${rest%%:*}"
        kind="${rest##*:}"

        if ! echo " $existing_idxs " | grep -q " $idx "; then
            echo "DEAD pane=$name idx=$idx"
            dead=$((dead+1))
            continue
        fi

        raw_file="$tmpdir/pane-$idx.txt"
        tmux capture-pane -p -t "$SESSION:$WINDOW.$idx" -S -50 > "$raw_file" 2>/dev/null
        if [ ! -s "$raw_file" ]; then
            echo "UNKNOWN pane=$name idx=$idx reason=capture_failed"
            unknown=$((unknown+1))
            continue
        fi

        out=$(python3 - "$raw_file" "$kind" "$FORGE_IDLE_PROMPTS_FILE" <<'PYEOF'
import sys, re, yaml

raw_file, expected_kind, prompts_file = sys.argv[1], sys.argv[2], sys.argv[3]

with open(raw_file) as f:
    raw = f.read()

# Same V3 normalization the stall classifier uses.
strip_rules = [
    (r'\x1B\[[0-9;]*[A-Za-z]', ''),
    (r'\x1B\][0-9;]*\x07', ''),
    (r'^•\s+Working\s+\([^)]*\)(\s+·\s+.*)?$', '• Working (...)'),
    (r'^─\s+Worked\s+for\s+\d+m?\s*\d*s\s*─*$', '─ Worked for X ──'),
    (r'…\s*$', ''),
    (r'[⠀-⣿]+\s*$', ''),
    (r'\s+$', ''),
]
def normalize(text):
    out = text
    for pat, repl in strip_rules:
        out = re.sub(pat, repl, out, flags=re.MULTILINE)
    return out

norm = normalize(raw)
lines = [ln for ln in norm.splitlines() if ln.strip() != '']
tail = lines[-25:] if lines else []
tail_text = '\n'.join(tail)

try:
    with open(prompts_file) as f:
        prompts = yaml.safe_load(f) or {}
except (FileNotFoundError, yaml.YAMLError):
    print(f"UNKNOWN reason=prompts_file_missing")
    sys.exit(0)

cfg = prompts.get(expected_kind) or {}
idle_re = cfg.get('idle_prompt_anchor') or ''
active_re = cfg.get('active_work_marker') or ''
approval_re = cfg.get('approval_prompt') or ''

def any_match(pattern, text):
    if not pattern:
        return False
    try:
        return re.search(pattern, text, re.MULTILINE) is not None
    except re.error:
        return False

# Detect the broad family. Claude panes show '━' bordered prompt; codex
# panes show 'gpt-X.X' header. Look for ANY claude/codex idle anchor across
# all known kinds, then compare against the expected one.
all_idle = {}
all_active = {}
for k, v in (prompts or {}).items():
    if not isinstance(v, dict):
        continue
    all_idle[k] = v.get('idle_prompt_anchor') or ''
    all_active[k] = v.get('active_work_marker') or ''

detected_kind = None
for k, pat in all_idle.items():
    if any_match(pat, tail_text):
        detected_kind = k
        break
if detected_kind is None:
    for k, pat in all_active.items():
        if any_match(pat, tail_text):
            detected_kind = k
            break

if detected_kind is None:
    # No worker prompts detected. Heuristic for raw shell.
    last = tail[-1] if tail else ''
    shellish = bool(re.search(r'[\$%#>]\s*$', last)) or 'bash-' in last or last.endswith('$')
    if shellish:
        print(f"WRONG_PROCESS got=shell")
    else:
        print(f"UNKNOWN reason=no_marker_match")
    sys.exit(0)

# Normalize family: claude-opus/claude-sonnet → claude, codex-a/codex-b → codex
def family(k):
    if k.startswith('claude'): return 'claude'
    if k.startswith('codex'):  return 'codex'
    return k

if family(detected_kind) != family(expected_kind):
    print(f"WRONG_PROCESS got={detected_kind}")
    sys.exit(0)

# Right family. Determine state.
state = 'idle'
if any_match(active_re, tail_text):
    state = 'busy'
elif any_match(approval_re, tail_text):
    state = 'prompting'
elif any_match(idle_re, tail_text):
    state = 'idle'
else:
    state = 'unknown'

print(f"OK kind={family(detected_kind)} state={state}")
PYEOF
)
        case "$out" in
            OK*)            echo "OK pane=$name idx=$idx ${out#OK }"; ok=$((ok+1)) ;;
            WRONG_PROCESS*) echo "WRONG_PROCESS pane=$name idx=$idx expected=$kind ${out#WRONG_PROCESS }"; wrong=$((wrong+1)) ;;
            *)              echo "UNKNOWN pane=$name idx=$idx ${out#UNKNOWN }"; unknown=$((unknown+1)) ;;
        esac
    done

    echo "SUMMARY total=5 ok=$ok dead=$dead wrong=$wrong unknown=$unknown session=$SESSION identity_state=${ID_state:-UNAVAILABLE}"

    if [ "$ok" -eq 5 ]; then
        return 0
    fi
    return 1
}

# identity — print ONLY the descriptor block; documented exit code. NO --export, NO
# eval-able output. Exit 0 = MATCH / CROSS_SESSION_DECLARED; exit 3 = MISMATCH /
# AMBIGUOUS / UNAVAILABLE.
cmd_identity() {
    require_identity "identity" diagnostic
    _print_identity_block
    case "${ID_state:-}" in
        MATCH|CROSS_SESSION_DECLARED) return 0 ;;
        *) return 3 ;;
    esac
}

# ---- Global cross-session flags (session-pin hardening P1.6) ----
# PROCESS-LOCAL, NEVER exported → authorization cannot be inherited by a nested bridge
# call, and an in-pane orchestrator cannot acquire the bypass from its session env.
# Stripped from ANYWHERE in argv before the subcommand. --target-session without
# --cross-session is always a usage error.
_FORGE_TARGET=""; _FORGE_CROSS=0; _FORGE_TARGET_ROOT=""
_fb_argv=()
while [ $# -gt 0 ]; do
    case "$1" in
        --target-session) _FORGE_TARGET="$2"; shift 2 ;;
        --cross-session)  _FORGE_CROSS=1; shift ;;
        --target-root)    _FORGE_TARGET_ROOT="$2"; shift 2 ;;
        *) _fb_argv+=("$1"); shift ;;
    esac
done
set -- ${_fb_argv[@]+"${_fb_argv[@]}"}
if [ -n "$_FORGE_TARGET" ] && [ "$_FORGE_CROSS" != "1" ]; then
    echo "ERROR: --target-session requires --cross-session (cross-session routing must be explicitly declared)." >&2
    exit 2
fi
if [ "$_FORGE_CROSS" = "1" ]; then
    case "${1:-}" in
        send|callback) ;;
        *) echo "ERROR: --cross-session is only valid for 'send' and 'callback' (got '${1:-}')." >&2; exit 2 ;;
    esac
fi

# ---- Main ----

case "${1:-help}" in
    send)            shift
                     # Strip a caller-supplied private bypass flag: only the in-process
                     # dispatch delivery (cmd_send --_internal, which never traverses the
                     # router) may set it. A top-level `send --_internal` must NOT bypass.
                     _sa=(); for _a in "$@"; do [ "$_a" = "--_internal" ] || _sa+=("$_a"); done
                     cmd_send ${_sa[@]+"${_sa[@]}"} ;;
    read)            shift; cmd_read "$@" ;;
    focus)           shift; cmd_focus "$@" ;;
    back)            cmd_back ;;
    signal)          shift; cmd_signal "$@" ;;
    check-signals)   cmd_check_signals ;;
    clear-signals)   cmd_clear_signals ;;
    review-status)   cmd_review_status ;;
    log)             shift; cmd_log "$@" ;;
    log-response)    shift; cmd_log_response "$@" ;;
    history)         shift; cmd_history "$@" ;;
    pipeline-log)    shift; cmd_pipeline_log "$@" ;;
    context)         cmd_context ;;
    set-context)     shift; cmd_set_context "$@" ;;
    add-note)        shift; cmd_add_note "$@" ;;
    usage)           shift; cmd_usage "$@" ;;
    preflight)       cmd_preflight ;;
    status)          shift; cmd_status "$@" ;;
    dispatch)        shift; cmd_dispatch "$@" ;;
    callback)        shift; cmd_callback "$@" ;;
    callback-consume) shift; cmd_callback_consume "$@" ;;
    park)            shift; cmd_park "$@" ;;
    blocked-audit)   shift; cmd_blocked_audit "$@" ;;
    infra-lock)      shift; cmd_infra_lock "$@" ;;
    wait)            shift; cmd_wait "$@" ;;
    digest)          shift; cmd_digest "$@" ;;
    emit)            shift; cmd_emit "$@" ;;
    stall-check)         shift; cmd_stall_check "$@" ;;
    stall-check-status)  shift; require_identity "stall-check-status" host-degrade || true; cmd_stall_check_status "$@" ;;
    alias-self-test)     shift; cmd_alias_self_test "$@" ;;
    identity)            cmd_identity ;;
    health)              cmd_health ;;
    help|*)
        echo "forge-bridge — cross-pane messaging with hooks and audit log"
        echo ""
        echo "Tmux-required commands (operate on panes; need an active forge session):"
        echo "  send <pane> <message>         Send to a pane (enforces per-target log-before-send)"
        echo "  send --force <pane> <message>  Bypass log check (non-pipeline messages)"
        echo "  read <pane> [lines]           Read last N lines from a pane"
        echo "  focus <pane>                  Switch focus to a pane"
        echo "  back                          Return focus to orchestrator"
        echo "  dispatch --slug <s> --stage <s> --worker <w> [--clear] [--dry-run]"
        echo "                                Render stage prompt from ~/.config/forge/prompts/, write, log, send"
        echo "  wait --slug <s> --stage <s> --worker <w> [--timeout <s>] [--digest-template <name>]"
        echo "                                Block until callback or stall; emit one structured block"
        echo "  stall-check [--project-root <p>] <pane>"
        echo "                                Classify pane state (IDLE/ACTIVE/STALLED/PROMPTING/COMPLETED-PENDING-LOG-RESPONSE/DEAD/UNKNOWN)"
        echo "  health                        Verify all 5 panes exist and run expected worker process; exits 0 only if all OK"
        echo ""
        echo "No-tmux commands (file-based; work from any directory, with or without a session):"
        echo "  preflight                     Print kickoff snapshot (pwd, branch, merge state, halt status)"
        echo "  signal <from> <message>       Write a signal file to .dev/signals/"
        echo "  check-signals                 List pending signals"
        echo "  clear-signals                 Remove all signal files"
        echo "  review-status                 Show pending/completed review counts and blocking items"
        echo "  log --slug <s> --stage <s> --from <f> --to <t> --prompt <p>"
        echo "                                Log a dispatch entry"
        echo "  history [lines]               Show project-wide summary"
        echo "  pipeline-log <slug> [lines]   Show per-pipeline detail"
        echo "  status                        Render and print .dev/forge-status.md (human-readable rolling summary)"
        echo "  context                       Show current pipeline state"
        echo "  set-context --slug <s>        Set active pipeline (auto-derives state)"
        echo "  add-note <text>               Add a note to context (persists across sessions)"
        echo "  usage [<worker>]              Show per-worker usage snapshot (read-only; from forge-usage.<session>.yml)"
        echo "  identity                      Print host/target identity descriptor; exit 0 (MATCH/CROSS) or 3 (MISMATCH/AMBIGUOUS/UNAVAILABLE)"
        echo "  stall-check-status [--project-root <p>]"
        echo "                                List panes with pending dispatch and stale stall-check coverage"
        echo "  alias-self-test [--strict]    Verify pane alias maps stay in lockstep"
        echo "  log-response --slug <s> --response <r> [--to <pane>] [--stage <stage>] [--file <path:action>]..."
        echo "                                Update a pending entry; --to disambiguates when multiple pending"
        echo "  callback --slug <s> --stage <s> --status <DONE|BLOCKED|ERROR> [--message <m>] [--worker <w>] [--quiet]"
        echo "                                Worker-side declarative completion: writes callback file, auto-logs, notifies orchestrator (--quiet suppresses notification)"
        echo "                                Terminal DONE/ERROR closes the pending FIRST then publishes atomically; non-terminal BLOCKED keeps the pending open"
        echo "  callback-consume --slug <s> --stage <s> [--status BLOCKED]"
        echo "                                Archive a consumed non-terminal (BLOCKED) callback AFTER a send --force continuation; structured no-op if none. See infra-lock Shape A."
        echo "  park --slug <s> --stage <s> --reason <text> [--worker <w>] [--uncommitted]"
        echo "                                Park an open BLOCKED item: keeps the pending open, writes a durable parked record, flips the callback to PARKED. Use 'park --resolve --slug <s> --stage <s> [--note <text>]' to close a parked item."
        echo "  blocked-audit [--root <path>] [--json]"
        echo "                                Read-only audit of BLOCKED/PARKED callbacks, half-parked records, duplicate open pendings, and stale state keys. MUTATES NOTHING."
        echo "  infra-lock <acquire|release|status> --slug <s> --stage <t> [--timeout N] [--interval I] [--force]"
        echo "                                Cross-worktree mutex for infra stages {coding,qa,qa-fix,qa-retry,verify}. acquire blocks (default ${FORGE_INFRA_LOCK_TIMEOUT_S:-1800}s ceiling, ${FORGE_INFRA_LOCK_INTERVAL_S:-15}s poll); release on stage terminality; status reports FREE/HELD/STALE/foreign."
        echo "  digest --slug <s> --stage <s> --template <name> [--worker <w>]"
        echo "                                Render digest prompt to .dev/forge-tmp/ for ad-hoc Agent dispatch"
        echo "  emit <TYPE> --slug <s> [--stage <s>] [key=value …]"
        echo "                                Orchestrator-driven heartbeat emit (TYPE: DISPATCH|WAIT|CALLBACK|DIGEST|STAGE|STALL|ERROR|COMPLETE|USAGE)"
        echo ""
        echo "Panes: claude-opus/opus/inline/general (0), claude/orchestrator/claude-orchestrator (1), codex/codex-a (2), codex-b (3), claude-sonnet/sonnet (4)"
        echo ""
        echo "Hooks (automatic):"
        echo "  - send blocks unless a pending log entry targets the same pane (per-target check)"
        echo "  - log-response auto-updates forge-context.yml (qa/qa-fix/qa-retry are orchestrator-decided)"
        echo "  - require_pane_count validates pane count at every tmux session entry point"
        echo "  - preflight halts on BRANCH_MERGED_WITH_DRIFT / WRONG_DIRECTORY / DETACHED_HEAD / BRANCH_UNCLEAR"
        ;;
esac
