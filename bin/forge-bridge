#!/bin/bash
# ============================================================
# forge-bridge — cross-pane messaging with hooks and audit log
# ============================================================
#
# Auto-detects which tmux session you're in.
# Falls back to .dev/.forge-session file, then scans for forge sessions.
#
# Pane layout:
#   0 = claude-opus worker      TOP-LEFT
#   1 = claude orchestrator     BOTTOM-LEFT
#   2 = codex A                 TOP-RIGHT
#   3 = codex B                 MIDDLE-RIGHT
#   4 = claude-sonnet worker    BOTTOM-RIGHT
#
# Hooks (enforced by the script, not by skills):
#   1. send refuses to dispatch unless a pending log entry targets the same pane
#      (per-target log-before-send; alias-normalized so historical `to: inline`
#      entries resolve to the canonical `claude-opus` pane-0 worker name and
#      historical `to: claude` entries match the canonical `claude` orchestrator name)
#   2. log-response auto-updates .dev/forge-context.yml on completion
#      (qa, qa-fix, qa-retry do NOT auto-advance — orchestrator decides)
#   3. context command loads pipeline state for session start
#   4. require_pane_count validates pane count at every tmux session entry point
#
# Tmux-required commands (operate on panes):
#   send <pane> <message>       — type into a pane (per-target log-before-send hook)
#   send --force <pane> <msg>   — bypass log check (for non-pipeline messages / callbacks)
#   read <pane> [lines]         — read from a pane
#   focus <pane>                — switch focus to a pane
#   back                        — return focus to orchestrator
#
# No-tmux commands (file-based; work from any directory):
#   preflight                   — kickoff snapshot: pwd, branch, merge state, halt code
#   signal <from> <message>     — file-based signal
#   check-signals               — list pending signals
#   clear-signals               — remove all signal files
#   review-status               — commit-review verdict counts
#   log --slug <s> --stage <s> --from <f> --to <t> --prompt <p>
#   log-response --slug <s> --response <r> [--file <path:action>]...
#   history [lines]             — project-wide summary
#   pipeline-log <slug> [lines] — per-pipeline detail
#   context                     — load current pipeline state (for session start)
#   set-context --slug <s>      — manually set the active pipeline
#   add-note <text>             — annotate context (persists across sessions)
#   alias-self-test [--strict]  — verify pane alias maps stay in lockstep
#
# Pane names: inline/general/claude-opus/opus (0), claude/orchestrator/claude-orchestrator (1),
#             codex/codex-a (2), codex-b (3), claude-sonnet/sonnet (4)
# ============================================================

# --- Session-independent globals (no tmux required) ---

WINDOW="0"
DEV_DIR=".dev"
SUMMARY_LOG="$DEV_DIR/forge-log.yml"
CONTEXT_FILE="$DEV_DIR/forge-context.yml"
SESSION=""   # populated by require_tmux_session() for tmux-required commands

# Required pane count (Phase 2: 5 panes)
FORGE_REQUIRED_PANES="${FORGE_REQUIRED_PANES:-5}"

# --- Session Detection (called explicitly by tmux-required commands) ---

require_pane_count() {
    local s="$1"
    local required="${2:-$FORGE_REQUIRED_PANES}"
    local count
    count=$(tmux list-panes -t "$s" 2>/dev/null | wc -l | tr -d ' ')
    if [ "$count" -lt "$required" ]; then
        cat >&2 <<EOF
ERROR: Forge session '$s' has $count panes (need $required).
       This session is pre-Phase-2 (4-pane). Migration required:
         1. Pause or complete the current pipeline stage
         2. tmux kill-session -t $s
         3. rm -f ~/.cache/forge/${s}-pane*.snapshot ~/.cache/forge/${s}-pane*.last-stall-check
         4. forge-start
         5. ~/bin/forge-bridge context && type 'forge-resume' to the orchestrator
EOF
        return 1
    fi
    return 0
}

require_tmux_session() {
    local cmd="${1:-(unknown)}"

    # Resolution order:
    #   1. TMUX_SESSION env (explicit override)
    #   2. tmux display-message — ONLY if we're inside tmux ($TMUX set)
    #   3. .dev/.forge-session walk-up from cwd
    #   4. Auto-pick a forge-* session with the required pane count
    # Outside tmux, `tmux display-message` returns the most-recently-attached
    # session globally, which is unrelated to cwd. Skip step 2 in that case so
    # cwd-rooted invocations (Claude Code agents, cron, headless scripts) route
    # to the correct session via .dev/.forge-session.
    SESSION="${TMUX_SESSION:-}"
    if [ -z "$SESSION" ] && [ -n "${TMUX:-}" ]; then
        SESSION="$(tmux display-message -p '#{session_name}' 2>/dev/null)"
    fi

    # Fallback 1: read session name from .dev/.forge-session (written by forge-start)
    local _session_source=""
    if [ -n "$SESSION" ]; then
        _session_source="env-or-tmux"
    fi
    if [ -z "$SESSION" ]; then
        local _dir _session_file=""
        _dir="$(pwd)"
        while [ "$_dir" != "/" ]; do
            if [ -f "$_dir/.dev/.forge-session" ]; then
                SESSION=$(cat "$_dir/.dev/.forge-session")
                _session_file="$_dir/.dev/.forge-session"
                _session_source="forge-session-file"
                break
            fi
            _dir=$(dirname "$_dir")
        done
        # If .dev/.forge-session resolved a name, validate the session exists
        # before falling through to auto-detect — stale files used to silently
        # misroute callers to a random forge-* session.
        if [ -n "$SESSION" ] && ! tmux has-session -t "$SESSION" 2>/dev/null; then
            cat >&2 <<EOF
ERROR: .dev/.forge-session refers to tmux session '$SESSION' but no such session exists.
       File: $_session_file
       Either delete the stale file (rm "$_session_file") or run forge-start to (re)create the session.
EOF
            return 1
        fi
    fi

    # Fallback 2: auto-detect a forge session with the required pane count.
    # Refuse-if-ambiguous: only auto-pick when exactly one forge-* session has
    # the required pane count. Picking arbitrarily when many candidates exist
    # is what made the orchestrator wander into other users' sessions.
    if [ -z "$SESSION" ]; then
        local _candidates _ncand
        _candidates=$(tmux list-sessions -F '#{session_name}' 2>/dev/null \
            | grep '^forge' \
            | while read -r s; do
                local panes
                panes=$(tmux list-panes -t "$s" 2>/dev/null | wc -l | tr -d ' ')
                if [ "$panes" -ge "$FORGE_REQUIRED_PANES" ]; then echo "$s"; fi
              done)
        _ncand=$(printf '%s\n' "$_candidates" | grep -c '^forge' || true)
        if [ "$_ncand" -gt 1 ]; then
            {
                echo "ERROR: multiple forge sessions present — refuse to auto-pick for command '$cmd'."
                echo "Candidates with >= $FORGE_REQUIRED_PANES panes:"
                printf '%s\n' "$_candidates" | sed 's/^/  /'
                echo "Resolve by either:"
                echo "  - export TMUX_SESSION=<name>   (explicit override)"
                echo "  - run from a project dir containing .dev/.forge-session"
            } >&2
            return 1
        fi
        if [ "$_ncand" -eq 1 ]; then
            SESSION="$_candidates"
            _session_source="auto-detect-sole-candidate"
        fi
    fi

    if [ -z "$SESSION" ]; then
        echo "ERROR: command '$cmd' requires a tmux forge session. Run forge-start first." >&2
        return 1
    fi

    # Validate pane count at every entry point, not just the auto-scan fallback
    require_pane_count "$SESSION" "$FORGE_REQUIRED_PANES" || return 1
    return 0
}

# ---- Helpers ----

# Alias maps must stay in lockstep across:
#   - pane_index() / pane_name()
#   - every inline Python ALIAS_TO_CANONICAL map in this file
#   - cmd_stall_check_status NAME_TO_IDX
#   - cmd_send worker allowlist
# Run `~/bin/forge-bridge alias-self-test --strict` after edits.
pane_index() {
    case "$1" in
        inline|general|claude-general|claude-opus|opus) echo "0" ;;
        claude|orchestrator|claude-orchestrator)        echo "1" ;;
        codex|codex-a)                                  echo "2" ;;
        codex-b)                                        echo "3" ;;
        claude-sonnet|sonnet)                           echo "4" ;;
        *)                                              echo "$1" ;;
    esac
}

pane_name() {
    case "$1" in
        0) echo "claude-opus" ;;
        1) echo "claude" ;;
        2) echo "codex-a" ;;
        3) echo "codex-b" ;;
        4) echo "claude-sonnet" ;;
        *) echo "pane-$1" ;;
    esac
}

timestamp() {
    date -u +"%Y-%m-%dT%H:%M:%SZ"
}

ensure_pipeline_log() {
    local slug="$1"
    local dir="$DEV_DIR/proposals/$slug"
    local log="$dir/forge-log.yml"
    mkdir -p "$dir"
    if [ ! -f "$log" ]; then
        cat > "$log" << EOF
pipeline: $slug
entries:
EOF
    fi
}

ensure_summary_log() {
    mkdir -p "$DEV_DIR"
    if [ ! -f "$SUMMARY_LOG" ]; then
        cat > "$SUMMARY_LOG" << EOF
entries:
EOF
    fi
}

yaml_escape() {
    local text="$1"
    if echo "$text" | grep -q $'\n'; then
        echo "|"
        echo "$text" | sed 's/^/      /'
    else
        local escaped
        escaped=$(echo "$text" | sed 's/"/\\"/g')
        echo "\"$escaped\""
    fi
}

# ---- Heartbeat event log helpers (passive pane-1 event stream) ----
#
# Caller-visible behavior: any value passed through _sanitize_event_value
# is mutated for the log line:
#   1) CR/LF/TAB collapse to space
#   2) double-quote -> single-quote
#   3) runs of whitespace -> single underscore (keeps KV tokens parseable)
#   4) byte-truncate to 200 bytes, with "…" suffix on overflow
# Idempotent. cmd_emit callers (e.g. the orchestrator) should keep values
# short and avoid embedded whitespace; verbatim round-trip is NOT preserved.
_sanitize_event_value() {
    local raw="$1"
    local clean
    clean=$(printf '%s' "$raw" \
        | tr '\r\n\t' '   ' \
        | sed -e 's/"/'\''/g' -e 's/[[:space:]][[:space:]]*/_/g')
    printf '%s' "$clean" | awk '{ if (length($0) > 200) print substr($0, 1, 200) "…"; else print $0 }'
}

# _emit_event <TYPE> <slug> [fields-string]
# Best-effort line-emit to <project_root>/.dev/forge-tmp/orchestrator-events.log.
# Never writes to stdout/stderr (bridge contract: callers may parse those).
# Silently skips on unresolvable project root or fs write failure.
# Structured key=value tokens are NOT re-sanitized here — callers sanitize
# freeform values via _sanitize_event_value before assembling the fields arg.
_emit_event() {
    local type="$1"; shift
    local slug="$1"; shift
    local project_root
    project_root=$(_resolve_project_root "" 2>/dev/null) || return 0
    [ -z "$project_root" ] && return 0
    local log_dir="$project_root/.dev/forge-tmp"
    local log_file="$log_dir/orchestrator-events.log"
    mkdir -p "$log_dir" 2>/dev/null || return 0
    printf '%s: pipeline=%s %s\n' "$type" "$slug" "$*" >> "$log_file" 2>/dev/null || true
}

# ---- Hook: Check for pending log entry ----

# Resolve any pane alias to its canonical name via pane_index → pane_name.
canonical_pane_name() {
    pane_name "$(pane_index "$1")"
}

# Per-target pending-log check. Returns 0 if a log entry with
# response: null exists targeting the canonical form of the requested pane.
# Both the request and each log entry's `to:` field are normalized via
# the alias map so historical entries (e.g. `to: claude`) resolve correctly.
has_pending_log_for() {
    local target_canonical="$1"
    if [ ! -f "$SUMMARY_LOG" ]; then
        return 1
    fi
    python3 - "$SUMMARY_LOG" "$target_canonical" << 'PYEOF'
import sys, yaml

log_file, target_canonical = sys.argv[1], sys.argv[2]

# Inline alias map mirroring shell pane_index/pane_name.
# Keep this in lockstep with all other ALIAS_TO_CANONICAL maps.
ALIAS_TO_CANONICAL = {
    'inline': 'claude-opus', 'general': 'claude-opus', 'claude-general': 'claude-opus',
    'claude-opus': 'claude-opus', 'opus': 'claude-opus',
    'claude': 'claude', 'orchestrator': 'claude', 'claude-orchestrator': 'claude',
    'codex': 'codex-a', 'codex-a': 'codex-a',
    'codex-b': 'codex-b',
    'claude-sonnet': 'claude-sonnet', 'sonnet': 'claude-sonnet',
}

def canonical(name):
    return ALIAS_TO_CANONICAL.get(name, name)

try:
    with open(log_file) as f:
        data = yaml.safe_load(f) or {}
except FileNotFoundError:
    sys.exit(1)

for entry in data.get('entries', []):
    if entry.get('response') is not None:
        continue
    entry_target = canonical(entry.get('to', ''))
    if entry_target == target_canonical:
        sys.exit(0)
sys.exit(1)
PYEOF
}

# ---- Hook: Update forge-context.yml ----

update_context() {
    local slug="$1"
    local stage="$2"
    local status="$3"  # done, blocked, error
    local worker="$4"
    local ts
    ts=$(timestamp)

    mkdir -p "$DEV_DIR"

    # Read existing notes if any
    local existing_notes=""
    if [ -f "$CONTEXT_FILE" ]; then
        existing_notes=$(python3 -c "
import yaml, sys
try:
    with open('$CONTEXT_FILE') as f:
        data = yaml.safe_load(f) or {}
    notes = data.get('notes', [])
    for n in notes:
        print(n)
except:
    pass
" 2>/dev/null)
    fi

    # Determine next stage.
    # qa, qa-fix, and qa-retry do NOT auto-advance — the orchestrator
    # decides whether to enter qa-fix (findings present), qa-retry,
    # verify, or halt. For these stages, preserve any prior orchestrator
    # intent in next_stage; otherwise fall back to "pending-orchestrator-decision".
    local next_stage=""
    if [ "$status" = "done" ]; then
        case "$stage" in
            proposal)            next_stage="review" ;;
            review)              next_stage="incorporate" ;;
            incorporate)         next_stage="implementation" ;;
            implementation)      next_stage="impl-review" ;;
            impl-review)         next_stage="coding" ;;
            coding)              next_stage="qa" ;;
            qa|qa-fix|qa-retry)  next_stage="" ;;       # orchestrator decides
            verify)              next_stage="complete" ;;
            commit-review)       next_stage="" ;;       # side-channel, not a pipeline stage
            *)                   next_stage="unknown" ;;
        esac

        # For orchestrator-decision stages, preserve previous intent if any.
        if [ -z "$next_stage" ] && [ "$stage" != "commit-review" ]; then
            local existing
            existing=$(grep "^next_stage:" "$CONTEXT_FILE" 2>/dev/null | awk '{print $2}')
            next_stage="${existing:-pending-orchestrator-decision}"
        fi
    fi

    # Write context file
    cat > "$CONTEXT_FILE" << EOF
# Forge Context — auto-updated by forge-bridge hooks
# Read this on session start to resume pipeline state
active_pipeline: $slug
last_stage_completed: $stage
last_stage_status: $status
last_worker: $worker
next_stage: $next_stage
updated_at: "$ts"
EOF

    # Append notes if they exist
    if [ -n "$existing_notes" ]; then
        echo "notes:" >> "$CONTEXT_FILE"
        echo "$existing_notes" | while IFS= read -r line; do
            echo "  - \"$line\"" >> "$CONTEXT_FILE"
        done
    else
        echo "notes: []" >> "$CONTEXT_FILE"
    fi

    # Heartbeat: stage RESULT recorded (not necessarily an advance).
    # commit-review is a side-channel, not a pipeline stage transition — skip.
    # Fires from both cmd_log_response (normal callback path) and cmd_set_context
    # (manual operator recovery); the second source is intentional so pane 1 sees
    # interventions.
    if [ "$stage" != "commit-review" ]; then
        _emit_event STAGE "$slug" "result_stage=$stage status=$status next=${next_stage:-pending-orchestrator-decision} worker=$worker"
    fi

    # Heartbeat: pipeline complete — strict terminal condition.
    if [ "$stage" = "verify" ] && [ "$status" = "done" ] && [ "$next_stage" = "complete" ]; then
        _emit_event COMPLETE "$slug" "last_stage=$stage worker=$worker"
    fi
}

# ---- Signal (file-based, no tmux needed — works from sandboxed agents) ----

SIGNAL_DIR=".dev/signals"

cmd_signal() {
    local from="$1"
    shift
    local msg="$*"
    local ts
    ts=$(timestamp)
    mkdir -p "$SIGNAL_DIR"
    local filename="${from}-$(date +%s).signal"
    cat > "$SIGNAL_DIR/$filename" << EOF
from: $from
timestamp: $ts
message: $msg
EOF
    echo "Signal sent: $from | $msg"
}

cmd_check_signals() {
    local signal_dir="$SIGNAL_DIR"
    if [ ! -d "$signal_dir" ] || [ -z "$(ls -A "$signal_dir"/*.signal 2>/dev/null)" ]; then
        echo "(no pending signals)"
        return 1
    fi
    for f in "$signal_dir"/*.signal; do
        cat "$f"
        echo "---"
    done
}

cmd_clear_signals() {
    rm -f "$SIGNAL_DIR"/*.signal 2>/dev/null
    echo "Signals cleared"
}

# ---- Review Status ----

REVIEWS_DIR=".dev/reviews"

cmd_review_status() {
    local pending_dir="$REVIEWS_DIR/pending"
    local pending=0 pass=0 concerns=0 blocking=0 total_reviewed=0

    # Count pending
    if [ -d "$pending_dir" ]; then
        pending=$(ls -1 "$pending_dir"/*.review 2>/dev/null | wc -l | tr -d ' ')
    fi

    # Scan completed reviews (YAML frontmatter)
    if [ -d "$REVIEWS_DIR" ]; then
        for f in "$REVIEWS_DIR"/*.md; do
            [ -f "$f" ] || continue
            local verdict
            verdict=$(sed -n 's/^verdict: *//p' "$f" 2>/dev/null | head -1 | tr -d ' ')
            case "$verdict" in
                PASS)     pass=$((pass + 1)) ;;
                CONCERNS) concerns=$((concerns + 1)) ;;
                BLOCKING) blocking=$((blocking + 1)) ;;
            esac
            total_reviewed=$((total_reviewed + 1))
        done
    fi

    local total=$((pending + total_reviewed))

    if [ "$total" -eq 0 ]; then
        echo "(no reviews)"
        return 0
    fi

    echo "Reviews: $total total"
    echo "  pending:  $pending"
    echo "  pass:     $pass"
    echo "  concerns: $concerns"
    echo "  blocking: $blocking"

    if [ "$blocking" -gt 0 ]; then
        echo ""
        echo "BLOCKING reviews:"
        for f in "$REVIEWS_DIR"/*.md; do
            [ -f "$f" ] || continue
            local v short subj
            v=$(sed -n 's/^verdict: *//p' "$f" 2>/dev/null | head -1 | tr -d ' ')
            if [ "$v" = "BLOCKING" ]; then
                short=$(sed -n 's/^short: *//p' "$f" 2>/dev/null | head -1)
                subj=$(sed -n 's/^subject: *"*\([^"]*\)"*/\1/p' "$f" 2>/dev/null | head -1)
                echo "  $short — $subj"
            fi
        done
    fi

    if [ "$pending" -gt 0 ]; then
        echo ""
        echo "Pending reviews:"
        for f in "$pending_dir"/*.review; do
            [ -f "$f" ] || continue
            local short subj
            short=$(sed -n 's/^short: *//p' "$f" 2>/dev/null | head -1)
            subj=$(sed -n 's/^subject: *"*\([^"]*\)"*/\1/p' "$f" 2>/dev/null | head -1)
            echo "  $short — $subj"
        done
    fi

    return 0
}

# ---- Commands ----

cmd_send() {
    require_tmux_session "send" || return 1

    local FORCE=false
    if [ "$1" = "--force" ]; then
        FORCE=true
        shift
    fi

    local PANE_NAME="$1"
    local PANE
    PANE=$(pane_index "$1")
    local TARGET
    TARGET=$(canonical_pane_name "$1")
    shift
    local MSG="$*"

    # Per-target log-before-send hook. Worker panes only.
    # Hard Rule 20's /clear is the only worker-pane --force exemption.
    if [ "$FORCE" = false ]; then
        case "$TARGET" in
            codex-a|codex-b|claude-opus|claude-sonnet)
                if ! has_pending_log_for "$TARGET"; then
                    echo "HOOK BLOCKED: No pending log entry targeting '$TARGET'." >&2
                    echo "Run 'forge-bridge log --to $TARGET ...' before sending." >&2
                    echo "Or use 'forge-bridge send --force' to bypass for non-pipeline messages." >&2
                    return 1
                fi
                ;;
        esac
    fi

    tmux select-pane -t "$SESSION:$WINDOW.$PANE"
    sleep 0.3
    tmux send-keys -t "$SESSION:$WINDOW.$PANE" "$MSG" Enter
    sleep 0.2
    tmux send-keys -t "$SESSION:$WINDOW.$PANE" "" Enter
}

cmd_read() {
    require_tmux_session "read" || return 1
    local PANE
    PANE=$(pane_index "$1")
    local LINES="${2:-20}"
    tmux capture-pane -t "$SESSION:$WINDOW.$PANE" -p -S "-$LINES"
}

cmd_focus() {
    require_tmux_session "focus" || return 1
    local PANE
    PANE=$(pane_index "$1")
    tmux select-pane -t "$SESSION:$WINDOW.$PANE"
}

cmd_back() {
    require_tmux_session "back" || return 1
    tmux select-pane -t "$SESSION:$WINDOW.1"
}

cmd_log() {
    local slug="" stage="" from="" to="" prompt=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)    slug="$2";    shift 2 ;;
            --stage)   stage="$2";   shift 2 ;;
            --from)    from="$2";    shift 2 ;;
            --to)      to="$2";      shift 2 ;;
            --prompt)  prompt="$2";  shift 2 ;;
            *)         shift ;;
        esac
    done

    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$from" ] || [ -z "$to" ] || [ -z "$prompt" ]; then
        echo "ERROR: Missing required flags."
        echo "Usage: forge-bridge log --slug <s> --stage <s> --from <f> --to <t> --prompt <p>"
        return 1
    fi

    local ts
    ts=$(timestamp)
    local escaped_prompt
    escaped_prompt=$(yaml_escape "$prompt")

    # Phase 1b Step 4b: record session in pending entries so cmd_stall_check_status
    # can filter by current session (multi-session correlation, review item #4).
    # Session resolution mirrors require_tmux_session: only consult
    # `tmux display-message` when inside tmux; otherwise walk up to .dev/.forge-session.
    local session
    session="${TMUX_SESSION:-}"
    if [ -z "$session" ] && [ -n "${TMUX:-}" ]; then
        session="$(tmux display-message -p '#{session_name}' 2>/dev/null)"
    fi
    if [ -z "$session" ]; then
        local _dir
        _dir="$(pwd)"
        while [ "$_dir" != "/" ]; do
            if [ -f "$_dir/.dev/.forge-session" ]; then
                session=$(cat "$_dir/.dev/.forge-session")
                break
            fi
            _dir=$(dirname "$_dir")
        done
    fi
    [ -z "$session" ] && session="unknown"

    ensure_pipeline_log "$slug"
    ensure_summary_log

    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"

    cat >> "$pipeline_log" << EOF

  - timestamp: "$ts"
    stage: $stage
    from: $from
    to: $to
    session: $session
    prompt: $escaped_prompt
    response: null
    files: []
EOF

    cat >> "$SUMMARY_LOG" << EOF

  - timestamp: "$ts"
    pipeline: $slug
    stage: $stage
    from: $from
    to: $to
    session: $session
    response: null
EOF

    echo "Logged: $from → $to | $slug/$stage | $ts (session=$session)"
}

cmd_log_response() {
    # Phase 1b Step 4a: target-aware response update.
    # New flags: --to <pane> (alias-normalized), --stage <stage>
    # Without --to/--stage, ambiguity guard refuses if more than one
    # `response: null` entry exists in the pipeline log (review item #3).
    # Backward compat: single-pending-entry pipelines work unchanged.

    local slug="" response="" target="" target_stage=""
    local -a files=()

    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)     slug="$2";     shift 2 ;;
            --response) response="$2"; shift 2 ;;
            --file)     files+=("$2"); shift 2 ;;
            --to)       target="$2";   shift 2 ;;
            --stage)    target_stage="$2"; shift 2 ;;
            *)          shift ;;
        esac
    done

    if [ -z "$slug" ] || [ -z "$response" ]; then
        echo "ERROR: Missing required flags."
        echo "Usage: forge-bridge log-response --slug <s> --response <r> [--to <pane>] [--stage <stage>] [--file <path:action>]..."
        return 1
    fi

    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"

    if [ ! -f "$pipeline_log" ]; then
        echo "ERROR: No log file for pipeline '$slug'"
        return 1
    fi

    # Normalize --to via the same alias map used in has_pending_log_for.
    local target_canonical=""
    if [ -n "$target" ]; then
        target_canonical=$(canonical_pane_name "$target")
    fi

    local files_yaml="[]"
    if [ ${#files[@]} -gt 0 ]; then
        files_yaml=""
        for f in "${files[@]}"; do
            local fpath="${f%%:*}"
            local faction="${f##*:}"
            files_yaml="$files_yaml
      - path: $fpath
        action: $faction"
        done
    fi

    # Determine status from response keyword.
    local status="unknown"
    if echo "$response" | grep -qi "FORGE_DONE"; then
        status="done"
    elif echo "$response" | grep -qi "FORGE_BLOCKED"; then
        status="blocked"
    elif echo "$response" | grep -qi "FORGE_ERROR"; then
        status="error"
    fi

    # Find the target entry's timestamp (the surgical anchor for string-replace).
    # Filter pending entries by --to (canonical) and --stage. Apply ambiguity
    # guard if no filters provided and more than one pending entry exists.
    local matched
    matched=$(python3 - "$pipeline_log" "$target_canonical" "$target_stage" << 'PYEOF'
import sys, yaml

pipeline_log = sys.argv[1]
target_canonical = sys.argv[2] or None
target_stage = sys.argv[3] or None

ALIAS_TO_CANONICAL = {
    'inline': 'claude-opus', 'general': 'claude-opus', 'claude-general': 'claude-opus',
    'claude-opus': 'claude-opus', 'opus': 'claude-opus',
    'claude': 'claude', 'orchestrator': 'claude', 'claude-orchestrator': 'claude',
    'codex': 'codex-a', 'codex-a': 'codex-a',
    'codex-b': 'codex-b',
    'claude-sonnet': 'claude-sonnet', 'sonnet': 'claude-sonnet',
}
def canonical(name):
    return ALIAS_TO_CANONICAL.get(name, name)

try:
    with open(pipeline_log) as f:
        data = yaml.safe_load(f) or {}
except Exception as ex:
    print(f"ERR_PARSE:{ex}", file=sys.stderr); sys.exit(2)

entries = data.get('entries') or []
pending = [e for e in entries if e.get('response') is None]
if not pending:
    print("ERR_NO_PENDING", file=sys.stderr); sys.exit(2)

def matches(e):
    if target_canonical and canonical(e.get('to', '')) != target_canonical:
        return False
    if target_stage and e.get('stage', '') != target_stage:
        return False
    return True

candidates = [e for e in pending if matches(e)]
if not candidates:
    filt = []
    if target_canonical: filt.append(f"--to={target_canonical}")
    if target_stage: filt.append(f"--stage={target_stage}")
    print(f"ERR_NO_MATCH:{' '.join(filt)}", file=sys.stderr); sys.exit(2)

# Ambiguity guard: only when caller supplied no filters.
if len(candidates) > 1 and not target_canonical and not target_stage:
    msg = f"ERR_AMBIGUOUS:{len(candidates)} pending entries (run with --to and/or --stage to disambiguate):\n"
    for e in candidates:
        msg += f"  - to={e.get('to','?')} stage={e.get('stage','?')} ts={e.get('timestamp','?')}\n"
    print(msg, file=sys.stderr); sys.exit(2)

# Most recent matching entry (last in list-order).
chosen = candidates[-1]
print(f"OK\t{chosen.get('timestamp','')}\t{chosen.get('stage','')}\t{chosen.get('to','')}")
PYEOF
)
    local rc=$?
    if [ $rc -ne 0 ] || [[ "$matched" != OK* ]]; then
        # python wrote diagnostic to stderr already; surface a one-line stdout summary
        echo "ERROR: log-response: target-resolution failed for slug=$slug" >&2
        return 1
    fi

    local target_ts target_stage_resolved target_to
    target_ts=$(echo "$matched" | awk -F'\t' '{print $2}')
    target_stage_resolved=$(echo "$matched" | awk -F'\t' '{print $3}')
    target_to=$(echo "$matched" | awk -F'\t' '{print $4}')

    # Targeted string-replace anchored to the resolved timestamp. Preserves
    # YAML formatting / comments (yaml.dump would re-emit and lose them).
    python3 << PYEOF
import re, sys

target_ts = """$target_ts"""
escaped_response = """$response""".replace('\\\\', '\\\\\\\\').replace('"', '\\\\"')
files_data = """$files_yaml"""
# Preserve the leading newline that separates `files:` from the first list
# item; an inline `files:- path:` is malformed YAML. Keep trailing whitespace
# trimmed only.
files_data = files_data.rstrip()

# Match the entry by its timestamp anchor; replace ONLY its response: null
# (and files: [] if files_data is provided).
pat = re.compile(
    r'(timestamp:\s*"' + re.escape(target_ts) + r'"[^\n]*\n(?:\s+[^\n]*\n)*?\s+)response:\s*null',
    re.MULTILINE)

def patch_response(text):
    new_text, n = pat.subn(
        lambda m: m.group(1) + 'response: "' + escaped_response + '"', text, count=1)
    return new_text, n

# Pipeline log
with open("$pipeline_log") as f:
    content = f.read()
content, n = patch_response(content)
if n != 1:
    print(f"ERR: pipeline_log patch failed (n={n}, ts={target_ts})", file=sys.stderr)
    sys.exit(2)
if files_data and files_data != "[]":
    fpat = re.compile(
        r'(timestamp:\s*"' + re.escape(target_ts) + r'"[^\n]*\n(?:\s+[^\n]*\n)*?\s+)files:\s*\[\]',
        re.MULTILINE)
    content, _ = fpat.subn(
        lambda m: m.group(1) + 'files:' + files_data, content, count=1)
with open("$pipeline_log", "w") as f:
    f.write(content)

# Summary log: same anchor; soft-fail if not found (older entries may pre-date Phase 1b).
try:
    with open("$SUMMARY_LOG") as f:
        s_content = f.read()
    s_new, sn = patch_response(s_content)
    if sn == 1:
        with open("$SUMMARY_LOG", "w") as f:
            f.write(s_new)
except FileNotFoundError:
    pass

print("Updated: $slug | to=$target_to | stage=$target_stage_resolved | ts=$target_ts | response: $response")
PYEOF

    # Hook 2: auto-update forge-context.yml using the resolved entry.
    if [ -n "$target_stage_resolved" ] && [ -n "$status" ]; then
        update_context "$slug" "$target_stage_resolved" "$status" "$target_to"
    fi
}

cmd_history() {
    local LINES="${1:-30}"
    if [ -f "$SUMMARY_LOG" ]; then
        tail -n "$LINES" "$SUMMARY_LOG"
    else
        echo "(no log entries yet)"
    fi
}

cmd_pipeline_log() {
    local slug="$1"
    local LINES="${2:-50}"

    if [ -z "$slug" ]; then
        echo "Usage: forge-bridge pipeline-log <slug> [lines]"
        return 1
    fi

    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"
    if [ -f "$pipeline_log" ]; then
        tail -n "$LINES" "$pipeline_log"
    else
        echo "(no log for pipeline '$slug')"
    fi
}

# ---- Context (session start / recovery) ----

cmd_context() {
    # Phase 1b Step 3: prepend stall-check-status section if non-empty.
    # Inserted BEFORE the existing early-return so stale-pending warnings
    # surface even when no $CONTEXT_FILE exists yet.
    local _stall_status_output
    local _resolved_root
    _resolved_root=$(_resolve_project_root "")
    if [ -n "$_resolved_root" ]; then
        _stall_status_output=$(cmd_stall_check_status --project-root "$_resolved_root" 2>/dev/null)
    else
        _stall_status_output=$(cmd_stall_check_status 2>/dev/null)
    fi
    if [ -n "$_stall_status_output" ]; then
        echo "$_stall_status_output"
        echo ""
    fi

    if [ ! -f "$CONTEXT_FILE" ]; then
        echo "(no forge context — no active pipeline)"
        echo ""
        echo "Start a new pipeline with forge-bridge log, or set one manually:"
        echo "  forge-bridge set-context --slug <slug-name>"

        # Still show reviews even without a pipeline
        local has_reviews_noctx=false
        if [ -d "$REVIEWS_DIR/pending" ] && [ -n "$(ls -A "$REVIEWS_DIR/pending/"*.review 2>/dev/null)" ]; then
            has_reviews_noctx=true
        fi
        if [ -n "$(ls -A "$REVIEWS_DIR/"*.md 2>/dev/null)" ]; then
            has_reviews_noctx=true
        fi
        if [ "$has_reviews_noctx" = true ]; then
            echo ""
            echo "=== Commit Reviews ==="
            cmd_review_status
        fi
        return 0
    fi

    echo "=== Forge Context ==="
    cat "$CONTEXT_FILE"
    echo ""

    # Show last few log entries for the active pipeline
    local slug
    slug=$(grep "active_pipeline:" "$CONTEXT_FILE" 2>/dev/null | awk '{print $2}')
    if [ -n "$slug" ] && [ "$slug" != "null" ]; then
        local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"
        if [ -f "$pipeline_log" ]; then
            echo "=== Recent Activity ($slug) ==="
            tail -20 "$pipeline_log"
        fi

        # Check for pending signals
        if [ -d "$SIGNAL_DIR" ] && [ -n "$(ls -A "$SIGNAL_DIR"/*.signal 2>/dev/null)" ]; then
            echo ""
            echo "=== Pending Signals ==="
            cmd_check_signals
        fi
    fi

    # Show review status if any reviews exist
    local has_reviews=false
    if [ -d "$REVIEWS_DIR/pending" ] && [ -n "$(ls -A "$REVIEWS_DIR/pending/"*.review 2>/dev/null)" ]; then
        has_reviews=true
    fi
    if [ -n "$(ls -A "$REVIEWS_DIR/"*.md 2>/dev/null)" ]; then
        has_reviews=true
    fi
    if [ "$has_reviews" = true ]; then
        echo ""
        echo "=== Commit Reviews ==="
        cmd_review_status
    fi
}

cmd_set_context() {
    local slug=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --slug) slug="$2"; shift 2 ;;
            *)      shift ;;
        esac
    done

    if [ -z "$slug" ]; then
        echo "Usage: forge-bridge set-context --slug <slug-name>"
        return 1
    fi

    mkdir -p "$DEV_DIR"

    # If pipeline log exists, derive state from it
    local pipeline_log="$DEV_DIR/proposals/$slug/forge-log.yml"
    local last_stage="none"
    local last_status="none"
    local last_worker="none"

    if [ -f "$pipeline_log" ]; then
        last_stage=$(python3 -c "
import yaml
with open('$pipeline_log') as f:
    data = yaml.safe_load(f) or {}
entries = data.get('entries', [])
for e in reversed(entries):
    r = e.get('response', '')
    if r and 'FORGE_DONE' in str(r):
        print(e.get('stage', 'none'))
        break
else:
    print('none')
" 2>/dev/null || echo "none")
        last_worker=$(python3 -c "
import yaml
with open('$pipeline_log') as f:
    data = yaml.safe_load(f) or {}
entries = data.get('entries', [])
for e in reversed(entries):
    r = e.get('response', '')
    if r and 'FORGE_DONE' in str(r):
        print(e.get('to', 'none'))
        break
else:
    print('none')
" 2>/dev/null || echo "none")
        if [ "$last_stage" != "none" ]; then
            last_status="done"
        fi
    fi

    update_context "$slug" "$last_stage" "$last_status" "$last_worker"
    echo "Context set to pipeline: $slug"
    cmd_context
}

# ---- Status file (.dev/forge-status.md) ----
#
# Human-readable rolling summary. Re-rendered as a side effect of dispatch,
# wait, and callback so a fresh `cat .dev/forge-status.md` always works.
# Computed from forge-context.yml + the per-pipeline log; never the source of
# truth.

FORGE_STATUS_FILE_NAME="forge-status.md"

_render_status_file() {
    # Resolve project root; if we can't, skip silently (status is best-effort).
    local project_root
    project_root=$(_resolve_project_root "" 2>/dev/null)
    if [ -z "$project_root" ]; then
        return 0
    fi
    local out_file="$project_root/$DEV_DIR/$FORGE_STATUS_FILE_NAME"
    mkdir -p "$(dirname "$out_file")"
    python3 - "$project_root/$CONTEXT_FILE" "$project_root/$DEV_DIR" "$out_file" <<'PYEOF'
import sys, os, yaml, datetime

context_file, dev_dir, out_file = sys.argv[1:4]

ctx = {}
try:
    with open(context_file) as f:
        ctx = yaml.safe_load(f) or {}
except FileNotFoundError:
    pass

slug          = ctx.get('active_pipeline') or '(none)'
last_stage    = ctx.get('last_stage_completed') or '(none)'
last_status   = ctx.get('last_stage_status') or '(none)'
last_worker   = ctx.get('last_worker') or '(none)'
next_stage    = ctx.get('next_stage') or '(none)'
notes         = ctx.get('notes') or []

# Read per-pipeline log (canonical event timeline for this slug). Fall back
# to regex extraction when yaml.safe_load fails on malformed entries
# (some legacy log-response emissions produced bad indentation in `files:`).
entries = []
if slug and slug != '(none)':
    pipeline_log = os.path.join(dev_dir, 'proposals', slug, 'forge-log.yml')
    if os.path.exists(pipeline_log):
        try:
            with open(pipeline_log) as f:
                data = yaml.safe_load(f) or {}
            entries = data.get('entries', []) or []
        except Exception:
            import re
            with open(pipeline_log) as f:
                raw = f.read()
            # Best-effort parse of `  - timestamp: ... stage: ... to: ... response: ...` blocks.
            # Splits on the entry-start marker and reconstructs fields per block.
            block_re = re.compile(
                r'^\s*-\s+timestamp:\s*"([^"]+)"', re.MULTILINE)
            starts = [(m.start(), m.group(1)) for m in block_re.finditer(raw)]
            for i, (off, ts) in enumerate(starts):
                end = starts[i+1][0] if i+1 < len(starts) else len(raw)
                blk = raw[off:end]
                def grab(field):
                    m = re.search(rf'^\s+{field}:\s*(.*?)\s*$', blk, re.MULTILINE)
                    return m.group(1).strip() if m else None
                stage = grab('stage')
                to    = grab('to')
                # Response can be `null` or a quoted string.
                rmatch = re.search(r'^\s+response:\s*(null|"(?:[^"\\]|\\.)*")', blk, re.MULTILINE)
                if not rmatch:
                    continue
                resp_raw = rmatch.group(1)
                response = None if resp_raw == 'null' else resp_raw.strip('"').replace('\\"', '"')
                entries.append({
                    'timestamp': ts, 'stage': stage, 'to': to, 'response': response,
                    'files': [],
                })

# Pending = response: null entries; current stage = most recent pending.
pending = [e for e in entries if e.get('response') is None]
current_stage  = (pending[-1].get('stage')  if pending else next_stage) or '(idle)'
current_worker = (pending[-1].get('to')     if pending else None)
current_since  = (pending[-1].get('timestamp') if pending else None)

def short_time(ts):
    return ts[11:16] if isinstance(ts, str) and len(ts) >= 16 else (ts or '?')

# Recent activity: last 15 entries.
activity = []
for e in entries[-15:]:
    ts = short_time(e.get('timestamp'))
    stage = e.get('stage', '?')
    worker = e.get('to', '?')
    resp = e.get('response')
    if resp is None:
        activity.append(f"  {ts}  · dispatched {stage:<14} → {worker} (PENDING)")
    else:
        rs = str(resp)
        if 'FORGE_DONE' in rs:
            icon, tag = '✓', 'complete'
        elif 'FORGE_BLOCKED' in rs:
            icon, tag = '✗', 'BLOCKED'
        elif 'FORGE_ERROR' in rs:
            icon, tag = '⚠', 'ERROR'
        else:
            icon, tag = '·', 'updated'
        tail = rs.split('—', 1)[1].strip() if '—' in rs else ''
        tail = (tail[:60] + '…') if len(tail) > 60 else tail
        line = f"  {ts}  {icon} {stage:<14} {tag}"
        if tail:
            line += f"  ({tail})"
        activity.append(line)

# Artifacts: union of `files[].path` across entries.
artifacts = []
seen = set()
for e in entries:
    for f_entry in (e.get('files') or []):
        if isinstance(f_entry, dict):
            p = f_entry.get('path', '')
            if p and p not in seen:
                seen.add(p)
                artifacts.append(p)

now = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')

L = []
L.append("# Forge Pipeline Status")
L.append("")
L.append(f"Pipeline: {slug}")
if pending:
    L.append(f"Current stage: {current_stage} ({current_worker}, PENDING since {short_time(current_since)})")
else:
    L.append(f"Current stage: (idle) — last completed: {last_stage} → {last_status} by {last_worker}")
L.append(f"Next stage: {next_stage}")
L.append(f"Last update: {now}")
L.append("")
L.append("## Recent activity")
L.append("")
L.extend(activity or ["  (no activity yet)"])
L.append("")
L.append("## Pending callbacks")
L.append("")
if pending:
    for e in pending:
        L.append(f"  - {e.get('stage','?')} ({e.get('to','?')}, since {short_time(e.get('timestamp'))})")
else:
    L.append("  (none)")
L.append("")
L.append("## Artifacts")
L.append("")
if artifacts:
    for a in artifacts:
        L.append(f"  {a}")
else:
    L.append("  (none yet)")
L.append("")
L.append("## Notes")
L.append("")
if notes:
    for n in notes:
        L.append(f"  - {n}")
else:
    L.append("  (none)")
L.append("")

with open(out_file, 'w') as f:
    f.write("\n".join(L))
PYEOF
}

cmd_status() {
    _render_status_file
    local project_root
    project_root=$(_resolve_project_root "" 2>/dev/null)
    if [ -z "$project_root" ]; then
        echo "ERROR: status requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi
    local out_file="$project_root/$DEV_DIR/$FORGE_STATUS_FILE_NAME"
    if [ -f "$out_file" ]; then
        cat "$out_file"
    else
        echo "(no status file)"
    fi
}

# ---- Prompt template rendering (Phase 3) ----
#
# Template directories:
#   ~/.config/forge/prompts/  — stage prompts; supports <<<INCLUDE _name>>>
#   ~/.config/forge/digests/  — digest prompts; same include syntax
#
# Variables substituted in rendered prompts:
#   {slug}, {worker}, {worker_pane}, {project_root}
#
# The synthetic <<<INCLUDE _preamble>>> is generated from forge-project.yml
# (services.backend, services.frontend, forge.expected_root). Other includes
# resolve to ~/.config/forge/prompts/<name>.txt.

FORGE_PROMPTS_DIR="${FORGE_PROMPTS_DIR:-$HOME/.config/forge/prompts}"
FORGE_DIGESTS_DIR="${FORGE_DIGESTS_DIR:-$HOME/.config/forge/digests}"

# Render the {ENVIRONMENT_PREAMBLE} block from a project_root containing
# .claude/forge-project.yml. Echoes preamble text on stdout; empty on miss.
_render_preamble() {
    local project_root="$1"
    local yml="$project_root/.claude/forge-project.yml"
    if [ ! -f "$yml" ]; then
        return 0
    fi
    python3 - "$yml" "$project_root" <<'PYEOF'
import sys, yaml
yml_path, project_root = sys.argv[1], sys.argv[2]
try:
    with open(yml_path) as f:
        data = yaml.safe_load(f) or {}
except Exception:
    sys.exit(0)
services = data.get('services') or {}
backend = services.get('backend') or {}
frontend = services.get('frontend') or {}
lines = ["Environment setup (run before any other commands):"]
lines.append(f"  Working directory: {project_root}")
venv = backend.get('activate_venv')
if venv:
    bw = backend.get('working_dir')
    if bw and venv.startswith('source ') and not venv.startswith(f'source {bw}/'):
        venv = f"source {bw}/" + venv[len('source '):]
    lines.append(f"  Python venv: {venv}")
app_env = (data.get('forge') or {}).get('app_env') or data.get('app_env')
if app_env:
    lines.append(f"  APP_ENV: {app_env}")
bp = backend.get('port')
if bp:
    lines.append(f"  Backend port: {bp}")
fp = frontend.get('port')
if fp:
    lines.append(f"  Frontend port: {fp}")
print("\n".join(lines))
PYEOF
}

# Render a template file with includes + variable substitution.
# Args: template_path slug stage worker worker_pane project_root
# Echoes rendered text on stdout. Returns 1 if template missing.
_render_template() {
    local tmpl_path="$1" slug="$2" stage="$3" worker="$4" worker_pane="$5" project_root="$6"
    if [ ! -f "$tmpl_path" ]; then
        echo "ERROR: template not found: $tmpl_path" >&2
        return 1
    fi
    local preamble
    preamble=$(_render_preamble "$project_root")
    python3 - "$tmpl_path" "$FORGE_PROMPTS_DIR" "$slug" "$stage" "$worker" \
        "$worker_pane" "$project_root" "$preamble" <<'PYEOF'
import sys, os, re
(tmpl_path, prompts_dir, slug, stage, worker, worker_pane, project_root, preamble) = sys.argv[1:9]

with open(tmpl_path) as f:
    text = f.read()

INCLUDE_RE = re.compile(r'<<<INCLUDE\s+(\S+)\s*>>>')

def resolve_include(name):
    if name == '_preamble':
        return preamble
    path = os.path.join(prompts_dir, f"{name}.txt")
    if not os.path.exists(path):
        sys.stderr.write(f"ERROR: include not found: {name}\n")
        sys.exit(2)
    with open(path) as f:
        return f.read().rstrip('\n')

# Resolve includes (single pass; nested includes are not supported by design).
def expand(m):
    return resolve_include(m.group(1))
text = INCLUDE_RE.sub(expand, text)

# Substitute variables.
text = (text
        .replace('{slug}', slug)
        .replace('{stage}', stage)
        .replace('{worker}', worker)
        .replace('{worker_pane}', str(worker_pane))
        .replace('{project_root}', project_root))

sys.stdout.write(text)
PYEOF
}

# dispatch — render a stage prompt, write it, log, send.
#   forge-bridge dispatch --slug <s> --stage <s> --worker <w>
#                          [--clear] [--dry-run]
# --clear: send /clear to the worker pane before the dispatch (Hard Rule 20).
# --dry-run: print rendered prompt to stdout; do NOT write/log/send.
cmd_dispatch() {
    local slug="" stage="" worker="" do_clear=false dry_run=false
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)    slug="$2";   shift 2 ;;
            --stage)   stage="$2";  shift 2 ;;
            --worker)  worker="$2"; shift 2 ;;
            --clear)   do_clear=true; shift ;;
            --dry-run) dry_run=true;  shift ;;
            *)         shift ;;
        esac
    done

    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$worker" ]; then
        echo "Usage: forge-bridge dispatch --slug <s> --stage <s> --worker <w> [--clear] [--dry-run]" >&2
        return 1
    fi

    local worker_canonical worker_pane
    worker_canonical=$(canonical_pane_name "$worker")
    worker_pane=$(pane_index "$worker")

    case "$worker_canonical" in
        claude-opus|claude-sonnet|codex-a|codex-b) ;;
        *)
            _emit_event ERROR "$slug" "stage=$stage reason=invalid-worker worker=$worker"
            echo "ERROR: --worker must resolve to a worker pane (claude-opus|claude-sonnet|codex-a|codex-b); got '$worker_canonical'" >&2
            return 1
            ;;
    esac

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: dispatch requires a forge-project.yml. Walk-up from cwd failed." >&2
        return 1
    fi

    local tmpl_path="$FORGE_PROMPTS_DIR/$stage.txt"
    local rendered
    rendered=$(_render_template "$tmpl_path" "$slug" "$stage" "$worker_canonical" "$worker_pane" "$project_root") || {
        _emit_event ERROR "$slug" "stage=$stage reason=template-render-failed"
        return 1
    }

    if [ "$dry_run" = true ]; then
        printf '%s' "$rendered"
        return 0
    fi

    require_tmux_session "dispatch" || {
        _emit_event ERROR "$slug" "stage=$stage reason=tmux-session-missing"
        return 1
    }

    local prompt_file="$project_root/.dev/forge-tmp/${worker_canonical}-${stage}-${slug}.txt"
    mkdir -p "$(dirname "$prompt_file")"
    printf '%s' "$rendered" > "$prompt_file"

    # Hard Rule 20 — orchestrator (this bridge call) drives /clear, never the worker.
    if [ "$do_clear" = true ]; then
        tmux send-keys -t "$SESSION:$WINDOW.$worker_pane" "/clear" Enter
        sleep "${FORGE_CLEAR_WAIT_S:-2}"
    fi

    local ref_msg="Read and follow instructions in .dev/forge-tmp/${worker_canonical}-${stage}-${slug}.txt"
    cmd_log --slug "$slug" --stage "$stage" --from claude --to "$worker_canonical" --prompt "$ref_msg" >/dev/null
    cmd_send "$worker_canonical" "$ref_msg" || {
        _emit_event ERROR "$slug" "stage=$stage reason=send-failed worker=$worker_canonical"
        return 1
    }

    _emit_event DISPATCH "$slug" "stage=$stage worker=$worker_canonical"
    _render_status_file
    echo "DISPATCHED stage=$stage worker=$worker_canonical slug=$slug prompt=$prompt_file"
}

# callback — worker-side declarative completion signal.
#   forge-bridge callback --slug <s> --stage <s> --status <DONE|BLOCKED|ERROR>
#                         [--message <m>] [--worker <w>]
# Behavior:
#   1. Writes .dev/forge-tmp/callbacks/<slug>-<stage>.callback (machine-readable)
#   2. Auto-calls log-response to mark the matching pending log entry done
#   3. (Back-compat) sends a FORGE_<STATUS>: <stage> — <message> line to the
#      orchestrator pane for any human reading scrollback.
# --worker auto-resolves from TMUX_PANE if omitted.
cmd_callback() {
    local slug="" stage="" status="" message="" worker="" quiet=false
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)    slug="$2";    shift 2 ;;
            --stage)   stage="$2";   shift 2 ;;
            --status)  status="$2";  shift 2 ;;
            --message) message="$2"; shift 2 ;;
            --worker)  worker="$2";  shift 2 ;;
            --quiet)   quiet=true;   shift ;;
            *)         shift ;;
        esac
    done
    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$status" ]; then
        echo "Usage: forge-bridge callback --slug <s> --stage <s> --status <DONE|BLOCKED|ERROR> [--message <m>] [--worker <w>] [--quiet]" >&2
        return 1
    fi
    case "$status" in
        DONE|BLOCKED|ERROR) ;;
        *)
            _emit_event ERROR "$slug" "stage=$stage reason=invalid-status status=$status"
            echo "ERROR: --status must be DONE, BLOCKED, or ERROR; got '$status'" >&2
            return 1
            ;;
    esac

    # Auto-resolve worker from TMUX_PANE if not supplied.
    if [ -z "$worker" ]; then
        local pane_id="${TMUX_PANE:-}"
        if [ -n "$pane_id" ]; then
            local sess
            sess="${TMUX_SESSION:-$(tmux display-message -p '#{session_name}' 2>/dev/null)}"
            if [ -n "$sess" ]; then
                local idx
                idx=$(tmux list-panes -t "$sess:$WINDOW" -F '#{pane_index} #{pane_id}' 2>/dev/null \
                    | awk -v pid="$pane_id" '$2==pid {print $1}')
                if [ -n "$idx" ]; then
                    worker=$(pane_name "$idx")
                fi
            fi
        fi
    fi
    if [ -z "$worker" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=worker-unresolvable"
        echo "ERROR: callback requires --worker (TMUX_PANE auto-resolution failed)" >&2
        return 1
    fi
    local worker_canonical
    worker_canonical=$(canonical_pane_name "$worker")

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: callback requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi

    local cb_dir="$project_root/.dev/forge-tmp/callbacks"
    mkdir -p "$cb_dir"
    local cb_file="$cb_dir/${slug}-${stage}.callback"
    local ts
    ts=$(timestamp)
    cat > "$cb_file" <<EOF
slug: $slug
stage: $stage
status: $status
worker: $worker_canonical
timestamp: $ts
message: $(yaml_escape "$message")
EOF

    # Auto log-response. Construct the legacy-style response string.
    local legacy="FORGE_${status}: ${stage}"
    if [ -n "$message" ]; then
        legacy="${legacy} — ${message}"
    fi
    (cd "$project_root" && cmd_log_response --slug "$slug" --stage "$stage" \
        --to "$worker_canonical" --response "$legacy" >/dev/null 2>&1) || true

    # Back-compat: still notify the orchestrator pane so humans see the line.
    # Suppressed by --quiet. Only attempts when inside a tmux session.
    #
    # Split the send-keys call: type the text first, sleep briefly so Claude's
    # TUI input buffer commits the line, THEN press Enter. Combining text and
    # Enter into one send-keys call leaves the text sitting in the input
    # unsubmitted on current Claude TUI builds.
    if [ "$quiet" != true ] && [ -n "${TMUX:-}" ]; then
        local sess
        sess="${TMUX_SESSION:-$(tmux display-message -p '#{session_name}' 2>/dev/null)}"
        if [ -n "$sess" ]; then
            tmux send-keys -t "$sess:$WINDOW.1" -l "$legacy" 2>/dev/null || true
            sleep 0.2
            tmux send-keys -t "$sess:$WINDOW.1" Enter 2>/dev/null || true
        fi
    fi

    local cb_msg_len
    cb_msg_len=$(printf '%s' "$message" | wc -c | tr -d ' ')
    _emit_event CALLBACK "$slug" "stage=$stage worker=$worker_canonical status=$status message_len=$cb_msg_len callback_file=$cb_file"

    _render_status_file
    echo "CALLBACK $status stage=$stage slug=$slug worker=$worker_canonical → $cb_file"
}

# wait — block until a callback file appears for <slug>/<stage>, or until
# stall-check classifies the worker as STALLED/PROMPTING/DEAD.
#   forge-bridge wait --slug <s> --stage <s> --worker <w>
#                     [--timeout <seconds>]
#                     [--digest-template <name>]
#                     [--interval <seconds>]
# Outputs a single structured block on stdout. Forwards SIGINT cleanly.
cmd_wait() {
    local slug="" stage="" worker="" timeout="" digest_template="" interval="${FORGE_WAIT_INTERVAL_S:-15}"
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)            slug="$2";            shift 2 ;;
            --stage)           stage="$2";           shift 2 ;;
            --worker)          worker="$2";          shift 2 ;;
            --timeout)         timeout="$2";         shift 2 ;;
            --digest-template) digest_template="$2"; shift 2 ;;
            --interval)        interval="$2";        shift 2 ;;
            *)                 shift ;;
        esac
    done
    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$worker" ]; then
        echo "Usage: forge-bridge wait --slug <s> --stage <s> --worker <w> [--timeout <s>] [--digest-template <name>] [--interval <s>]" >&2
        return 1
    fi

    local worker_canonical
    worker_canonical=$(canonical_pane_name "$worker")

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: wait requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi

    require_tmux_session "wait" || {
        _emit_event ERROR "$slug" "stage=$stage reason=tmux-session-missing"
        return 1
    }

    local cb_file="$project_root/.dev/forge-tmp/callbacks/${slug}-${stage}.callback"
    local started
    started=$(date +%s)

    # Trap SIGINT: emit ERROR FIRST so it survives even if the printf is
    # interrupted; use :-unknown defaults so a SIGINT during arg-parse still
    # produces a §4.1.8-conforming line.
    trap '_emit_event ERROR "${slug:-unknown}" "stage=${stage:-unknown} worker=${worker_canonical:-unknown} reason=INTERRUPTED"; printf "STATUS: INTERRUPTED\nSTAGE: %s\nSLUG: %s\nWORKER: %s\n" "$stage" "$slug" "$worker_canonical"; exit 130' INT

    _emit_event WAIT "$slug" "stage=$stage worker=$worker_canonical"

    while true; do
        if [ -f "$cb_file" ]; then
            _wait_emit_callback "$cb_file" "$slug" "$stage" "$worker_canonical" \
                "$digest_template" "$project_root"
            _render_status_file
            return 0
        fi

        local sc_out sc_state
        sc_out=$(cmd_stall_check --project-root "$project_root" "$worker_canonical" 2>/dev/null)
        sc_state=$(echo "$sc_out" | awk '{print $1}')
        case "$sc_state" in
            STALLED|PROMPTING|DEAD)
                _emit_event STALL "$slug" "stage=$stage worker=$worker_canonical state=$sc_state"
                printf 'STATUS: %s\nSTAGE: %s\nSLUG: %s\nWORKER: %s\nDETAIL: %s\n' \
                    "$sc_state" "$stage" "$slug" "$worker_canonical" "$sc_out"
                _render_status_file
                return 0
                ;;
        esac

        if [ -n "$timeout" ]; then
            local elapsed
            elapsed=$(( $(date +%s) - started ))
            if [ "$elapsed" -ge "$timeout" ]; then
                _emit_event STALL "$slug" "stage=$stage worker=$worker_canonical state=TIMEOUT elapsed=${elapsed}s"
                printf 'STATUS: TIMEOUT\nSTAGE: %s\nSLUG: %s\nWORKER: %s\nELAPSED: %ss\n' \
                    "$stage" "$slug" "$worker_canonical" "$elapsed"
                _render_status_file
                return 0
            fi
        fi

        sleep "$interval"
    done
}

# Internal: emit the structured block from a callback file. Optionally render
# a digest prompt to disk for the orchestrator to spawn an Agent against.
_wait_emit_callback() {
    local cb_file="$1" slug="$2" stage="$3" worker_canonical="$4" digest_template="$5" project_root="$6"

    local status message
    status=$(grep '^status:' "$cb_file" | awk '{print $2}')
    message=$(python3 -c "
import yaml, sys
with open('$cb_file') as f:
    d = yaml.safe_load(f) or {}
print(d.get('message', '') or '')
" 2>/dev/null)

    printf 'STATUS: %s\nSTAGE: %s\nSLUG: %s\nWORKER: %s\nCALLBACK: %s\n' \
        "$status" "$stage" "$slug" "$worker_canonical" "$message"

    if [ -n "$digest_template" ] && [ "$status" = "DONE" ]; then
        local digest_tmpl="$FORGE_DIGESTS_DIR/$digest_template.txt"
        if [ ! -f "$digest_tmpl" ]; then
            _emit_event ERROR "$slug" "stage=$stage reason=digest-template-not-found template=$digest_template"
            printf 'DIGEST_PROMPT_ERROR: template not found: %s\n' "$digest_tmpl"
            return 0
        fi
        local digest_out_dir="$project_root/.dev/forge-tmp"
        mkdir -p "$digest_out_dir"
        local digest_out="$digest_out_dir/digest-${stage}-${slug}.txt"
        local worker_pane
        worker_pane=$(pane_index "$worker_canonical")
        _render_template "$digest_tmpl" "$slug" "$stage" "$worker_canonical" \
            "$worker_pane" "$project_root" > "$digest_out" || return 0
        _emit_event DIGEST "$slug" "stage=$stage template=$digest_template event=prompt-rendered out_file=$digest_out"
        printf 'DIGEST_PROMPT: %s\n' "$digest_out"
    fi
}

# digest — render a digest prompt to disk for ad-hoc use.
#   forge-bridge digest --slug <s> --stage <s> --template <name> [--worker <w>]
# Worker defaults to claude-opus when not supplied (digest agents are
# orchestrator-side; the worker token here only affects {worker}/{worker_pane}
# substitutions, which most digest templates do not reference).
cmd_digest() {
    local slug="" stage="" template="" worker="claude-opus"
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)     slug="$2";     shift 2 ;;
            --stage)    stage="$2";    shift 2 ;;
            --template) template="$2"; shift 2 ;;
            --worker)   worker="$2";   shift 2 ;;
            *)          shift ;;
        esac
    done
    if [ -z "$slug" ] || [ -z "$stage" ] || [ -z "$template" ]; then
        echo "Usage: forge-bridge digest --slug <s> --stage <s> --template <name> [--worker <w>]" >&2
        return 1
    fi

    local project_root
    project_root=$(_resolve_project_root "")
    if [ -z "$project_root" ]; then
        _emit_event ERROR "$slug" "stage=$stage reason=project-root-unresolvable"
        echo "ERROR: digest requires forge-project.yml in cwd ancestry" >&2
        return 1
    fi

    local worker_canonical worker_pane
    worker_canonical=$(canonical_pane_name "$worker")
    worker_pane=$(pane_index "$worker")

    local tmpl_path="$FORGE_DIGESTS_DIR/$template.txt"
    local out_dir="$project_root/.dev/forge-tmp"
    mkdir -p "$out_dir"
    local out_file="$out_dir/digest-${stage}-${slug}.txt"

    _render_template "$tmpl_path" "$slug" "$stage" "$worker_canonical" \
        "$worker_pane" "$project_root" > "$out_file" || {
        _emit_event ERROR "$slug" "stage=$stage reason=template-render-failed template=$template"
        return 1
    }

    _emit_event DIGEST "$slug" "stage=$stage template=$template event=prompt-rendered out_file=$out_file"
    echo "DIGEST_PROMPT: $out_file"
}

# emit — orchestrator-driven event emission for the heartbeat log.
#   forge-bridge emit <TYPE> --slug <s> [--stage <s>] [key=value …]
# Validates TYPE against the 8-event whitelist; sanitizes the RHS of each
# passthrough key=value and forwards through _emit_event. Used by the
# orchestrator to emit DIGEST verdicts after consuming digest output
# (and, in v2, routing-decision events).
cmd_emit() {
    if [ $# -lt 1 ]; then
        echo "Usage: forge-bridge emit <TYPE> --slug <s> [--stage <s>] [key=value …]" >&2
        return 1
    fi
    local type="$1"; shift
    case "$type" in
        DISPATCH|WAIT|CALLBACK|DIGEST|STAGE|STALL|ERROR|COMPLETE) ;;
        *)
            echo "ERROR: emit TYPE must be one of DISPATCH|WAIT|CALLBACK|DIGEST|STAGE|STALL|ERROR|COMPLETE; got '$type'" >&2
            return 1
            ;;
    esac
    local slug="" stage=""
    local -a passthrough=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --slug)  slug="$2";  shift 2 ;;
            --stage) stage="$2"; shift 2 ;;
            *)
                if [[ "$1" == *=* ]]; then
                    local k="${1%%=*}" v="${1#*=}"
                    local v_clean
                    v_clean=$(_sanitize_event_value "$v")
                    passthrough+=("$k=$v_clean")
                else
                    passthrough+=("$1")
                fi
                shift
                ;;
        esac
    done
    if [ -z "$slug" ]; then
        echo "ERROR: emit requires --slug" >&2
        return 1
    fi
    local fields=""
    [ -n "$stage" ] && fields="stage=$stage"
    if [ "${#passthrough[@]}" -gt 0 ]; then
        if [ -n "$fields" ]; then
            fields="$fields ${passthrough[*]}"
        else
            fields="${passthrough[*]}"
        fi
    fi
    _emit_event "$type" "$slug" "$fields"
}

cmd_preflight() {
    # Pre-flight discipline (Phase 1a). Prints a kickoff snapshot and a
    # final status_code line. Does NOT require a tmux session. Always
    # exits 0; orchestrator decides whether to halt based on status_code.

    local cur_pwd
    cur_pwd=$(pwd)

    # Resolve expected_root: forge-project.yml field, else nearest-ancestor walk-up.
    local expected_root="" project_yml=""
    local _dir="$cur_pwd"
    while [ "$_dir" != "/" ]; do
        if [ -f "$_dir/.claude/forge-project.yml" ]; then
            project_yml="$_dir/.claude/forge-project.yml"
            break
        fi
        _dir=$(dirname "$_dir")
    done

    if [ -n "$project_yml" ]; then
        expected_root=$(python3 -c "
import yaml
try:
    with open('$project_yml') as f:
        data = yaml.safe_load(f) or {}
    print(data.get('forge', {}).get('expected_root', ''))
except Exception:
    pass
" 2>/dev/null)
        if [ -z "$expected_root" ]; then
            expected_root=$(dirname "$(dirname "$project_yml")")
        fi
    fi

    local directory_state="OK"
    if [ -z "$expected_root" ]; then
        directory_state="UNKNOWN"
    elif [ "$cur_pwd" != "$expected_root" ]; then
        directory_state="WRONG_DIRECTORY"
    fi

    # Branch detection
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    local detached="false"
    if [ -z "$branch" ]; then
        local sha
        sha=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
        branch="(detached: $sha)"
        detached="true"
    fi

    # Resolve base_ref: forge-project.yml override, else origin/HEAD, else origin/main, else main
    local base_ref=""
    if [ -n "$project_yml" ]; then
        base_ref=$(python3 -c "
import yaml
try:
    with open('$project_yml') as f:
        data = yaml.safe_load(f) or {}
    print(data.get('forge', {}).get('base_ref', ''))
except Exception:
    pass
" 2>/dev/null)
    fi
    if [ -z "$base_ref" ]; then
        base_ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/@@')
    fi
    if [ -z "$base_ref" ] && git rev-parse --verify origin/main >/dev/null 2>&1; then
        base_ref="origin/main"
    fi
    if [ -z "$base_ref" ]; then
        base_ref="main"
    fi

    # Merge state detection — see check_merge_state() below
    local merge_state="" merge_method="" merge_detail=""
    if [ "$detached" = "true" ]; then
        merge_state="DETACHED_HEAD"
        merge_method="n/a"
        merge_detail="HEAD is detached at $branch"
    else
        # Method 1: gh-aware
        if command -v gh >/dev/null && gh auth status >/dev/null 2>&1; then
            local pr_json
            pr_json=$(gh pr list --state merged --head "$branch" --limit 1 --json number,mergedAt 2>/dev/null)
            local pr_num
            pr_num=$(echo "$pr_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0]['number']) if d else None" 2>/dev/null)
            if [ -n "$pr_num" ] && [ "$pr_num" != "None" ]; then
                local pr_merged_at
                pr_merged_at=$(echo "$pr_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0]['mergedAt'][:10]) if d else None" 2>/dev/null)
                local cherry_count
                cherry_count=$(git rev-list --cherry-pick --right-only --count "$base_ref...$branch" 2>/dev/null || echo "?")
                merge_method="gh"
                if [ "$cherry_count" = "0" ]; then
                    merge_state="BRANCH_MERGED_CLEAN"
                    merge_detail="PR #$pr_num merged $pr_merged_at; no drift"
                elif [ "$cherry_count" = "?" ]; then
                    merge_state="BRANCH_UNCLEAR"
                    merge_detail="PR #$pr_num merged $pr_merged_at; cherry-pick count failed"
                else
                    merge_state="BRANCH_MERGED_WITH_DRIFT"
                    merge_detail="PR #$pr_num merged $pr_merged_at; $cherry_count commits since merge (vs $base_ref)"
                fi
            fi
        fi

        # Method 2: git-only fallback
        if [ -z "$merge_state" ]; then
            merge_method="git-only"
            if git merge-base --is-ancestor HEAD "$base_ref" 2>/dev/null; then
                merge_state="BRANCH_MERGED_CLEAN"
                merge_detail="HEAD is an ancestor of $base_ref"
            else
                local cherry_count
                cherry_count=$(git rev-list --cherry-pick --right-only --count "$base_ref...$branch" 2>/dev/null)
                if [ "$cherry_count" = "0" ]; then
                    merge_state="BRANCH_MERGED_CLEAN"
                    merge_detail="cherry-pick count vs $base_ref is 0"
                else
                    merge_state="BRANCH_UNMERGED"
                    merge_detail="${cherry_count:-?} unique commits vs $base_ref"
                fi
            fi
        fi
    fi

    # Determine status_code and human status
    local status_code=""
    local status=""
    case "$merge_state" in
        BRANCH_UNMERGED)
            if [ "$directory_state" = "WRONG_DIRECTORY" ]; then
                status_code="WRONG_DIRECTORY"
                status="HALT: pwd does not match expected_root ($expected_root)."
            else
                status_code="OK"
                status="OK"
            fi
            ;;
        BRANCH_MERGED_CLEAN)
            if [ "$directory_state" = "WRONG_DIRECTORY" ]; then
                status_code="WRONG_DIRECTORY"
                status="HALT: pwd does not match expected_root ($expected_root)."
            else
                status_code="BRANCH_MERGED_CLEAN"
                status="WARN: branch is fully merged with no drift. Proceed only if intentionally re-using a merged branch."
            fi
            ;;
        BRANCH_MERGED_WITH_DRIFT)
            status_code="BRANCH_MERGED_WITH_DRIFT"
            status="HALT: branch was merged in $merge_detail. Continuing risks piling onto an already-merged branch."
            ;;
        DETACHED_HEAD)
            status_code="DETACHED_HEAD"
            status="HALT: HEAD is detached. Check out a branch before running pipeline."
            ;;
        BRANCH_UNCLEAR)
            status_code="BRANCH_UNCLEAR"
            status="HALT: merge state is ambiguous. Resolve manually before proceeding."
            ;;
        *)
            status_code="UNKNOWN"
            status="HALT: merge state could not be determined."
            ;;
    esac

    cat <<EOF
=== Forge Preflight ===
pwd:                $cur_pwd
expected_root:      ${expected_root:-(not configured)}
directory_state:    $directory_state
branch:             $branch
base_ref:           $base_ref
merge_state:        $merge_state
merge_check_method: $merge_method
merge_check_detail: $merge_detail
status:             $status
status_code:        $status_code
EOF
    return 0
}

cmd_add_note() {
    local note="$*"

    if [ -z "$note" ]; then
        echo "Usage: forge-bridge add-note <your note>"
        return 1
    fi

    if [ ! -f "$CONTEXT_FILE" ]; then
        echo "ERROR: No active context. Run set-context first."
        return 1
    fi

    python3 << PYEOF
import yaml

with open("$CONTEXT_FILE") as f:
    data = yaml.safe_load(f) or {}

notes = data.get("notes", [])
if isinstance(notes, list):
    notes.append("$note")
else:
    notes = ["$note"]
data["notes"] = notes

with open("$CONTEXT_FILE", "w") as f:
    yaml.dump(data, f, default_flow_style=False, sort_keys=False)

print("Note added.")
PYEOF
}

# ---- Stall Detection (Phase 1b) ----

# Cache and config locations.
FORGE_CACHE_DIR="${FORGE_CACHE_DIR:-$HOME/.cache/forge}"
FORGE_IDLE_PROMPTS_FILE="${FORGE_IDLE_PROMPTS_FILE:-$HOME/.config/forge/idle-prompts.yml}"

# Resolve project root. With $1 set (explicit --project-root arg), validate
# the path contains .claude/forge-project.yml. Without, walk up from cwd.
# Echoes the resolved absolute path on success; empty on failure.
_resolve_project_root() {
    local explicit="$1"
    if [ -n "$explicit" ]; then
        if [ -d "$explicit" ] && [ -f "$explicit/.claude/forge-project.yml" ]; then
            (cd "$explicit" && pwd)
            return 0
        fi
        return 1
    fi
    local _dir
    _dir="$(pwd)"
    while [ "$_dir" != "/" ]; do
        if [ -f "$_dir/.claude/forge-project.yml" ]; then
            echo "$_dir"
            return 0
        fi
        _dir=$(dirname "$_dir")
    done
    return 1
}

# stall-check — classify pane state per Phase 1b §2.1 gate.
# Tmux-required. Reads pane via capture-pane; writes per-pane snapshot to
# ~/.cache/forge/; writes signal via cmd_signal on STALLED/PROMPTING/
# COMPLETED-PENDING-LOG-RESPONSE/DEAD; never writes to .dev/forge-log.yml.
cmd_stall_check() {
    local project_root_arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --project-root) project_root_arg="$2"; shift 2 ;;
            --) shift; break ;;
            -*) echo "Unknown flag: $1" >&2; return 1 ;;
            *) break ;;
        esac
    done
    local target="$1"
    if [ -z "$target" ]; then
        echo "Usage: forge-bridge stall-check [--project-root <path>] <pane>" >&2
        return 1
    fi

    # §2.6: resolve project root and cd before any .dev/ access.
    local project_root
    project_root=$(_resolve_project_root "$project_root_arg")
    if [ -z "$project_root" ]; then
        echo "UNKNOWN no_project_root pane=$target"
        return 0
    fi
    cd "$project_root" || { echo "UNKNOWN cd_failed pane=$target"; return 0; }

    require_tmux_session "stall-check" || return 1

    local canonical idx
    canonical=$(canonical_pane_name "$target")
    idx=$(pane_index "$target")

    # Pane existence check → DEAD signal.
    if ! tmux list-panes -t "$SESSION:$WINDOW" -F '#{pane_index}' 2>/dev/null | grep -qx "$idx"; then
        cmd_signal "stall-check" "DEAD pane=$canonical session=$SESSION" >/dev/null
        echo "DEAD pane=$canonical session=$SESSION"
        return 0
    fi

    mkdir -p "$FORGE_CACHE_DIR"
    local cache_file="$FORGE_CACHE_DIR/${SESSION}-pane${idx}.snapshot"
    local last_check_file="$FORGE_CACHE_DIR/${SESSION}-pane${idx}.last-stall-check"

    # Capture pane → temp file (avoids argv size limits on large scrollback).
    local raw_file
    raw_file=$(mktemp -t forge-stall-XXXXXX)
    tmux capture-pane -p -t "$SESSION:$WINDOW.$idx" -S -50 > "$raw_file" 2>/dev/null
    if [ ! -s "$raw_file" ]; then
        rm -f "$raw_file"
        echo "UNKNOWN capture_failed pane=$canonical"
        return 0
    fi

    # has_pending_log_for is internal; runs against $SUMMARY_LOG in cwd.
    local pending="false"
    if has_pending_log_for "$canonical"; then
        pending="true"
    fi

    local threshold="${FORGE_STALL_THRESHOLD_S:-600}"
    local now
    now=$(date +%s)

    # Run the classifier. Outputs: STATE: <line> [\n SIGNAL: <payload>].
    local out
    out=$(python3 - "$raw_file" "$cache_file" "$last_check_file" "$pending" \
        "$threshold" "$now" "$canonical" "$FORGE_IDLE_PROMPTS_FILE" \
        "$SUMMARY_LOG" "$project_root" <<'PYEOF'
import sys, os, re, hashlib, yaml

(raw_file, cache_file, last_check_file, pending_str,
 threshold_s, now_s, canonical, prompts_file, summary_log, project_root) = sys.argv[1:11]
pending = (pending_str == "true")
threshold = int(threshold_s)
now = int(now_s)

with open(raw_file) as f:
    raw = f.read()

# V3 normalization rules (committed at verification/phase1b-step0/normalize/regex.yml).
strip_rules = [
    (r'\x1B\[[0-9;]*[A-Za-z]', ''),
    (r'\x1B\][0-9;]*\x07', ''),
    (r'^•\s+Working\s+\([^)]*\)(\s+·\s+.*)?$', '• Working (...)'),
    (r'^─\s+Worked\s+for\s+\d+m?\s*\d*s\s*─*$', '─ Worked for X ──'),
    (r'…\s*$', ''),
    (r'[⠀-⣿]+\s*$', ''),
    (r'\s+$', ''),
]
def normalize(text):
    out = text
    for pat, repl in strip_rules:
        out = re.sub(pat, repl, out, flags=re.MULTILINE)
    return out

# Regex tables from idle-prompts.yml. Missing/empty → UNKNOWN per §3 #3.
prompts = {}
try:
    with open(prompts_file) as f:
        prompts = yaml.safe_load(f) or {}
except (FileNotFoundError, yaml.YAMLError):
    prompts = {}

regex_set = (prompts.get(canonical) or {}) if isinstance(prompts, dict) else {}
idle_re_str = (regex_set.get('idle_prompt_anchor') or
               regex_set.get('idle_prompt') or '').strip()
prompting_re_str = (regex_set.get('approval_prompt') or '').strip()
active_re_str = (regex_set.get('active_work_marker') or '').strip()

idle_re = None
if idle_re_str:
    try:
        idle_re = re.compile(idle_re_str, re.MULTILINE)
    except re.error:
        idle_re = None

prompting_re = None
if prompting_re_str:
    try:
        prompting_re = re.compile(prompting_re_str, re.MULTILINE)
    except re.error:
        prompting_re = None

active_re = None
if active_re_str:
    try:
        active_re = re.compile(active_re_str, re.MULTILINE)
    except re.error:
        active_re = None

normalized = normalize(raw)
new_hash = hashlib.sha256(normalized.encode()).hexdigest()

def _drop_trailing_blanks(text):
    out = text.splitlines()
    while out and not out[-1].strip():
        out.pop()
    return out

raw_lines = _drop_trailing_blanks(raw)
norm_lines_stripped = _drop_trailing_blanks(normalized)
last5 = '\n'.join(raw_lines[-5:])
norm_last5 = '\n'.join(norm_lines_stripped[-5:])
norm_last30 = '\n'.join(norm_lines_stripped[-30:])
lines = raw.splitlines()  # PROMPTING excerpt scan uses raw lines.

# Look up pending entry meta (slug, stage) for signal payload enrichment.
ALIAS_TO_CANONICAL = {
    'inline': 'claude-opus', 'general': 'claude-opus', 'claude-general': 'claude-opus',
    'claude-opus': 'claude-opus', 'opus': 'claude-opus',
    'claude': 'claude', 'orchestrator': 'claude', 'claude-orchestrator': 'claude',
    'codex': 'codex-a', 'codex-a': 'codex-a',
    'codex-b': 'codex-b',
    'claude-sonnet': 'claude-sonnet', 'sonnet': 'claude-sonnet',
}
def alias_canonical(name):
    return ALIAS_TO_CANONICAL.get(name, name)

def lookup_pending_meta():
    try:
        with open(summary_log) as f:
            data = yaml.safe_load(f) or {}
    except (FileNotFoundError, yaml.YAMLError):
        return None, None
    for e in data.get('entries', []) or []:
        if e.get('response') is not None: continue
        if alias_canonical(e.get('to', '')) != canonical: continue
        return e.get('pipeline', ''), e.get('stage', '')
    return None, None

slug_meta, stage_meta = lookup_pending_meta()

cache = None
if os.path.exists(cache_file):
    try:
        with open(cache_file) as f:
            cache = yaml.safe_load(f) or {}
    except Exception:
        cache = None

def write_cache(c):
    with open(cache_file, 'w') as f:
        yaml.safe_dump(c, f, default_flow_style=False, sort_keys=False)

def touch_last_check():
    with open(last_check_file, 'w') as f:
        f.write(str(now))

def emit(state, extra="", signal_payload=None):
    line = f"{state} pane={canonical}"
    if extra:
        line += f" {extra}"
    print(f"STATE: {line}")
    if signal_payload:
        print(f"SIGNAL: {signal_payload}")
    touch_last_check()

def make_payload(state, **kv):
    parts = [f"{state} pane={canonical}"]
    if slug_meta: parts.append(f"slug={slug_meta}")
    if stage_meta: parts.append(f"stage={stage_meta}")
    for k, v in kv.items():
        parts.append(f"{k}={v}")
    return " ".join(parts)

# 1. PROMPTING — before any threshold (§2.3).
if prompting_re and prompting_re.search(raw):
    excerpt = ""
    for line in lines[::-1]:
        if prompting_re.search(line):
            excerpt = line.strip()[:100].replace('"', "'")
            break
    payload = make_payload("PROMPTING", excerpt=f'"{excerpt}"' if excerpt else 'none')
    emit("PROMPTING", f'excerpt="{excerpt}"' if excerpt else "", payload)
    sys.exit(0)

# 2. No cache → baseline (§2.2 explicit UNKNOWN, never ACTIVE).
if not cache:
    write_cache({'version': 1, 'hash': new_hash,
                 'last_changed_at': now, 'last_checked_at': now,
                 'last_signaled_state': '', 'last_signaled_at': 0,
                 'project_root': project_root})
    emit("UNKNOWN", "baseline_pending")
    sys.exit(0)

# Project-root mismatch → wipe and rebaseline (§2.6 self-heal).
if cache.get('project_root') and cache.get('project_root') != project_root:
    write_cache({'version': 1, 'hash': new_hash,
                 'last_changed_at': now, 'last_checked_at': now,
                 'last_signaled_state': '', 'last_signaled_at': 0,
                 'project_root': project_root})
    emit("UNKNOWN", "project_root_mismatch_rebased")
    sys.exit(0)

# Version mismatch → wipe and rebaseline.
if cache.get('version') != 1:
    write_cache({'version': 1, 'hash': new_hash,
                 'last_changed_at': now, 'last_checked_at': now,
                 'last_signaled_state': '', 'last_signaled_at': 0,
                 'project_root': project_root})
    emit("UNKNOWN", "version_mismatch_rebased")
    sys.exit(0)

# 3. No pending dispatch → IDLE. By construction never STALLED (§2.1 gate).
if not pending:
    if new_hash != cache.get('hash'):
        cache.update(hash=new_hash, last_changed_at=now, last_checked_at=now)
    else:
        cache['last_checked_at'] = now
    write_cache(cache)
    emit("IDLE")
    sys.exit(0)

# 4. Pending exists. Idle-regex availability pre-check (§3 #3 — never permissive).
if not idle_re:
    cache['last_checked_at'] = now
    write_cache(cache)
    emit("UNKNOWN", "reason=idle_regex_unavailable")
    sys.exit(0)

# Phase 2: Claude panes require active_work_marker negative gate (§3 #3).
CLAUDE_WORKERS = {'claude-opus', 'claude-sonnet'}
if canonical in CLAUDE_WORKERS and not active_re:
    cache['last_checked_at'] = now
    write_cache(cache)
    emit("UNKNOWN", "reason=active_work_marker_unavailable")
    sys.exit(0)

# 5. Hash changed → real activity.
if new_hash != cache.get('hash'):
    cache.update(hash=new_hash, last_changed_at=now, last_checked_at=now,
                 last_signaled_state='', last_signaled_at=0)
    write_cache(cache)
    elapsed = now - cache['last_changed_at']
    emit("ACTIVE", f"elapsed={elapsed}s")
    sys.exit(0)

elapsed = now - cache.get('last_changed_at', now)

# Phase 2: ACTIVE-via-active_work_marker. This must precede COMPLETED-PENDING
# because Claude's model status line is visible during work and matches the
# idle anchor; the active marker is the discriminator.
if active_re and active_re.search(norm_last30):
    cache.update(hash=new_hash, last_changed_at=now, last_checked_at=now,
                 last_signaled_state='', last_signaled_at=0)
    write_cache(cache)
    elapsed = now - cache['last_changed_at']
    emit("ACTIVE", f"elapsed={elapsed}s")
    sys.exit(0)

# 6. Hash unchanged AND idle regex matches normalized tail → COMPLETED-PENDING-LOG-RESPONSE.
if idle_re.search(norm_last5):
    payload = make_payload("COMPLETED-PENDING-LOG-RESPONSE",
                           hint=f'"run forge-bridge log-response --to {canonical} from pane scrollback"')
    cache.update(last_checked_at=now,
                 last_signaled_state='COMPLETED-PENDING-LOG-RESPONSE',
                 last_signaled_at=now)
    write_cache(cache)
    emit("COMPLETED-PENDING-LOG-RESPONSE", "", payload)
    sys.exit(0)

# 7. Hash unchanged + no idle match + elapsed >= threshold → STALLED (idempotent).
if elapsed >= threshold:
    last_signaled_at = cache.get('last_signaled_at', 0) or 0
    last_changed_at = cache.get('last_changed_at', 0) or 0
    signal_payload = None
    if cache.get('last_signaled_state') != 'STALLED' or last_signaled_at < last_changed_at:
        signal_payload = make_payload("STALLED",
            elapsed=f"{elapsed}s",
            last_change=last_changed_at,
            reason="no-output-with-pending-dispatch")
        cache['last_signaled_state'] = 'STALLED'
        cache['last_signaled_at'] = now
    cache['last_checked_at'] = now
    write_cache(cache)
    emit("STALLED", f"elapsed={elapsed}s", signal_payload)
    sys.exit(0)

# 8. Hash unchanged + below threshold → ACTIVE (waiting). Don't bump last_changed_at.
cache['last_checked_at'] = now
write_cache(cache)
emit("ACTIVE", f"elapsed={elapsed}s")
PYEOF
)
    rm -f "$raw_file"

    local state_line signal_payload
    state_line=$(echo "$out" | grep '^STATE: ' | sed 's/^STATE: //' | head -1)
    signal_payload=$(echo "$out" | grep '^SIGNAL: ' | sed 's/^SIGNAL: //' | head -1)

    if [ -n "$signal_payload" ]; then
        cmd_signal "stall-check" "$signal_payload" >/dev/null
    fi

    if [ -n "$state_line" ]; then
        echo "$state_line"
    else
        echo "UNKNOWN classifier_failed pane=$canonical"
    fi
}

# stall-check-status — no-tmux self-check for stale stall-check coverage.
# Reads pending entries from $SUMMARY_LOG, filters by current session,
# checks last-stall-check timestamp per pane, prints WARN block to stdout
# when stale entries exist. Empty output when healthy.
cmd_stall_check_status() {
    local project_root_arg=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --project-root) project_root_arg="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local project_root
    project_root=$(_resolve_project_root "$project_root_arg")
    [ -z "$project_root" ] && return 0
    cd "$project_root" || return 0

    local threshold="${FORGE_STALL_THRESHOLD_S:-600}"

    # Resolve current session (no tmux required for the env path).
    # Only trust `tmux display-message` when actually inside tmux.
    local current_session
    current_session="${TMUX_SESSION:-}"
    if [ -z "$current_session" ] && [ -n "${TMUX:-}" ]; then
        current_session="$(tmux display-message -p '#{session_name}' 2>/dev/null)"
    fi
    if [ -z "$current_session" ] && [ -f ".dev/.forge-session" ]; then
        current_session=$(cat ".dev/.forge-session")
    fi

    python3 - "$SUMMARY_LOG" "$FORGE_CACHE_DIR" "$current_session" "$threshold" "$project_root" <<'PYEOF'
import sys, os, time, yaml

summary_log, cache_dir, current_session, threshold_s, project_root = sys.argv[1:6]
threshold = int(threshold_s)
now = int(time.time())
stale_threshold = 2 * threshold

ALIAS_TO_CANONICAL = {
    'inline': 'claude-opus', 'general': 'claude-opus', 'claude-general': 'claude-opus',
    'claude-opus': 'claude-opus', 'opus': 'claude-opus',
    'claude': 'claude', 'orchestrator': 'claude', 'claude-orchestrator': 'claude',
    'codex': 'codex-a', 'codex-a': 'codex-a',
    'codex-b': 'codex-b',
    'claude-sonnet': 'claude-sonnet', 'sonnet': 'claude-sonnet',
}
def canonical(name): return ALIAS_TO_CANONICAL.get(name, name)

NAME_TO_IDX = {'claude-opus': 0, 'claude': 1, 'codex-a': 2, 'codex-b': 3, 'claude-sonnet': 4}

try:
    with open(summary_log) as f:
        data = yaml.safe_load(f) or {}
except (FileNotFoundError, yaml.YAMLError):
    sys.exit(0)

warnings = []
for entry in data.get('entries', []) or []:
    if entry.get('response') is not None:
        continue
    target = canonical(entry.get('to', ''))
    idx = NAME_TO_IDX.get(target)
    if idx is None:
        continue
    entry_session = entry.get('session', '')
    if entry_session and current_session and entry_session != current_session:
        continue  # different session; skip silently
    legacy = not bool(entry_session)
    session_for_cache = current_session or entry_session or 'unknown'
    last_check_file = os.path.join(cache_dir, f"{session_for_cache}-pane{idx}.last-stall-check")
    age = None
    if os.path.exists(last_check_file):
        try:
            age = now - int(open(last_check_file).read().strip())
        except Exception:
            age = None
    if age is None or age > stale_threshold:
        slug = entry.get('pipeline', '?')
        stage = entry.get('stage', '?')
        ago = f"{age // 60}m" if age is not None else "never"
        legacy_note = " (legacy entry, no session field)" if legacy else ""
        cmd = f"~/bin/forge-bridge stall-check --project-root \"{project_root}\" {target}"
        warnings.append((target, slug, stage, ago, legacy_note, cmd))

if warnings:
    print("=== Stall Check Status ===")
    for (target, slug, stage, ago, legacy_note, cmd) in warnings:
        print(f"WARN: {target} has pending dispatch (slug={slug}, stage={stage})")
        print(f"      stall-check has not run in {ago}.{legacy_note}")
        print(f"      Run: {cmd}")
PYEOF
}

cmd_alias_self_test() {
    local STRICT=false
    if [ "${1:-}" = "--strict" ]; then
        STRICT=true
        shift
    fi

    python3 - "$0" "$STRICT" <<'PYEOF'
import re, sys

bridge = sys.argv[1]
strict = (sys.argv[2] == 'true')
with open(bridge) as f:
    src = f.read()

pane_index_block = re.search(r'pane_index\(\)\s*\{(.*?)\n\}', src, re.DOTALL)
pane_name_block = re.search(r'pane_name\(\)\s*\{(.*?)\n\}', src, re.DOTALL)
problems = []
if not pane_index_block:
    problems.append("missing pane_index() block")
if not pane_name_block:
    problems.append("missing pane_name() block")
if problems:
    for p in problems:
        print(f"alias-self-test: {p}", file=sys.stderr)
    sys.exit(1)

m_idx = {}
for line in pane_index_block.group(1).splitlines():
    mm = re.match(r'\s+(\S+)\)\s*echo\s*"(\d+|\$1)"', line)
    if not mm:
        continue
    if mm.group(2) == '$1':
        continue
    for alias in mm.group(1).split('|'):
        m_idx[alias] = int(mm.group(2))

m_name = {}
for line in pane_name_block.group(1).splitlines():
    mm = re.match(r'\s+(\d+)\)\s*echo\s*"([^"]+)"', line)
    if mm:
        m_name[int(mm.group(1))] = mm.group(2)

expected_canonical = {alias: m_name[idx] for alias, idx in m_idx.items() if idx in m_name}
if strict and len(expected_canonical) < 7:
    print(f"alias-self-test: STRICT FAIL — parser found {len(expected_canonical)} aliases, expected >=7", file=sys.stderr)
    sys.exit(2)

py_maps = re.findall(r"ALIAS_TO_CANONICAL\s*=\s*\{([^}]+)\}", src)
if strict and len(py_maps) < 4:
    print(f"alias-self-test: STRICT FAIL — parser found {len(py_maps)} ALIAS_TO_CANONICAL maps, expected >=4", file=sys.stderr)
    sys.exit(2)

for i, py_map in enumerate(py_maps):
    pairs = re.findall(r"'([^']+)':\s*'([^']+)'", py_map)
    py_canon = dict(pairs)
    for alias, canonical in expected_canonical.items():
        if alias not in py_canon:
            problems.append(f"map#{i}: missing alias '{alias}'")
        elif py_canon[alias] != canonical:
            problems.append(f"map#{i}: '{alias}' bash='{canonical}' python='{py_canon[alias]}'")

name_to_idx_match = re.search(r"NAME_TO_IDX\s*=\s*\{([^}]+)\}", src)
if not name_to_idx_match:
    problems.append("NAME_TO_IDX missing")
else:
    pairs = re.findall(r"'([^']+)':\s*(\d+)", name_to_idx_match.group(1))
    name_to_idx = dict(pairs)
    for canonical in set(expected_canonical.values()):
        if canonical not in name_to_idx:
            problems.append(f"NAME_TO_IDX missing '{canonical}'")

if problems:
    for p in problems:
        print(f"alias-self-test: {p}", file=sys.stderr)
    sys.exit(1)

print(f"alias-self-test: OK ({len(expected_canonical)} aliases verified, {len(py_maps)} maps checked)")
PYEOF
}

cmd_health() {
    # Per-pane health check. For each canonical pane in the active forge
    # session, verify the pane exists and capture-pane output indicates the
    # expected worker process is running. Exits 0 only if every pane is OK.
    #
    # Output: one line per pane, machine-parseable:
    #   OK pane=<name> idx=<n> kind=<claude|codex> state=<idle|busy|prompting>
    #   DEAD pane=<name> idx=<n>
    #   WRONG_PROCESS pane=<name> idx=<n> expected=<kind> got=<shell|other|empty>
    #   UNKNOWN pane=<name> idx=<n> reason=<capture_failed|...>
    #
    # Followed by a one-line summary: SUMMARY total=5 ok=N dead=N wrong=N unknown=N

    require_tmux_session "health" || return 1

    local tmpdir
    tmpdir=$(mktemp -d -t forge-health-XXXXXX)
    trap 'rm -rf "$tmpdir"' RETURN

    # Expected (canonical_name, idx, kind) tuples.
    # kind is 'claude' or 'codex' — matched against idle-prompts.yml regex tables.
    local specs=(
        "claude-opus:0:claude-opus"
        "claude:1:claude-opus"
        "codex-a:2:codex-a"
        "codex-b:3:codex-b"
        "claude-sonnet:4:claude-sonnet"
    )

    local existing_idxs
    existing_idxs=$(tmux list-panes -t "$SESSION:$WINDOW" -F '#{pane_index}' 2>/dev/null | tr '\n' ' ')

    local ok=0 dead=0 wrong=0 unknown=0
    local spec name idx kind raw_file out
    for spec in "${specs[@]}"; do
        name="${spec%%:*}"
        local rest="${spec#*:}"
        idx="${rest%%:*}"
        kind="${rest##*:}"

        if ! echo " $existing_idxs " | grep -q " $idx "; then
            echo "DEAD pane=$name idx=$idx"
            dead=$((dead+1))
            continue
        fi

        raw_file="$tmpdir/pane-$idx.txt"
        tmux capture-pane -p -t "$SESSION:$WINDOW.$idx" -S -50 > "$raw_file" 2>/dev/null
        if [ ! -s "$raw_file" ]; then
            echo "UNKNOWN pane=$name idx=$idx reason=capture_failed"
            unknown=$((unknown+1))
            continue
        fi

        out=$(python3 - "$raw_file" "$kind" "$FORGE_IDLE_PROMPTS_FILE" <<'PYEOF'
import sys, re, yaml

raw_file, expected_kind, prompts_file = sys.argv[1], sys.argv[2], sys.argv[3]

with open(raw_file) as f:
    raw = f.read()

# Same V3 normalization the stall classifier uses.
strip_rules = [
    (r'\x1B\[[0-9;]*[A-Za-z]', ''),
    (r'\x1B\][0-9;]*\x07', ''),
    (r'^•\s+Working\s+\([^)]*\)(\s+·\s+.*)?$', '• Working (...)'),
    (r'^─\s+Worked\s+for\s+\d+m?\s*\d*s\s*─*$', '─ Worked for X ──'),
    (r'…\s*$', ''),
    (r'[⠀-⣿]+\s*$', ''),
    (r'\s+$', ''),
]
def normalize(text):
    out = text
    for pat, repl in strip_rules:
        out = re.sub(pat, repl, out, flags=re.MULTILINE)
    return out

norm = normalize(raw)
lines = [ln for ln in norm.splitlines() if ln.strip() != '']
tail = lines[-25:] if lines else []
tail_text = '\n'.join(tail)

try:
    with open(prompts_file) as f:
        prompts = yaml.safe_load(f) or {}
except (FileNotFoundError, yaml.YAMLError):
    print(f"UNKNOWN reason=prompts_file_missing")
    sys.exit(0)

cfg = prompts.get(expected_kind) or {}
idle_re = cfg.get('idle_prompt_anchor') or ''
active_re = cfg.get('active_work_marker') or ''
approval_re = cfg.get('approval_prompt') or ''

def any_match(pattern, text):
    if not pattern:
        return False
    try:
        return re.search(pattern, text, re.MULTILINE) is not None
    except re.error:
        return False

# Detect the broad family. Claude panes show '━' bordered prompt; codex
# panes show 'gpt-X.X' header. Look for ANY claude/codex idle anchor across
# all known kinds, then compare against the expected one.
all_idle = {}
all_active = {}
for k, v in (prompts or {}).items():
    if not isinstance(v, dict):
        continue
    all_idle[k] = v.get('idle_prompt_anchor') or ''
    all_active[k] = v.get('active_work_marker') or ''

detected_kind = None
for k, pat in all_idle.items():
    if any_match(pat, tail_text):
        detected_kind = k
        break
if detected_kind is None:
    for k, pat in all_active.items():
        if any_match(pat, tail_text):
            detected_kind = k
            break

if detected_kind is None:
    # No worker prompts detected. Heuristic for raw shell.
    last = tail[-1] if tail else ''
    shellish = bool(re.search(r'[\$%#>]\s*$', last)) or 'bash-' in last or last.endswith('$')
    if shellish:
        print(f"WRONG_PROCESS got=shell")
    else:
        print(f"UNKNOWN reason=no_marker_match")
    sys.exit(0)

# Normalize family: claude-opus/claude-sonnet → claude, codex-a/codex-b → codex
def family(k):
    if k.startswith('claude'): return 'claude'
    if k.startswith('codex'):  return 'codex'
    return k

if family(detected_kind) != family(expected_kind):
    print(f"WRONG_PROCESS got={detected_kind}")
    sys.exit(0)

# Right family. Determine state.
state = 'idle'
if any_match(active_re, tail_text):
    state = 'busy'
elif any_match(approval_re, tail_text):
    state = 'prompting'
elif any_match(idle_re, tail_text):
    state = 'idle'
else:
    state = 'unknown'

print(f"OK kind={family(detected_kind)} state={state}")
PYEOF
)
        case "$out" in
            OK*)            echo "OK pane=$name idx=$idx ${out#OK }"; ok=$((ok+1)) ;;
            WRONG_PROCESS*) echo "WRONG_PROCESS pane=$name idx=$idx expected=$kind ${out#WRONG_PROCESS }"; wrong=$((wrong+1)) ;;
            *)              echo "UNKNOWN pane=$name idx=$idx ${out#UNKNOWN }"; unknown=$((unknown+1)) ;;
        esac
    done

    echo "SUMMARY total=5 ok=$ok dead=$dead wrong=$wrong unknown=$unknown session=$SESSION"

    if [ "$ok" -eq 5 ]; then
        return 0
    fi
    return 1
}

