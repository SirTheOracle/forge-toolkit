#!/bin/bash
# forge — command center facade (Phase A).
#
# The bridge (forge-bridge) stays the pipeline primitive with its verbs
# untouched; the center's user-facing verbs live here.
#
# Verbs (Phase A):
#   forge dispatch @<session> "<instruction>" [--sender S] [--pointer]
#                  [--allow-api-billing] [--dry-run] [--answers <ask-id>] [--wait [--timeout N]]
#   forge reply @<session> [<dispatch-id>] [--json|--snippet]   print a worker's answer
#   forge spawn [name] [--root PATH] [--allow-api-billing] [--no-populate] [--force]
#                  ensure-semantics 5-pane session (single-root invariant)
#   forge ask  --session-scope "<question>"                 (called BY workers)
#   forge ask  --slug S --stage T --worker W "<question>"
#   forge preflight [--root PATH] [--allow-api-billing]
#   forge register <root> [--force]
#   forge board [--all]             human board (--all lists maintenance residue)
#   forge board --json              machine cc-board/1 JSON
#   forge status [--board]          alias for board (--board = the JSON)
#   forge gc [--root PATH] [--days N]
#   forge gc --install | --uninstall    daily launchd backstop (com.forge.gc)
#
# Dispatch REUSES `forge-bridge send claude` (the proven 3-step cmd_send split);
# it never reimplements tmux send-keys. Every write lands under the target root's
# .dev/attention/ — forge-watch only reads them.
set -euo pipefail

FORGE_BRIDGE_BIN="${FORGE_BRIDGE_BIN:-$HOME/bin/forge-bridge}"
FORGE_WATCH_BIN="${FORGE_WATCH_BIN:-$HOME/bin/forge-watch}"
INLINE_MAX="${FORGE_DISPATCH_INLINE_MAX:-280}"
TTL_D="${FORGE_ATTENTION_TTL_D:-7}"
CC_HOOK_MARK="forge-cc-hook"
REGISTRY_FILE="${FORGE_REGISTRY_FILE:-$HOME/.config/forge/registry.yml}"
FORGE_TMUX_BIN="${FORGE_TMUX_BIN:-tmux}"
FORGE_START_BIN="${FORGE_START_BIN:-$HOME/bin/forge-start}"

die() { printf 'forge: %s\n' "$*" >&2; exit 1; }

# Step 6: fire a detached, fail-open forge-watch check after a state-changing write so the board/
# ambient surface update at ~1s. FORGE_WATCH_TRIGGER=0 disables (tests); the watcher's non-blocking
# flock coalesces concurrent triggers; callers never block on it.
fire_watch_check() {
    [ "${FORGE_WATCH_TRIGGER:-1}" = "1" ] || return 0
    [ -x "$FORGE_WATCH_BIN" ] || return 0
    ( nohup "$FORGE_WATCH_BIN" check >/dev/null 2>&1 & ) 2>/dev/null || true
}

# Resolve the toolkit root, following symlinks — BSD `readlink` has no -f on
# macOS (verified), so walk the link chain portably. Locates
# ../config/claude-cc-hooks.json when `forge` runs as a ~/bin symlink into the repo.
_toolkit_root() {
    local src="$0" dir
    while [ -L "$src" ]; do
        dir="$(cd "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        case "$src" in /*) ;; *) src="$dir/$src" ;; esac
    done
    ( cd "$(dirname "$src")/.." && pwd )
}

# session_root <session> → prints realpath of the session cwd; nonzero if none.
# Test seam: FORGE_TMUX_LIST names a 'name<TAB>path' file (forge-watch's convention).
session_root() {
    local sess="$1" inject="${FORGE_TMUX_LIST:-}"
    if [ -n "$inject" ]; then
        awk -F'\t' -v s="$sess" '$1==s{print $2; f=1} END{exit !f}' "$inject"
    else
        tmux list-sessions -F '#{session_name}	#{session_path}' 2>/dev/null \
            | awk -F'\t' -v s="$sess" '$1==s{print $2; f=1} END{exit !f}'
    fi
}

# ── naming: sanitize BY TRANSFORMATION (P4) ──────────────────────────────
# The bridge charset guard (^[A-Za-z0-9_.-]+$) REJECTS-TO-EMPTY, so sanitize
# BEFORE any name reaches it: map disallowed → '-', collapse runs, trim.
sanitize_name() {
    printf '%s' "$1" | LC_ALL=C sed -E 's/[^A-Za-z0-9_.-]+/-/g; s/-+/-/g; s/^-+//; s/-+$//'
}

# repo identity (P3a): realpath of the git COMMON dir — shared across all
# worktrees of a clone, distinct per clone/fork. "" (nonzero) if not a git repo.
repo_identity() {   # repo_identity <root>
    local cd
    cd="$(git -C "$1" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
    [ -n "$cd" ] || return 1
    ( cd "$cd" 2>/dev/null && pwd -P )
}

# ── registry (mini-spec 1 / P3) — durable per-REPO declaration ────────────
# ~/.config/forge/registry.yml. MAP keyed by repo_id (natural unit + dedup).
# flock-guarded atomic write mirroring the bridge's infra-lock fcntl.flock
# pattern, with a re-parse-before-publish guard (precedent: the hook-merge at
# cmd_register). LOUD (never silent sys.exit(0)) on corrupt YAML / unexpected
# shape (non-empty files must carry schema cc-registry/1 — foreign YAML dicts
# are never adopted) / dup-alias-for-a-different-repo. Missing path RECORDED,
# not fatal.
registry_write() {   # registry_write <repo_id> <alias> <path>
    FORGE_REG_ID="$1" FORGE_REG_ALIAS="$2" FORGE_REG_PATH="$3" \
    FORGE_REG_FILE="$REGISTRY_FILE" python3 - <<'PY'
import os, sys, fcntl, datetime
try:
    import yaml
except ImportError:
    sys.exit("forge: registry requires PyYAML (python3 -m pip install pyyaml)")
fp = os.environ["FORGE_REG_FILE"]; rid = os.environ["FORGE_REG_ID"]
alias = os.environ["FORGE_REG_ALIAS"]; path = os.environ["FORGE_REG_PATH"]
if not rid:
    sys.exit("forge: registry — empty repo_id (not a git repo?)")
os.makedirs(os.path.dirname(fp), exist_ok=True)
with open(fp + ".lock", "w") as lf:
    fcntl.flock(lf, fcntl.LOCK_EX)
    try:
        data = {"schema": "cc-registry/1", "repos": {}}
        if os.path.exists(fp):
            try:
                with open(fp) as f: loaded = yaml.safe_load(f)
            except Exception as e:
                sys.exit(f"forge: REFUSE — registry {fp} is corrupt YAML ({e}); not touched")
            if loaded is not None:
                # Adopt an existing non-empty file ONLY if it self-identifies as
                # ours: an arbitrary valid-YAML dict (a misdirected forge-project.yml,
                # say) must not be silently repurposed and rewritten as a registry.
                # A future-schema file is refused too — this writer would downgrade it.
                if (not isinstance(loaded, dict)
                        or loaded.get("schema") != "cc-registry/1"
                        or not isinstance(loaded.get("repos", {}), dict)
                        or not all(isinstance(v, dict) for v in (loaded.get("repos") or {}).values())):
                    sys.exit(f"forge: REFUSE — registry {fp} has an unexpected shape "
                             f"(not a cc-registry/1 map); not touched")
                data = loaded
        repos = data.setdefault("repos", {}); data["schema"] = "cc-registry/1"
        for k, v in repos.items():
            if k != rid and isinstance(v, dict) and v.get("alias") == alias:
                sys.exit(f"forge: REFUSE — alias '{alias}' already registered to a different repo "
                         f"({k}); pass a distinct --alias")
        entry = repos.get(rid) if isinstance(repos.get(rid), dict) else {}
        # color_slot / port_range are RESERVED for a future chrome/ports pass —
        # declaration, not allocation (nothing consumes them yet; the merge-
        # upsert admits new keys later with zero migration).
        entry.setdefault("color_slot", None)
        entry.setdefault("port_range", None)
        entry.setdefault("registered_at", datetime.datetime.now(datetime.timezone.utc)
                         .strftime("%Y-%m-%dT%H:%M:%SZ"))
        entry.update({"alias": alias, "path": path, "repo_id": rid,
                      "path_exists": os.path.isdir(path)})
        repos[rid] = entry
        tmp = fp + ".tmp.%d" % os.getpid()
        with open(tmp, "w") as f:
            yaml.safe_dump(data, f, default_flow_style=False, sort_keys=True)
        with open(tmp) as f:                                  # re-parse before publish
            if not isinstance(yaml.safe_load(f), dict):
                os.remove(tmp); sys.exit("forge: REFUSE — serialized registry failed re-parse; not published")
        os.replace(tmp, fp)
    finally:
        fcntl.flock(lf, fcntl.LOCK_UN)
print(f"registry: {alias} -> {path} [{rid}]")
PY
}

# registry_alias_for <root> → alias for this root's repo, else sanitized dirname.
# READ-ONLY (safe in --dry-run).
registry_alias_for() {
    local root="$1"
    FORGE_REG_ROOT="$root" FORGE_REG_FILE="$REGISTRY_FILE" python3 - <<'PY' 2>/dev/null \
        || sanitize_name "$(basename "$root")"
import os, sys, subprocess
root, fp = os.environ["FORGE_REG_ROOT"], os.environ["FORGE_REG_FILE"]
try:
    import yaml
except ImportError:
    raise SystemExit(1)
if not os.path.exists(fp):
    raise SystemExit(1)
with open(fp) as f: reg = yaml.safe_load(f) or {}
cd = subprocess.run(["git", "-C", root, "rev-parse", "--path-format=absolute", "--git-common-dir"],
                    capture_output=True, text=True)
rid = os.path.realpath(cd.stdout.strip()) if cd.returncode == 0 and cd.stdout.strip() else None
for k, v in (reg.get("repos") or {}).items():
    if isinstance(v, dict) and (k == rid or v.get("repo_id") == rid) and v.get("alias"):
        print(v["alias"]); raise SystemExit(0)
raise SystemExit(1)
PY
}

# One-time migration: seed the registry from the live watch-roots list (P3c).
# Registry-only — skips the gitignore gate + hook merge (those roots came
# through the normal register path already, or will).
registry_seed() {
    local wr="$HOME/.config/forge/watch-roots"
    [ -f "$wr" ] || { echo "no watch-roots to seed ($wr)"; return 0; }
    local r rid
    grep -v '^[[:space:]]*#' "$wr" | sed '/^[[:space:]]*$/d' | while read -r r; do
        [ -d "$r" ] || { echo "skip (missing path): $r" >&2; continue; }
        rid="$(repo_identity "$r")" || { echo "skip (not a git repo): $r" >&2; continue; }
        registry_write "$rid" "$(sanitize_name "$(basename "$r")")" "$r" \
            || echo "skip (registry refused): $r" >&2
    done
}

# spawn-state attention event (P6) — cc-spawn/1, event=spawn-state. Keyed
# spawn-<session>-<state>.json so a re-run OVERWRITES (forge-watch dedups
# findings by key; the real reason for keyed filenames is that a RESOLVED
# state must be removable and files must not accumulate). Swept by the same
# 7d/-maxdepth 2 attention GC (HC6). Never fails the caller.
spawn_state_event() {   # spawn_state_event <root> <session> <state> <detail>
    FORGE_SS_ROOT="$1" FORGE_SS_SESS="$2" FORGE_SS_STATE="$3" FORGE_SS_DET="${4:-}" \
    python3 - <<'PY' || true
import os, json, datetime
root = os.environ["FORGE_SS_ROOT"]; sess = os.environ["FORGE_SS_SESS"]
st   = os.environ["FORGE_SS_STATE"]; det = os.environ.get("FORGE_SS_DET", "")
now  = datetime.datetime.now(datetime.timezone.utc)
adir = os.path.join(root, ".dev", "attention"); os.makedirs(adir, exist_ok=True)
rec  = {"schema": "cc-spawn/1", "event": "spawn-state", "session": sess, "root": root,
        "state": st, "detail": det, "emitted_at": now.strftime("%Y-%m-%dT%H:%M:%SZ")}
path = os.path.join(adir, f"spawn-{sess}-{st}.json"); tmp = path + f".tmp.{os.getpid()}"
with open(tmp, "w") as f: json.dump(rec, f, indent=2)
os.chmod(tmp, 0o600); os.replace(tmp, path)
PY
}

# ── billing preflight (mini-spec 5) ──────────────────────────────────────
billing_preflight() {   # billing_preflight <root> <allow:0|1>
    local root="${1:-}" allow="${2:-0}"
    [ "${FORGE_ALLOW_API_BILLING:-0}" = "1" ] && allow=1
    FORGE_BILLING_ROOT="$root" FORGE_BILLING_ALLOW="$allow" python3 - <<'PY'
import os, sys, json
root  = os.environ.get("FORGE_BILLING_ROOT", "")
allow = os.environ.get("FORGE_BILLING_ALLOW", "0") == "1"
hits, lines = [], []
def note(label, bad, where=""):
    lines.append(("FAIL" if bad else "OK  ") + "  " + label + (f" ({where})" if bad and where else ""))
    if bad: hits.append(label + ((" in " + where) if where else ""))
env = os.environ
for k in ("ANTHROPIC_API_KEY", "ANTHROPIC_AUTH_TOKEN", "ANTHROPIC_BASE_URL",
          "ANTHROPIC_BEDROCK_BASE_URL", "ANTHROPIC_VERTEX_BASE_URL"):
    note(f"env {k} unset", bool(env.get(k)), "shell env")
for k in ("CLAUDE_CODE_USE_BEDROCK", "CLAUDE_CODE_USE_VERTEX"):
    note(f"env {k} off", env.get(k, "") not in ("", "0", "false", "False"), "shell env")
files = []
if root:
    files += [os.path.join(root, ".claude", "settings.json"),
              os.path.join(root, ".claude", "settings.local.json")]
files.append(os.path.expanduser("~/.claude/settings.json"))
for fp in files:
    try:
        with open(fp) as f: d = json.load(f)
    except (OSError, ValueError):
        continue
    if not isinstance(d, dict): continue
    if d.get("apiKeyHelper"): note("apiKeyHelper unset", True, fp)
    e = d.get("env") or {}
    if isinstance(e, dict):
        for k in ("ANTHROPIC_API_KEY", "ANTHROPIC_AUTH_TOKEN", "ANTHROPIC_BASE_URL",
                  "CLAUDE_CODE_USE_BEDROCK", "CLAUDE_CODE_USE_VERTEX"):
            v = e.get(k)
            note(f"env.{k} unset", v not in (None, "", "0", "false", "False"), fp)
print("billing preflight:")
print("\n".join("  " + l for l in lines))
if hits:
    print(f"VERDICT: {'WARN (overridden by --allow-api-billing)' if allow else 'FAIL'} — "
          f"{len(hits)} issue(s): {', '.join(hits)}")
    sys.exit(0 if allow else 2)
print("VERDICT: OK — subscription billing route clean")
sys.exit(0)
PY
}

# ── attention GC (mini-spec 1 retention) — forge owns deletion under .dev/ ─
gc_root() {   # gc_root <root>
    local att="$1/.dev/attention"
    [ -d "$att" ] || return 0
    # Task-aware 7d sweep (P17). Same reach as the old
    # `find -maxdepth 2 -name '*.json'/'*.txt' -mtime +TTL -delete`, but a record whose task
    # never reached a terminal state is EXEMPT: a dispatch-<id>.json with no response.<id>.txt
    # (+ its instruction payload payloads/<id>.txt), and a wprompt.* whose task_id has no
    # matching wstop.*. A genuinely stuck task stays visible (TASK-STUCK) instead of vanishing on
    # day 7. Fail-open: any error → leave files in place (never a broad delete).
    FORGE_GC_ATT="$att" FORGE_GC_TTL="$TTL_D" python3 - <<'PY' 2>/dev/null || true
import os, glob, json, time
att = os.environ["FORGE_GC_ATT"]; ttl = int(os.environ["FORGE_GC_TTL"])
cutoff = time.time() - ttl * 86400
pdir = os.path.join(att, "payloads")
def old(p):
    try: return os.path.getmtime(p) < cutoff
    except OSError: return False
exempt = set()   # realpaths never deleted regardless of age
# unterminated dispatched tasks: dispatch-<id>.json with no response.<id>.txt
for dp in glob.glob(os.path.join(att, "dispatch-*.json")):
    did = os.path.basename(dp)[len("dispatch-"):-len(".json")]
    if not os.path.exists(os.path.join(pdir, f"response.{did}.txt")):
        exempt.add(os.path.realpath(dp))
        ip = os.path.join(pdir, f"{did}.txt")          # keep its instruction payload too
        if os.path.exists(ip): exempt.add(os.path.realpath(ip))
# unterminated worker turns: wprompt whose task_id has no matching wstop (task_id read from the
# JSON body — robust to a dot in the id, which filename-splitting is not).
wstop_tids = set()
for wsp in glob.glob(os.path.join(att, "wstop.*.json")):
    try: wstop_tids.add((json.load(open(wsp)) or {}).get("task_id"))
    except Exception: pass
for wpp in glob.glob(os.path.join(att, "wprompt.*.json")):
    try: tid = (json.load(open(wpp)) or {}).get("task_id")
    except Exception: tid = None
    if tid is None or tid not in wstop_tids:
        exempt.add(os.path.realpath(wpp))
# sweep depth<=2 (.json/.txt): everything aged out except the exempt set
bases = [att] + [os.path.join(att, d) for d in os.listdir(att)
                 if os.path.isdir(os.path.join(att, d))]
for base in bases:
    for name in os.listdir(base):
        p = os.path.join(base, name)
        if not os.path.isfile(p): continue
        if not (name.endswith(".json") or name.endswith(".txt")): continue
        if os.path.realpath(p) in exempt: continue
        if old(p):
            try: os.remove(p)
            except OSError: pass
PY
}

cmd_preflight() {
    local root="" allow=0
    while [ $# -gt 0 ]; do case "$1" in
        --root) root="$2"; shift 2 ;;
        --allow-api-billing) allow=1; shift ;;
        *) shift ;;
    esac; done
    [ -n "$root" ] || root="$(pwd -P)"
    billing_preflight "$root" "$allow"
}

# _dispatch_fail <msg> — die; but if this dispatch is an --answers reply the ask
# is already claimed (archived + BLOCKED callback consumed), so ANY post-claim
# failure must tell the operator the answer is recorded and how to re-deliver.
# Reads the caller's $answers/$session (cmd_dispatch locals) via bash dynamic scope.
_dispatch_fail() {
    if [ -n "${answers:-}" ]; then
        die "$1 AFTER the answer was recorded (ask $answers archived + callback consumed). Re-deliver with a PLAIN dispatch (no --answers): forge dispatch @$session \"<answer>\""
    fi
    die "$1"
}

# ── dispatch (mini-spec 1) ───────────────────────────────────────────────
cmd_dispatch() {
    local session="" instr="" sender="" force_pointer=false allow=0 dry=false answers=""
    local wait=false timeout="${FORGE_DISPATCH_WAIT_TIMEOUT:-180}"
    [ "${FORGE_DISPATCH_DRY_RUN:-0}" = "1" ] && dry=true
    while [ $# -gt 0 ]; do case "$1" in
        @*) session="${1#@}"; shift ;;
        --sender) sender="$2"; shift 2 ;;
        --pointer) force_pointer=true; shift ;;
        --allow-api-billing) allow=1; shift ;;
        --dry-run) dry=true; shift ;;
        --answers) answers="$2"; shift 2 ;;
        --wait) wait=true; shift ;;
        --timeout) timeout="$2"; shift 2 ;;
        --*) die "unknown flag $1" ;;
        *) if [ -z "$instr" ]; then instr="$1"; else instr="$instr $1"; fi; shift ;;
    esac; done
    [ -n "$session" ] || die "dispatch requires @<session>"
    [ -n "$instr" ]   || die "dispatch requires an instruction"
    [ -n "$sender" ]  || sender="${FORGE_SENDER:-seat}"

    local root
    root="$(session_root "$session")" || die "no live session '$session' (session_path unresolvable)"
    root="$(cd "$root" 2>/dev/null && pwd -P)" || die "session '$session' root does not exist"

    # Billing preflight — silent on pass, loud on fail, BEFORE any write/inject.
    local bp brc
    bp="$(billing_preflight "$root" "$allow" 2>&1)"; brc=$?
    if [ "$brc" -ne 0 ]; then
        printf '%s\n' "$bp" >&2
        die "billing preflight failed for $root (use --allow-api-billing to override)"
    fi

    # ── answer lifecycle (Phase B, mini-spec 3) ──────────────────────────────
    # Claim the ask by ATOMIC archive (the exactly-once gate), enforce the session
    # guard, then consume its BLOCKED callback. AFTER billing (billing gates every
    # dispatch incl. --answers) and BEFORE the event write/inject, so a
    # double-answer fails loud before anything is injected and a billing failure
    # never orphans an ask. The <ask-id> is charset-guarded against path traversal.
    local ans_mode="" ans_slug="" ans_stage=""
    if [ -n "$answers" ]; then
        local af; af="$(mktemp "${TMPDIR:-/tmp}/forge-answers.XXXXXX")"
        FORGE_ANS_SESSION="$session" python3 - "$root" "$answers" "$af" <<'PY' \
            || { rm -f "$af"; exit 1; }
import os, sys, json, re
root, ask_id, af = sys.argv[1], sys.argv[2], sys.argv[3]
want_session = os.environ.get("FORGE_ANS_SESSION", "")
if not re.fullmatch(r"ask-[0-9A-Za-z-]+", ask_id):
    sys.exit(f"forge: answer: '{ask_id}' is not a valid ask-id (ask-<ts>-<hex>)")
adir = os.path.join(root, ".dev", "attention")
src = os.path.join(adir, ask_id + ".json")
arch_dir = os.path.join(adir, "archive"); arch = os.path.join(arch_dir, ask_id + ".json")
if not os.path.exists(src):
    if os.path.exists(arch):
        sys.exit(f"forge: answer: ask {ask_id} already answered (archived)")
    sys.exit(f"forge: answer: unknown ask-id {ask_id} (no such ask under {root})")
try:
    with open(src) as f: rec = json.load(f)
except (OSError, ValueError):
    sys.exit(f"forge: answer: ask {ask_id} is unreadable or corrupt")
ask_sess = rec.get("session") or ""
if ask_sess and want_session and ask_sess != want_session:
    sys.exit(f"forge: answer: ask {ask_id} belongs to session '{ask_sess}', not '@{want_session}' "
             f"— dispatch --answers to the right session")
os.makedirs(arch_dir, exist_ok=True)
try:
    os.replace(src, arch)          # atomic exactly-once claim (archive-not-delete)
except OSError:
    sys.exit(f"forge: answer: ask {ask_id} could not be claimed (already answered / race)")
with open(af, "w") as f:
    f.write("\t".join(str(rec.get(k) or "") for k in ("mode", "slug", "stage")))
PY
        IFS=$'\t' read -r ans_mode ans_slug ans_stage < "$af" || true
        rm -f "$af"
        # Consume the worker's BLOCKED callback EXACTLY ONCE (stage-mode asks only).
        # Idempotent structured no-op if already consumed (e.g. by the orchestrator).
        if [ "$ans_mode" = "stage" ] && [ -n "$ans_slug" ] && [ -n "$ans_stage" ]; then
            ( cd "$root" && "$FORGE_BRIDGE_BIN" callback-consume \
                --slug "$ans_slug" --stage "$ans_stage" --status BLOCKED >/dev/null 2>&1 ) \
              || printf 'forge: warning: callback-consume failed for %s (answer still recorded).\n' "$answers" >&2
        fi
    fi

    # Write event + (pointer) payload atomically; python emits the inject one-liner.
    local outf; outf="$(mktemp "${TMPDIR:-/tmp}/forge-dispatch.XXXXXX")"
    FORGE_CC_INSTR="$instr" FORGE_CC_ANSWERS="$answers" python3 - "$root" "$session" "$sender" \
        "$force_pointer" "$INLINE_MAX" "$outf" <<'PY' || { rm -f "$outf"; _dispatch_fail "failed to stage dispatch event"; }
import os, sys, json, re, hashlib, secrets, datetime
root, session, sender = sys.argv[1], sys.argv[2], sys.argv[3]
force_pointer = sys.argv[4] == "true"; inline_max = int(sys.argv[5]); outf = sys.argv[6]
instr = os.environ.get("FORGE_CC_INSTR", "")
now = datetime.datetime.now(datetime.timezone.utc)
ts  = now.strftime("%Y-%m-%dT%H:%M:%SZ")
did = "cc-" + now.strftime("%Y%m%dT%H%M%SZ") + "-" + secrets.token_hex(3)
sha = hashlib.sha256(instr.encode("utf-8", "replace")).hexdigest()
SECRETS = re.compile(
    # (?<!…) left boundary (lockstep with forge-cc-hook): English words containing
    # key-shaped substrings survive ("task-notification", "risk-assessment").
    r"(?<![A-Za-z0-9_-])"
    r"(sk-[A-Za-z0-9_\-]{8,}|ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}"
    r"|AKIA[0-9A-Z]{12,}|xox[baprs]-[A-Za-z0-9-]{8,}|AIza[0-9A-Za-z_\-]{20,})")
KV = re.compile(r"(?i)\b(api[_-]?key|token|secret|password)(\s*[=:]\s*)\S+")
def redact(s):
    s = SECRETS.sub("«redacted»", s or ""); return KV.sub(r"\1\2«redacted»", s)
adir = os.path.join(root, ".dev", "attention"); os.makedirs(adir, exist_ok=True)
pointer = force_pointer or ("\n" in instr) or (len(instr.encode("utf-8")) > inline_max)
rec = {"schema": "cc-dispatch/1", "event": "dispatch", "dispatch_id": did,
       "session": session, "root": root, "target_pane": 1,
       "mode": "pointer" if pointer else "inline",
       "instruction_snippet": redact(instr[:200]).replace("\n", " "),
       "instruction_sha256": sha, "dispatched_at": ts, "sender": sender,
       "state": "queued-input",
       "answers_ask_id": (os.environ.get("FORGE_CC_ANSWERS") or None)}
if pointer:
    pdir = os.path.join(adir, "payloads"); os.makedirs(pdir, exist_ok=True)
    rel = os.path.join(".dev", "attention", "payloads", did + ".txt")
    ppath = os.path.join(root, rel); ptmp = ppath + f".tmp.{os.getpid()}"
    with open(ptmp, "w") as f: f.write(instr)
    os.chmod(ptmp, 0o600); os.replace(ptmp, ppath)
    rec["payload_path"] = rel; rec["payload_bytes"] = len(instr.encode("utf-8"))
    oneliner = (f"Read and follow the dispatched instruction in {rel} "
                f"[dispatch_id:{did}] [sha256:{sha[:12]}]")
else:
    oneliner = f"{instr} [dispatch_id:{did}]"
etmp = os.path.join(adir, f".{did}.json.tmp"); epath = os.path.join(adir, f"dispatch-{did}.json")
with open(etmp, "w") as f: json.dump(rec, f, indent=2)
os.chmod(etmp, 0o600); os.replace(etmp, epath)
with open(outf, "w") as f: f.write(oneliner + "\n" + did + "\n")
sys.stderr.write(f"dispatch_id={did} mode={'pointer' if pointer else 'inline'}\n")
PY
    local oneliner="" did=""
    { IFS= read -r oneliner; IFS= read -r did || true; } < "$outf"
    rm -f "$outf"

    gc_root "$root"

    # Inject via the bridge's cmd_send 3-step split. TMUX_SESSION is the bridge's
    # resolution step 1 (trusted unconditionally), so this targets <session>:0.1
    # from any cwd; pane 1 (claude) is outside cmd_send's worker guard (no --force).
    if [ "$dry" = true ]; then
        printf 'DRY-RUN inject → %s:0.1: %s\n' "$session" "$oneliner"
    else
        if ! TMUX_SESSION="$session" "$FORGE_BRIDGE_BIN" send claude "$oneliner"; then
            _dispatch_fail "injection failed (forge-bridge send)"
        fi
        printf 'DISPATCHED @%s pane=1 sender=%s%s\n' "$session" "$sender" \
            "$([ -n "$answers" ] && printf ' answers=%s' "$answers")"
        fire_watch_check    # Step 6: surface the new queued/accepted task at ~1s (real inject only)
        # --wait (opt-in): block until THIS dispatch's answer lands, then print it.
        # The dispatch is recorded + injected ABOVE, so a timeout never loses it.
        if [ "$wait" = true ]; then
            local rpath="$root/.dev/attention/payloads/response.$did.txt"
            local poll="${FORGE_DISPATCH_WAIT_POLL_S:-2}" nows deadline
            deadline=$(( $(date +%s) + timeout ))
            while :; do
                if [ -f "$rpath" ]; then cat "$rpath"; exit 0; fi
                nows=$(date +%s)
                if [ "$nows" -ge "$deadline" ]; then break; fi
                sleep "$poll"
            done
            printf 'still working; your dispatch may have been absorbed into a running turn — its answer is usually in `forge reply @%s`. Retrieve this specific one later: forge reply @%s %s\n' \
                "$session" "$session" "$did" >&2
            exit 124
        fi
    fi
}

# ── ask (mini-spec 3) — called BY WORKERS to escalate a blocking question. ──
# Explicit CLI call from ANY pane (not a hook) → no pane/role gating. Writes ONE
# ask attention event (event="ask"; extends the reserved cc-attention/1 ask
# envelope with an additive ask_id) to the calling root's .dev/attention/. Stage
# mode ALSO rides forge-bridge's existing `callback --status BLOCKED --quiet` so
# the orchestrator's `wait` unblocks and the pipeline pending stays open. NEVER
# fails the worker: every non-usage path exits 0. Resolution: $TMUX_PANE → tmux
# (production; session_path is the key forge-watch scans on); --root forces
# hermetic/override mode (session from $TMUX_SESSION); cwd walk-up to
# .claude/forge-project.yml is the out-of-tmux fallback.
cmd_ask() {
    local scope="" slug="" stage="" worker="" root_override="" question=""
    while [ $# -gt 0 ]; do case "$1" in
        --session-scope) scope="session"; shift ;;
        --slug)   slug="$2";   shift 2 ;;
        --stage)  stage="$2";  shift 2 ;;
        --worker) worker="$2"; shift 2 ;;
        --root)   root_override="$2"; shift 2 ;;
        --*) die "ask: unknown flag $1" ;;
        *) if [ -z "$question" ]; then question="$1"; else question="$question $1"; fi; shift ;;
    esac; done
    [ -n "$question" ] || die "ask requires a question"
    local want_stage=0
    if [ "$scope" != "session" ] && [ -n "$slug$stage$worker" ]; then
        { [ -n "$slug" ] && [ -n "$stage" ] && [ -n "$worker" ]; } \
            || die "ask: stage mode requires --slug, --stage, and --worker together (or use --session-scope)"
        want_stage=1
    fi

    # Resolve session/root/pane, pre-check the open pending (stage mode), and write
    # the ask event atomically — all in one python. Reports id/mode/session/root/
    # snippet back via <outf>.
    local outf; outf="$(mktemp "${TMPDIR:-/tmp}/forge-ask.XXXXXX")"
    FORGE_ASK_Q="$question" python3 - "$want_stage" "$slug" "$stage" "$worker" "$root_override" "$outf" <<'PY' \
        || { rm -f "$outf"; die "ask: failed to write the ask event"; }
import os, sys, json, re, hashlib, secrets, datetime, subprocess
want_stage = sys.argv[1] == "1"
slug, stage, worker, root_override, outf = sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], sys.argv[6]
q = os.environ.get("FORGE_ASK_Q", "")

# ── resolve pane_index / session / root ──────────────────────────────────────
# Production: the calling pane via $TMUX_PANE → tmux. --root forces
# hermetic/override mode (skip tmux; session from $TMUX_SESSION). Fallback: cwd
# walk-up to .claude/forge-project.yml (out-of-tmux ask).
meta = None
tmux_pane = os.environ.get("TMUX_PANE", "")
pane_index = ""; session = ""; root = ""
if not root_override and tmux_pane:
    try:
        meta = subprocess.run(
            ["tmux", "display-message", "-p", "-t", tmux_pane,
             "#{pane_index}\t#{session_name}\t#{session_path}"],
            capture_output=True, text=True, timeout=5).stdout.strip()
    except (OSError, subprocess.SubprocessError):
        meta = None
if meta:
    p = meta.split("\t")
    if len(p) == 3:
        pane_index, session, root = p[0], p[1], os.path.realpath(p[2])
if root_override:
    root = os.path.realpath(root_override)
if not root:
    d = os.getcwd()
    while d != "/" and not os.path.isfile(os.path.join(d, ".claude", "forge-project.yml")):
        d = os.path.dirname(d)
    root = os.path.realpath(d)
if not session:
    session = os.environ.get("TMUX_SESSION", "")
if not session:
    sys.stderr.write("forge ask: no tmux session resolved — this ask is board-visible only and "
                     "cannot be answered via `forge dispatch @<session> --answers`. Run forge ask "
                     "from inside the initiative's tmux session (or pass --root with TMUX_SESSION).\n")

SECRETS = re.compile(
    # (?<!…) left boundary (lockstep with forge-cc-hook): English words containing
    # key-shaped substrings survive ("task-notification", "risk-assessment").
    r"(?<![A-Za-z0-9_-])"
    r"(sk-[A-Za-z0-9_\-]{8,}|ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}"
    r"|AKIA[0-9A-Z]{12,}|xox[baprs]-[A-Za-z0-9-]{8,}|AIza[0-9A-Za-z_\-]{20,})")
KV = re.compile(r"(?i)\b(api[_-]?key|token|secret|password)(\s*[=:]\s*)\S+")
def redact(s):
    s = SECRETS.sub("«redacted»", s or ""); return KV.sub(r"\1\2«redacted»", s)
snippet = redact(q.strip().replace("\n", " "))[:280]   # redact BEFORE truncating

# ── no-pending pre-check (faithful to forge-watch pending_entries) ───────────
def has_open_pending():
    logp = os.path.join(root, ".dev", "proposals", slug, "forge-log.yml")
    try:
        with open(logp) as f: raw = f.read()
    except OSError:
        return False
    entries = None
    try:
        import yaml
        entries = (yaml.safe_load(raw) or {}).get("entries", []) or []
    except Exception:
        entries = None
    if entries is not None:
        return any(isinstance(e, dict) and e.get("stage") == stage
                   and e.get("response") is None for e in entries)
    # Regex fallback (port of the bridge/forge-watch fallback) for legacy logs.
    block_re = re.compile(r'^\s*-\s+timestamp:\s*"([^"]+)"', re.MULTILINE)
    starts = [m.start() for m in block_re.finditer(raw)]
    for i, off in enumerate(starts):
        end = starts[i + 1] if i + 1 < len(starts) else len(raw)
        blk = raw[off:end]
        st = re.search(r'^\s+stage:\s*(.*?)\s*$', blk, re.MULTILINE)
        rp = re.search(r'^\s+response:\s*(null|")', blk, re.MULTILINE)
        if st and st.group(1).strip() == stage and rp and rp.group(1) == 'null':
            return True
    return False

mode = "session-scope"
if want_stage:
    if has_open_pending():
        mode = "stage"
    else:
        sys.stderr.write(f"forge ask: no open pending for slug={slug} stage={stage} in {root} "
                         f"— falling back to session-scope (question still escalated).\n")

now = datetime.datetime.now(datetime.timezone.utc)
ask_id = "ask-" + now.strftime("%Y%m%dT%H%M%SZ") + "-" + secrets.token_hex(3)
role = os.environ.get("FORGE_ROLE") or ("orchestrator" if pane_index == "1" else "worker")
rec = {"schema": "cc-attention/1", "event": "ask", "variant": "ask",
       "session": session or None, "root": root,
       "pane_index": pane_index or None, "role": role, "tmux_pane": tmux_pane,
       "emitted_at": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
       "ask_id": ask_id, "mode": mode,
       "question_snippet": snippet,
       "question_sha256": hashlib.sha256(q.encode("utf-8", "replace")).hexdigest(),
       "slug": slug or None, "stage": stage or None, "worker": worker or None}
adir = os.path.join(root, ".dev", "attention")
try:
    os.makedirs(adir, exist_ok=True)
except OSError:
    sys.exit(1)
path = os.path.join(adir, ask_id + ".json"); tmp = path + f".tmp.{os.getpid()}"
with open(tmp, "w") as f: json.dump(rec, f, indent=2)
os.chmod(tmp, 0o600); os.replace(tmp, path)
with open(outf, "w") as f: f.write("\t".join([ask_id, mode, session, root, snippet]))
sys.stderr.write(f"ask_id={ask_id} mode={mode}\n")
PY
    local a_id a_mode a_sess a_root a_snip
    # `read` returns 1 at EOF-without-newline (python writes no trailing \n) but
    # still assigns — don't let set -e kill the ask here.
    IFS=$'\t' read -r a_id a_mode a_sess a_root a_snip < "$outf" || true
    rm -f "$outf"

    # Stage mode → ALSO raise a quiet BLOCKED callback. --quiet: the attention path
    # notifies the human; don't double-notify pane 1. --message is the REDACTED
    # snippet (one redaction pass feeds both the event and the callback file). A
    # bridge failure NEVER fails the worker — the attention event already carries it.
    if [ "$a_mode" = "stage" ]; then
        ( cd "$a_root" && TMUX_SESSION="$a_sess" "$FORGE_BRIDGE_BIN" callback \
            --slug "$slug" --stage "$stage" --worker "$worker" \
            --status BLOCKED --message "$a_snip" --quiet >/dev/null 2>&1 ) \
          || printf 'forge ask: bridge BLOCKED callback failed (ask %s still escalated via attention).\n' "$a_id" >&2
    fi
    fire_watch_check    # Step 6: surface the NEEDS-ASK escalation at ~1s
    printf 'ASKED %s mode=%s session=%s\n' "$a_id" "$a_mode" "$a_sess"
    return 0
}

# ── register: gitignore gate + hook merge (1.4) + watch-roots ─────────────
cmd_register() {
    local root="" force=0 alias="" seed=0
    while [ $# -gt 0 ]; do case "$1" in
        --force) force=1; shift ;;
        --alias) alias="$(sanitize_name "$2")"; shift 2 ;;
        --seed)  seed=1; shift ;;
        *) root="$1"; shift ;;
    esac; done
    if [ "$seed" = 1 ]; then registry_seed; return; fi
    [ -n "$root" ] || die "register requires <root>"
    root="$(cd "$root" 2>/dev/null && pwd -P)" || die "no such root '$root'"

    # A `.dev/` (trailing-slash) gitignore pattern can only match an EXISTING
    # directory — create it first or a brand-new root fails the gate below
    # despite a correct .gitignore (found on the Phase C live smoke).
    mkdir -p "$root/.dev"

    if [ "$force" != 1 ] && ! git -C "$root" check-ignore -q .dev 2>/dev/null; then
        die ".dev/ is not gitignored in $root — attention files would be committable.
       Fix: echo '.dev/' >> '$root/.gitignore'  (untrack any tracked .dev paths), then re-run.
       Override with --force only if you accept the exposure."
    fi

    local block="$(_toolkit_root)/config/claude-cc-hooks.json"
    [ -f "$block" ] || block="$HOME/.claude/forge-toolkit/config/claude-cc-hooks.json"
    [ -f "$block" ] || die "canonical hook block not found ($block)"

    FORGE_HOOK_BLOCK="$block" FORGE_HOOK_ROOT="$root" FORGE_HOOK_MARK="$CC_HOOK_MARK" python3 - <<'PY'
import os, sys, json, tempfile
block_fp = os.environ["FORGE_HOOK_BLOCK"]; root = os.environ["FORGE_HOOK_ROOT"]
MARK = os.environ["FORGE_HOOK_MARK"]
sdir = os.path.join(root, ".claude"); os.makedirs(sdir, exist_ok=True)
spath = os.path.join(sdir, "settings.json")
with open(block_fp) as f: block = json.load(f)
if os.path.exists(spath):
    try:
        with open(spath) as f: data = json.load(f)
    except ValueError as e:
        sys.exit(f"forge: REFUSE — {spath} is not valid JSON ({e}); not touched")
    if not isinstance(data, dict):
        sys.exit(f"forge: REFUSE — {spath} root is not an object; not touched")
else:
    data = {}
hooks = data.setdefault("hooks", {})
if not isinstance(hooks, dict): sys.exit("forge: REFUSE — .hooks is not an object")
def is_cc(entry):
    return any(MARK in (h.get("command", "") or "")
               for h in (entry or {}).get("hooks", []) or [])
for event, entries in block.items():
    arr = hooks.setdefault(event, [])
    if not isinstance(arr, list): sys.exit(f"forge: REFUSE — .hooks.{event} is not a list")
    arr[:] = [e for e in arr if not is_cc(e)]   # drop stale CC (idempotent/upgrade)
    arr.extend(entries)                          # append canonical CC
assert isinstance(data.get("hooks"), dict)
for event in block:
    lst = data["hooks"][event]; assert isinstance(lst, list)
    for e in lst:
        for h in e.get("hooks", []):
            assert h.get("type") == "command" and isinstance(h.get("command"), str)
fd, tmp = tempfile.mkstemp(dir=sdir, suffix=".tmp")
with os.fdopen(fd, "w") as f: json.dump(data, f, indent=2); f.write("\n")
with open(tmp) as f: json.load(f)     # re-parse validation
os.replace(tmp, spath)
print(f"registered CC hooks in {spath}")
PY

    # ── codex parity (Step 7): merge the codex CC block into <root>/.codex/hooks.json ──
    # Non-managed /hooks path (Gate 1): repo-level hooks.json; one-time per-hash /hooks trust
    # review per root; trust re-required if the block changes (the marker records the hash).
    # Idempotent merge mirroring the .claude/settings.json merge above.
    local cblock="$(_toolkit_root)/config/codex-cc-hooks.json"
    [ -f "$cblock" ] || cblock="$HOME/.claude/forge-toolkit/config/codex-cc-hooks.json"
    if [ -f "$cblock" ]; then
        FORGE_CODEX_BLOCK="$cblock" FORGE_HOOK_ROOT="$root" FORGE_HOOK_MARK="$CC_HOOK_MARK" python3 - <<'PY'
import os, sys, json, tempfile, hashlib, datetime
block_fp = os.environ["FORGE_CODEX_BLOCK"]; root = os.environ["FORGE_HOOK_ROOT"]
MARK = os.environ["FORGE_HOOK_MARK"]
cdir = os.path.join(root, ".codex"); os.makedirs(cdir, exist_ok=True)
hpath = os.path.join(cdir, "hooks.json")
with open(block_fp) as f: block = json.load(f)      # {"UserPromptSubmit":[...],"Stop":[...]}
data = {}
if os.path.exists(hpath):
    try:
        with open(hpath) as f: data = json.load(f)
    except ValueError as e:
        sys.exit(f"forge: REFUSE — {hpath} is not valid JSON ({e}); not touched")
    if not isinstance(data, dict):
        sys.exit(f"forge: REFUSE — {hpath} root is not an object; not touched")
hooks = data.setdefault("hooks", {})                # codex hooks.json wraps events under "hooks"
if not isinstance(hooks, dict): sys.exit("forge: REFUSE — codex .hooks is not an object")
def is_cc(entry):
    return any(MARK in (h.get("command", "") or "")
               for h in (entry or {}).get("hooks", []) or [])
for event, entries in block.items():
    arr = hooks.setdefault(event, [])
    if not isinstance(arr, list): sys.exit(f"forge: REFUSE — codex .hooks.{event} is not a list")
    arr[:] = [e for e in arr if not is_cc(e)]       # drop stale CC (idempotent/upgrade)
    arr.extend(entries)
fd, tmp = tempfile.mkstemp(dir=cdir, suffix=".tmp")
with os.fdopen(fd, "w") as f: json.dump(data, f, indent=2); f.write("\n")
with open(tmp) as f: json.load(f)                   # re-parse validation
os.replace(tmp, hpath)
# marker for CODEX-EMISSION-OFF (no `event` field → skipped by the attention scan loop).
h = hashlib.sha256(json.dumps(block, sort_keys=True).encode()).hexdigest()
adir = os.path.join(root, ".dev", "attention"); os.makedirs(adir, exist_ok=True)
mp = os.path.join(adir, "codex-register.json"); mt = mp + f".tmp.{os.getpid()}"
with open(mt, "w") as f:
    json.dump({"schema": "cc-codex-register/1", "hook_sha256": h, "hooks_path": hpath,
               "registered_at": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")}, f, indent=2)
os.replace(mt, mp)
print(f"registered codex CC hooks in {hpath} (trust: one-time /hooks review per root)")
PY
        echo "  codex: run /hooks in each codex pane at $root to trust the hook (one-time per hash)."
    fi

    local wr="$HOME/.config/forge/watch-roots"
    mkdir -p "$(dirname "$wr")"; touch "$wr"
    if ! grep -qxF "$root" "$wr"; then echo "$root" >> "$wr"; echo "added $root to $wr"; fi

    # Durable per-repo declaration (P3). LAST — a hook-merge refuse or the
    # gitignore gate above aborts BEFORE any registry write.
    local rid; rid="$(repo_identity "$root")" \
        || die "register: '$root' is not a git repo (repo identity requires git)"
    [ -n "$alias" ] || alias="$(sanitize_name "$(basename "$root")")"
    registry_write "$rid" "$alias" "$root"
}

# _spawn_session_at_root <root> → first live session NAME whose session_path==root
# (single-root invariant, identity=session_path). Test seam: FORGE_TMUX_LIST.
_spawn_session_at_root() {
    local root="$1" inject="${FORGE_TMUX_LIST:-}"
    { if [ -n "$inject" ]; then cat "$inject"
      else "$FORGE_TMUX_BIN" list-sessions -F '#{session_name}	#{session_path}' 2>/dev/null || true; fi
    } | awk -F'\t' -v r="$root" '
        { p=""; cmd="cd \x27" $2 "\x27 2>/dev/null && pwd -P"
          if ((cmd | getline p) <= 0) p=""; close(cmd)
          if (p == r) { print $1; exit } }' || true
}

_spawn_pane_count() {
    "$FORGE_TMUX_BIN" list-panes -t "$1" -F '#{pane_index}' 2>/dev/null | grep -c . || true
}

# _spawn_on_spawn_cmd <root> → on_spawn argv (one token/line) or nothing. LOUD on
# a malformed non-null value.
_spawn_on_spawn_cmd() {
    python3 - "$1" <<'PY'
import os, sys
fp = os.path.join(sys.argv[1], ".claude", "forge-project.yml")
if not os.path.exists(fp): sys.exit(0)
try:
    import yaml
    with open(fp) as f: d = yaml.safe_load(f) or {}
except Exception as e:
    sys.exit(f"forge: spawn — {fp} is unreadable/invalid ({e})")
try:
    cmd = ((d.get("forge") or {}).get("control_center") or {}).get("on_spawn")
except Exception:
    cmd = None
if cmd is None: sys.exit(0)
if not (isinstance(cmd, list) and cmd and all(isinstance(x, str) for x in cmd)):
    sys.exit(f"forge: spawn — forge.control_center.on_spawn in {fp} must be a non-empty list of strings")
print("\n".join(cmd))
PY
}

# ── spawn (mini-spec 5) — ensure-semantics 5-pane session for a root ──────────
# Positional NAME overrides the derived session name; identity is session_path,
# the name is cosmetic. Substrate first (detached, session-wide -e stamps); tmux's
# duplicate-session error is the mutex. Then the project's on_spawn populates the
# EXISTING session (per-pane roles injected by forge-start). Population failure is
# recorded + rendered — never a kill.
cmd_spawn() {
    local name="" root="" allow=0 dry=false no_populate=false force=0
    if [ "${FORGE_SPAWN_DRY_RUN:-0}" = "1" ]; then dry=true; fi
    while [ $# -gt 0 ]; do case "$1" in
        --root)   root="$2"; shift 2 ;;
        --name)   name="$2"; shift 2 ;;
        --allow-api-billing) allow=1; shift ;;
        --dry-run) dry=true; shift ;;
        --no-populate) no_populate=true; shift ;;
        --force)  force=1; shift ;;
        --*) die "spawn: unknown flag $1" ;;
        *) if [ -z "$name" ]; then name="$1"; else die "spawn: unexpected extra arg '$1'"; fi; shift ;;
    esac; done
    if [ -z "$root" ]; then root="$(pwd -P)"; fi
    root="$(cd "$root" 2>/dev/null && pwd -P)" || die "spawn: no such root '$root'"

    # 1. Billing preflight gates every spawn (P1e), BEFORE any mutation. In
    #    --dry-run the verdict is REPORTED in the plan (rc 2 on FAIL); the real
    #    path dies on it.
    local bp="" brc=0
    bp="$(billing_preflight "$root" "$allow" 2>&1)" || brc=$?
    if [ "$brc" -ne 0 ] && [ "$dry" = false ]; then
        printf '%s\n' "$bp" >&2
        die "spawn: billing preflight failed for $root (use --allow-api-billing to override)"
    fi

    # 2. Register: gitignore gate + hook MERGE (P5) + watch-roots + registry (P3).
    #    Mutating — SKIPPED in --dry-run (naming below only READS the registry).
    if [ "$dry" = false ]; then
        if [ "$force" = 1 ]; then cmd_register "$root" --force >/dev/null
        else cmd_register "$root" >/dev/null || die "spawn: register failed for $root (see above)"; fi
    fi

    # 3. Name: default forge-<alias>-<worktree-dirname>, sanitized (P4).
    if [ -z "$name" ]; then name="forge-$(registry_alias_for "$root")-$(basename "$root")"; fi
    name="$(sanitize_name "$name")"
    [ -n "$name" ] || die "spawn: name sanitized to empty; pass an explicit ascii --name"

    # 4. ENSURE by session_path IDENTITY (P1a/b): a live session already at this
    #    root IS the initiative (no-op) regardless of name. Unhealthy (wrong pane
    #    count) → needs-repair: recorded, never reused, never killed.
    local at_root="" pc=""
    at_root="$(_spawn_session_at_root "$root")"
    if [ -n "$at_root" ]; then
        pc="$(_spawn_pane_count "$at_root")"
        if [ "${pc:-0}" -ge 5 ]; then
            if [ "$dry" = true ]; then
                printf 'PLAN ATTACH session=%s root=%s billing=%s\n' "$at_root" "$root" \
                    "$([ "$brc" -eq 0 ] && echo OK || echo FAIL)"
                if [ "$brc" -eq 0 ]; then return 0; else return 2; fi
            fi
            rm -f "$root/.dev/attention/spawn-$at_root-needs-repair.json" \
                  "$root/.dev/attention/spawn-$at_root-population-failure.json" 2>/dev/null || true
            echo "ENSURE @$at_root (already active at $root, ${pc} panes) — no-op"; return 0
        fi
        if [ "$dry" = true ]; then
            printf 'PLAN NEEDS-REPAIR session=%s root=%s panes=%s\n' "$at_root" "$root" "${pc:-?}"
            return 3
        fi
        spawn_state_event "$root" "$at_root" "needs-repair" "session at root has ${pc:-?} panes (expected 5)"
        die "spawn: session '$at_root' at $root is unhealthy (${pc:-?} panes, need 5) — needs-repair (recorded to the board), NOT reused/killed. Repair it, or kill it and re-spawn."
    fi

    # 5. Dry-run: report the CREATE plan (billing verdict included), mutate nothing.
    if [ "$dry" = true ]; then
        printf 'DRY-RUN new-session -d -s %s -c %s -e TMUX_SESSION=%s -e FORGE_INITIATIVE=%s -e FORGE_ROOT=%s billing=%s\n' \
            "$name" "$root" "$name" "$name" "$root" "$([ "$brc" -eq 0 ] && echo OK || echo FAIL)"
        if [ "$no_populate" = false ]; then
            printf 'DRY-RUN on_spawn: %s %s\n' "$(_spawn_on_spawn_cmd "$root" | tr '\n' ' ')" "$name"
        fi
        if [ "$brc" -eq 0 ]; then return 0; else return 2; fi
    fi

    # 6. Name-mutex CREATE (P1a/c). tmux duplicate-session error IS the mutex.
    #    Substrate first: detached, session-wide stamps via -e (reach every pane).
    if ! "$FORGE_TMUX_BIN" new-session -d -s "$name" -c "$root" \
            -e "TMUX_SESSION=$name" -e "FORGE_INITIATIVE=$name" -e "FORGE_ROOT=$root" 2>/dev/null; then
        local other=""
        other="$(session_root "$name" 2>/dev/null || true)"
        other="$(cd "$other" 2>/dev/null && pwd -P || true)"
        if [ "$other" = "$root" ]; then echo "ENSURE @$name (raced; now active at $root) — no-op"; return 0; fi
        die "spawn: name '$name' already exists at a DIFFERENT root ($other, not $root) — COLLISION, refusing (identity is session_path; pass a distinct --name)."
    fi

    # 7. First-launch (P1f) — keyed to the CREATE itself: trust lives in Claude
    #    Code's own store, so .forge-session presence is a false proxy. The
    #    folder-trust dialog is a STARTUP prompt no Phase A hook sees; this
    #    once-only nudge (policy 'once' in forge-watch) keeps a fresh pane from
    #    parking silently. NOT cleared on populate success.
    spawn_state_event "$root" "$name" "first-launch" "new session — if a pane shows a folder-trust dialog, approve it in the tab"

    # 8. on_spawn / populate (P1g). Per-pane roles live in forge-start (P1d).
    #    Session name appended as final argv. Exit recorded; failure rendered,
    #    session left alive, no rollback.
    if [ "$no_populate" = false ]; then
        local osf; osf="$(mktemp "${TMPDIR:-/tmp}/forge-onspawn.XXXXXX")"
        _spawn_on_spawn_cmd "$root" > "$osf" || { rm -f "$osf"; die "spawn: on_spawn is malformed (see above)"; }
        local -a on_spawn=()
        if [ -s "$osf" ]; then
            # portable read (mapfile needs bash 4; /bin/bash on macOS is 3.2)
            while IFS= read -r _tok; do on_spawn+=("$_tok"); done < "$osf"
        fi
        rm -f "$osf"
        if [ "${#on_spawn[@]}" -eq 0 ]; then on_spawn=("$FORGE_START_BIN" --populate-existing); fi
        if ( cd "$root" && TMUX_SESSION="$name" "${on_spawn[@]}" "$name" ); then :; else
            local prc=$?
            spawn_state_event "$root" "$name" "population-failure" "on_spawn exited $prc (session left alive)"
            printf 'forge: spawn — on_spawn FAILED (exit %s) for %s; the headless session is ALIVE and recorded to the board.\n' "$prc" "$name" >&2
            return 4
        fi
    fi

    # 9. Verify (P1h), then clear-on-PASS only. Order is load-bearing: clearing
    #    before/without verification would delete the needs-repair this very
    #    block may need to write. Per-pane CHILD role is by construction +
    #    proven in tests; tmux exposes no read of a running child's env.
    local stamp="" fpc="" vok=1
    stamp="$("$FORGE_TMUX_BIN" show-environment -t "$name" TMUX_SESSION 2>/dev/null | sed 's/^TMUX_SESSION=//' || true)"
    if [ "$stamp" != "$name" ]; then
        vok=0; printf 'forge: spawn — WARNING: TMUX_SESSION stamp missing/mismatched on %s.\n' "$name" >&2
    fi
    if [ "$no_populate" = false ]; then
        fpc="$(_spawn_pane_count "$name")"
        if [ "${fpc:-0}" -lt 5 ]; then
            vok=0; printf 'forge: spawn — WARNING: %s has %s panes after populate (expected 5).\n' "$name" "${fpc:-?}" >&2
        fi
    fi
    if [ "$vok" = 1 ]; then
        rm -f "$root/.dev/attention/spawn-$name-needs-repair.json" \
              "$root/.dev/attention/spawn-$name-population-failure.json" 2>/dev/null || true
    else
        spawn_state_event "$root" "$name" "needs-repair" "post-spawn verify: stamp='$stamp' panes=${fpc:-?}"
    fi
    echo "SPAWNED @$name root=$root (stamps set; board via forge-watch)"
}

cmd_gc() {
    local root="" days="$TTL_D" action=""
    while [ $# -gt 0 ]; do case "$1" in
        --root) root="$2"; shift 2 ;;
        --days) days="$2"; shift 2 ;;
        --install) action="install"; shift ;;
        --uninstall) action="uninstall"; shift ;;
        *) shift ;;
    esac; done
    if [ -n "$action" ]; then "gc_launchd_$action"; return; fi
    TTL_D="$days"
    if [ -n "$root" ]; then gc_root "$(cd "$root" && pwd -P)"; return; fi
    # Backstop sweep (the com.forge.gc tick lands here): registered watch-roots
    # ∪ live tmux session paths, so roots whose session is gone still age out.
    local wr="${FORGE_WATCH_ROOTS_FILE:-$HOME/.config/forge/watch-roots}"
    {
        { [ -f "$wr" ] && grep -v '^[[:space:]]*#' "$wr"; } || true
        if [ -n "${FORGE_TMUX_LIST:-}" ]; then
            cut -f2 "$FORGE_TMUX_LIST"
        else
            tmux list-sessions -F '#{session_path}' 2>/dev/null || true
        fi
    } | sed '/^[[:space:]]*$/d' | sort -u | while read -r r; do
        { [ -d "$r/.dev" ] && gc_root "$r"; } || true
    done
    gc_watch_logs
    return 0
}

# forge-watch's launchd.out grows without bound (every-30s findings dumps;
# 37MB by 2026-07-06). delivered.log + state.json carry the durable signal,
# so past the cap the log is truncated in place (launchd writes O_APPEND —
# an open writer just continues at the new end). forge-watch itself is
# read-only by invariant and must never delete; the sweep lives here.
gc_watch_logs() {
    local wcache="${FORGE_WATCH_CACHE_DIR:-$HOME/.cache/forge-watch}"
    local cap=$((10 * 1024 * 1024)) f sz
    for f in "$wcache/launchd.out" "$wcache/launchd.err"; do
        [ -f "$f" ] || continue
        sz=$(stat -f%z "$f" 2>/dev/null || echo 0)
        if [ "$sz" -gt "$cap" ]; then
            : > "$f"
            echo "gc: truncated ${f##*/} ($((sz / 1048576))MB > 10MB cap)"
        fi
    done
    return 0
}

# ── gc launchd backstop — GC otherwise only runs when `forge` runs; forge-watch
# is read-only by invariant and must never delete. Mirrors forge-watch install.
GC_LABEL="com.forge.gc"
GC_PLIST="$HOME/Library/LaunchAgents/$GC_LABEL.plist"

gc_launchd_install() {
    local cache="$HOME/.cache/forge-gc"
    mkdir -p "$cache" "$(dirname "$GC_PLIST")"
    cat > "$GC_PLIST" <<PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$GC_LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$HOME/bin/forge</string>
    <string>gc</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>3</integer><key>Minute</key><integer>17</integer></dict>
  <key>RunAtLoad</key><true/>
  <key>StandardErrorPath</key><string>$cache/launchd.err</string>
  <key>StandardOutPath</key><string>$cache/launchd.out</string>
</dict>
</plist>
PLISTEOF
    launchctl unload "$GC_PLIST" 2>/dev/null || true
    launchctl load "$GC_PLIST"
    echo "Loaded launchd agent $GC_LABEL (daily 03:17 + once at load)."
}

gc_launchd_uninstall() {
    launchctl unload "$GC_PLIST" 2>/dev/null || true
    rm -f "$GC_PLIST"
    echo "Unloaded and removed launchd agent $GC_LABEL."
}

# ── reply (return path) — print a worker's answer to a seat dispatch ──────
# Reads the persisted payload keyed by dispatch_id (or the session's latest via
# the stop event's response_paths[0]). Never scrapes panes. Exit codes: 2 = the
# dispatch-id argument failed the charset guard; 3 = no response payload yet.
cmd_reply() {
    local session="" did="" mode="text"
    while [ $# -gt 0 ]; do case "$1" in
        @*) session="${1#@}"; shift ;;
        --json) mode="json"; shift ;;
        --snippet) mode="snippet"; shift ;;
        --*) die "reply: unknown flag $1" ;;
        *) if [ -z "$did" ]; then did="$1"; else die "reply: unexpected extra arg '$1'"; fi; shift ;;
    esac; done
    [ -n "$session" ] || die "reply requires @<session>"
    local root
    root="$(session_root "$session")" || die "no live session '$session' (session_path unresolvable)"
    root="$(cd "$root" 2>/dev/null && pwd -P)" || die "session '$session' root does not exist"
    FORGE_REPLY_DID="$did" FORGE_REPLY_MODE="$mode" python3 - "$root" "$session" <<'PY'
import os, sys, json, re
root, session = sys.argv[1], sys.argv[2]
did  = os.environ.get("FORGE_REPLY_DID", "")
mode = os.environ.get("FORGE_REPLY_MODE", "text")
adir = os.path.join(root, ".dev", "attention")
def fail(code, msg):
    sys.stderr.write("forge: reply: %s\n" % msg); sys.exit(code)
# Validate the id FIRST — before any path is built (mirrors the ask-id guard).
if did and not re.fullmatch(r"[A-Za-z0-9._-]+", did):
    fail(2, "'%s' is not a valid dispatch-id (charset [A-Za-z0-9._-])" % did)
stop = None
try:
    with open(os.path.join(adir, "stop.%s.json" % session)) as f:
        stop = json.load(f)
    if not isinstance(stop, dict):
        stop = None
except (OSError, ValueError):
    stop = None
if mode == "json":
    if stop is None:
        fail(3, "no stop event recorded for @%s yet" % session)
    print(json.dumps(stop, indent=2)); sys.exit(0)
if mode == "snippet":
    if stop is None:
        fail(3, "no stop event recorded for @%s yet" % session)
    print(stop.get("snippet") or ""); sys.exit(0)
# text mode: resolve the payload path
if did:
    rel = os.path.join(".dev", "attention", "payloads", "response.%s.txt" % did)
else:
    paths = (stop or {}).get("response_paths") or []
    if not paths:
        fail(3, "no response recorded for @%s (no stop event / no payload pointer yet)" % session)
    rel = paths[0]
try:
    with open(os.path.join(root, rel)) as f:
        payload = f.read()
except OSError:
    if did:
        fail(3, "no response yet for %s (retrieve later once the worker answers)" % did)
    fail(3, "response payload missing for @%s" % session)
# one-line header from the recorded facts, then the payload (already redacted).
if stop is not None:
    dids = stop.get("response_dispatch_ids") or []
    hdr = "%s · %s" % (session, stop.get("emitted_at") or "?")
    if dids:
        hdr += " · " + ",".join(dids)
    if stop.get("looks_like_question"):
        hdr += " · [ends in a question]"
    print(hdr)
sys.stdout.write(payload)
if not payload.endswith("\n"):
    sys.stdout.write("\n")
# truncated note APPENDED after the body (plan wording: "append"), so the payload stays
# contiguous under the header for a clean relay.
if stop is not None and stop.get("truncated"):
    print("(truncated; %d of %s bytes — full text in the session tab)"
          % (len(payload.encode("utf-8")), stop.get("full_bytes")))
sys.exit(0)
PY
}

case "${1:-help}" in
    dispatch)  shift; cmd_dispatch "$@" ;;
    reply)     shift; cmd_reply "$@" ;;
    ask)       shift; cmd_ask "$@" ;;
    preflight) shift; cmd_preflight "$@" ;;
    register)  shift; cmd_register "$@" ;;
    spawn)     shift; cmd_spawn "$@" ;;
    # Human board by default; --json (or legacy status --board) = cc-board/1
    # JSON for machines. Raw findings remain at `forge-watch status`.
    status)    shift; if [ "${1:-}" = "--board" ]; then exec "$FORGE_WATCH_BIN" status --board; else exec "$FORGE_WATCH_BIN" status --pretty "$@"; fi ;;
    board)     shift; if [ "${1:-}" = "--json" ]; then exec "$FORGE_WATCH_BIN" status --board; else exec "$FORGE_WATCH_BIN" status --pretty "$@"; fi ;;
    # Read-only per-TASK projection over cc-board/1 tasks[] (no task-creating verb).
    tasks)     shift; exec "$FORGE_WATCH_BIN" status --tasks "$@" ;;
    gc)        shift; cmd_gc "$@" ;;
    -h|--help|help) sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//' ;;
    *) die "unknown verb '$1' (try: dispatch reply spawn ask preflight register status board tasks gc)" ;;
esac
