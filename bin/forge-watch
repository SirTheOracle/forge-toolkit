#!/bin/bash
# forge-watch — Blocked-on-You notifications for forge pipelines.
#
# A single READ-ONLY watcher. It discovers live forge sessions from tmux,
# derives pipeline state from bridge-owned files under each project's .dev/,
# and notifies the operator (macOS notification) only when a pipeline is
# actually waiting on a human: a decision after QA, a BLOCKED worker, a stage
# error, a stalled worker, or a pipeline error.
#
# It NEVER writes under any project's .dev/, NEVER sends input to panes, and
# NEVER touches tmux/session state. Its only writes are its own cache/config
# (~/.cache/forge-watch, ~/.config/forge) and, on `install`, a launchd plist.
# If the watcher is dead or uninstalled, the workflow degrades to exactly
# today's poll-the-tabs behavior — no pipeline depends on it.
#
# See .tmpFiles/forge-watch-proposal.md (r3) for the full design.
#
# Verbs:
#   forge-watch check      one scan; print findings AND deliver notifications
#   forge-watch status     one scan; print findings only (no notifications)
#   forge-watch ack <t>    silence current conditions for <t> (session|slug|root)
#   forge-watch install    write+load the launchd agent (30s interval)
#   forge-watch uninstall  unload+remove the launchd agent
#
# Tuning (env var wins, else ~/.config/forge/watch.env, else default):
#   FORGE_STALL_THRESHOLD_S   default 600  (STALE = 2x this, matches the bridge)
#   FORGE_WATCH_DWELL_S       default 300  (NEEDS-DECISION dwell)
#   FORGE_WATCH_RENOTIFY_S    default 900  (re-notify base; x2 backoff, cap 4h)
#   FORGE_WATCH_ZOMBIE_AGE_D  default 7    (recent-context window for ZOMBIE-ACTIVE
#                                           and the WORKER-STALLED/residue split)
#   FORGE_WATCH_NOTIFY_COMPLETE       default 1  (notify on pipeline completion)
#   FORGE_WATCH_NOTIFY_STALE_ZOMBIE   default 0  (notify on old zombie contexts)
#   FORGE_WATCH_ROOTS_FILE            path to a roots list (default ~/.config/forge/watch-roots)
#   FORGE_WATCH_CHECK_TIMEOUT_S       default 90 (check-mode engine watchdog, seconds; 0 disables)
#   FORGE_WATCH_QUIET_UNCHANGED       default 1  (check prints nothing when findings are
#                                                 unchanged and stdout is not a tty)
#   FORGE_WATCH_NOTIFY_TIMEOUT_S      default 15 (bound on a single notifier call; env-only —
#                                                 read by bash, not a watch.env key)

set -euo pipefail

LABEL="com.forge.watch"
CACHE_DIR="${FORGE_WATCH_CACHE_DIR:-$HOME/.cache/forge-watch}"
CONFIG_DIR="${FORGE_WATCH_CONFIG_DIR:-$HOME/.config/forge}"
WATCH_ENV="$CONFIG_DIR/watch.env"
WATCH_ROOTS="$CONFIG_DIR/watch-roots"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"

# Resolve the real path of this script so the plist points at the installed
# location (works whether ~/bin/forge-watch is a symlink or a copy).
SELF="$( cd "$(dirname "$0")" >/dev/null 2>&1 && pwd )/$(basename "$0")"

mkdir -p "$CACHE_DIR" "$CONFIG_DIR" 2>/dev/null || true

# ── Notification sink (the one swappable shell function) ──────────────────
# In tests, set FORGE_WATCH_SINK_CAPTURE to a file: notifications are appended
# as "title<TAB>body" instead of being delivered, so the full debounce path is
# exercised without real notifications.
fw_escape() { printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'; }

# Append a delivery-audit line to forge-watch's OWN cache (read-only-under-.dev preserved).
# The engine reads the LAST line → DELIVERY-UNVERIFIED when it returned nonzero.
_fw_log_delivery() {   # _fw_log_delivery <title> <body> <channel> <rc>
    FW_T="$1" FW_B="$2" FW_CH="$3" FW_RC="$4" FW_LOG="$CACHE_DIR/delivered.log" \
    python3 - <<'PY' 2>/dev/null || true
import os, json, datetime
rec = {"ts": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
       "title": os.environ.get("FW_T", ""), "body": os.environ.get("FW_B", "")[:200],
       "channel": os.environ.get("FW_CH", ""), "rc": int(os.environ.get("FW_RC", "0") or 0)}
with open(os.environ["FW_LOG"], "a") as f:
    f.write(json.dumps(rec) + "\n")
PY
}

# Bounded exec for notifier calls. macOS ships no coreutils `timeout`; alarm(2)
# survives execve, so the exec'd notifier inherits the pending SIGALRM and is
# killed (rc 142) if it wedges. FORGE_WATCH_NOTIFY_TIMEOUT_S=0 disables.
fw_timed() {
    if command -v perl >/dev/null 2>&1; then
        perl -e 'alarm(shift @ARGV); exec @ARGV; exit 127;' \
            "${FORGE_WATCH_NOTIFY_TIMEOUT_S:-15}" "$@"
    else
        "$@"
    fi
}

fw_notify() {
    local title="$1" body="$2" channel rc=0 nb="${FORGE_WATCH_NOTIFIER_BIN:-}"
    # SINK_CAPTURE short-circuits UNLESS a stub notifier is wired (FORGE_WATCH_NOTIFIER_BIN) to
    # exercise the rc/audit path. Every branch logs an audit line and returns 0 (fail-open). A
    # notifier with its own grantable identity (terminal-notifier) returns nonzero when it cannot
    # deliver; osascript (attributed to Script Editor) cannot self-report and stays the fallback.
    if [ -z "$nb" ] && [ -n "${FORGE_WATCH_SINK_CAPTURE:-}" ]; then
        printf '%s\t%s\n' "$title" "$body" >> "$FORGE_WATCH_SINK_CAPTURE"
        _fw_log_delivery "$title" "$body" sink 0
        return 0
    fi
    # `|| rc=$?` (not `; rc=$?`): this script runs under set -e — a bare failing notifier
    # would abort the whole scan before the audit line is written (the failure tdel proves).
    # Every branch runs under fw_timed: a wedged notifier once stalled a check ~110s
    # (2026-07-06); a timeout kill reads as rc!=0 → the existing DELIVERY-UNVERIFIED path.
    if [ -n "$nb" ]; then
        channel=stub; fw_timed "$nb" "$title" "$body" >/dev/null 2>&1 || rc=$?
    elif command -v terminal-notifier >/dev/null 2>&1; then
        channel=terminal-notifier
        fw_timed terminal-notifier -title "$title" -message "$body" >/dev/null 2>&1 || rc=$?
    else
        channel=osascript
        fw_timed osascript -e "display notification \"$(fw_escape "$body")\" with title \"$(fw_escape "$title")\"" >/dev/null 2>&1 || rc=$?
    fi
    _fw_log_delivery "$title" "$body" "$channel" "$rc"
    return 0
}

# ── The engine: scan → evaluate → debounce → emit ────────────────────────
# argv: <mode: check|status|ack> <notify_out: path|-> <ack_target>
# Human-readable findings go to stdout. When notify_out is a file, one
# "title<TAB>body" line per notification-to-deliver is appended to it.
run_engine() {
    python3 - "$1" "$2" "${3:-}" <<'PYEOF'
import sys, os, re, glob, json, time, fcntl, datetime, subprocess

MODE       = sys.argv[1]
NOTIFY_OUT = sys.argv[2]
ACK_TARGET = sys.argv[3] if len(sys.argv) > 3 else ''
# Only `check` may mutate persistent state (event offsets, debounce timestamps).
# `status` is a pure read; `ack` persists ONLY the acked flags it sets.
PERSIST    = (MODE == 'check')
# FORGE_WATCH_BOARD: '1' = machine JSON (cc-board/1, contract unchanged),
# '2' = pretty human board. FORGE_WATCH_SHOWALL expands maintenance in pretty.
BOARD      = os.environ.get('FORGE_WATCH_BOARD') == '1'
PRETTY     = os.environ.get('FORGE_WATCH_BOARD') == '2'
SHOWALL    = os.environ.get('FORGE_WATCH_SHOWALL') == '1'

HOME       = os.path.expanduser('~')
CACHE_DIR  = os.environ.get('FORGE_WATCH_CACHE_DIR',  os.path.join(HOME, '.cache', 'forge-watch'))
CONFIG_DIR = os.environ.get('FORGE_WATCH_CONFIG_DIR', os.path.join(HOME, '.config', 'forge'))
STATE_FILE = os.path.join(CACHE_DIR, 'state.json')
LOCK_FILE  = os.path.join(CACHE_DIR, 'state.lock')
WATCH_ENV  = os.path.join(CONFIG_DIR, 'watch.env')
WATCH_ROOTS= os.path.join(CONFIG_DIR, 'watch-roots')

os.makedirs(CACHE_DIR, exist_ok=True)

UTC = datetime.timezone.utc
NOW = datetime.datetime.now(UTC)

# ── config (watch.env parsed as DATA, never sourced) ─────────────────────
ALLOWED_KEYS = {
    'FORGE_STALL_THRESHOLD_S', 'FORGE_WATCH_DWELL_S', 'FORGE_WATCH_RENOTIFY_S',
    'FORGE_WATCH_ZOMBIE_AGE_D', 'FORGE_WATCH_NOTIFY_COMPLETE',
    'FORGE_WATCH_NOTIFY_STALE_ZOMBIE', 'FORGE_WATCH_ROOTS_FILE',
    'FORGE_WATCH_NOTIFY_REPLY', 'FORGE_WATCH_NOTIFY_DONE',
    'FORGE_WATCH_NOTIFY_PANE_DONE', 'FORGE_WATCH_TASK_WINDOW_S',
    'FORGE_WATCH_TASK_STUCK_S', 'FORGE_WATCH_CHECK_TIMEOUT_S',
    'FORGE_WATCH_QUIET_UNCHANGED',
}
# Conservative value grammar: allow path-ish chars (incl. space and ~ for real
# paths) but no shell metacharacters, substitutions, or quotes. Values are only
# ever used as data (int/bool/path), never sourced or eval'd.
_SAFE_VAL = re.compile(r'^[A-Za-z0-9 _./:+~-]*$')
config = {}
config_warnings = []

def load_config():
    if not os.path.exists(WATCH_ENV):
        return
    try:
        with open(WATCH_ENV) as f:
            lines = f.read().splitlines()
    except OSError as e:
        config_warnings.append(f"watch.env unreadable: {e}")
        return
    for n, raw in enumerate(lines, 1):
        line = raw.strip()
        if not line or line.startswith('#'):
            continue
        if '=' not in line:
            config_warnings.append(f"watch.env:{n}: not KEY=value, ignored")
            continue
        key, val = line.split('=', 1)
        key, val = key.strip(), val.strip()
        if key not in ALLOWED_KEYS:
            config_warnings.append(f"watch.env:{n}: unknown key '{key}', ignored")
            continue
        if not _SAFE_VAL.match(val):
            config_warnings.append(f"watch.env:{n}: unsafe value for '{key}', ignored")
            continue
        config[key] = val

load_config()

def cfg(key, default):
    # env var wins (interactive), then watch.env (launchd), then default.
    v = os.environ.get(key)
    if v is None:
        v = config.get(key)
    return v if v is not None else default

def cfg_int(key, default):
    try:
        return int(cfg(key, default))
    except (TypeError, ValueError):
        return default

def cfg_bool(key, default):
    v = str(cfg(key, '1' if default else '0')).lower()
    return v in ('1', 'true', 'yes', 'on')

STALL_THRESHOLD = cfg_int('FORGE_STALL_THRESHOLD_S', 600)
STALE_AGE       = 2 * STALL_THRESHOLD
DWELL_S         = cfg_int('FORGE_WATCH_DWELL_S', 300)
RENOTIFY_S      = cfg_int('FORGE_WATCH_RENOTIFY_S', 900)
BACKOFF_CAP_S   = 4 * 3600
ZOMBIE_AGE_S    = cfg_int('FORGE_WATCH_ZOMBIE_AGE_D', 7) * 86400
NOTIFY_COMPLETE = cfg_bool('FORGE_WATCH_NOTIFY_COMPLETE', True)
NOTIFY_STALE_ZOMBIE = cfg_bool('FORGE_WATCH_NOTIFY_STALE_ZOMBIE', False)
# Return-path knobs (default OFF; the board row is unconditional — only the bell is opt-in).
NOTIFY_REPLY    = cfg_bool('FORGE_WATCH_NOTIFY_REPLY', False)
NOTIFY_DONE     = cfg_bool('FORGE_WATCH_NOTIFY_DONE', False)
# Task-visibility knobs. PANE-DONE ring default OFF (code default stays 0 — the rollout flip to
# 1 is watch.env config, per operator decision). TASK_WINDOW bounds the live tasks[]/PANE-DONE
# view; TASK_STUCK is when an unanswered dispatched task becomes a loud, hot TASK-STUCK.
NOTIFY_PANE_DONE = cfg_bool('FORGE_WATCH_NOTIFY_PANE_DONE', False)
TASK_WINDOW_S    = cfg_int('FORGE_WATCH_TASK_WINDOW_S', 86400)   # 24h live-task window
TASK_STUCK_S     = cfg_int('FORGE_WATCH_TASK_STUCK_S', 21600)    # 6h → TASK-STUCK
STALE_TICK_S     = 3 * 30    # board/ambient freshness: ~3x the 30s launchd interval

# ── check-mode watchdog ──────────────────────────────────────────────────
# A hung check holds state.lock while every 30s tick skips silently; one ~110s
# run read as "watcher stale (115s)" on the menubar (2026-07-06). Bound the
# whole engine: die loudly on stderr, drop the lock, let the next tick recover.
CHECK_TIMEOUT_S = cfg_int('FORGE_WATCH_CHECK_TIMEOUT_S', 90)
if MODE == 'check' and CHECK_TIMEOUT_S > 0:
    import signal
    def _watchdog(signum, frame):
        sys.stderr.write(f"forge-watch: check aborted — exceeded {CHECK_TIMEOUT_S}s watchdog\n")
        os._exit(70)
    signal.signal(signal.SIGALRM, _watchdog)
    signal.alarm(CHECK_TIMEOUT_S)

# ── time helpers ─────────────────────────────────────────────────────────
def parse_iso(ts):
    # PyYAML auto-types an unquoted `updated_at: 2026-...Z` into a datetime/date;
    # accept those directly so the dwell/recency gates still work.
    if isinstance(ts, datetime.datetime):
        return ts if ts.tzinfo else ts.replace(tzinfo=UTC)
    if isinstance(ts, datetime.date):
        return datetime.datetime(ts.year, ts.month, ts.day, tzinfo=UTC)
    if not ts or not isinstance(ts, str):
        return None
    raw = ts.strip().strip('"').strip("'")
    iso = raw[:-1] + '+00:00' if raw.endswith('Z') else raw
    try:
        dt = datetime.datetime.fromisoformat(iso)
    except ValueError:
        return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=UTC)
    return dt

def age_s(ts):
    dt = parse_iso(ts)
    return None if dt is None else (NOW - dt).total_seconds()

def hhmm(ts):
    return ts[11:16] if isinstance(ts, str) and len(ts) >= 16 else (ts or '?')

def human_age(sec):
    if sec is None:
        return '?'
    sec = int(sec)
    if sec < 90:
        return f"{sec}s"
    if sec < 5400:
        return f"{sec // 60}m"
    if sec < 172800:
        return f"{sec // 3600}h"
    return f"{sec // 86400}d"

# ── state (lock-guarded, atomic write, corrupt-recovery) ─────────────────
# 'a' (not 'w'): opening must not truncate the holder's start-time stamp below.
_lock_fh = open(LOCK_FILE, 'a')
try:
    fcntl.flock(_lock_fh, fcntl.LOCK_EX | fcntl.LOCK_NB)
except OSError:
    # Another instance holds the lock (manual run vs launchd tick). Exit 0 so
    # launchd stays green, but leave a stderr trace — silent skips hid a
    # 2-minute stall from launchd.err entirely (2026-07-06).
    held = ''
    try:
        with open(LOCK_FILE) as _lf:
            _t = parse_iso(_lf.read().strip())
        if _t is not None:
            held = f" for ~{int((NOW - _t).total_seconds())}s"
    except OSError:
        pass
    sys.stderr.write(f"forge-watch: {MODE} skipped — state.lock held by another run{held}\n")
    sys.exit(0)
# We hold the lock: stamp our start time so a skipped run can report how long.
_lock_fh.seek(0)
_lock_fh.truncate()
_lock_fh.write(NOW.isoformat())
_lock_fh.flush()

def load_state():
    if not os.path.exists(STATE_FILE):
        return {'event_offsets': {}, 'conditions': {}}
    try:
        with open(STATE_FILE) as f:
            data = json.load(f)
        if not isinstance(data, dict):
            raise ValueError('state root not an object')
        data.setdefault('event_offsets', {})
        data.setdefault('conditions', {})
        return data
    except (ValueError, OSError):
        # Preserve the bad file; continue with empty advisory state.
        try:
            bad = STATE_FILE + '.bad.' + NOW.strftime('%Y%m%dT%H%M%SZ')
            os.replace(STATE_FILE, bad)
            config_warnings.append(f"corrupt state preserved as {os.path.basename(bad)}")
        except OSError:
            pass
        return {'event_offsets': {}, 'conditions': {}}

def save_state(state):
    tmp = STATE_FILE + '.tmp.' + str(os.getpid())
    with open(tmp, 'w') as f:
        json.dump(state, f, indent=2, sort_keys=True)
    os.replace(tmp, STATE_FILE)

state = load_state()

# ── discovery ────────────────────────────────────────────────────────────
def tmux_sessions():
    """Map session_name -> realpath(session_path). Empty if no tmux server.
    Test seam: FORGE_WATCH_TMUX_LIST names a file of 'name<TAB>path' lines used
    instead of shelling out to tmux."""
    inject = os.environ.get('FORGE_WATCH_TMUX_LIST')
    if inject is not None:
        m = {}
        try:
            with open(inject) as f:
                for line in f:
                    line = line.rstrip('\n')
                    if '\t' in line:
                        name, path = line.split('\t', 1)
                        m[name] = os.path.realpath(path)
        except OSError:
            pass
        return m
    try:
        out = subprocess.run(
            ['tmux', 'list-sessions', '-F', '#{session_name}\t#{session_path}'],
            capture_output=True, text=True, timeout=5)
    except (OSError, subprocess.SubprocessError):
        return {}
    if out.returncode != 0:
        return {}
    m = {}
    for line in out.stdout.splitlines():
        if '\t' not in line:
            continue
        name, path = line.split('\t', 1)
        m[name] = os.path.realpath(path)
    return m

SESSIONS = tmux_sessions()

def discover_roots():
    roots = set(SESSIONS.values())
    roots_file = os.path.expanduser(cfg('FORGE_WATCH_ROOTS_FILE', WATCH_ROOTS))
    if roots_file and os.path.exists(roots_file):
        try:
            with open(roots_file) as f:
                for line in f:
                    p = line.strip()
                    if p and not p.startswith('#'):
                        roots.add(os.path.realpath(os.path.expanduser(p)))
        except OSError:
            pass
    # Only roots that actually have a .dev/ dir are interesting.
    return sorted(r for r in roots if os.path.isdir(os.path.join(r, '.dev')))

# ── low-level parsers ────────────────────────────────────────────────────
try:
    import yaml
    HAVE_YAML = True
except ImportError:
    HAVE_YAML = False

# Files whose parse failed both ways this scan -> STATE-UNPARSEABLE findings.
unparseable = []  # list of (root, path)

def note_unparseable(root, path):
    unparseable.append((root, path))

def load_context(root, path):
    """Return dict of context fields, or None if unparseable."""
    try:
        with open(path) as f:
            raw = f.read()
    except OSError:
        return None
    if HAVE_YAML:
        try:
            data = yaml.safe_load(raw) or {}
            if isinstance(data, dict):
                return data
        except Exception:
            pass
    # Minimal line fallback (tolerates heredoc and yaml.dump writer styles).
    data = {}
    for line in raw.splitlines():
        m = re.match(r'^([a-z_]+):\s*(.*)$', line)
        if m:
            k, v = m.group(1), m.group(2).strip().strip('"').strip("'")
            data[k] = v
    if not data:
        note_unparseable(root, path)
        return None
    return data

def pending_entries(root, path):
    """Open (response: null) entries in a forge-log.yml.
    Returns list of dicts {stage,to,timestamp}. Uses the bridge's regex
    fallback when yaml.safe_load chokes on legacy malformed entries."""
    try:
        with open(path) as f:
            raw = f.read()
    except OSError:
        return []
    entries = None
    if HAVE_YAML:
        try:
            data = yaml.safe_load(raw) or {}
            entries = data.get('entries', []) or []
        except Exception:
            entries = None
    if entries is None:
        # Port of forge-bridge _render_status_file regex fallback.
        entries = []
        block_re = re.compile(r'^\s*-\s+timestamp:\s*"([^"]+)"', re.MULTILINE)
        starts = [(m.start(), m.group(1)) for m in block_re.finditer(raw)]
        if not starts and raw.strip():
            note_unparseable(root, path)
            return []
        for i, (off, ts) in enumerate(starts):
            end = starts[i + 1][0] if i + 1 < len(starts) else len(raw)
            blk = raw[off:end]
            def grab(field):
                mm = re.search(rf'^\s+{field}:\s*(.*?)\s*$', blk, re.MULTILINE)
                return mm.group(1).strip() if mm else None
            rmatch = re.search(r'^\s+response:\s*(null|"(?:[^"\\]|\\.)*")', blk, re.MULTILINE)
            if not rmatch:
                continue
            resp = None if rmatch.group(1) == 'null' else rmatch.group(1)
            entries.append({'timestamp': ts, 'stage': grab('stage'),
                            'to': grab('to'), 'response': resp})
    out = []
    for e in entries:
        # A hand-edited/legacy log can yield non-dict list items; skip them
        # rather than letting e.get() abort the whole root's scan.
        if isinstance(e, dict) and e.get('response') is None:
            out.append({'stage': e.get('stage'), 'to': e.get('to'),
                        'timestamp': e.get('timestamp')})
    return out

def parse_callback(path):
    """Parse a .callback file's scalar header. Returns dict or None."""
    try:
        with open(path) as f:
            raw = f.read()
    except OSError:
        return None
    d = {}
    for line in raw.splitlines():
        if line.startswith('message:'):
            break
        m = re.match(r'^([a-z_]+):\s*(.*)$', line)
        if m:
            d[m.group(1)] = m.group(2).strip()
    return d or None

# ── findings ─────────────────────────────────────────────────────────────
# policy: 'standard' (backoff), 'daily' (>=24h), 'never' (status-only)
findings = []  # dict: condition, root, key, policy, session, slug, stage, msg
TASKS = []     # cc-board/1 tasks[] projection (Step 3): read-time fold, no ledger

def add_finding(condition, root, key, msg, policy='standard',
                session=None, slug=None, stage=None):
    findings.append({
        'condition': condition, 'root': root,
        'key': f"{root}\t{condition}\t{key}", 'policy': policy,
        'session': session, 'slug': slug, 'stage': stage, 'msg': msg,
    })

def root_label(root):
    return os.path.basename(root.rstrip('/')) or root

QA_FAMILY = {'qa', 'qa-fix', 'qa-retry'}

def scan_root(root):
    dev = os.path.join(root, '.dev')
    tmp = os.path.join(dev, 'forge-tmp')
    label = root_label(root)

    # --- pipeline logs: open + stale pendings, indexed by slug ---
    open_by_slug = {}     # slug -> [pending,...]
    stale_pendings = []   # (slug, pending)
    for logp in glob.glob(os.path.join(dev, 'proposals', '*', 'forge-log.yml')):
        slug = os.path.basename(os.path.dirname(logp))
        pend = pending_entries(root, logp)
        if pend:
            open_by_slug[slug] = pend
        for p in pend:
            a = age_s(p.get('timestamp'))
            if a is not None and a > STALE_AGE:
                stale_pendings.append((slug, p))

    def has_open_pending(slug, stage=None):
        pend = open_by_slug.get(slug, [])
        if stage is None:
            return bool(pend)
        return any(p.get('stage') == stage for p in pend)

    # --- callback files: live BLOCKED (open pending still present) ---
    live_blocked = {}  # (slug,stage) -> callback dict
    for cbp in glob.glob(os.path.join(tmp, 'callbacks', '*.callback')):
        cb = parse_callback(cbp)
        if not cb:
            continue
        if (cb.get('status') or '').upper() != 'BLOCKED':
            continue
        slug, stage = cb.get('slug'), cb.get('stage')
        if slug and stage and has_open_pending(slug, stage):
            live_blocked[(slug, stage)] = cb

    for (slug, stage), cb in live_blocked.items():
        msg = f"{label} · {slug} — worker BLOCKED at {stage} (needs a human)"
        add_finding('WORKER-BLOCKED', root, f"{slug}\t{stage}", msg,
                    slug=slug, stage=stage)

    # --- WORKER-STALLED (suppressed when a live BLOCKED callback covers it) ---
    # A pending crossing the STALE threshold (2x FORGE_STALL_THRESHOLD_S) is an
    # actionable stall ONLY within the zombie age window; beyond that it is an
    # abandoned/never-closed proposal log (live .dev dirs accumulate months of
    # them), which is residue, not a worker to chase — so it is status-only.
    # Same active-vs-residue split the zombie triggers use, same knob.
    for slug, p in stale_pendings:
        stage = p.get('stage')
        if (slug, stage) in live_blocked:
            continue
        # Activity gate: a stage actively writing artifacts under its proposals
        # dir is WORKING, not stalled — a multi-round plan stage legitimately
        # outlives the pending-age window (live false alarm 2026-07-06).
        # forge-log.yml is excluded: the dispatch append itself is not liveness.
        sdir = os.path.join(dev, 'proposals', slug)
        fresh = False
        try:
            for dp, _, fns in os.walk(sdir):
                for fn in fns:
                    if fn == 'forge-log.yml':
                        continue
                    try:
                        if NOW.timestamp() - os.path.getmtime(os.path.join(dp, fn)) < STALL_THRESHOLD:
                            fresh = True
                            break
                    except OSError:
                        continue
                if fresh:
                    break
        except OSError:
            pass
        if fresh:
            continue
        sec = age_s(p.get('timestamp'))
        a = human_age(sec)
        if sec is not None and sec <= ZOMBIE_AGE_S:
            msg = (f"{label} · {slug} — worker stalled at {stage} "
                   f"(pending {a}, to {p.get('to')})")
            add_finding('WORKER-STALLED', root, f"{slug}\t{stage}", msg,
                        slug=slug, stage=stage)
        else:
            msg = (f"{label} · {slug} — abandoned open pending at {stage} "
                   f"(pending {a}, to {p.get('to')}); never-closed log residue")
            add_finding('STALE-PENDING', root, f"{slug}\t{stage}", msg,
                        policy='never', slug=slug, stage=stage)

    # --- event log (per-root; offset baselined to EOF on first sight) ---
    evlog = os.path.join(tmp, 'orchestrator-events.log')
    if os.path.exists(evlog):
        try:
            size = os.path.getsize(evlog)
        except OSError:
            size = 0
        offsets = state['event_offsets']
        prev = offsets.get(root)
        if prev is None or prev > size:
            # First sight, or log recreated/truncated -> baseline, process nothing.
            # Persist the baseline ONLY on `check`: a read-only `status`/`ack`
            # peek must never consume events out from under the launchd `check`.
            if PERSIST:
                offsets[root] = size
        else:
            # Binary read: offsets are byte positions (text-mode seek only
            # accepts tell() values and breaks on multibyte content).
            try:
                with open(evlog, 'rb') as f:
                    f.seek(prev)
                    blob = f.read()
            except OSError:
                blob = b''
            # Only consume complete lines (a half-written trailing line waits).
            nl = blob.rfind(b'\n')
            consumed = blob[:nl + 1] if nl >= 0 else b''
            if PERSIST:
                offsets[root] = prev + len(consumed)
            for line in consumed.decode('utf-8', 'replace').splitlines():
                _handle_event_line(root, label, line)

    # --- context files ---
    live_seen = False
    ctx_paths = sorted(glob.glob(os.path.join(dev, 'forge-context.*.yml')))
    for cp in ctx_paths:
        base = os.path.basename(cp)
        m = re.match(r'^forge-context\.(.+)\.yml$', base)
        embedded = m.group(1) if m else ''
        is_live = (embedded in SESSIONS and SESSIONS[embedded] == root)
        if is_live:
            live_seen = True
        _eval_context(root, label, cp, embedded, is_live,
                      has_open_pending, open_by_slug, live_blocked)

    # --- LEGACY bare context (status-only, only if no live suffixed ctx) ---
    legacy = os.path.join(dev, 'forge-context.yml')
    if os.path.exists(legacy) and not live_seen:
        ctx = load_context(root, legacy)
        if ctx:
            slug = str(ctx.get('active_pipeline') or '').strip()
            if slug and slug != 'null':
                msg = (f"{label} — legacy forge-context.yml points at '{slug}' "
                       f"(stage {ctx.get('last_stage_completed')}); "
                       f"migration hint, not owned by any live session")
                add_finding('LEGACY-CONTEXT', root, slug, msg, policy='never',
                            slug=slug)

def _handle_event_line(root, label, line):
    if ':' not in line:
        return
    typ, rest = line.split(':', 1)
    typ = typ.strip()
    fields = {}
    toks = rest.split()
    slug = None
    for t in toks:
        if '=' in t:
            k, v = t.split('=', 1)
            fields[k] = v
            if k == 'pipeline':
                slug = v
    stage = fields.get('result_stage') or fields.get('stage')
    if typ == 'CALLBACK' and fields.get('status', '').upper() == 'BLOCKED':
        msg = f"{label} · {slug} — worker BLOCKED at {stage} (needs a human)"
        add_finding('WORKER-BLOCKED', root, f"{slug}\t{stage}", msg,
                    slug=slug, stage=stage)
    elif typ == 'STAGE' and fields.get('status') == 'error':
        msg = f"{label} · {slug} — stage {stage} ERRORED"
        add_finding('STAGE-ERROR', root, f"{slug}\t{stage}", msg,
                    slug=slug, stage=stage)
    elif typ in ('ERROR', 'GUARD_BLOCK'):
        reason = fields.get('reason', typ.lower())
        msg = f"{label} · {slug} — pipeline {typ.lower()} at {stage} ({reason})"
        add_finding('PIPELINE-ERROR', root, f"{slug}\t{stage}\t{reason}", msg,
                    slug=slug, stage=stage)
    elif typ == 'STALL':
        st = fields.get('state', '')
        msg = f"{label} · {slug} — worker stall reported at {stage} ({st})"
        add_finding('WORKER-STALL-EVENT', root, f"{slug}\t{stage}\t{st}", msg,
                    slug=slug, stage=stage)
    elif typ == 'COMPLETE' and NOTIFY_COMPLETE:
        msg = f"{label} · {slug} — pipeline COMPLETE"
        add_finding('PIPELINE-COMPLETE', root, slug, msg, policy='once', slug=slug)

def _eval_context(root, label, cp, embedded, is_live,
                  has_open_pending, open_by_slug, live_blocked):
    ctx = load_context(root, cp)
    if ctx is None:
        return  # unparseable already recorded
    slug   = str(ctx.get('active_pipeline') or '').strip()
    last   = str(ctx.get('last_stage_completed') or '').strip()
    status = str(ctx.get('last_stage_status') or '').strip()
    nxt    = str(ctx.get('next_stage') or '').strip()
    updated = ctx.get('updated_at')
    if not slug or slug == 'null':
        return

    if is_live:
        # PIPELINE-COMPLETE fallback: context reached terminal next_stage with
        # no COMPLETE event seen. Same slug key as the event source, so the two
        # dedup; the context source persists the condition so the event-consumed
        # finding does not re-fire on the next scan.
        if nxt == 'complete' and NOTIFY_COMPLETE:
            add_finding('PIPELINE-COMPLETE', root, slug,
                        f"{label} · {slug} — pipeline COMPLETE",
                        policy='once', session=embedded, slug=slug)
        # STAGE-ERROR from context.
        if status == 'error':
            msg = f"{label} · {slug} — stage {last} ERRORED"
            add_finding('STAGE-ERROR', root, f"{slug}\t{last}", msg,
                        session=embedded, slug=slug, stage=last)
        # NEEDS-DECISION: decision predicate + no open pending + dwelled.
        decision = (nxt == 'pending-orchestrator-decision' or
                    (last in QA_FAMILY and status == 'done' and nxt != 'complete'))
        if decision and not has_open_pending(slug):
            a = age_s(updated)
            if a is not None and a >= DWELL_S:
                msg = (f"{label} · {slug} — decision needed after {last} "
                       f"(idle {human_age(a)})")
                add_finding('NEEDS-DECISION', root, slug, msg,
                            session=embedded, slug=slug, stage=last)
        return

    # --- zombie: context whose session is not live at this root ---
    if nxt == 'complete':
        return  # finished; not a zombie
    evidence = (has_open_pending(slug) or
                any(s == slug for (s, _st) in live_blocked) or
                status == 'error')
    a = age_s(updated)
    recent = (a is not None and a <= ZOMBIE_AGE_S)
    if evidence or recent:
        msg = (f"{label} · {slug} — ZOMBIE (session '{embedded}' gone, "
               f"stage {last}, next {nxt or '(empty)'}, {human_age(a)} old)")
        add_finding('ZOMBIE-ACTIVE', root, slug, msg, policy='daily',
                    session=embedded, slug=slug, stage=last)
    else:
        policy = 'standard' if NOTIFY_STALE_ZOMBIE else 'never'
        msg = (f"{label} · {slug} — stale zombie context (session '{embedded}' "
               f"gone, stage {last}, next {nxt or '(empty)'}, {human_age(a)} old)")
        add_finding('ZOMBIE-STALE-CONTEXT', root, slug, msg, policy=policy,
                    session=embedded, slug=slug, stage=last)

# ── attention ingestion (command center; READ-ONLY) ─────────────────────
def _load_att(path):
    try:
        with open(path) as f:
            d = json.load(f)
        return d if isinstance(d, dict) else None
    except (ValueError, OSError):
        return None

def perm_detail(pr):
    # Detail slot of a NEEDS-PERMISSION row. An AskUserQuestion perm record
    # carries question_snippet/question_options (forge-cc-hook, 2026-07-07) —
    # show WHAT is being asked so the operator's tab-switch is informed, not
    # blind. Records without the fields render exactly as before.
    tool = pr.get('tool_name') or 'tool'
    q = (pr.get('question_snippet') or '').strip()
    if q:
        msg = f"question ({tool}): {q[:100]}"
        opts = [o for o in (pr.get('question_options') or []) if o][:4]
        if opts:
            msg += " · options: " + " / ".join(o[:30] for o in opts)
        more = (pr.get('question_count') or 1) - 1
        if more > 0:
            msg += f" (+{more} more)"
        return msg
    cmd = (pr.get('command') or '').strip()
    return f"permission needed: {tool}" + (f" ({cmd[:60]})" if cmd else "")

def scan_attention(root, label):
    """Read <root>/.dev/attention/*.json (written by bin/forge + forge-cc-hook)
    and add findings. READ-ONLY — never writes or deletes. The live queued/
    working/done state is DERIVED by pairing the newest dispatch event against the
    rolling prompt/stop activity files; no file is ever mutated. Exactly ONE
    lifecycle state per session (queued > done > working by priority)."""
    adir = os.path.join(root, '.dev', 'attention')
    if not os.path.isdir(adir):
        return
    latest_disp, prompt_ev, stop_ev = {}, {}, {}
    dispatch_by_id = {}
    perms = {}
    asks = []
    spawn_states = []
    worker_prompts, worker_stops, worker_perms = {}, [], []   # namespaced per-turn files
    for fp in sorted(glob.glob(os.path.join(adir, '*.json'))):
        rec = _load_att(fp)
        if rec is None:
            note_unparseable(root, fp)
            continue
        base = os.path.basename(fp)
        # Worker hook files are namespaced per-turn and MUST NOT reach the canonical
        # session-lifecycle structures below — routed by FILENAME (robust even if the `role`
        # field is ever missing; a wstop carries event="stop" and would otherwise set
        # stop_ev[sess] and mark the SESSION done — the forbidden behavior).
        if base.startswith('wprompt.'):
            s = rec.get('session')
            if s:
                worker_prompts[(s, rec.get('pane_index'))] = rec   # per-pane LWW (turns sequential)
            continue
        if base.startswith('wstop.'):
            worker_stops.append(rec); continue
        if base.startswith('wperm.'):
            worker_perms.append(rec); continue
        ev = rec.get('event') or ''
        sess = rec.get('session')
        if ev == 'ask':
            asks.append(rec)          # session OPTIONAL: an ask stays surfaced
            continue                  # even when fired outside tmux
        if ev == 'spawn-state':
            spawn_states.append(rec)  # needs-repair / population-failure / first-launch
            continue
        if not sess:
            continue
        if ev == 'dispatch':
            if age_s(rec.get('dispatched_at')) is None:
                continue
            cur = latest_disp.get(sess)
            if cur is None or (age_s(rec.get('dispatched_at')) <
                               (age_s(cur.get('dispatched_at')) or 1e18)):
                latest_disp[sess] = rec        # newest = smallest age
            rid = rec.get('dispatch_id')
            if rid:
                dispatch_by_id[rid] = rec      # keyed by id for the answered-did gate
        elif ev == 'userpromptsubmit':
            prompt_ev[sess] = rec              # rolling: last-writer-wins
        elif ev == 'stop':
            stop_ev[sess] = rec
        elif ev == 'permissionrequest':
            perms.setdefault(sess, []).append(rec)
    sessions = set(latest_disp) | set(prompt_ev) | set(stop_ev) | set(perms)
    for sess in sessions:
        s_stop = stop_ev.get(sess)
        stop_at = parse_iso(s_stop.get('emitted_at')) if s_stop else None
        # NEEDS-PERMISSION (hot, notifies): a later Stop supersedes it (turn moved
        # on / answered); a request past the recency window is residue.
        for pr in perms.get(sess, []):
            pat = parse_iso(pr.get('emitted_at'))
            if stop_at is not None and pat is not None and stop_at > pat:
                continue
            a = age_s(pr.get('emitted_at'))
            if a is not None and a > ZOMBIE_AGE_S:
                continue
            add_finding('NEEDS-PERMISSION', root, f"{sess}\t{pr.get('command_hash','')}",
                        f"{label} · {sess} — {perm_detail(pr)}", session=sess)
        # lifecycle: EXACTLY ONE of queued-input / working / done per session.
        d = latest_disp.get(sess)
        accepted = False
        if d is not None:
            did = d.get('dispatch_id'); disp_at = parse_iso(d.get('dispatched_at'))
            p = prompt_ev.get(sess)
            if p is not None and p.get('dispatch_id') and p.get('dispatch_id') == did:
                accepted = True                # idle-landing: UserPromptSubmit id match
            elif stop_at is not None and disp_at is not None and stop_at >= disp_at:
                accepted = True                # absorption: next Stop after dispatch
        if d is not None and not accepted:
            snip = (d.get('instruction_snippet') or '')[:60]
            add_finding('SESSION-QUEUED', root, sess,
                        f"{label} · {sess} — queued-input: {snip}",
                        policy='never', session=sess)
        else:
            p = prompt_ev.get(sess)
            p_at = parse_iso(p.get('emitted_at')) if p else None
            if stop_at is not None and (p_at is None or stop_at >= p_at):
                snip = (s_stop.get('snippet') or '')
                # NEEDS-REPLY: this done turn is a seat-correlated counter-question.
                # Gate on the dispatch the stop event RECORDS it answered
                # (response_dispatch_ids[0]), NOT latest_disp (newest-by-time = the
                # wrong dispatch mid-turn). Old events w/o the field degrade to
                # latest_disp, back-filling aid so the ack key is never `sess\tNone`.
                aid = (s_stop.get('response_dispatch_ids') or [None])[0]
                dr = dispatch_by_id.get(aid) if aid else None
                if dr is None:
                    dr = latest_disp.get(sess)
                    if aid is None and dr is not None:
                        aid = dr.get('dispatch_id')
                dstop = age_s(s_stop.get('emitted_at'))
                if (s_stop.get('looks_like_question')
                        and dr is not None and dr.get('sender') == 'seat'
                        and dstop is not None and dstop <= ZOMBIE_AGE_S):
                    qs = (s_stop.get('question_snippet') or snip or '').strip()
                    add_finding('NEEDS-REPLY', root, f"{sess}\t{aid}",
                                f"{label} · {sess} — awaiting reply: {qs[:100]}{'…' if len(qs) > 100 else ''}" if qs
                                else f"{label} · {sess} — awaiting reply (worker waiting; see tab)",
                                policy=('standard' if NOTIFY_REPLY else 'never'),
                                session=sess)
                else:
                    add_finding('SESSION-DONE', root, sess,
                                f"{label} · {sess} — done" + (f": {snip}" if snip else ""),
                                policy=('standard' if NOTIFY_DONE else 'never'),
                                session=sess)
            elif p_at is not None:
                add_finding('SESSION-WORKING', root, sess,
                            f"{label} · {sess} — working", policy='never', session=sess)
    # NEEDS-ASK (hot, notifies): a worker's explicit escalation via `forge ask`.
    # Keyed by ask_id so each ask is a distinct escalation. An ask is NOT
    # superseded by a later Stop — it stays hot until answered (dispatch --answers
    # archives it out of this depth-1 glob). A very old ask is abandoned residue
    # (same ZOMBIE_AGE_S cutoff the permission feed uses). Precedence ask > BLOCKED
    # is enforced by the WORKER-BLOCKED suppression at the run-scan level below.
    for rec in asks:
        aid = rec.get('ask_id')
        if not aid:
            continue
        a = age_s(rec.get('emitted_at'))
        if a is not None and a > ZOMBIE_AGE_S:
            continue
        sess = rec.get('session')
        slug = rec.get('slug'); stage = rec.get('stage'); worker = rec.get('worker')
        q = (rec.get('question_snippet') or '').strip()
        who = sess or label
        tag = f" ({slug}/{stage})" if slug and stage else ""
        msg = f"{label} · {who} — worker asks{tag}: {q[:80]}" if q \
            else f"{label} · {who} — worker asks{tag} (see tab)"
        add_finding('NEEDS-ASK', root, aid, msg, session=sess, slug=slug, stage=stage)
    # SPAWN lifecycle (P6): needs-repair / population-failure surface HOT;
    # first-launch is a one-time nudge (policy 'once'). Recency-gated by
    # ZOMBIE_AGE_S. Event files are keyed spawn-<session>-<state>.json so a
    # re-run OVERWRITES (findings dedup by key anyway; the keyed filename is
    # what lets spawn REMOVE a resolved state and keeps files from piling up).
    # READ-ONLY — spawn owns the files; forge-watch never mutates.
    for rec in spawn_states:
        sess = rec.get('session')
        if not sess:
            continue
        a = age_s(rec.get('emitted_at'))
        if a is not None and a > ZOMBIE_AGE_S:
            continue
        st = rec.get('state') or ''
        det = (rec.get('detail') or '').strip()
        if st == 'needs-repair':
            add_finding('SPAWN-NEEDS-REPAIR', root, f"{sess}\tneeds-repair",
                        f"{label} · {sess} — spawn needs-repair" + (f": {det}" if det else ""),
                        session=sess)
        elif st == 'population-failure':
            add_finding('SPAWN-POPULATE-FAILED', root, f"{sess}\tpopfail",
                        f"{label} · {sess} — population FAILED" + (f": {det}" if det else ""),
                        session=sess)
        elif st == 'first-launch':
            add_finding('SPAWN-FIRST-LAUNCH', root, f"{sess}\tfirstlaunch",
                        f"{label} · {sess} — first launch" + (f": {det}" if det else ""),
                        policy='once', session=sess)

    # ── worker per-turn ingestion (Step 2/3): NEVER touches the session lifecycle ──
    adir_p = os.path.join(adir, 'payloads')
    # latest worker Stop per (session, pane) — SESSIONS latest-per-pane + perm supersession.
    latest_wstop = {}
    for ws in worker_stops:
        k = (ws.get('session'), ws.get('pane_index'))
        a = age_s(ws.get('emitted_at'))
        if a is None:
            continue
        cur = latest_wstop.get(k)
        if cur is None or a < (age_s(cur.get('emitted_at')) or 1e18):
            latest_wstop[k] = ws
    # a pane that started a newer turn (wprompt after its last wstop) is WORKING again.
    now_working = set()
    for (sess, pane), wp in worker_prompts.items():
        ws = latest_wstop.get((sess, pane))
        wp_at = parse_iso(wp.get('emitted_at'))
        ws_at = parse_iso(ws.get('emitted_at')) if ws else None
        if ws is None or (wp_at is not None and ws_at is not None and wp_at > ws_at):
            now_working.add((sess, pane))
    # worker NEEDS-PERMISSION (reuses the hot condition); a later worker Stop supersedes it.
    for pr in worker_perms:
        sess = pr.get('session'); pane = pr.get('pane_index')
        a = age_s(pr.get('emitted_at'))
        if a is None or a > ZOMBIE_AGE_S:
            continue
        ws = latest_wstop.get((sess, pane))
        pat = parse_iso(pr.get('emitted_at'))
        wat = parse_iso(ws.get('emitted_at')) if ws else None
        if wat is not None and pat is not None and wat > pat:
            continue
        add_finding('NEEDS-PERMISSION', root, f"{sess}\tp{pane}\t{pr.get('command_hash','')}",
                    f"{label} · {sess} p{pane} — {perm_detail(pr)}", session=sess)
    # PANE-DONE (active): latest done turn per pane, within the window, not working again.
    # policy 'never' by default (board row, no ring); FORGE_WATCH_NOTIFY_PANE_DONE arms it.
    for (sess, pane), ws in latest_wstop.items():
        if (sess, pane) in now_working:
            continue
        a = age_s(ws.get('emitted_at'))
        if a is None or a > TASK_WINDOW_S:
            continue
        sn = (ws.get('snippet') or '')
        add_finding('PANE-DONE', root, f"{sess}\tp{pane}\t{ws.get('task_id')}",
                    f"{label} · {sess} p{pane} — pane done ({ws.get('agent','?')})"
                    + (f": {sn[:80]}" if sn else ""),
                    policy=('standard' if NOTIFY_PANE_DONE else 'never'), session=sess)
    # older worker-done turns (beyond the window) collapse into ONE maintenance count.
    old_done = sum(1 for ws in worker_stops if (age_s(ws.get('emitted_at')) or 0) > TASK_WINDOW_S)
    if old_done:
        add_finding('PANE-DONE-RESIDUE', root, f"{label}\told-worker-done",
                    f"{label} — {old_done} older worker-done turn(s) (see `forge tasks`)",
                    policy='never')
    # ── tasks[] projection: dispatched (queued/accepted/answered) + worker (working/done) ──
    def _mtime_iso(p):
        try:
            return datetime.datetime.fromtimestamp(os.path.getmtime(p), UTC).strftime('%Y-%m-%dT%H:%M:%SZ')
        except OSError:
            return None
    for did, d in dispatch_by_id.items():
        resp = os.path.join(adir_p, f'response.{did}.txt')
        answered = os.path.exists(resp)
        p = prompt_ev.get(d.get('session'))
        accepted = bool(p and p.get('dispatch_id') == did)
        state = 'answered' if answered else ('accepted' if accepted else 'queued')
        disp_at = d.get('dispatched_at')
        if state == 'answered' and (age_s(disp_at) or 0) > TASK_WINDOW_S:
            continue                       # terminal + old → out of the live view
        TASKS.append({'task_id': did, 'session': d.get('session'), 'root': root, 'label': label,
                      'agent': 'claude', 'pane': d.get('target_pane', 1), 'state': state,
                      'dispatched_at': disp_at, 'started_at': None,
                      'answered_at': (_mtime_iso(resp) if answered else None),
                      'response_path': (os.path.join('.dev', 'attention', 'payloads', f'response.{did}.txt') if answered else None),
                      'prompt_snippet': d.get('instruction_snippet'), 'snippet': None})
    for (sess, pane) in now_working:
        wp = worker_prompts[(sess, pane)]
        if (age_s(wp.get('emitted_at')) or 0) > TASK_WINDOW_S:
            continue
        TASKS.append({'task_id': wp.get('task_id'), 'session': sess, 'root': root, 'label': label,
                      'agent': wp.get('agent', 'claude'), 'pane': pane, 'state': 'working',
                      'dispatched_at': None, 'started_at': wp.get('emitted_at'), 'answered_at': None,
                      'response_path': None, 'prompt_snippet': wp.get('prompt_snippet'), 'snippet': None})
    for ws in worker_stops:
        if (age_s(ws.get('emitted_at')) or 1e18) > TASK_WINDOW_S:
            continue
        TASKS.append({'task_id': ws.get('task_id'), 'session': ws.get('session'), 'root': root,
                      'label': label, 'agent': ws.get('agent', 'claude'), 'pane': ws.get('pane_index'),
                      'state': 'done', 'dispatched_at': None, 'started_at': None,
                      'answered_at': ws.get('emitted_at'), 'response_path': None,
                      'prompt_snippet': ws.get('prompt_snippet'), 'snippet': ws.get('snippet')})
    # ── TASK-STUCK (Step 4 partner): a dispatched task unterminated past the stall window ──
    for did, d in dispatch_by_id.items():
        if os.path.exists(os.path.join(adir_p, f'response.{did}.txt')):
            continue
        a = age_s(d.get('dispatched_at'))
        if a is not None and a > TASK_STUCK_S:
            add_finding('TASK-STUCK', root, f"{d.get('session')}\t{did}",
                        f"{label} · {d.get('session')} — task {did} unanswered for {human_age(a)} "
                        f"(dispatched, never returned)", session=d.get('session'))
    # ── CODEX-EMISSION-OFF (Step 7): codex hooks installed but no codex signal seen yet ──
    # Observational trust proxy: the register marker is present but no codex-tagged worker file
    # has appeared. Clears on the first codex emission. GC-bounded (7d) — see §7 limitations.
    if os.path.isfile(os.path.join(adir, 'codex-register.json')):
        seen_codex = (any(ws.get('agent') == 'codex' for ws in worker_stops)
                      or any(wp.get('agent') == 'codex' for wp in worker_prompts.values()))
        if not seen_codex:
            add_finding('CODEX-EMISSION-OFF', root, f"{label}\tcodex",
                        f"{label} — codex hooks installed but no codex emission seen; complete the "
                        f"one-time `/hooks` trust review in a codex pane at this root", policy='never')

# ── run the scan ─────────────────────────────────────────────────────────
for root in discover_roots():
    try:
        scan_root(root)
    except Exception as e:
        config_warnings.append(f"scan error in {root_label(root)}: {e}")
    try:
        scan_attention(root, root_label(root))
    except Exception as e:
        config_warnings.append(f"attention scan error in {root_label(root)}: {e}")

# ── delivery audit → DELIVERY-UNVERIFIED (Step 5) ─────────────────────────
# Read the LAST delivered.log line: a nonzero rc means the ring is unverified. A later
# successful delivery appends an rc:0 line → the finding self-clears. Machine-scoped (keyed to
# CACHE_DIR → root_label 'forge-watch'), not per-root. policy='never' — a board/ambient row, not
# a bell.
def _last_delivery():
    try:
        with open(os.path.join(CACHE_DIR, 'delivered.log')) as f:
            lines = f.readlines()[-20:]
    except OSError:
        return None
    for ln in reversed(lines):
        try:
            return json.loads(ln)
        except ValueError:
            continue
    return None
_dl = _last_delivery()
if _dl and _dl.get('rc', 0) != 0:
    a = age_s(_dl.get('ts'))
    if a is None or a <= ZOMBIE_AGE_S:
        add_finding('DELIVERY-UNVERIFIED', CACHE_DIR, f"delivery\t{_dl.get('ts')}",
                    f"forge-watch — last notification FAILED (channel {_dl.get('channel')}, "
                    f"rc {_dl.get('rc')}); the ring is unverified — run `forge-watch selftest`",
                    policy='never', session=None)
# selftest sentinel sent but not yet confirmed → DELIVERY-UNVERIFIED banner (P22).
try:
    with open(os.path.join(CACHE_DIR, 'selftest.json')) as f:
        _st = json.load(f)
except (OSError, ValueError):
    _st = None
if isinstance(_st, dict) and _st.get('id') and not _st.get('confirmed'):
    add_finding('DELIVERY-UNVERIFIED', CACHE_DIR, f"selftest\t{_st.get('id')}",
                f"forge-watch — delivery self-test {_st.get('id')} sent but not confirmed; run "
                f"`forge-watch selftest --confirm {_st.get('id')}` when you see the notification",
                policy='never', session=None)

# STATE-UNPARSEABLE (keyed by path + mtime/size so a changed file re-fires).
for root, path in unparseable:
    try:
        stt = os.stat(path)
        ver = f"{int(stt.st_mtime)}:{stt.st_size}"
    except OSError:
        ver = '0:0'
    msg = f"{root_label(root)} — unparseable state file {os.path.basename(path)}"
    add_finding('STATE-UNPARSEABLE', root, f"{path}\t{ver}", msg, slug=None)

# A dead-session pipeline with a stale open pending would otherwise fire both
# ZOMBIE-ACTIVE and WORKER-STALLED/STALE-PENDING for the same (root, slug). The
# zombie carries strictly more information (session gone), so drop the stall/
# residue twins for any slug already flagged as a zombie.
zombie_slugs = {(f['root'], f['slug']) for f in findings
                if f['condition'] == 'ZOMBIE-ACTIVE' and f['slug']}
if zombie_slugs:
    findings = [f for f in findings
                if not (f['condition'] in ('WORKER-STALLED', 'STALE-PENDING')
                        and (f['root'], f['slug']) in zombie_slugs)]

# Precedence ask > open BLOCKED callback: a stage-mode `forge ask` writes BOTH an
# ask event (NEEDS-ASK) AND a BLOCKED callback (WORKER-BLOCKED via scan_root) for
# the same (root,slug,stage). Keep only the richer NEEDS-ASK (it carries the
# question) so one escalation is not notified twice.
ask_stage_keys = {(f['root'], f['slug'], f['stage']) for f in findings
                  if f['condition'] == 'NEEDS-ASK' and f['slug'] and f['stage']}
if ask_stage_keys:
    findings = [f for f in findings
                if not (f['condition'] == 'WORKER-BLOCKED'
                        and (f['root'], f['slug'], f['stage']) in ask_stage_keys)]

# Precedence NEEDS-ASK > NEEDS-REPLY: a stage-mode `forge ask` ends its turn on a
# '?' too, so the same session can raise both. Keep only the richer NEEDS-ASK.
# Keyed (root, session) so same-named sessions in different roots never cross-suppress.
ask_sessions = {(f['root'], f['session']) for f in findings
                if f['condition'] == 'NEEDS-ASK' and f.get('session')}
if ask_sessions:
    findings = [f for f in findings
                if not (f['condition'] == 'NEEDS-REPLY'
                        and (f['root'], f['session']) in ask_sessions)]

# ── dedup findings by key (context+event may agree) ──────────────────────
by_key = {}
for f in findings:
    by_key.setdefault(f['key'], f)
findings = list(by_key.values())

# ── ACK mode: mark matching current conditions acked, then exit ──────────
def finding_matches(f, target):
    fields = [f.get('session'), f.get('slug'),
              os.path.basename(f['root'].rstrip('/')), f['root']]
    return any(x and x == target for x in fields)

if MODE == 'ack':
    conds = state['conditions']
    n = 0
    for f in findings:
        if finding_matches(f, ACK_TARGET):
            e = conds.setdefault(f['key'], {'first_seen': NOW.isoformat(),
                                            'last_notified': None, 'count': 0})
            e['acked'] = True
            n += 1
            print(f"  acked: {f['condition']}  {f['msg']}")
    save_state(state)
    if n == 0:
        print(f"(no active conditions match '{ACK_TARGET}')")
    else:
        print(f"Acknowledged {n} condition(s) for '{ACK_TARGET}'.")
    sys.exit(0)

# ── debounce / backoff, decide deliveries ────────────────────────────────
conds = state['conditions']
current_keys = set()
deliveries = []  # (title, body)

def interval_for(policy, count):
    if policy == 'daily':
        return 86400
    return min(RENOTIFY_S * (2 ** max(0, count - 1)), BACKOFF_CAP_S)

# Only `check` mutates debounce state and persists. `status` is a pure read
# (below, the output section reads `conds` without touching it).
FINDINGS_CHANGED = True   # status/ack always print; check compares signatures below
if MODE == 'check':
    for f in findings:
        key = f['key']
        current_keys.add(key)
        policy = f['policy']
        e = conds.get(key)
        if policy == 'never':
            if e is None:
                conds[key] = {'first_seen': NOW.isoformat(),
                              'last_notified': None, 'count': 0, 'acked': False}
            continue
        want = False
        if e is None:
            conds[key] = {'first_seen': NOW.isoformat(),
                          'last_notified': NOW.isoformat(), 'count': 1, 'acked': False}
            want = True
        elif e.get('acked') or policy == 'once':
            # 'once' = notify on transition only; never re-notify while it
            # persists (e.g. a completed pipeline whose pane stays open).
            want = False
        else:
            last = parse_iso(e.get('last_notified'))
            count = e.get('count', 1)
            due = last is None or (NOW - last).total_seconds() >= interval_for(policy, count)
            if due:
                e['count'] = count + 1
                e['last_notified'] = NOW.isoformat()
                want = True
        if want:
            deliveries.append((f"forge · {f['condition']}", f['msg']))

    # Clear entries whose condition is no longer current (fresh on re-entry).
    for key in list(conds.keys()):
        if key not in current_keys:
            del conds[key]

    # Findings signature: lets the next tick print nothing when nothing changed
    # (launchd.out hit 37MB from identical 30s dumps; delivered.log + state.json
    # carry the durable signal).
    _sig = json.dumps(sorted([f['condition'], f['msg']] for f in findings))
    FINDINGS_CHANGED = state.get('findings_sig') != _sig
    state['findings_sig'] = _sig
    # Heartbeat for the board/ambient freshness line. Completion time, NOT the
    # module-level NOW: a slow run must not stamp a heartbeat that is already
    # stale at birth (the 115s-stale incident double-counted its own hang).
    state['last_tick'] = datetime.datetime.now(UTC).isoformat()
    save_state(state)

# ── output ───────────────────────────────────────────────────────────────
NOTIFY = ['SPAWN-POPULATE-FAILED', 'SPAWN-NEEDS-REPAIR', 'DELIVERY-UNVERIFIED',
          'NEEDS-ASK', 'NEEDS-REPLY', 'NEEDS-DECISION', 'WORKER-BLOCKED', 'NEEDS-PERMISSION',
          'TASK-STUCK', 'STAGE-ERROR', 'PIPELINE-ERROR', 'WORKER-STALLED', 'WORKER-STALL-EVENT',
          'PIPELINE-COMPLETE', 'ZOMBIE-ACTIVE', 'SPAWN-FIRST-LAUNCH', 'STATE-UNPARSEABLE']
order = {c: i for i, c in enumerate(
    NOTIFY + ['SESSION-QUEUED', 'SESSION-WORKING', 'SESSION-DONE', 'PANE-DONE',
              'ZOMBIE-STALE-CONTEXT', 'STALE-PENDING', 'PANE-DONE-RESIDUE',
              'CODEX-EMISSION-OFF', 'LEGACY-CONTEXT'])}
findings.sort(key=lambda f: (order.get(f['condition'], 99), f['msg']))

HOT = {'SPAWN-POPULATE-FAILED', 'SPAWN-NEEDS-REPAIR', 'SPAWN-FIRST-LAUNCH',
       'NEEDS-ASK', 'NEEDS-REPLY', 'NEEDS-DECISION', 'WORKER-BLOCKED', 'NEEDS-PERMISSION',
       'TASK-STUCK', 'DELIVERY-UNVERIFIED',
       'STAGE-ERROR', 'PIPELINE-ERROR', 'WORKER-STALLED', 'WORKER-STALL-EVENT',
       'ZOMBIE-ACTIVE', 'STATE-UNPARSEABLE'}
ACTIVE = {'SESSION-QUEUED', 'SESSION-WORKING', 'SESSION-DONE', 'PIPELINE-COMPLETE', 'PANE-DONE'}
STATE_OF = {'SESSION-QUEUED': 'queued-input', 'SESSION-WORKING': 'working',
            'SESSION-DONE': 'done', 'PANE-DONE': 'done', 'NEEDS-PERMISSION': 'needs-input',
            'NEEDS-DECISION': 'needs-input', 'NEEDS-ASK': 'needs-input',
            'NEEDS-REPLY': 'needs-input', 'TASK-STUCK': 'needs-input',
            'DELIVERY-UNVERIFIED': 'needs-input',
            'SPAWN-NEEDS-REPAIR': 'needs-input', 'SPAWN-POPULATE-FAILED': 'needs-input',
            'SPAWN-FIRST-LAUNCH': 'needs-input'}
def _cls(c):
    return 'hot' if c in HOT else 'active' if c in ACTIVE else 'maintenance'

def _task_ts(t):
    return t.get('answered_at') or t.get('dispatched_at') or t.get('started_at') or ''

# ── human rendering helpers (shared by the --tasks view and the pretty board) ──
import shutil
R_WIDTH = max(60, min(shutil.get_terminal_size((100, 24)).columns, 120))
R_COLOR = sys.stdout.isatty() and not os.environ.get('NO_COLOR')
def paint(code, s):
    return f"\033[{code}m{s}\033[0m" if R_COLOR else s
def flat(s):
    return ' '.join((s or '').split())
def clip(s, w):
    # word-boundary clip: never end a row mid-word
    s = flat(s)
    if len(s) <= w:
        return s
    cut = s[:max(1, w - 1)]
    sp = cut.rfind(' ')
    if sp >= int(w * 0.6):
        cut = cut[:sp]
    return cut.rstrip(' ,;:-') + '…'
def sect(title, extra='', color='1'):
    # section band: bold title + dim rule to the terminal edge
    pad = R_WIDTH - len(title) - (len(extra) + 1 if extra else 0) - 1
    return (paint(color, title) + (' ' + paint('2', extra) if extra else '')
            + ' ' + paint('2', '─' * max(0, pad)))
def natkey(s):
    return [int(x) if x.isdigit() else x for x in re.split(r'(\d+)', s or '')]
STAGE_DISPATCH = re.compile(r'\.dev/forge-tmp/([^\s`"\']+?)(?:\.(?:md|txt))?(?=[\s`"\']|$)')
def task_desc(t):
    # Pipeline stage dispatches all read "Read and follow instructions in
    # .dev/forge-tmp/<worker-stage-slug>.md" — the basename IS the identity;
    # surface it instead of the boilerplate.
    d = flat(t.get('prompt_snippet') or t.get('snippet') or '')
    m = STAGE_DISPATCH.search(d)
    if m and re.match(r'(?i)(override|read and follow)', d):
        return 'stage · ' + m.group(1)
    return d
TASK_COL = {'answered': '32', 'done': '32', 'working': '33', 'accepted': '33',
            'queued': '2'}
def task_rows(t, indent, show_sess=False):
    # one task = one line (state · age · pane/agent · what) + a paste-ready
    # retrieval hint under answered tasks
    st = t['state']
    ts = _task_ts(t)
    a = age_s(ts) if ts else None
    age = human_age(a) if a is not None else ''
    pane = f"p{t['pane']}" if t.get('pane') is not None else 'p1'
    who = (f"{t.get('session') or t.get('label') or ''}  " if show_sess else '')
    meta = f"{pane} {t.get('agent') or ''}".strip()
    used = len(indent) + 9 + 6 + len(who) + max(11, len(meta)) + 2
    lines = [indent + paint(TASK_COL.get(st, '2'), f"{st:<9}")
             + paint('2', f"{age:>4}  ") + paint('2', f"{who}{meta:<11}") + '  '
             + clip(task_desc(t), max(20, R_WIDTH - used))]
    if st == 'answered' and t.get('session'):
        lines.append(indent + '  ' + paint('36',
                     f"↳ forge reply @{t['session']} {t['task_id']}"))
    return lines

if os.environ.get('FORGE_WATCH_TASKS') == '1':
    # `forge tasks [@<session>] [--json]` — the operator projection. Optional @session filter
    # and a --json machine path (both threaded from cmd_status; see Diff 3f). Reconcile B-C1.
    want = os.environ.get('FORGE_WATCH_TASKS_SESSION') or ''
    tsorted = sorted((t for t in TASKS if not want or t.get('session') == want),
                     key=_task_ts, reverse=True)
    if os.environ.get('FORGE_WATCH_TASKS_JSON') == '1':
        print(json.dumps(tsorted, indent=2)); sys.exit(0)
    print(sect('FORGE TASKS', f'· {len(tsorted)} task(s)'))
    if not tsorted:
        print(paint('2', '  no tasks in the current window'))
    for t in tsorted[:40]:
        for ln in task_rows(t, '  ', show_sess=True):
            print(ln)
    sys.exit(0)

if BOARD:
    def _row(f):
        c = f['condition']
        return {'condition': c, 'class': _cls(c), 'session': f.get('session'),
                'root': f['root'], 'label': root_label(f['root']),
                'slug': f.get('slug'), 'stage': f.get('stage'),
                'state': STATE_OF.get(c), 'msg': f['msg'],
                'acked': bool(conds.get(f['key'], {}).get('acked'))}
    hot, active, maint = [], [], []
    for f in findings:
        r = _row(f)
        (hot if r['class'] == 'hot' else active if r['class'] == 'active' else maint).append(r)
    tick = state.get('last_tick'); tick_age = age_s(tick) if tick else None
    task_rows = sorted(TASKS, key=_task_ts, reverse=True)[:200]
    board = {'schema': 'cc-board/1',
             'generated_at': NOW.strftime('%Y-%m-%dT%H:%M:%SZ'),
             'heartbeat': tick,
             'heartbeat_age_s': (int(tick_age) if tick_age is not None else None),
             'stale': (tick_age is None or tick_age > STALE_TICK_S),
             'hot': hot, 'active': active,
             'maintenance': {'collapsed': True, 'count': len(maint), 'rows': maint},
             'tasks': task_rows}
    print(json.dumps(board, indent=2))
    sys.exit(0)

if PRETTY:
    # Human board: NEEDS YOU first, one line per live session, residue hidden.
    # Pure rendering over the same findings — no new detection, no writes.
    def detail_of(f):
        m = flat(f['msg'])                    # msg is "label · who — <detail>"
        return m.split(' — ', 1)[1] if ' — ' in m else m
    hot    = [f for f in findings if _cls(f['condition']) == 'hot']
    active = [f for f in findings if _cls(f['condition']) == 'active']
    maint  = [f for f in findings if _cls(f['condition']) == 'maintenance']

    for w in config_warnings:
        print(paint('33', f"! {w}"))
    sess_map = {s: p for s, p in SESSIONS.items()
                if os.path.isdir(os.path.join(p, '.dev'))}
    stamp = datetime.datetime.now().strftime('%a %H:%M')
    _tick = state.get('last_tick'); _tage = age_s(_tick) if _tick else None
    _fresh = _tage is not None and _tage <= STALE_TICK_S
    print(sect('FORGE BOARD',
               f'· {stamp} · {len(sess_map)} session(s) live'
               + (f' · watch {human_age(_tage)}' if _fresh else '')))
    if not _fresh:
        print(paint('33', "! forge-watch last ran "
                    + ((human_age(_tage) + ' ago') if _tage is not None else 'never')
                    + " — reload with `forge-watch install`"))

    print()
    if not hot:
        print(paint('1;32', 'NEEDS YOU — nothing.')
              + paint('2', '  All sessions are self-sufficient.'))
    else:
        print(sect(f'NEEDS YOU ({len(hot)})', color='1;31'))
        for f in hot:
            who = f.get('session') or root_label(f['root'])
            tag = f" ({f['slug']}/{f['stage']})" if f.get('slug') and f.get('stage') else ''
            ack = paint('2', '  [acked]') if conds.get(f['key'], {}).get('acked') else ''
            print('  ' + paint('1;31', '! ')
                  + paint('1', f"{who} · {root_label(f['root'])} — {f['condition']}{tag}") + ack)
            print('    ' + clip(detail_of(f), R_WIDTH - 4))
            if f['condition'] == 'NEEDS-ASK':
                aid = f['key'].split('\t')[2]
                at = f"@{f['session']}" if f.get('session') \
                    else f"@<session at {root_label(f['root'])}>"
                print('    ' + paint('36',
                      f'-> answer with: forge dispatch {at} "<answer>" --answers {aid}'))
            elif f['condition'] == 'NEEDS-REPLY':
                at = f"@{f['session']}" if f.get('session') \
                    else f"@<session at {root_label(f['root'])}>"
                print('    ' + paint('36',
                      f'-> reply with: forge dispatch {at} "<your reply>"'))
            elif f['condition'] == 'NEEDS-PERMISSION':
                # Honest for ALL permission dialogs (incl. AskUserQuestion):
                # the pane is modally waiting on a selector — dispatched
                # text+Enter cannot answer it (the cmd_send failure class).
                where = f": tmux attach -t {f['session']}" if f.get('session') else ''
                print('    ' + paint('36',
                      '-> interactive prompt — answer in the pane '
                      f'(cannot be dispatched){where}'))

    if sess_map:
        print()
        print(sect('SESSIONS'))
        by_sess = {}
        for f in findings:
            if f.get('session'):
                by_sess.setdefault(f['session'], []).append(f)
        GLYPH = {'hot': ('! needs you', '1;31'), 'queued': ('~ queued', '33'),
                 'working': ('~ working', '33'), 'done': ('+ done', '32'),
                 'idle': ('- idle', '2')}
        wname = max(len(s) for s in sess_map)
        wlab = min(max(len(root_label(p)) for p in sess_map.values()), 24)
        for s in sorted(sess_map, key=natkey):
            fs = by_sess.get(s, [])
            state, det = 'idle', ''
            hf = [f for f in fs if _cls(f['condition']) == 'hot']
            if hf:
                state, det = 'hot', hf[0]['condition']
            else:
                for cond, st in (('SESSION-QUEUED', 'queued'), ('SESSION-DONE', 'done'),
                                 ('SESSION-WORKING', 'working')):
                    m = [f for f in fs if f['condition'] == cond]
                    if m:
                        state = st
                        det = re.sub(r'^(done|queued-input|working):?\s*', '',
                                     detail_of(m[0]))
                        break
            g, col = GLYPH[state]
            line = (f"  {s:<{wname}}  {clip(root_label(sess_map[s]), wlab):<{wlab}}  "
                    + paint(col, f'{g:<12}'))
            room = R_WIDTH - (wname + wlab + 20)
            if det and room > 10:
                line += '  ' + paint('2', clip(det, room))
            print(line)

    # TASKS — the operator's unit of thought; N turns in one pane are N rows. Recency-bounded
    # (older worker-done already collapsed to a PANE-DONE-RESIDUE maintenance count); queued/
    # accepted/working dispatched tasks always show.
    tsorted = sorted(TASKS, key=_task_ts, reverse=True)
    def _trecent(t):
        a = age_s(_task_ts(t))
        return (a is None) or (a <= TASK_WINDOW_S) or t['state'] in ('queued', 'accepted', 'working')
    trecent = [t for t in tsorted if _trecent(t)]
    if trecent:
        print()
        print(sect('TASKS', f'({len(trecent)})'))
        # grouped by session, most recent activity first; per-group cap keeps
        # one busy pane from drowning the rest
        groups = {}
        for t in trecent:
            groups.setdefault(t.get('session') or t.get('label') or '?', []).append(t)
        PER_GROUP = 5
        shown = 0
        for s in sorted(groups, key=lambda k: _task_ts(groups[k][0]), reverse=True):
            if shown >= 24:
                break
            ts_ = groups[s]
            lbl = root_label(ts_[0].get('root') or '')
            print('  ' + paint('1', s)
                  + (paint('2', f' · {lbl}') if lbl and lbl != s else ''))
            for t in ts_[:PER_GROUP]:
                for ln in task_rows(t, '    '):
                    print(ln)
                shown += 1
            if len(ts_) > PER_GROUP:
                print('    ' + paint('2',
                      f'… {len(ts_) - PER_GROUP} more · forge tasks @{s}'))
        older = len(tsorted) - len(trecent)
        if older > 0:
            print(paint('2', f"  … {older} older task(s) in maintenance"))

    pipes = [f for f in active if f['condition'] == 'PIPELINE-COMPLETE']
    if pipes:
        print()
        print(sect('PIPELINES'))
        for f in pipes:
            print('  ' + paint('32', '+ ') + clip(flat(f['msg']), R_WIDTH - 4))

    if maint:
        print()
        counts = {}
        for f in maint:
            counts[f['condition']] = counts.get(f['condition'], 0) + 1
        summary = ', '.join(f"{n} {c}" for c, n in sorted(counts.items()))
        if SHOWALL:
            print(sect(f'MAINTENANCE ({len(maint)})', summary))
            for f in maint:
                print(paint('2', f"  [{f['condition']}] {clip(flat(f['msg']), R_WIDTH - 4)}"))
        else:
            print(paint('2', f"MAINTENANCE — {len(maint)} old item(s) hidden ({summary})"
                             " · `forge board --all` to list"))

    if not findings and not sess_map:
        print(paint('2', 'all clear — no live forge sessions, nothing pending'
                         + ('' if SESSIONS else ' (no tmux server)')))
    sys.exit(0)

# Quiet ticks: under launchd (stdout not a tty) an unchanged check prints
# nothing, so the 30s dump only lands in launchd.out when something changed.
# A tty (manual run) always prints; FORGE_WATCH_QUIET_UNCHANGED=0 disables.
QUIET = (MODE == 'check' and not FINDINGS_CHANGED and not config_warnings
         and not sys.stdout.isatty()
         and cfg_bool('FORGE_WATCH_QUIET_UNCHANGED', True))
if not QUIET:
    for w in config_warnings:
        print(f"! {w}")
    if not findings:
        print("forge-watch: all clear" + ("" if SESSIONS else " (no tmux server)"))
    else:
        for f in findings:
            acked = conds.get(f['key'], {}).get('acked')
            tag = ' [acked]' if acked else ''
            print(f"[{f['condition']}]{tag} {f['msg']}")

# Emit deliveries for the bash sink.
if MODE == 'check' and NOTIFY_OUT and NOTIFY_OUT != '-' and deliveries:
    with open(NOTIFY_OUT, 'w') as f:
        for title, body in deliveries:
            f.write(f"{title}\t{body}\n")
PYEOF
}

# ── verbs ────────────────────────────────────────────────────────────────
cmd_check() {
    # `|| rc=$?`: a watchdog-killed engine (exit 70) must still clean up the
    # temp file, and its exit status must reach launchd instead of being
    # swallowed by set -e mid-function.
    local nout rc=0; nout="$(mktemp "$CACHE_DIR/notify.XXXXXX")"
    run_engine check "$nout" "" || rc=$?
    if [ -s "$nout" ]; then
        while IFS=$'\t' read -r title body; do
            [ -n "$title" ] && fw_notify "$title" "$body"
        done < "$nout"
    fi
    rm -f "$nout"
    return "$rc"
}

cmd_status() {
    # --board = machine JSON (cc-board/1, unchanged contract);
    # --pretty = human board; --all expands maintenance in pretty mode;
    # --tasks = the read-only task projection (FORGE_WATCH_TASKS render), with an optional
    # @<session> filter and --json (both honored only under --tasks — `forge board --json`
    # execs `status --board`, which never sets FORGE_WATCH_TASKS).
    local board=0 showall=0 tasks=0 tsession="" tjson=0 a
    for a in "$@"; do
        case "$a" in
            --board)  board=1 ;;
            --pretty) board=2 ;;
            --all)    showall=1 ;;
            --tasks)  tasks=1 ;;
            --json)   tjson=1 ;;
            @*)       tsession="${a#@}" ;;
        esac
    done
    FORGE_WATCH_BOARD="$board" FORGE_WATCH_SHOWALL="$showall" FORGE_WATCH_TASKS="$tasks" \
        FORGE_WATCH_TASKS_SESSION="$tsession" FORGE_WATCH_TASKS_JSON="$tjson" \
        run_engine status "-" ""
}

cmd_ack() {
    if [ -z "${1:-}" ]; then
        echo "Usage: forge-watch ack <session|slug|project-dirname>" >&2
        return 1
    fi
    run_engine ack "-" "$1"
}

# Channel proof (P22). `selftest` fires ONE sentinel with a monotonic id + a pending marker; the
# board shows DELIVERY-UNVERIFIED until `selftest --confirm <id>`. Re-run daily to catch a later
# permission revocation. LIVE-FIRE — operator-gated per §5.
cmd_selftest() {
    if [ "${1:-}" = "--confirm" ]; then
        FW_ID="${2:-}" FW_CACHE="$CACHE_DIR" python3 - <<'PY'
import os, sys, json, datetime
p = os.path.join(os.environ["FW_CACHE"], "selftest.json")
try:
    st = json.load(open(p))
except (OSError, ValueError):
    sys.exit("forge-watch: no pending self-test to confirm")
if st.get("id") != os.environ.get("FW_ID"):
    sys.exit(f"forge-watch: id mismatch (pending: {st.get('id')})")
st["confirmed"] = True
st["confirmed_at"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
json.dump(st, open(p, "w"))
print(f"confirmed delivery of sentinel {st['id']}")
PY
        return
    fi
    local id; id="st-$(date -u +%Y%m%dT%H%M%SZ)-$$"
    FW_ID="$id" FW_CACHE="$CACHE_DIR" python3 - <<'PY'
import os, json, datetime
p = os.path.join(os.environ["FW_CACHE"], "selftest.json"); os.makedirs(os.path.dirname(p), exist_ok=True)
json.dump({"id": os.environ["FW_ID"],
           "sent_at": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
           "confirmed": False}, open(p, "w"))
PY
    fw_notify "forge-watch selftest" "sentinel $id — confirm with: forge-watch selftest --confirm $id"
    echo "sent sentinel $id"
    echo "if you saw the notification, run: forge-watch selftest --confirm $id"
}

cmd_install() {
    # launchd runs with a minimal PATH (/usr/bin:/bin:/usr/sbin:/sbin) that does
    # NOT include Homebrew — where tmux and (often) python3 live. Without this,
    # `tmux list-sessions` fails to launch and the agent silently sees zero
    # sessions. Bake in the dirs of the tmux/python3 we resolve right now.
    local tmux_dir py_dir fw_path
    tmux_dir="$(dirname "$(command -v tmux 2>/dev/null || echo /opt/homebrew/bin/tmux)")"
    py_dir="$(dirname "$(command -v python3 2>/dev/null || echo /usr/bin/python3)")"
    fw_path="$tmux_dir:$py_dir:/usr/bin:/bin:/usr/sbin:/sbin"

    cat > "$PLIST" <<PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$SELF</string>
    <string>check</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>$fw_path</string>
  </dict>
  <key>StartInterval</key><integer>30</integer>
  <key>RunAtLoad</key><true/>
  <key>StandardErrorPath</key><string>$CACHE_DIR/launchd.err</string>
  <key>StandardOutPath</key><string>$CACHE_DIR/launchd.out</string>
</dict>
</plist>
PLISTEOF

    # Seed watch.env from the current shell's values so launchd (which does not
    # inherit .zshrc) agrees with the interactive environment.
    if [ ! -f "$WATCH_ENV" ]; then
        {
            echo "# forge-watch tuning — parsed as data (KEY=value), never sourced."
            for k in FORGE_STALL_THRESHOLD_S FORGE_WATCH_DWELL_S \
                     FORGE_WATCH_RENOTIFY_S FORGE_WATCH_ZOMBIE_AGE_D; do
                v="$(eval "printf '%s' \"\${$k:-}\"")"
                [ -n "$v" ] && echo "$k=$v"
            done
        } > "$WATCH_ENV"
        echo "Seeded $WATCH_ENV"
    fi

    # The engine supports a roots registry but it does not exist live — create it
    # (empty) so `forge register` and manual edits have a home. Live sessions are
    # discovered from tmux directly, so this is only for roots without a session.
    if [ ! -f "$WATCH_ROOTS" ]; then
        echo "# forge-watch roots — one absolute project path per line." > "$WATCH_ROOTS"
        echo "Created $WATCH_ROOTS"
    fi

    launchctl unload "$PLIST" 2>/dev/null || true
    launchctl load "$PLIST"
    echo "Loaded launchd agent $LABEL (30s interval)."

    # Best-effort test notification. NOTE: notifications from osascript are
    # attributed to Script Editor/osascript; if that app lacks notification
    # permission, delivery silently no-ops.
    fw_notify "forge-watch installed" "If you do not see this, grant notification permission to Script Editor in System Settings ▸ Notifications."
    echo "Fired a test notification. If you did not see it, grant notification"
    echo "permission to 'Script Editor' in System Settings ▸ Notifications, then"
    echo "re-run: forge-watch check"
}

cmd_uninstall() {
    launchctl unload "$PLIST" 2>/dev/null || true
    rm -f "$PLIST"
    echo "Unloaded and removed launchd agent $LABEL."
    echo "(Cache and config left in place: $CACHE_DIR, $CONFIG_DIR)"
}

usage() {
    cat >&2 <<EOF
forge-watch — blocked-on-you notifications for forge pipelines

Usage:
  forge-watch check       one scan; print findings and deliver notifications
  forge-watch status      one scan; print raw findings only (no notifications)
  forge-watch status --pretty [--all]   human board (--all lists maintenance)
  forge-watch status --board            machine JSON (cc-board/1)
  forge-watch ack <t>     silence current conditions for <t> (session|slug|dir)
  forge-watch install     write+load the launchd agent (30s interval)
  forge-watch uninstall   unload+remove the launchd agent
EOF
}

case "${1:-status}" in
    check)     cmd_check ;;
    status)    shift; cmd_status "$@" ;;
    ack)       shift; cmd_ack "${1:-}" ;;
    selftest)  shift; cmd_selftest "$@" ;;
    install)   cmd_install ;;
    uninstall) cmd_uninstall ;;
    -h|--help|help) usage ;;
    *) usage; exit 1 ;;
esac
